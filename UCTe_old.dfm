  object USql_Notas: TIBUpdateSQL
    ModifySQL.Strings = (
      'update TRANSITENS_NOTAS'
      'set  '
      '    SERIE                         = :SERIE , '
      '    MODELO                     = :MODELO ,   '
      '    DT_EMISSAO              = :DT_EMISSAO  ,     '
      '    CFOP                          = :CFOP,'
      '    CHAVE_NFE                = :CHVE_NFE,   '
      '    ROMANEIO                 = :ROMANEIO,   '
      '    PEDIDO                       = :PEDIDO ,'
      '    BASE_ICMS_NORMAL = :BASE_ICMS_NORMAL ,'
      '    VR_ICMS_NORMAL     = :VR_ICMS_NORMAL  , '
      '    BASE_ICMS_ST           = :BASE_ICMS_ST , '
      '    VR_ICMS_ST               = :VR_ICMS_ST,'
      '    VALOR_PRODUTOS    = :VALOR_PRODUTOS ,    '
      '    VALOR                        = :VALOR'
      'where'
      '  NUM_DOC = :OLD_NUM_DOC and'
      '  TRANSACAO_ID = :OLD_TRANSACAO_ID')
    InsertSQL.Strings = (
      'insert into TRANSITENS_NOTAS'
      '  (TRANSACAO_ID,  '
      '   NUM_DOC,'
      '   MODELO,'
      '   SERIE,'
      '  CFOP,'
      ' BASE_ICMS_NORMAL,'
      'VR_ICMS_NORMAL,'
      'BASE_ICMS_ST,'
      'VR_ICMS_ST,'
      'VALOR_PRODUTOS,'
      'VALOR, '
      'CHAVE_NFE)             '
      'values'
      '   ( :TRANSACAO_ID,'
      '     :NUM_DOC,'
      '     :MODELO,'
      '     :SERIE,'
      '     :CFOP, '
      '     :BASE_CALC_ICMS,'
      '     :VR_ICMS_NORMAL,'
      '     :BASE_ICMS_ST,'
      '     :VR_ICMS_ST,'
      '     :VALOR_PRODUTOS,'
      '     :VALOR, '
      '     :CHAVE_NFE)')
    DeleteSQL.Strings = (
      'delete from TRANSITENS_NOTAS'
      'where'
      '  NUM_DOC = :OLD_NUM_DOC and'
      '  TRANSACAO_ID = :OLD_TRANSACAO_ID')
    Left = 152
    Top = 600
  end
