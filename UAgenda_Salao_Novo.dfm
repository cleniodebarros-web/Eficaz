  object QId_Func: TFDQuery
    Connection = FrmData.DbF_Eficaz
    FetchOptions.AssignedValues = [evAutoFetchAll]
    FetchOptions.AutoFetchAll = afTruncate
    SQL.Strings = (
      ''
      'SELECT FUNCIONARIO_ID FROM FUNCIONARIOS'
      'WHERE'
      '(APELIDO = :APELIDO)'
      'AND (STATUS = '#39'A'#39')')
    Left = 356
    Top = 84
    ParamData = <
      item
        Name = 'APELIDO'
        ParamType = ptInput
      end>
  end
