  object Qagenda: TFDQuery
    Connection = FrmData.DbF_Eficaz
    SQL.Strings = (
      'SELECT AGENDA.* , FUNCIONARIOS.APELIDO'
      'FROM AGENDA'
      
        'INNER JOIN FUNCIONARIOS ON AGENDA.FUNCIONARIO_ID = FUNCIONARIOS.' +
        'FUNCIONARIO_ID'
      'WHERE DT_AGENDA = :DT_AGENDA'
      'ORDER BY COLUNA,HORA')
    Left = 568
    Top = 264
    ParamData = <
      item
        Name = 'DT_AGENDA'
        ParamType = ptInput
        Value = Null
      end>
  end
  object QSearch: TFDQuery
    Connection = FrmData.DbF_Eficaz
    SQL.Strings = (
      'SELECT AGENDA.* , FUNCIONARIOS.APELIDO,CLIENTES.TRATAMENTO NOME'
      'FROM AGENDA'
      
        'INNER JOIN FUNCIONARIOS ON AGENDA.FUNCIONARIO_ID = FUNCIONARIOS.' +
        'FUNCIONARIO_ID'
      'LEFT JOIN CLIENTES ON AGENDA.CLIENTE_ID = CLIENTES.CLIENTE_ID'
      'WHERE DT_AGENDA = :DT_AGENDA'
      'ORDER BY HORA')
    Left = 656
    Top = 264
    ParamData = <
      item
        Name = 'DT_AGENDA'
        ParamType = ptInput
        Value = Null
      end>
  end
