procedure TFrmPrincipal.Consiste_EstoqueClick(Sender: TObject);
begin
 if LeIni(Arq_Ini, 'Sistema', 'NŃo Exigir Senha ao Consistir Estoque') <> 'True' then
 Begin
  Application.CreateForm(TFrmPasswordDlg, FrmPasswordDlg);
  try
    if FrmPasswordDlg.ShowModal = mrOk then
    begin
      if FrmPasswordDlg.Password.Text = Senha_Suporte then
      begin
       if not ThereIs('Consiste') then
       TFrmConsiste.Create(Application);
       if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
       Cascade;
      end
      else
        Application.MessageBox('Acesso negado', PChar(Msg_Title), mb_IconStop);
    end;
  finally
  FrmPasswordDlg.Release;
  end;
 End
 Else
 Begin
  if not ThereIs('Consiste') then
  TFrmConsiste.Create(Application);
  if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
  Cascade;
 End;
End;

procedure TFrmPrincipal.ConsultarClick(Sender: TObject);
begin
  OpenDialog1.Title      := 'Selecione a NFE';
  OpenDialog1.DefaultExt := '*-nfe.XML';
  OpenDialog1.Filter     := 'Arquivos NFE (*-nfe.XML)|*-nfe.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrNFe1.Configuracoes.Arquivos.GetPathNFe;

  if OpenDialog1.Execute then
  begin
    ACBrNFe1.NotasFiscais.Clear;
    ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);
    ACBrNFe1.Consultar;

    ShowMessage('N║ do Protocolo: ' + FrmPrincipal.ACBrNFe1.WebServices.Consulta.Protocolo);
    ShowMessage('Data da Nota: ' + DateToStr(FrmPrincipal.ACBrNFe1.WebServices.Consulta.DhRecbto));

  end;
end;

