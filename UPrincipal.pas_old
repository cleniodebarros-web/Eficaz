            'Erro: ' + e.Message), PChar(Msg_Title), mb_IconStop + mb_TaskModal);
        end;}
           Application.Terminate;
  end;



  try
    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT * FROM LICENCA');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(SERIAL = :SERIAL)');

    QRel.ParamByName('SERIAL').AsString := SerialNum('C');

    QRel.Prepare;
    QRel.Open;

    IQuery.SQL.Clear;
    IQuery.Sql.Add('SELECT COUNT(*) QTD FROM EMPRESAS');
    IQuery.Prepare;
    IQuery.Open;


    if (QRel.FieldByName('REGISTRO').AsString = '') AND (QEmpresa.FieldByName('RAZAO').AsString <> 'MATRIZ')
        and (QRel.FieldByName('LICENCA').AsString <> '') AND (NOT Qrel.FieldByName('LICENCA').IsNull) then
    begin
      Try
          IP := TIdHTTP.Create(nil);
          with IP do
          begin
            Temporario := Get('http://checkip.dyndns.org');
            For X := 1 to Length(Temporario) do
              if (Temporario[X] in ['0'..'9']) or (Temporario[X] = '.') then
                 Endereco := Endereco + Temporario[X];
          end;
          Result := Trim(Endereco);
          IP.Free;
        except
          Result := 'ERRO';
        end;

      Application.CreateForm(TFrmEnvio_Email, FrmEnvio_Email);
      try
        FrmEnvio_Email.edtSenderName.Text    := 'Registro Eficaz';
        FrmEnvio_Email.edtSenderAddress.Text := 'eficaz@eficazautomacao.com.br';
        FrmEnvio_Email.edtHost.Text          := 'smtp.eficazautomacao.com.br';
        FrmEnvio_Email.edtPort.Text          := '587';
        FrmEnvio_Email.rbAuthDefault.Checked := True;
        FrmEnvio_Email.edtUsername.Text      := 'eficaz=eficazautomacao.com.br';
        FrmEnvio_Email.edtPassword.Text      := 'EficazSuporteArilmaq421';
        FrmEnvio_Email.edtRecipients.Text    := 'registro@eficazautomacao.com.br';
        FrmEnvio_Email.edtSubject.Text       := 'Cliente Eficaz Autenticado!!';

        FrmEnvio_Email.mBody.Lines.Add('RazŃo Social: ' + QEmpresa.FieldByName('RAZAO').AsString);
        FrmEnvio_Email.mBody.Lines.Add('InscrińŃo: ' + QEmpresa.FieldByName('INSCR_ESTADUAL').AsString);
        FrmEnvio_Email.mBody.Lines.Add('CNPJ: ' + QEmpresa.FieldByName('CNPJ').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Endereńo: ' + QEmpresa.FieldByName('ENDERECO').AsString + ', ' + QEmpresa.FieldByName('NUMERO').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Telefone: ' + QEmpresa.FieldByName('TELEFONE').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Bairro: ' + QEmpresa.FieldByName('BAIRRO').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Cidade: ' + QEmpresa.FieldByName('MUNICIPIO').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Email: ' + QEmpresa.FieldByName('EMAIL').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Serial: ' + QRel.FieldByName('SERIAL').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Quantidade de Empresas no Banco: ' + IQuery.FieldByName('QTD').AsString);
        FrmEnvio_Email.mBody.Lines.Add('Ip-Cliente: ' + Result);
        FrmEnvio_Email.mBody.Lines.Add('Data: ' + DateToStr(Date) + ' Hora: ' + TimeToStr(Time));


        FrmEnvio_Email.btnExecutaClick(Sender);

        FrmEnvio_Email.edtRecipients.Text    := 'clenioeficaz@yahoo.com.br';

        FrmEnvio_Email.btnExecutaClick(Sender);

      finally
        FrmEnvio_Email.Release;
      end;

      if (not Erro_Envio) and (QRel.FieldByName('LICENCA').AsString <> '')  then
      begin
        QRel.Sql.Clear;
        QRel.Sql.Add('UPDATE LICENCA SET REGISTRO = :REGISTRO');
        QRel.Sql.Add('WHERE');
        QRel.Sql.Add('(SERIAL = :SERIAL)');

        QRel.ParamByName('REGISTRO').AsString := 'S';
        QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

        QRel.Prepare;
        QRel.ExecSql;


      end;

    end;
  finally


  end;



  //Timer1.Enabled := True;

  if LeIni(Arq_Ini, 'Sistema', 'Orńamento Rßpido') = 'True' then
    OrcamentoClick(Sender);



end;

