begin
  QRel.Sql.Clear;

  QRel.Sql.Add('SELECT * FROM PRODUTOS');
  QRel.Sql.Add('WHERE');
  QRel.Sql.Add('(EMPRESA_ID = :EMPRESA_ID)');
  QRel.Sql.Add('AND (STATUS = :STATUS)');

  if StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo')) > 0 then
  begin
    QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

    QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo'));
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Fornecedor')) > 0 then
  begin
    QRel.Sql.Add('AND (PRODUTOS.FORNECEDOR_ID = :FORNECEDOR_ID)');

    QRel.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Fornecedor'));
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo')) > 0 then
  begin
    QRel.Sql.Add('AND (PRODUTOS.GRUPO_ID = :GRUPO_ID)');

    QRel.ParamByName('GRUPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo'));
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo')) > 0 then
  begin
    QRel.Sql.Add('AND (PRODUTOS.SUBTIPO_ID = :SUBTIPO_ID)');

    QRel.ParamByName('SUBTIPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo'));
  end;

  if StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo')) = 0 then
  begin
    if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo')) > 0 then
    begin
      QRel.Sql.Add('AND (PRODUTOS.LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo'));
    end;
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Produto Inicial')) > 0 then
  begin
    QRel.Sql.Add('AND (PRODUTO_ID BETWEEN :PRODUTO_INICIAL AND :PRODUTO_FINAL)');

    QRel.ParamByName('PRODUTO_INICIAL').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Produto Inicial'));
    QRel.ParamByName('PRODUTO_FINAL').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Produto Final'));
  end;

  QRel.Sql.Add('ORDER BY DESCRICAO');

  QRel.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QRel.ParamByName('STATUS').AsString      := 'A';

  Qrel.Prepare;
  QRel.Open;

  if LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo') = '0' then
    QRLabel40.Caption := 'Grupo: TODOS'
  else
    QRLabel40.Caption := 'Grupo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo')), '7');

  if LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo') = '0' then
    QRLabel41.Caption := 'Sub-Tipo: TODOS'
  else
    QRLabel41.Caption := 'Sub-Tipo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo')), '5');

  if LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo') = '0' then
    QRLabel42.Caption := 'LocalizańŃo: TODAS'
  else
    QRLabel42.Caption := 'LocalizańŃo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo')), '8');

  if QRel.IsEmpty then
    Application.MessageBox('NŃo hß dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
  else
    Tabela_Produtos.PreviewModal;
end;

procedure TFrmPrincipal.Timer1Timer(Sender: TObject);
var
Janela: HWND;
Server,Server_c, Local: String;
begin
  if MDIChildCount = 0 then
  begin

    Local  := ExtractFilePath(ParamStr(0)) + 'Eficaz.Exe';
    Server:= LeIni(Arq_Ini, 'AtualizańŃo', 'Download') + 'Eficaz.Exe';

    if FileExists(Server) then
    begin

    if not Comparar(Server, Local) then
      begin
        Timer1.Enabled := False;

        Application.MessageBox('Existe uma versŃo do aplicativo mais atualizada', PChar(Msg_Title), mb_IconInformation);
        WinExec(PAnsiChar(ExtractFilePath(ParamStr(0)) + 'Atu_Versao.Exe'), SW_HIDE);

        Janela := FindWindow('TFrmAtualiza', nil);

        if Janela <> 0 then
           PostMessage(Janela, WM_QUIT, 0, 0);
      end;
    end;
  end;
end;

procedure TFrmPrincipal.Timer2Timer(Sender: TObject);
begin
  try
    Timer2.Enabled := False;
    if LeIni(Arq_Ini, 'Sistema', 'ImportańŃo Automßtica Eficaz') = 'True' then
    Carga_Bd;
  finally
    Timer2.Enabled := True;
  end;
end;

procedure TFrmPrincipal.timer_tcppdvTimer(Sender: TObject);
begin
 config.Refresh;

  if (StrToDate(Copy(Config.FieldByName('TCPPDV').AsString,1,10)) >= Date) AND (IncSecond(StrToTime(Copy(config.FieldByName('TCPPDV').AsString,12,8)),30) > Time) then
 Begin
 btntcppdv.PngImage.LoadFromFile(ExtractFilePath(ParamStr(0)) + 'tcp-pdv-on.png');
 btntcppdv.Refresh;
 End
 ELSE
 Begin
 btntcppdv.PngImage.LoadFromFile(ExtractFilePath(ParamStr(0)) + 'tcp-pdv-off.png');
 btntcppdv.Refresh;
 End;


end;

