procedure TFrmPrincipal.QRBand13BeforePrint(Sender: TQRCustomBand;
  var PrintBand: Boolean);
begin
  QRLabel70.Caption := QEmpresa.FieldByName('MUNICIPIO').AsString + '(' +
                       QEmpresa.FieldByName('ESTADO').AsString + '), ' + Copy(DateToStr(date), 1, 2) + ' de ' +
                       NomeMes(StrToInt(Copy(DateToStr(date), 4, 2))) + ' de ' + Copy(DateToStr(date), 7, 4);
end;

procedure TFrmPrincipal.QRBand16BeforePrint(Sender: TQRCustomBand;
  var PrintBand: Boolean);
begin
  if (QRel.FieldByName('PROMO_INICIAL').AsDateTime >= Abertura.FieldByName('DT_MOVIMENTO').AsDateTime) and (QRel.FieldByName('PROMO_FINAL').AsDatetime <= Abertura.FieldByName('DT_MOVIMENTO').AsDateTime) and (QRel.FieldByName('PRECO_PROMOCAO').AsFloat > 0) then
    QRLabel79.Caption := FormatFloat('#,##0.00', QRel.FieldByName('PRECO_PROMOCAO').AsFloat)
  else
    QRLabel79.Caption := FormatFloat('#,##0.00', QRel.FieldByName('PRECO_VAREJO').AsFloat);
end;

procedure TFrmPrincipal.Liberar_Lancamentos_TransacoesClick(Sender: TObject);
var
InputString: String;
begin
  try
    InputString := InputBox(PChar(Msg_Title), 'TransańŃo ID' , '0');

    if StrToInt(InputString) > 0 then
    begin

      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE TRANSPARCELAS SET TIPO_TRANSACAO = :TIPO_TRANSACAO');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
      QRel.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANS)');

      QRel.ParamByName('TIPO_TRANSACAO').AsString := 'U';
      QRel.ParamByName('TRANSACAO_ID').AsInteger  := StrToInt(InputString);
      QRel.ParamByName('TIPO_TRANS').AsString     := 'T';

      QRel.Prepare;
      QRel.ExecSql;




      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE TRANSACOES SET DT_MOVIMENTO = :DT_MOVIMENTO, FUNCIONARIO_ID = :FUNCIONARIO_ID');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

      QRel.ParamByName('DT_MOVIMENTO').AsDateTime   := Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      QRel.ParamByName('TRANSACAO_ID').AsInteger    := StrToInt(InputString);
      QRel.ParamByName('FUNCIONARIO_ID').AsInteger  := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;

      QRel.Prepare;
      QRel.ExecSql;




      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE TRANSPARCELAS SET TIPO_TRANSACAO = :TIPO_TRANSACAO');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
      QRel.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANS)');

      QRel.ParamByName('TIPO_TRANSACAO').AsString := 'T';
      QRel.ParamByName('TRANSACAO_ID').AsInteger  := StrToInt(InputString);
      QRel.ParamByName('TIPO_TRANS').AsString     := 'U';

      QRel.Prepare;
      QRel.ExecSql;



    end;

  except
    Application.MessageBox('Ocorreu um erro ao liberar a transacńŃo', PChar(Msg_Title), mb_IconStop);
  end;
end;

