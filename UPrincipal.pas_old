procedure TFrmPrincipal.ScriptsSQLClick(Sender: TObject);
begin
  Application.CreateForm(TFrmPasswordDlg, FrmPasswordDlg);
  try
    if FrmPasswordDlg.ShowModal = mrOk then
    begin
      if FrmPasswordDlg.Password.Text = Senha_Suporte then
      begin
        if not ThereIs('Scripts SQL') then
          TFrmSql.Create(Application);

        if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
          Cascade;
      end
      else
        Application.MessageBox('Acesso negado', PChar(Msg_Title), mb_IconStop);
    end;
  finally
    FrmPasswordDlg.Release;
  end;
end;

procedure TFrmPrincipal.SenhasClick(Sender: TObject);
begin
  if MDIChildCount = 0 then
  begin
    if not ThereIs('ManutenńŃo de Senhas') then
      TFrmSenhas.Create(Application);

    if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
      Cascade;
  end
  else
  begin
    if MDIChildCount = 1 then
      Application.MessageBox('Existe janela aberta. Seria melhor fechß-la antes de encerrar', PChar(Msg_Title), mb_IconStop)
    else
      Application.MessageBox('Existem janelas abertas. Seria melhor fechß-las antes de encerrar', PChar(Msg_Title), mb_IconStop);
  end;
end;

