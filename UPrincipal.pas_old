procedure TFrmPrincipal.Totalizacao_PatrimonioClick(Sender: TObject);
begin
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT PATRIMONIO.*, TABELAS.DESCRICAO DESCR_LOCALIZACAO');
  QRel.Sql.Add('FROM PATRIMONIO');
  QRel.Sql.Add('INNER JOIN TABELAS');
  QRel.Sql.Add('ON (PATRIMONIO.LOCALIZACAO_ID = TABELAS.TABELA_ID AND TABELAS.TIPO_TABELA = :TIPO_TABELA)');
  QRel.Sql.Add('WHERE');
  QRel.Sql.Add('(PATRIMONIO.EMPRESA_ID = :EMPRESA_ID)');
  QRel.Sql.Add('AND (PATRIMONIO.STATUS = :STATUS)');
  QRel.Sql.Add('ORDER BY TABELAS.DESCRICAO, PATRIMONIO.DESCRICAO');

  QRel.ParamByName('TIPO_TABELA').AsString := '8';
  QRel.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QRel.ParamByName('STATUS').AsString      := 'A';

  QRel.Prepare;
  QRel.Open;

  QRLabel61.Caption := '*** TOTALIZAŪ├O DO PATRIMįNIO ***';

  if QRel.IsEmpty then
    Application.MessageBox('NŃo hß dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
  else
    Rel_Totalizacao_Patrimonio.PreviewModal;
end;

