procedure TFrmPrincipal.Gerar_Arq_Pro_CountClick(Sender: TObject);
var
F1: TextFile;
begin
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT * FROM PRODUTOS');
  QRel.Sql.Add('WHERE');
  QRel.Sql.Add('(PRODUTOS.STATUS = :STATUS)');

  if StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo')) > 0 then
  begin
    QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

    QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo'));
  end;

  QRel.ParamByName('STATUS').AsString := 'A';

  QRel.Prepare;
  QRel.Open;

  AssignFile(F1, ExtractFilePath(ParamStr(0)) + 'PROCOUNT.TXT');
  Rewrite(F1);

  try
    QRel.First;
    while not QRel.Eof do
    begin
      WriteLn(F1, StrZero(QRel.FieldByName('PRODUTO_ID').AsString, 6, 0) + ' ' +
                  '000000' + ' ' +
                  ForcaComprimento(QRel.FieldByName('COD_BARRA').AsString, 13, ' ') + ' ' +
                  ForcaComprimento(QRel.FieldByName('DESCRICAO').AsString, 24, ' ') + ' ' +
                  '        ' + ' ' +
                  StrZero(QRel.FieldByName('QUANTIDADE_G').AsString, 5, 0) + ' ' +
                  StrZero(QRel.FieldByName('CUSTOMEDIO').AsString, 12, 2) + ' ' +
                  ForcaComprimento(QRel.FieldByName('STATUS').AsString, 1, ' '));

      Application.ProcessMessages;
      QRel.Next;
    end;

    Application.MessageBox(PChar('O arquivo PROCOUNT.TXT foi gerado com sucesso na pasta ' + ExtractFilePath(ParamStr(0))), PChar(Msg_Title), mb_IconInformation);
  finally
    CloseFile(F1);
  end;
end;

