procedure TFrmPrincipal.ListarArquivos(Diretorio: string; Sub:Boolean);
var
  F: TSearchRec;
  Ret: Integer;
  TempNome: string;
begin
  Ret := FindFirst(Diretorio+'*.dll', faAnyFile, F);
  try
    while Ret = 0 do
    begin
        ListBox1.Items.Add(Diretorio+''+F.Name);
        Ret := FindNext(F);
    end;
  finally
  begin
    FindClose(F);
  end;
  end;
end;


Procedure GerarCodigo(Codigo: String; Canvas : TCanvas);
const
digitos : array['0'..'9'] of string[5]= ('00110', '10001', '01001', '11000',
'00101', '10100', '01100', '00011', '10010', '01010');
var s : string;
i, j, x, t : Integer;
begin
  // Gerar o valor para desenhar o c¾digo de barras
  // Caracter de inĒcio
  s := '0000';
  for i := 1 to length(codigo) div 2 do
  for j := 1 to 5 do
  s := s + Copy(Digitos[codigo[i * 2 - 1]], j, 1) + Copy(Digitos[codigo[i * 2]], j, 1);
  // Caracter de fim
  s := s + '100';
  // Desenhar em um objeto canvas
  // Configurar os parŌmetros iniciais
  x := 0;
  // Pintar o fundo do c¾digo de branco
  Canvas.Brush.Color := clWhite;
  Canvas.Pen.Color := clWhite;
  Canvas.Rectangle(0,0, 2000, 79);
  // Definir as cores da caneta
  Canvas.Brush.Color := clBlack;
  Canvas.Pen.Color := clBlack;
  // Escrever o c¾digo de barras no canvas
    for i := 1 to length(s) do
    begin
    // Definir a espessura da barra
    t := strToInt(s[i]) * 2 + 1;
    // Imprimir apenas barra sim barra nŃo (preto/branco - intercalado);
    if i mod 2 = 1 then
    Canvas.Rectangle(x, 0, x + t, 79);
    // Passar para a pr¾xima barra
    x := x + t;
    end;
end;


function AtualizarPagamento(cnpj,mes,ano,dia,dt_lancamento,operador:string;valor:Real;tp:integer):Boolean;
var
  Request: TIdHTTP;
  Parametros: TStringList;
  Resposta, API_KEY,url : string;
begin

  API_KEY    := 'F815084E9BB1E0827CF0A005A044348ED8866E27';
  Parametros := TStringList.Create;

  Parametros.Add('cnpj=' + cnpj);
  Parametros.Add('mes=' + mes);
  Parametros.Add('ano=' + ano);
  Parametros.Add('dia=' + dia);
  Parametros.Add('valor=' + StringReplace( FloatToStr(valor),',','.',[]));
  Parametros.Add('dt_lancamento='+ Copy(dt_lancamento,7,4) + '-' + Copy(dt_lancamento,4,2) + '-' + Copy(dt_lancamento,1,2));
  Parametros.Add('operador_id=' + operador);
  Parametros.Add('api_key='+API_KEY);
  Request := TIdHTTP.Create(nil);

  IF TP = 0 then
  URL := 'http://helpdesk/Rest/api/pagamento'
  else
  URL := 'http://helpdesk/Rest/api/pagamento/excluir';

  try

     Resposta := Request.Post(url, Parametros);

    if Resposta = '1' then
       Result := True
    else
    Begin
     Result := False;
     Application.MessageBox(PChar(resposta), PChar(Msg_Title), mb_IconInformation);
    End;

  except
     Application.MessageBox('Servidor help nŃo ativo favor verificart!', PChar(Msg_Title), mb_IconInformation);
  end;
  Request.Free;
  Parametros.Free;
end;

function LogEntry(Cmd, Msg: String; Dig: string): String;
begin
  Result := Format('%s%s' + '%s', [Cmd, Msg, (Dig)]);
end;

procedure ExportDataSetToCVS(DataSet: TDataSet; const FileName: string);
var
  fld: TField;
  lst: TStringList;
  wasActive: Boolean;
  writer: TTextWriter;
begin
  writer := TStreamWriter.Create(FileName);
  try
    lst := TStringList.Create;
    try
      lst.QuoteChar := '"';
      lst.Delimiter := ';';
      wasActive := DataSet.Active;
      try
        DataSet.Active := true;
        DataSet.GetFieldNames(lst);
        writer.WriteLine(lst.DelimitedText);
        DataSet.First;
        while not DataSet.Eof do begin
          lst.Clear;
          for fld in DataSet.Fields do
            lst.Add(fld.Text);
          writer.WriteLine(lst.DelimitedText);
          DataSet.Next;
        end;
      finally
        DataSet.Active := wasActive;
      end;
    finally
      lst.Free;
    end;
  finally
    writer.Free;
  end;
end;



function HoraServidorRemoto: TDateTime;
var
  IDSntp: TIDSntp;
begin
  IDSntp := TIDSntp.Create(nil);
  try
      IDSntp.Host := 'a.st1.ntp.br';
      IDSntp.ReceiveTimeout := 2000;
      Result :=  IDSntp.DateTime;
  finally
      IDSntp.Free;
  end;
end;

procedure VerificaPagamento;
var
Pagina, status, url,mensagem ,pagto,situacao,aviso,dias: String;
texto: TMemo;
Erro:Boolean;
//IdHTTP1: TIdHTTP;
begin
  FrmPrincipal.QRel.SQL.Clear;
  FrmPrincipal.QRel.SQL.Add('SELECT * FROM EMPRESAS WHERE STATUS = :STATUS ORDER BY EMPRESA_ID');
  FrmPrincipal.QRel.ParamByName('STATUS').AsString := 'A';
  FrmPrincipal.QRel.Prepare;
  FrmPrincipal.QRel.Open;
  FrmPrincipal.Qrel.First;

 while not FrmPrincipal.Qrel.Eof  do
 Begin

  FrmPrincipal.QEmpresa.Close;
  FrmPrincipal.QEmpresa.ParamByName('EMPRESA_ID').AsInteger := FrmPrincipal.QRel.FieldByName('EMPRESA_ID').AsInteger;
  FrmPrincipal.QEmpresa.Open;

  FrmPrincipal.Config.Open;

  if (FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString <> 'MATRIZ') and ( NOT FrmPrincipal.QEmpresa.FieldByName('CNPJ').IsNull) then
  begin

  try

    texto         := TMemo.Create(FrmPrincipal);
    texto.Parent  := FrmPrincipal;
    texto.Visible := False;
   // IdHTTP1       := TIdHTTP.Create(FrmPrincipal);
    FrmPrincipal.IdHTTP1.ConnectTimeout  := 10000;
    FrmPrincipal.IdHTTP1.RedirectMaximum := 15;
   try
    if (FrmPrincipal.QEmpresa.FieldByName('CNPJ').asstring ='03.744.921/0001-57') or
    (FrmPrincipal.QEmpresa.FieldByName('CNPJ').asstring ='18.278.820/0004-58') or
    (FrmPrincipal.QEmpresa.FieldByName('CNPJ').asstring ='18.278.820/0007-09') or
    (FrmPrincipal.QEmpresa.FieldByName('CNPJ').asstring ='18.278.820/0006-10') or
    (FrmPrincipal.QEmpresa.FieldByName('CNPJ').asstring ='05.835.195/0001-03') or
    (FrmPrincipal.QEmpresa.FieldByName('CNPJ').asstring ='18.278.820/0008-81') or
    (FrmPrincipal.QEmpresa.FieldByName('CNPJ').asstring ='18.278.820/0001-05') then
    Begin
    url := 'http://helpdesk/Rest/api/eficaz/users/id/' + SemMascara(FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString) + '/format/xml';
    Pagina:= FrmPrincipal.IdHTTP1.Get(URL);
    End
    Else
    Begin
    url := 'http://arilmaqmatriz.ddns.info:3535/Rest/api/eficaz/users/id/' + SemMascara(FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString) + '/format/xml';
    Pagina:= FrmPrincipal.IdHTTP1.Get(URL);
    End;
   except
   url := 'http://helpdesk/Rest/api/eficaz/users/id/' + SemMascara(FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString) + '/format/xml';
   Pagina:= FrmPrincipal.IdHTTP1.Get(URL);
   end;


    texto.Lines.Add(Utf8ToAnsi(Pagina));
    status := copy(texto.lines.text,pos('<status>', texto.lines.text) + 8, pos('</status>', texto.lines.text) - (pos('<status>', texto.lines.text) +8));
    mensagem :=  copy(texto.lines.text,pos('<mensagem>', texto.lines.text) + 10, pos('</mensagem>', texto.lines.text) - (pos('<mensagem>', texto.lines.text) +10));
    Pagto    :=  copy(texto.lines.text,pos('<ult-pagto>', texto.lines.text) + 11, pos('</ult-pagto>', texto.lines.text) - (pos('<ult-pagto>', texto.lines.text) +11));
    Situacao :=  copy(texto.lines.text,pos('<situacao-financeira>', texto.lines.text) + 21, pos('</situacao-financeira>', texto.lines.text) - (pos('<situacao-financeira>', texto.lines.text) +21));
    aviso    :=  copy(texto.lines.text,pos('<aviso>', texto.lines.text) + 7, pos('</aviso>', texto.lines.text) - (pos('<aviso>', texto.lines.text) +7));
    dias     :=  copy(texto.lines.text,pos('<dias_liberacao>', texto.lines.text) + 16, pos('</dias_liberacao>', texto.lines.text) - (pos('<dias_liberacao>', texto.lines.text) + 16));

      if situacao = 'PENDENTE' then
      begin
      Application.MessageBox('Sistema Bloqueado!' + #13 + 'Favor entre em contato com  Eficaz AutomańŃo e Sistemas Ltda  (38)37411478! '+' ', PChar(Msg_Title), mb_IconInformation);

       FrmPrincipal.Config.Edit;
       FrmPrincipal.Config.Fields[47].AsString := 'SISTEMA BLOQUEADO';
       FrmPrincipal.Config.Post;



      Application.Terminate;
      end
      Else if situacao = 'LIBERADO' then
      Begin
       Frmprincipal.IQuery.sql.clear;
       FrmPrincipal.IQuery.Sql.Add('UPDATE EMPRESAS SET LIBERA_HELP = :LIBERACAO WHERE EMPRESA_ID = :EMPRESA_ID');
       FrmPrincipal.IQuery.ParamByName('LIBERACAO').AsString   := LogEntry('', '', MD5.HashStringAsHex(FrmPrincipal.Qempresa.FieldByName('CNPJ').AsString + dateToStr(date) + 'LIBERADO CLENIO BARROS'));
       FrmPrincipal.IQuery.ParamByName('EMPRESA_ID').AsInteger := FrmPrincipal.Qrel.FieldByName('EMPRESA_ID').AsInteger;
       FrmPrincipal.IQuery.Prepare;
       FrmPrincipal.IQuery.ExecSQL;



       if FrmPrincipal.Qrel.FieldByName('EMPRESA_ID').AsInteger = 1 Then
       Begin
       FrmPrincipal.Config.Edit;
       FrmPrincipal.Config.FieldByName('DT_CONEXAO').AsString   := EncryptMsg(DateToStr(Date),33);
       FrmPrincipal.Config.FieldByName('DIAS_OFFLINE').AsString := EncryptMsg(dias,33);
       FrmPrincipal.Config.Post;

       End;



      End;

      if Status = 'PENDENTE' then
      Begin
       Application.MessageBox('Sistema Bloqueado Contrato Pendente!' + #13 + 'Favor entre em contato com  Eficaz AutomańŃo e Sistemas Ltda  (38)37411478! '+' ', PChar(Msg_Title), mb_IconInformation);
       FrmPrincipal.Config.Edit;
       FrmPrincipal.Config.Fields[47].AsString := 'SISTEMA BLOQUEADO';
       FrmPrincipal.Config.Post;


       Application.Terminate;
      End;

      if Mensagem <> 'SEM MENSAGEM'  then
      Application.MessageBox(Pchar('Mensagem Sistema Eficaz:' + #13 + mensagem), PChar(Msg_Title), MB_ICONWARNING);

      if aviso <> 'SEM MENSAGEM'  then
      Application.MessageBox(Pchar('Mensagem Sistema Eficaz:' + #13 + aviso), PChar(Msg_Title),MB_ICONWARNING);

  except


   if FrmPrincipal.Config.FieldByName('DIAS_OFFLINE').AsString  = '' then
   Dias := '5'
   Else
   dias :=  DecryptMsg(FrmPrincipal.Config.FieldByName('DIAS_OFFLINE').AsString,33);

     if  (DATE - StrToDate(DecryptMsg(FrmPrincipal.Config.FieldByName('DT_CONEXAO').AsString,33))) >= StrToInt(dias) Then
     Begin
       Application.MessageBox(Pchar('Sistema Bloqueado.' + #13 + 'Sem conexŃo com Servidores Eficaz AutomańŃo por mais de ' + dias + ' dias!' + #13 + 'RazŃo: ' + FrmPrincipal.Qempresa.FieldByName('RAZAO').AsString + #13 +
                            'Cnpj: ' + FrmPrincipal.Qempresa.FieldByName('CNPJ').AsString + #13 +  'Favor entre em contato com  Eficaz AutomańŃo e Sistemas Ltda  (38)37411478! '), PChar(Msg_Title), mb_IconInformation);
       if StrtoInt(dias) >= 30 then
       Begin
        Erro := False;

        FrmPrincipal.IQuery1.SQL.Clear;
        FrmPrincipal.IQuery1.SQL.add('SELECT * FROM EMPRESAS WHERE STATUS = :STATUS ORDER BY EMPRESA_ID ');
        FrmPrincipal.IQuery1.ParamByName('STATUS').AsString := 'A';
        FrmPrincipal.IQuery1.Prepare;
        FrmPrincipal.IQuery1.Open;
        FrmPrincipal.IQuery1.First;

        while not FrmPrincipal.IQuery1.eof do
        Begin

         InputString := InputBox(PChar(Msg_Title), 'LiberańŃo on-line Cnpj: ' + FrmPrincipal.IQuery1.FieldByName('CNPJ').AsString , '');

         if InputString = LogEntry('', '', MD5.HashStringAsHex(FrmPrincipal.IQuery1.FieldByName('CNPJ').AsString + DateToStr(Date)  + 'LIBERADO CLENIO BARROS'))  then
         Begin

          Frmprincipal.IQuery.sql.clear;
          FrmPrincipal.IQuery.Sql.Add('UPDATE EMPRESAS SET LIBERA_HELP = :LIBERACAO WHERE EMPRESA_ID = :EMPRESA_ID');
          FrmPrincipal.IQuery.ParamByName('LIBERACAO').AsString   := InputString;
          FrmPrincipal.IQuery.ParamByName('EMPRESA_ID').AsInteger := FrmPrincipal.IQuery1.FieldByName('EMPRESA_ID').AsInteger;

          FrmPrincipal.IQuery.Prepare;
          FrmPrincipal.IQuery.ExecSQL;

         End
         Else
         Begin
         Application.MessageBox('O valor digitado estß incorreto. Tente mais tarde', PChar(Msg_Title), mb_IconWarning);
         Erro := True;
         Application.Terminate;
         End;
         FrmPrincipal.IQuery1.next;
        End;

        if not erro then
        Begin
        FrmPrincipal.Config.Edit;
        FrmPrincipal.Config.FieldByName('DT_CONEXAO').AsString   := EncryptMsg(DateToStr(Date),33);
        FrmPrincipal.Config.Post;

        Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
        Application.Terminate;
        End;

       End
       Else
       Application.Terminate;
     End
     Else
     Begin
       if (FrmPrincipal.Qempresa.FieldByName('LIBERA_HELP').AsString <> LogEntry('', '', MD5.HashStringAsHex(FrmPrincipal.Qempresa.FieldByName('CNPJ').AsString + DecryptMsg(FrmPrincipal.Config.FieldByName('DT_CONEXAO').AsString,33)  + 'LIBERADO CLENIO BARROS')))  then
       Begin
       Application.MessageBox(Pchar('Sistema Bloqueado, sem conexŃo ou CNPJ nŃo entontrado!' + #13 + 'RazŃo: ' + FrmPrincipal.Qempresa.FieldByName('RAZAO').AsString + #13 +
                              'Cnpj: ' + FrmPrincipal.Qempresa.FieldByName('CNPJ').AsString + #13 +  'Favor entre em contato com  Eficaz AutomańŃo e Sistemas Ltda  (38)37411478! '), PChar(Msg_Title), mb_IconInformation);
       Application.Terminate;
       End;
     End;

       { on e:Exception do
        begin
          Application.MessageBox(PChar('Erro:' + #13 +
            'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
        end;  }

  end;
  end;
   FrmPrincipal.Qrel.Next;
 End;
end;


