  IniConf.WriteString(Secao, Item, Vl);
  IniConf.Free;
end;

function SemMascara(Txt: String): String;
var
X: Integer;
St: String;
begin
  St := '';

  for X := 1 to length(Txt) do
  begin
    if (Copy(Txt, X, 1) = '0') or (Copy(Txt, X, 1) = '1') or (Copy(Txt, X, 1) = '2') or
       (Copy(Txt, X, 1) = '3') or (Copy(Txt, X, 1) = '4') or (Copy(Txt, X, 1) = '5') or
       (Copy(Txt, X, 1) = '6') or (Copy(Txt, X, 1) = '7') or (Copy(Txt, X, 1) = '8') or
       (Copy(Txt, X, 1) = '9') then
      St := St + Copy(Txt, X, 1);
  end;

  Result := St;
end;

function ValidCPF(Const S: String): Boolean;
var
I, Numero, Resto: Byte;
DV1, DV2: Byte;
Total, Soma: Integer ;
begin
  Result := False;
  Total := 0;
  Soma := 0;

  if length(S) = 11 then
  begin
    for I := 1 to 9 do
    begin
      try
        Numero := StrToInt(S[I]);
      except
        Numero := 0;
      end;

      Total := Total + (Numero * (11 - I)) ;
      Soma := Soma + Numero;
    end;
  end;

  Resto := Total mod 11;

  if Resto > 1 then
    DV1 := 11 - Resto
  else
    DV1 := 0;

  Total := Total + Soma + 2 * DV1;
  Resto := Total mod 11;

  if Resto > 1 then
    DV2 := 11 - Resto
  else
    DV2 := 0;

  if (IntToStr (DV1) = S[10]) and (IntToStr (DV2) = S[11]) then
    Result := True;
end;

function ValidCGC(Const S: String): Boolean;
var
aDig: array [1..14] of Byte;
I, Resto: Byte;
DV1, DV2: Byte;
Total1, Total2: Integer;
begin
  Result := False;

  if Length(S) = 14 then
  begin
    for I := 1 to 14 do
    try
      aDig[I] := StrToInt(S[I]);
    except
      aDig[I] := 0;
    end;
  end;

  Total1 := aDig[1] * 5 + aDig[2] * 4 + aDig[3] * 3 +
  aDig[4] * 2 + aDig[5] * 9 + aDig[6] * 8 +
  aDig[7] * 7 + aDig[8] * 6 + aDig[9] * 5 +
  aDig[10] * 4 + aDig[11] * 3 + aDig[12] * 2 ;
  Resto := Total1 mod 11;

  if Resto > 1 then
    DV1 := 11 - Resto
  else
    DV1 := 0;

  Total2 := aDig[1] * 6 + aDig[2] * 5 + aDig[3] * 4 +
  aDig[4] * 3 + aDig[5] * 2 + aDig[6] * 9 +
  aDig[7] * 8 + aDig[8] * 7 + aDig[9] * 6 +
  aDig[10] * 5 + aDig[11] * 4 + aDig[12] * 3 + DV1 * 2 ;

  Resto := Total2 mod 11;

  if Resto > 1 then
    DV2 := 11 - Resto
  else
    DV2 := 0;

  if (DV1 = aDig[13]) and (DV2 = aDig[14]) then
    Result := True;
end;

function Digito(Const S: String): Boolean;
var
DIG, MULT: Real;
X: Integer;
COD: String;
begin
  Result := False;
  DIG := 0;
  MULT := 3;
  COD := Copy(S, 1, length(S) - 1);

  for X := length(S) - 1 downto 1 do
  begin
    DIG := DIG + StrToInt(Copy(S, X, 1)) * MULT;

    if MULT = 3 then
      MULT := 1
    else
      MULT := 3;
  end;

  MULT := Int(DIG / 10 + 0.9) * 10;
  DIG := MULT - DIG;
  COD := COD + FloatToStr(DIG);

  if S = COD then
    Result := True;
end;

function SerialNum(FDrive: String): String;
var
Serial: DWord;
DirLen, Flags: DWord;
DLabel: array [0..11] of char;
begin
  try
    GetVolumeInformation(PChar(FDrive + ':\'), dLabel, 12, @Serial, DirLen, Flags, nil, 0);
    Result := IntToHex(Serial, 8);
  except
    Result := '';
  end;
end;

function Dig(Const S: String): String;
var
DIGITO, MULT: Real;
X: Integer;
COD: String;
begin
  Result := '';
  DIGITO := 0;
  MULT := 3;
  COD := (S);

  for X := length(S) downto 1 do
  begin
    DIGITO := DIGITO + StrToInt(Copy(S, X, 1)) * MULT;

    if MULT = 3 then
      MULT := 1
    else
      MULT := 3;
  end;

  MULT := Int(DIGITO / 10 + 0.9) * 10;
  DIGITO := MULT - DIGITO;
  COD := COD + FloatToStr(DIGITO);
  Result := COD;
end;

