procedure TFrmPrincipal.Liberar_Cheques_EmitidosClick(Sender: TObject);
var
InputString: String;
begin
  try
    InputString := InputBox(PChar(Msg_Title), 'Num. Cheque' , '0');

    if StrToInt(InputString) > 0 then
    begin
      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE CHEQUES_EMITIDOS SET DT_MOVIMENTO = :DT_MOVIMENTO');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(NUM_CHEQUE = :NUM_CHEQUE)');

      QRel.ParamByName('DT_MOVIMENTO').AsDateTime := Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      QRel.ParamByName('NUM_CHEQUE').AsInteger    := StrToInt(InputString);

      QRel.Prepare;
      QRel.ExecSql;


    end;
  except
    Application.MessageBox('Ocorreu um erro ao liberar o lanńamento', PChar(Msg_Title), mb_IconStop);
  end;
end;

