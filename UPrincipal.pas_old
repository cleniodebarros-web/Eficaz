procedure TFrmPrincipal.Encerramento_mdfeClick(Sender: TObject);
begin
  OpenDialog1.Title      := 'Selecione MDFe';
  OpenDialog1.DefaultExt := '*-mdfe.XML';
  OpenDialog1.Filter     := 'Arquivos MDF (*-mdfe.XML)|*-mdfe.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrMDFe1.Configuracoes.Arquivos.GetPathMDFe();

  if OpenDialog1.Execute then
  begin
   ACBrMDFe1.Manifestos.Clear;
   ACBrMDFe1.Manifestos.LoadFromFile(OpenDialog1.FileName);



    QCancelamento.Sql.Clear;
    QCancelamento.Sql.Add('SELECT * FROM COMPL_MDEFISCAL');
    QCancelamento.Sql.Add('WHERE');
    QCancelamento.Sql.Add('(NO_DOC_FISCAL = :NO_DOC_FISCAL)');


    QCancelamento.ParamByName('NO_DOC_FISCAL').AsInteger := (ACBrMDFe1.Manifestos.Items[0].MDFe.Ide.nMDF);

    QCancelamento.Prepare;
    QCancelamento.Open;

   if QCancelamento.IsEmpty then
   begin
      Application.MessageBox('Nota Fiscal nŃo localizada no Banco de Dados', PChar(Msg_Title), mb_IconStop);
      abort
   end
   else
   begin

      ID   := QCancelamento.FieldByName('MDEFISCAL_ID').AsInteger;


      ACBrMDFe1.EventoMDFe.Evento.Clear;

    with ACBrMDFe1.EventoMDFe.Evento.Add do
    begin
     infEvento.chMDFe   := Copy(ACBrMDFe1.Manifestos.Items[0].MDFe.infMDFe.ID, 5, 44);
     infEvento.CNPJ     := FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString;
     infEvento.dhEvento := now;
//  TpcnTpEvento = (teCCe, teCancelamento, teManifDestConfirmacao, teManifDestCiencia,
//                  teManifDestDesconhecimento, teManifDestOperNaoRealizada,
//                  teEncerramento);
     infEvento.tpEvento   := teEncerramento;
     infEvento.nSeqEvento := 1;

     infEvento.detEvento.nProt := ACBrMDFe1.Manifestos.Items[0].MDFe.procMDFe.nProt;
     infEvento.detEvento.dtEnc := Date;
     infEvento.detEvento.cUF   := StrToInt(Copy(IntToStr(ACBrMDFe1.Manifestos.Items[0].MDFe.infDoc.infMunDescarga.Items[0].cMunDescarga),1,2));
     infEvento.detEvento.cMun  := ACBrMDFe1.Manifestos.Items[0].MDFe.infDoc.infMunDescarga.Items[0].cMunDescarga;
    end;

     if ACBrMDFe1.EnviarEvento(1) then
     begin
        with ACBrMDFe1.WebServices.EnvEvento do
        begin

            QRel.Sql.Clear;
            QRel.Sql.Add('UPDATE COMPL_MDEFISCAL SET STATUS =:STATUS');
            QRel.Sql.Add('WHERE');
            QRel.Sql.Add('(MDEFISCAL_ID = :MDEFISCAL_ID)');

            QRel.ParamByName('MDEFISCAL_ID').AsInteger := ID;
            QRel.ParamByName('STATUS').AsString        := 'ENCERRADO';

            QRel.Prepare;
            QRel.ExecSql;






         Application.MessageBox(PChar('Status: ' + IntToStr(EventoRetorno.retEvento.Items[0].RetInfEvento.cStat)), PChar(Msg_Title), mb_IconInformation);
         Application.MessageBox(PChar('N║ do Protocolo: ' + EventoRetorno.retEvento.Items[0].RetInfEvento.nProt), PChar(Msg_Title), mb_IconInformation);

        end;
     end;
   end;
  end;

end;

procedure TFrmPrincipal.Encerrar_DiaClick(Sender: TObject);
begin
  if MDIChildCount = 0 then
  begin
    Application.CreateForm(TFrmFechamento, FrmFechamento);
    try
      if FrmFechamento.ShowModal = mrOk then
        Application.Terminate;
    finally
      FrmFechamento.Release;
    end;
  end
  else
  begin
    if MDIChildCount = 1 then
      Application.MessageBox('Existe janela aberta. Seria melhor fechß-la antes de encerrar', PChar(Msg_Title), mb_IconStop)
    else
      Application.MessageBox('Existem janelas abertas. Seria melhor fechß-las antes de encerrar', PChar(Msg_Title), mb_IconStop);
  end;
end;

