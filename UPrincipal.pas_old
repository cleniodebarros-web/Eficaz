procedure TFrmPrincipal.Liberar_Lancamentos_ContabeisClick(Sender: TObject);
var
InputString: String;
begin
  try
    InputString := InputBox(PChar(Msg_Title), 'Lancamento ID' , '0');

    if StrToInt(InputString) > 0 then
    begin
      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE RAZAO SET DT_MOVIMENTO = :DT_MOVIMENTO');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
      QRel.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANSACAO)');

      QRel.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      QRel.ParamByName('TRANSACAO_ID').AsInteger  := StrToInt(InputString);
      QRel.ParamByName('TIPO_TRANSACAO').AsString := 'M';

      QRel.Prepare;
      QRel.ExecSql;


    end;
  except
    Application.MessageBox('Ocorreu um erro ao liberar o lanńamento', PChar(Msg_Title), mb_IconStop);
  end;
end;

