    Senhas.Visible        := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 25, 1));

    // Caso esteja invisĒvel desabilita o atalho de teclado
    Empresas.Enabled      := Empresas.Visible;
    Funcionarios.Enabled  := Funcionarios.Visible;
    Caixas_Bancos.Enabled := Caixas_Bancos.Visible;
    Produtos.Enabled      := Produtos.Visible;
    Patrimonio.Enabled    := Patrimonio.Visible;
    Servicos.Enabled      := Servicos.Visible;
    Clientes.Enabled      := Clientes.Visible;
    Fornecedores.Enabled  := Fornecedores.Visible;
    Senhas.Enabled        := Senhas.Visible;

    // Consultas
    Consulta_Preco.Visible         := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 26, 1));
    Ficha_Financeira.Visible       := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 27, 1));
    Historico_Clientes.Visible     := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 28, 1));
    Historico_Fornecedores.Visible := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 29, 1));

    // Caso esteja invisĒvel desabilita o atalho de teclado
    Consulta_Preco.Enabled         := Consulta_Preco.Visible;
    Ficha_Financeira.Enabled       := Ficha_Financeira.Visible;
    Historico_Clientes.Enabled     := Historico_Clientes.Visible;
    Historico_Fornecedores.Enabled := Historico_Fornecedores.Visible;

    // Trans. de Mov. Financeira
    Transf_Caixa.Visible := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 30, 1));
    Receita.Visible      := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 32, 1));
    Rec_Contas.Visible   := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 33, 1));
    Cheques.Visible      := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 34, 1));
    Despesa.Visible      := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 36, 1));
    Pag_Contas.Visible   := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 37, 1));

    // Caso esteja invisĒvel desabilita o atalho de teclado
    Transf_Caixa.Enabled := Transf_Caixa.Visible;
    Receita.Enabled      := Receita.Visible;
    Rec_Contas.Enabled   := Rec_Contas.Visible;
    Cheques.Enabled      := Cheques.Visible;
    Despesa.Enabled      := Despesa.Visible;
    Pag_Contas.Enabled   := Pag_Contas.Visible;

    // Trans de Estoque
    Pedido.Visible                 := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 38, 1));
    Compra.Visible                 := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 39, 1));
    Dev_Compra.Visible             := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 40, 1));
    Orcamento.Visible              := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 42, 1));
    Venda.Visible                  := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 43, 1));
    Dev_Venda.Visible              := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 44, 1));
    Outras_Entradas_Saidas.Visible := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 46, 1));
    Transferencia_Estoque.Visible  := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 48, 1));
    Atualizar_Precos.Visible       := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 50, 1));
    Programar_PDV.Visible          := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 51, 1));
    Programar_Balancas.Visible     := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 52, 1));
    Caixa_Rapido.Visible           := False; //Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 53, 1));
    Inventario.Visible             := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 54, 1));
    Reajuste_Preco.Visible         := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 63, 1));

    // Caso esteja invisĒvel desabilita o atalho de teclado
    Pedido.Enabled                 := Pedido.Visible;
    Compra.Enabled                 := Compra.Visible;
    Dev_Compra.Enabled             := Dev_Compra.Visible;
    Orcamento.Enabled              := Orcamento.Visible;
    Venda.Enabled                  := Venda.Visible;
    Dev_Venda.Enabled              := Dev_Venda.Visible;
    Outras_Entradas_Saidas.Enabled := Outras_Entradas_Saidas.Visible;
    Transferencia_Estoque.Enabled  := Transferencia_Estoque.Visible;
    Atualizar_Precos.Enabled       := Atualizar_Precos.Visible;
    Programar_PDV.Enabled          := Programar_PDV.Visible;
    Programar_Balancas.Enabled     := Programar_Balancas.Visible;
    Caixa_Rapido.Enabled           := Caixa_Rapido.Visible;
    Inventario.Enabled             := Inventario.Visible;
    Reajuste_Preco.Enabled         := Reajuste_Preco.Visible;

    // Relat¾rios
    Rel_Caixas_Bancos.Visible           := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 55, 1));
    Rel_Custos.Visible                  := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 56, 1));
    Rel_Contas_Pagar_Receber.Visible    := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 57, 1));
    Rel_Estoque_Servicos.Visible        := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 58, 1));
    Rel_Planejamento_Financeiro.Visible := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 59, 1));
    Extrato_Comissao.Visible            := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 64, 1));
   // Contabilidade.Visible             := Caso(Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString, 60, 1));

    // Caso esteja invisĒvel desabilita o atalho de teclado
    Rel_Caixas_Bancos.Enabled           := Rel_Caixas_Bancos.Visible;
    Rel_Custos.Enabled                  := Rel_Custos.Visible;
    Rel_Contas_Pagar_Receber.Enabled    := Rel_Contas_Pagar_Receber.Visible;
    Rel_Estoque_Servicos.Enabled        := Rel_Estoque_Servicos.Visible;
    Rel_Planejamento_Financeiro.Enabled := Rel_Planejamento_Financeiro.Visible;
    Extrato_Comissao.Enabled            := Extrato_Comissao.Visible;
   // Contabilidade.Enabled             := Contabilidade.Visible;

    // Desabilita/Habilita bot§es conforme menu
    // btnEmpresas.Enabled      := Empresas.Visible;
    // btnFuncionarios.Enabled  := Funcionarios.Visible;
   // btnCaixas_Bancos.Enabled := Caixas_Bancos.Visible;
    btnProdutos.Enabled      := Produtos.Visible;
    btnClientes.Enabled      := Clientes.Visible;
    btnFornecedores.Enabled  := Fornecedores.Visible;
    btnSenhas.Enabled        := Senhas.Visible;
    btnCompras.Enabled       := Compra.Visible;
    //btnOperadores.Enabled    := Programar_PDV.Visible;
    btnNFe.Enabled           := NFe.Visible;
    btnCte.Enabled           := CTe.Visible;
    btnSintegra.Enabled      := Rel_Estoque_Servicos.Visible;
  //  btnPlanejamento.Enabled  := Rel_Planejamento_Financeiro.Visible;
    btnSped.Enabled          := Contabilidade.Visible;

    // Desabilita/Habilita Gadget
    Img_Ordem_Servico.Enabled    := Orcamento.Visible;
    Img_Orcamento.Enabled        := Orcamento.Visible;
   // Img_Venda.Enabled            := Venda.Visible;
    Img_Cheques_Emitidos.Enabled := Cheques.Visible;
    Img_Quiosque.Enabled         := Consulta_Preco.Visible;
    Img_pedido_de_venda.Enabled  := Pedido_de_venda.Visible;

    if FrmData.QAcesso.FieldByName('LIBERA').AsString = 'SIM' then
      Liberar_Lancamentos.Visible := True
    else
      Liberar_Lancamentos.Visible := False;

    if Config.FieldByName('TURNO').AsString = 'True' then
      Extrato_Vendas_Turno.Visible := True
    else
      Extrato_Vendas_Turno.Visible := False;

    if Config.FieldByName('OBJETO_ORDEM').AsString = 'SoftBeer' then
      SoftBeer.Visible := True
    else
      SoftBeer.Visible := False;


   if  FrmPrincipal.QEmpresa.FieldByName('RNTRC').AsString <> '' then
    Begin
    BtnCte.Enabled  := True;
    btnmdfe.Enabled := True;
    Mdfe1.Visible   := True;
    End
   else
   Begin
    BtnCte.Enabled  := False;
    btnmdfe.Enabled := False;
    Mdfe1.Visible   := False;
   End;

   {if NOT Config.FieldByName('TCPPDV').IsNull then
