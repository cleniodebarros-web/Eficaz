          if (not FrmLembrete_Cheques_Recebidos.QCheques_Recebidos.IsEmpty) then
            FrmLembrete_Cheques_Recebidos.ShowModal;
        finally
          FrmLembrete_Cheques_Recebidos.Release;
        end;

        QRel.Sql.Clear;
        QRel.Sql.Add('SELECT * FROM ORDEM_SERVICO');
        QRel.Sql.Add('WHERE');
        QRel.Sql.Add('(FUNCIONARIO = :FUNCIONARIO)');
        QRel.Sql.Add('AND (STATUS = :STATUS)');

        QRel.ParamByName('FUNCIONARIO').AsInteger := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
        QRel.ParamByName('STATUS').AsString       := 'AGENDADA';

        QRel.Prepare;
        QRel.Open;

        if not QRel.IsEmpty then
        Ver_Agenda_Ordem_Servico(FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger);

        Rel_Aniversariantes(StrToInt(Copy(FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsString, 4, 2)));

        Mostrou_Lembrete := True;
      end;
    end;
  except
        {on e:Exception do
        begin
