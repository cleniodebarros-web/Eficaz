procedure TFrmPrincipal.Importar_Posicao_ColetorClick(Sender: TObject);
var
F1: TextFile;
S: String;
Qtd :  Real;
Total :Longint;
begin
  QArq.Sql.Clear;
  QArq.Sql.Add('SELECT * FROM INVENTARIO_PRODUTOS');
  QArq.Sql.Add('WHERE');
  QArq.Sql.Add('(DT_INVENTARIO = :DT_INVENTARIO)');

  QArq.ParamByName('DT_INVENTARIO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  QArq.Prepare;
  QArq.Open;

   if QArq.IsEmpty then
   Begin
   Application.MessageBox(Pchar('Nao existe inventßrio criado referente a data: ' + DateToStr (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime)), PChar(Msg_Title), mb_IconInformation);
   Abort;
   End;

  OpenDialog1.Title      := 'Selecione o Arquivo';
  OpenDialog1.DefaultExt := '*.Txt';
  OpenDialog1.Filter     := 'Arquivos TXT (*.Txt)|*.Txt|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ExtractFilePath(ParamStr(0));

  if OpenDialog1.Execute then
  begin
  AssignFile(F1, OpenDialog1.FileName);
  Reset(F1);
  Total := 0;
  while not Eof(F1) do
   begin
    ReadLn(F1,S);
    inc(Total);
   end;
    Reset(F1);
    try
      if Application.MessageBox('Deseja zerar os contadores antes de importar?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin
        if (FrmAguarde = nil) then
        FrmAguarde := TFrmAguarde.Create(Application);
        FrmAguarde.Label2.Visible := True;
        FrmAguarde.Label1.Caption := 'Realizando inventßrio..... Favor Aguarde...';
        FrmAguarde.Show;
        FrmAguarde.BringToFront;

        QArq.Sql.Clear;
        QArq.Sql.Add('UPDATE INVENTARIO_PRODUTOS SET QUANTIDADE_A = NULL');

        QArq.Prepare;
        QArq.ExecSql;


      end
      Else
      Begin
        if (FrmAguarde = nil) then
        FrmAguarde := TFrmAguarde.Create(Application);
        FrmAguarde.Label2.Visible := True;
        FrmAguarde.Label1.Caption := 'Realizando inventßrio..... Favor Aguarde...';
        FrmAguarde.Show;
        FrmAguarde.BringToFront;
      End;

      while not Eof(F1) do
       begin
        Try

        ReadLn(F1, S);

        QArq.Sql.Clear;
        QArq.Sql.Add('SELECT * FROM INVENTARIO_PRODUTOS');
        QArq.Sql.Add('WHERE');
        QArq.Sql.Add('(COD_BARRA = :COD_BARRA)');
        QArq.Sql.Add('AND (DT_INVENTARIO = :DT_INVENTARIO)');

        QArq.ParamByName('COD_BARRA').AsString       := Copy(S, 1, Pos(',', S) - 1);
        QArq.ParamByName('DT_INVENTARIO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

        QArq.Prepare;
        QArq.Open;

        if not QArq.IsEmpty then
        begin

          Qtd := QArq.FieldByName('QUANTIDADE_A').AsFloat;

          QArq.Sql.Clear;
          QArq.Sql.Add('UPDATE INVENTARIO_PRODUTOS SET QUANTIDADE_A = :CONTAGEM');
          QArq.Sql.Add('WHERE');
          QArq.Sql.Add('(COD_BARRA = :COD_BARRA)');
          QArq.Sql.Add('AND (DT_INVENTARIO = :DT_INVENTARIO)');

          QArq.ParamByName('CONTAGEM').AsFloat         := StrToFloat(Copy(S, Pos(',', S) + 1, 6)) + Qtd;
          QArq.ParamByName('COD_BARRA').AsString       := Copy(S, 1, Pos(',', S) - 1);
          QArq.ParamByName('DT_INVENTARIO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

          QArq.Prepare;
          QArq.ExecSql;



          FrmAguarde.Label1.Caption := 'Inventßrio C¾digo de Barras :' + Copy(S, 1, Pos(',', S) - 1) ;
          FrmAguarde.Label2.Caption := 'Produtos Restantes :' + InttoStr(Total);

        end;
        Application.ProcessMessages;
        Total := Total -1;
        Except
        on e:Exception do
          begin
            Application.MessageBox(PChar('Erro ao importar produtos do coletor verifique!' + #13 +
              'Erro: ' + e.Message + ' ' + Copy(S, 1, Pos(',', S) - 1) ), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
          end;
        End;
       end;

    Finally
      CloseFile(F1);
      FrmAguarde.Label1.Caption       := 'AtualizańŃo Concluida!';
      FrmAguarde.Close;
      FrmAguarde.Release;
    end;
    Application.MessageBox('Processo executado com sucesso', PChar(Msg_Title), mb_IconInformation);
  end;
end;

procedure TFrmPrincipal.Importar_Posicao_EstoqueClick(Sender: TObject);
var
F1: TextFile;
S: String;
Vl_Trans, Qtd, Vr_Unit: Real;
Id_Trans: Integer;
begin
  OpenDialog1.Title      := 'Selecione o Arquivo';
  OpenDialog1.DefaultExt := '*.Txt';
  OpenDialog1.Filter     := 'Arquivos TXT (*.Txt)|*.Txt|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ExtractFilePath(ParamStr(0));

  if OpenDialog1.Execute then
  begin
    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
    IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';

    IQuery.Prepare;
    IQuery.Open;

    Id_Trans := IQuery.FieldByName('ID').AsInteger;

    Vl_Trans := 0;

    QArq.Sql.Clear;
    QArq.Sql.Add('INSERT INTO TRANSACOES( ' +
                 'TRANSACAO_ID, DT_TRANS,   DT_MOVIMENTO, CONDUTA, ' +
                 'DEPTO,        EMPRESA_ID, CONTA_ID,     C_CUSTO_ID, ' +
                 'VALOR,        TPCTB,      AUTORIZ_ID,   HISTORICO, ' +
                 'CONTAAUX_ID) VALUES(' +
                 ':TRANSACAO_ID, :DT_TRANS,   :DT_MOVIMENTO, :CONDUTA, :DEPTO,      :EMPRESA_ID, ' +
                 ':CONTA_ID,     :C_CUSTO_ID, :VALOR,        :TPCTB,   :AUTORIZ_ID, :HISTORICO, ' +
                 ':CONTAAUX_ID)');

    QArq.ParamByName('TRANSACAO_ID').AsInteger  := Id_Trans;
    QArq.ParamByName('DT_TRANS').AsDateTime     := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
    QArq.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
    QArq.ParamByName('CONDUTA').AsString        := '18';
    QArq.ParamByName('DEPTO').AsString          := '07';
    QArq.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QArq.ParamByName('CONTA_ID').AsInteger      := FrmPrincipal.Config.FieldByName('CONTA_ESTOQUE').AsInteger;
    QArq.ParamByName('C_CUSTO_ID').AsInteger    := 1;
    QArq.ParamByName('VALOR').AsFloat           := 0;
    QArq.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;
    QArq.ParamByName('AUTORIZ_ID').AsInteger    := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
    QArq.ParamByName('HISTORICO').AsString      := 'AUDITORIA ESTOQUE - INVENTARIO';
    QArq.ParamByName('CONTAAUX_ID').AsInteger   := 0;

    QArq.Prepare;
    QArq.ExecSql;



    AssignFile(F1, OpenDialog1.FileName);
    Reset(F1);

    try
      while not Eof(F1) do
      begin
        ReadLn(F1, S);

        if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
          Qtd := StrToFloat(Copy(S, 7, 12)) / 100
        else
          Qtd := StrToFloat(Copy(S, 19, 12)) / 100;

        Vr_Unit := StrToFloat(Copy(S, 31, 12)) / 100;

        if Qtd > 0 then
        begin
          QArq.Sql.Clear;
          QArq.Sql.Add('INSERT INTO TRANSITENS( ' +
                       'TRANSACAO_ID, PRODUTO_ID, TP_PROD_SERV, DESCRICAO, ' +
                       'TRIBUTO_ID,   CFOP, QUANTIDADE, VR_UNITARIO,  VR_TOTAL) VALUES(' +
                       ':TRANSACAO_ID, :PRODUTO_ID, :TP_PROD_SERV, :DESCRICAO, ' +
                       ':TRIBUTO_ID,   :CFOP, :QUANTIDADE, :VR_UNITARIO,  :VR_TOTAL)');

          QArq.ParamByName('TRANSACAO_ID').AsInteger := Id_Trans;
          QArq.ParamByName('PRODUTO_ID').AsInteger   := QRel.FieldByName('PRODUTO_ID').AsInteger;
          QArq.ParamByName('TP_PROD_SERV').AsString  := 'P';
          QArq.ParamByName('DESCRICAO').AsString     := QRel.FieldByName('DESCRICAO').AsString;
          QArq.ParamByName('TRIBUTO_ID').AsInteger   := QRel.FieldByName('TRIBUTO_ID').AsInteger;
          QArq.ParamByName('QUANTIDADE').AsFloat     := Qtd;
          QArq.ParamByName('VR_UNITARIO').AsFloat    := Vr_Unit;
          QArq.ParamByName('VR_TOTAL').AsFloat       := (Qtd * Vr_Unit);
          QArq.ParamByName('CFOP').AsString          := '5556';

          QArq.Prepare;
          QArq.ExecSql;



          Vl_Trans := Vl_Trans + (Qtd * Vr_Unit);
        end;
      end;
    finally
      CloseFile(F1);
    end;

    QArq.Sql.Clear;
    QArq.Sql.Add('UPDATE TRANSACOES SET VALOR = :VALOR');
    QArq.Sql.Add('WHERE');
    QArq.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

    QArq.ParamByName('VALOR').AsFloat := Vl_Trans;
    QArq.ParamByName('TRANSACAO_ID').AsInteger := Id_Trans;

    QArq.Prepare;
    QArq.ExecSql;



    Application.MessageBox('Processo executado com sucesso', PChar(Msg_Title), mb_IconInformation);
  end;
end;

