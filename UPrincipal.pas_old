procedure Rel_Aniversariantes(Mes: Integer);
begin
  FrmPrincipal.QRel.Sql.Clear;
  FrmPrincipal.QRel.Sql.Add('SELECT EXTRACT(DAY FROM NASCIMENTO), CLIENTE_ID, NOME, DDD, TELEFONE_1, TELEFONE_2, NASCIMENTO');
  FrmPrincipal.QRel.Sql.Add('FROM CLIENTES');
  FrmPrincipal.QRel.Sql.Add('WHERE');
  FrmPrincipal.QRel.Sql.Add('(EXTRACT(MONTH FROM NASCIMENTO) = :MES)');
  FrmPrincipal.QRel.Sql.Add('AND (STATUS = :STATUS)');
  FrmPrincipal.QRel.Sql.Add('AND (NASCIMENTO IS NOT NULL)');
  FrmPrincipal.QRel.Sql.Add('AND (TIPO_CLIENTE = :TIPO_CLIENTE)');
  FrmPrincipal.QRel.Sql.Add('ORDER BY 1');

  FrmPrincipal.QRel.ParamByName('MES').AsInteger         := Mes;
  FrmPrincipal.QRel.ParamByName('STATUS').AsString       := 'A';
  FrmPrincipal.QRel.ParamByName('TIPO_CLIENTE').AsString := 'PESSOA F═SICA';

  FrmPrincipal.QRel.Prepare;
  FrmPrincipal.QRel.Open;

  FrmPrincipal.QRLabel60.Caption := 'MĻs: ' + NomeMes(Mes);

  if not FrmPrincipal.QRel.IsEmpty then  
    FrmPrincipal.Aniversariantes.PreviewModal;
end;

procedure TFrmPrincipal.Habilita_Menu;
