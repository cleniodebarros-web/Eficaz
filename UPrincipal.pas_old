procedure TFrmPrincipal.Atualizar_VersaoClick(Sender: TObject);
var
InputString: String;
begin
  Application.CreateForm(TFrmPasswordDlg, FrmPasswordDlg);
  try
    if FrmPasswordDlg.ShowModal = mrOk then
    begin
      if FrmPasswordDlg.Password.Text = Senha_Suporte then
      begin
        InputString := InputBox(PChar(Msg_Title), 'VersŃo' , 'LIGHT');

        if (LowerCase(InputString) = 'light') or  (LowerCase(InputString) = 'plus') then
        begin

          Config.Edit;
          Config.Fields[22].AsString :=EncryptMsg(lowerCase(InputString), 65);
          Config.Post;

          Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconInformation);
          
          Application.Terminate;
        end
        else
          Application.MessageBox('Valores aceitos: LIGHT, PLUS', PChar(Msg_Title), mb_IconStop);
      end
      else
        Application.MessageBox('Acesso negado', PChar(Msg_Title), mb_IconStop);
    end;
  finally
    FrmPasswordDlg.Release;
  end;
end;

procedure TFrmPrincipal.Atualiza_Banco;
var
X: Integer;
Vrs,Dt_Sistema,Dt_Eficaz: String;
SearchFile: TSearchRec;
lpSystemTime: TSystemTime;

begin

  FindFirst((ExtractFilePath(ParamStr(0))+'Eficaz.Exe'),faAnyFile,SearchFile);
  FileTimeToSystemTime(SearchFile.FindData.ftLastWriteTime,lpSystemTime);
  Dt_Eficaz := EncryptMsg(Copy(DateTimeToStr(SystemTimeToDateTime(lpSystemTime)),1,10),39);

  Versao := '7.1.1.0';

  try
    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT * FROM ACESSO');

    QRel.Prepare;
    QRel.Open;

    if QRel.IsEmpty then
    begin
      QRel.Sql.Clear;
      QRel.Sql.Add('INSERT INTO ACESSO(' +
                   'FUNCIONARIO_ID,  SENHA,     EMPRESA_ID, ' +
                   'TPCTB,           INCLUSAO,  ALTERACAO, ' +
                   'EXCLUSAO,        ABERTURA,  TROCAR_SENHA, ' +
                   'OPCOES) VALUES(' +
                   ':FUNCIONARIO_ID, :SENHA,    :EMPRESA_ID, ' +
                   ':TPCTB,          :INCLUSAO, :ALTERACAO, ' +
                   ':EXCLUSAO,       :ABERTURA, :TROCAR_SENHA, ' +
                   ':OPCOES)');

      QRel.ParamByName('FUNCIONARIO_ID').AsInteger := 1;
      QRel.ParamByName('SENHA').AsString           := 'sr';
      QRel.ParamByName('EMPRESA_ID').AsInteger     := 1;
      QRel.ParamByName('TPCTB').AsString           := '2';
      QRel.ParamByName('INCLUSAO').AsString        := 'SIM';
      QRel.ParamByName('ALTERACAO').AsString       := 'SIM';
      QRel.ParamByName('EXCLUSAO').AsString        := 'SIM';
      QRel.ParamByName('ABERTURA').AsString        := 'SIM';
      QRel.ParamByName('TROCAR_SENHA').AsString    := 'SIM';
      QRel.ParamByName('OPCOES').AsString          := 'NNNNNNSNSSSNNNNNSSNNNNNNSNNNNNSNNNSNNNNNSNNNSNSNSNNNNNNNNNN';

      QRel.Prepare;
      QRel.ExecSql;



      QRel.Sql.Clear;
      QRel.Sql.Add('INSERT INTO ACESSO(' +
                   'FUNCIONARIO_ID,  SENHA,     EMPRESA_ID, ' +
                   'TPCTB,           INCLUSAO,  ALTERACAO, ' +
                   'EXCLUSAO,        ABERTURA,  TROCAR_SENHA, ' +
                   'OPCOES) VALUES(' +
                   ':FUNCIONARIO_ID, :SENHA,    :EMPRESA_ID, ' +
                   ':TPCTB,          :INCLUSAO, :ALTERACAO, ' +
                   ':EXCLUSAO,       :ABERTURA, :TROCAR_SENHA, ' +
                   ':OPCOES)');

      QRel.ParamByName('FUNCIONARIO_ID').AsInteger := 1;
      QRel.ParamByName('SENHA').AsString           := 'ģéÅłåō';
      QRel.ParamByName('EMPRESA_ID').AsInteger     := 1;
      QRel.ParamByName('TPCTB').AsString           := '3';
      QRel.ParamByName('INCLUSAO').AsString        := 'SIM';
      QRel.ParamByName('ALTERACAO').AsString       := 'SIM';
      QRel.ParamByName('EXCLUSAO').AsString        := 'SIM';
      QRel.ParamByName('ABERTURA').AsString        := 'SIM';
      QRel.ParamByName('TROCAR_SENHA').AsString    := 'SIM';
      QRel.ParamByName('OPCOES').AsString          := 'NNNNNNSNSSSNNNNNSSNNNNNNSNNNNNSNNNSNNNNNSNNNSNSNSNNNNNNNNNN';

      QRel.Prepare;
      QRel.ExecSql;


    end;
  except
   on e:Exception do
        begin
          Application.MessageBox(PChar('Erro ao importar produtos!' + #13 +
            'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
        end;

  end;

 try
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT * FROM VERSAO');

  QRel.Prepare;
  QRel.Open;

  Vrs        := QRel.FieldByName('VERSAO').AsString;
  Dt_Sistema := QRel.FieldByName('DATA').AsString;

  if length(Dt_Sistema) > 10  then
  Begin

  IQuery.SQL.Clear;
  IQuery.SQL.Add('UPDATE VERSAO SET DATA = :DATA');
  IQuery.ParamByName('DATA').AsString := EncryptMsg('01/01/2000',39);

  IQuery.Prepare;
  IQuery.ExecSQL;


  End;

 Except
  on e:Exception do
        begin
        IQuery.SQL.Clear;
        IQuery.SQL.Add('ALTER TABLE VERSAO ADD DATA VARCHAR(20)');
        IQuery.Prepare;
        IQuery.ExecSQL;



        Application.MessageBox('Sistema Atualizado, favor acessar novamente!', PChar(Msg_Title), mb_IconStop);
        Application.Terminate;
        end;

 end;

   if (DT_Sistema = '') or (StrToDate(DecryptMsg(Dt_Sistema,39))  <  StrToDate(DecryptMsg(Dt_Eficaz,39))) then
   Begin

      IQuery.SQL.Clear;
      IQuery.SQL.Add('UPDATE VERSAO SET DATA = :DATA');
      IQuery.ParamByName('DATA').AsString := Dt_Eficaz;

      IQuery.Prepare;
      IQuery.ExecSQL;


   End;

  if (Versao < Vrs) or (StrToDate(DecryptMsg(Dt_Eficaz,39)) < StrToDate(DecryptMsg(Dt_Sistema,39)))  then
  begin

    Application.MessageBox('A versŃo atualmente utilizada ķ mais recente do que estß.' +#13+  'O Sistema serß finalizado!', PChar(Msg_Title), mb_IconStop);
    Application.Terminate;

  end
  else if (Versao > Vrs) Then
 begin

  if (FrmAguarde = nil) then
      FrmAguarde := TFrmAguarde.Create(Application);
      FrmAguarde.Label1.Caption := 'Atualizando Sistema para versŃo: ' + versao + '. Aguarde...';
      FrmAguarde.Show;
      FrmAguarde.BringToFront;



      for X := 2 to (Estrutura.Lines.Count - 1) do
    begin
      try
        QRel.Sql.Clear;
        QRel.Sql.Add(Estrutura.Lines.Strings[X]);

        QRel.Prepare;
        QRel.ExecSql;

      except

      end;
    end;


      try
        QRel.Sql.Clear;
        QRel.Sql.Add('UPDATE VERSAO SET VERSAO = :VERSAO');

        QRel.ParamByName('VERSAO').AsString := Versao;

        QRel.Prepare;
        QRel.ExecSql;


      except
        // MessageDlg('AtualizańŃo nŃo com concluida favor verificar acesso ao banco de dados!',mtinformation,[MBOK],0);

        on e:Exception do
        begin
          Application.MessageBox(PChar('AtualizańŃo nŃo com concluida favor verificar ! ' + #13 +
            'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
        end;
      end;

       Application.MessageBox(PChar('O Banco de Dados foi atualizado para a versŃo ' + Versao), PChar(Msg_Title), mb_IconInformation);

      FrmAguarde.Label1.Caption := 'AtualizańŃo Concluida!';
      FrmAguarde.Close;
      FrmAguarde.Release;

      Application.Terminate;
 end;


 if (StrToDate(DecryptMsg(Dt_Sistema,39))  <  StrToDate(DecryptMsg(Dt_Eficaz,39)))then
 begin
    for X := 2 to (Estrutura.Lines.Count - 1) do
    begin
      try
        QRel.Sql.Clear;
        QRel.Sql.Add(Estrutura.Lines.Strings[X]);

        QRel.Prepare;
        QRel.ExecSql;

      except

      end;
    end;

 end;
end;

procedure TFrmPrincipal.Verifica_Licenca;
var
InputString, Ult_Val, Validade: String;
Pede_Registro,Registro: Boolean;
begin
  Licenca.Open;


  QRel.SQL.Clear;
  QRel.SQL.Add('SELECT * FROM EMPRESAS WHERE STATUS = :STATUS ORDER BY EMPRESA_ID');
  QRel.ParamByName('STATUS').AsString := 'A';
  QRel.Prepare;
  QRel.Open;

  QEmpresa.Close;
  QEmpresa.ParamByName('EMPRESA_ID').AsInteger := QRel.FieldByName('EMPRESA_ID').AsInteger;
  QEmpresa.Open;

  Registro := False;



  if not Licenca.Locate('SERIAL', SerialNum('C'), [loCaseInsensitive]) then
  begin
    QRel.Sql.Clear;
    QRel.Sql.Add('INSERT INTO LICENCA(SERIAL, SENHA, VALIDADE, ACESSOS) VALUES(:SERIAL, :SENHA, :VALIDADE, :ACESSOS)');

    QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

    QRel.ParamByName('SENHA').AsString := EncryptMsg('AMO A DEUS E MINHA FAMILIA3' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 10, 1), 39);

    QRel.ParamByName('VALIDADE').AsString := '';
    QRel.ParamByName('ACESSOS').AsString  := EncryptMsg('1', 39);

    QRel.Prepare;
    QRel.ExecSql;



    Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);

    Registro := True;

    Application.Terminate;
  end;

  if Licenca.Fields[8].AsString = '' then
  begin
    if (date >= StrToDate('01/01/' + Copy(DateToStr(date), 7, 4))) and (date <= StrToDate('31/03/' + Copy(DateToStr(date), 7, 4))) then
      Validade := EncryptMsg('31/03/' + Copy(DateToStr(date), 7, 4), 65);

    if (date >= StrToDate('01/04/' + Copy(DateToStr(date), 7, 4))) and (date <= StrToDate('30/06/' + Copy(DateToStr(date), 7, 4))) then
      Validade := EncryptMsg('30/06/' + Copy(DateToStr(date), 7, 4), 65);

    if (date >= StrToDate('01/07/' + Copy(DateToStr(date), 7, 4))) and (date <= StrToDate('30/09/' + Copy(DateToStr(date), 7, 4))) then
      Validade := EncryptMsg('30/09/' + Copy(DateToStr(date), 7, 4), 65);

    if (date >= StrToDate('01/10/' + Copy(DateToStr(date), 7, 4))) and (date <= StrToDate('31/12/' + Copy(DateToStr(date), 7, 4))) then
      Validade := EncryptMsg('31/12/' + Copy(DateToStr(date), 7, 4), 65);



    QRel.Sql.Clear;
    QRel.Sql.Add('UPDATE LICENCA SET VALIDADE = :VALIDADE');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(SERIAL = :SERIAL)');

    QRel.ParamByName('VALIDADE').AsString := Validade;
    QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

    QRel.Prepare;
    QRel.ExecSql;


  end;

  Pede_Registro := False;

  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT COUNT(*) FROM PRODUTOS');

  QRel.Prepare;
  QRel.Open;

  if QRel.Fields[0].AsInteger > 5 then
    Pede_Registro := True;

  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT COUNT(*) FROM CLIENTES');

  QRel.Prepare;
  QRel.Open;

  if QRel.Fields[0].AsInteger > 5 then
    Pede_Registro := True;

  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT COUNT(*) FROM FORNECEDORES');

  QRel.Prepare;
  QRel.Open;

  if QRel.Fields[0].AsInteger > 5 then
  Pede_Registro := True;

  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT COUNT(*) FROM TRANSACOES');

  QRel.Prepare;
  QRel.Open;

  if QRel.Fields[0].AsInteger > 5 then
    Pede_Registro := True;



 if (Pede_Registro) and (DecryptMsg(Licenca.Fields[2].AsString, 65) <> LowerCase(LogEntry('', '', MD5.HashStringAsHex(DecryptMsg(Licenca.Fields[1].AsString, 39) + QEmpresa.FieldByName('CNPJ').AsString  + SerialNum('C'))))) then
  begin

    Application.MessageBox('╔ necessßrio registrar o software', PChar(Msg_Title), mb_IconInformation);

    If (not Registro) and (not Licenca.Fields[2].IsNull)     then
    Begin
    QRel.SQL.Clear;
    QRel.SQL.Add('DELETE FROM LICENCA WHERE SERIAL = :SERIAL');
    QRel.ParamByName('SERIAL').AsString := SerialNum('C');

    QRel.Prepare;
    QRel.ExecSQL;



    Application.Terminate;

    End;

    Application.CreateForm(TFrmRegistro, FrmRegistro);
    try
      FrmRegistro.ShowModal;
    finally
      FrmRegistro.Release;
    end;

    Application.Terminate;
  end;

  if DecryptMsg(Licenca.Fields[2].AsString, 65) <> LowerCase(LogEntry('', '', MD5.HashStringAsHex(DecryptMsg(Licenca.Fields[1].AsString, 39)+ QEmpresa.FieldByName('CNPJ').AsString  + SerialNum('C')))) then
  begin
    if Application.MessageBox('Deseja registrar o software?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
    begin
      Application.CreateForm(TFrmRegistro, FrmRegistro);
      try
        FrmRegistro.ShowModal;
      finally
        FrmRegistro.Release;
      end;
    end
    else
    begin
      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE LICENCA SET ACESSOS = :ACESSOS');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(SERIAL = :SERIAL)');

      if DecryptMsg(Licenca.Fields[3].AsString, 65) = '' then
        QRel.ParamByName('ACESSOS').AsString := EncryptMsg('1', 39)
      else
        QRel.ParamByName('ACESSOS').AsString := EncryptMsg(IntToStr(StrToInt(DecryptMsg(Licenca.Fields[3].AsString, 39)) + 1), 39);

      QRel.ParamByName('SERIAL').AsString := SerialNum('C');

      QRel.Prepare;
      QRel.ExecSql;



      if StrToInt(DecryptMsg(Licenca.Fields[3].AsString, 39)) > 23 then
      begin
        Application.MessageBox('Validade da c¾pia expirada', PChar(Msg_Title), mb_IconStop);
        Application.Terminate;
      end
      else
        Application.MessageBox(PChar('Falta(m) ' + IntToStr(23 - StrToInt(DecryptMsg(Licenca.Fields[3].AsString, 39))) + ' acesso(s) para expirar a validade. Contacte o suporte tķcnico'), PChar(Msg_Title), mb_IconWarning);
    end;
  end
  else
  begin  
    if Licenca.Fields[11].AsString <> '' then
    Begin
      try
        if (StrtoDate(DecryptMsg(Copy(Licenca.Fields[11].AsString,1,10), 39)) <= Date) then
        Begin

         FrmPrincipal.Licenca.Edit;
         FrmPrincipal.Licenca.Fields[11].AsString := '';
         FrmPrincipal.Licenca.Post;

         FrmPrincipal.Licenca.Refresh;

         Application.MessageBox('Validade da c¾pia expirada', PChar(Msg_Title), mb_IconStop);
          Application.Terminate;
        end
        else
          Application.MessageBox(PChar('Seu registro temporßrio e vßlido atķ ' + DecryptMsg(Licenca.Fields[11].AsString, 39) + ' ap¾s esta data entre em contato com o suporte tķcnico.'), PChar(Msg_Title), mb_IconWarning);
      Except
       FrmPrincipal.Licenca.Edit;
       FrmPrincipal.Licenca.Fields[11].AsString := '';
       FrmPrincipal.Licenca.Post;

       FrmPrincipal.Licenca.Refresh;

       Application.MessageBox('Validade da c¾pia expirada', PChar(Msg_Title), mb_IconStop);

        QRel.Sql.Clear;
        QRel.Sql.Add('UPDATE LICENCA SET REGISTRO = :REGISTRO ');
        QRel.Sql.Add('WHERE');
        QRel.Sql.Add('(SERIAL = :SERIAL)');

        QRel.ParamByName('REGISTRO').AsString := '';
        QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

        QRel.Prepare;
        QRel.ExecSql;




       Application.Terminate;
      end;
    End;

    if (Copy(DateToStr(date), 4, 2) = '03') and (DecryptMsg(Licenca.Fields[4].AsString, 65) <> LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA331/03/' + Copy(DateToStr(date), 7, 4) + SerialNum('C'))))) then
    begin
      if Application.MessageBox(Pchar('A validade do software expira no fim deste mĻs. VocĻ jß possui o c¾digo de liberańŃo?'+ ' (Informe ao Suporte! HD: ' + SerialNum('C') + ')'), PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin
        InputString := InputBox(PChar(Msg_Title), 'Licenńa (' + SerialNum('C') + ')' , '');

        if InputString = LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA331/03/' + Copy(DateToStr(date), 7, 4) + SerialNum('C')))) then
        begin
          QRel.Sql.Clear;
          QRel.Sql.Add('UPDATE LICENCA SET MARCO = :MARCO, VALIDADE = :VALIDADE');
          QRel.Sql.Add('WHERE');
          QRel.Sql.Add('(SERIAL = :SERIAL)');

          QRel.ParamByName('MARCO').AsString    := EncryptMsg(InputString, 65);
          QRel.ParamByName('VALIDADE').AsString := EncryptMsg('30/06/' + Copy(DateToStr(date), 7, 4), 65);
          QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

          QRel.Prepare;
          QRel.ExecSql;



          Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
          Application.Terminate;
        end
        else
          Application.MessageBox('O valor digitado estß incorreto. Tente mais tarde', PChar(Msg_Title), mb_IconWarning);
      end;
    end;

    if (Copy(DateToStr(date), 4, 2) = '06') and (DecryptMsg(Licenca.Fields[5].AsString, 65) <> LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA330/06/' + Copy(DateToStr(date), 7, 4) + SerialNum('C'))))) then
    begin
      if Application.MessageBox(Pchar('A validade do software expira no fim deste mĻs. VocĻ jß possui o c¾digo de liberańŃo?'+ ' (Informe ao Suporte! HD: ' + SerialNum('C') + ')'), PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin
        InputString := InputBox(PChar(Msg_Title), 'Licenńa (' + SerialNum('C') + ')' , '');

       if InputString = LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA330/06/' + Copy(DateToStr(date), 7, 4) + SerialNum('C')))) then
        begin
          QRel.Sql.Clear;
          QRel.Sql.Add('UPDATE LICENCA SET JUNHO = :JUNHO, VALIDADE = :VALIDADE');
          QRel.Sql.Add('WHERE');
          QRel.Sql.Add('(SERIAL = :SERIAL)');

          QRel.ParamByName('JUNHO').AsString    := EncryptMsg(InputString, 65);
          QRel.ParamByName('VALIDADE').AsString := EncryptMsg('30/09/' + Copy(DateToStr(date), 7, 4), 65);
          QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

          QRel.Prepare;
          QRel.ExecSql;



          Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
          Application.Terminate;
        end
        else
          Application.MessageBox('O valor digitado estß incorreto. Tente mais tarde', PChar(Msg_Title), mb_IconWarning);
      end;
    end;

    if (Copy(DateToStr(date), 4, 2) = '09') and (DecryptMsg(Licenca.Fields[6].AsString, 65) <> LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA330/09/' + Copy(DateToStr(date), 7, 4) + SerialNum('C'))))) then
    begin
      if Application.MessageBox(Pchar('A validade do software expira no fim deste mĻs. VocĻ jß possui o c¾digo de liberańŃo?'+ ' (Informe ao Suporte! HD: ' + SerialNum('C') + ')'), PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin
        InputString := InputBox(PChar(Msg_Title), 'Licenńa (' + SerialNum('C') + ')' , '');

        if InputString = LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA330/09/' + Copy(DateToStr(date), 7, 4) + SerialNum('C')))) then
        begin

          QRel.Sql.Clear;
          QRel.Sql.Add('UPDATE LICENCA SET SETEMBRO = :SETEMBRO, VALIDADE = :VALIDADE');
          QRel.Sql.Add('WHERE');
          QRel.Sql.Add('(SERIAL = :SERIAL)');

          QRel.ParamByName('SETEMBRO').AsString := EncryptMsg(InputString, 65);
          QRel.ParamByName('VALIDADE').AsString := EncryptMsg('31/12/' + Copy(DateToStr(date), 7, 4), 65);
          QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

          QRel.Prepare;
          QRel.ExecSql;



          Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
          Application.Terminate;
        end
        else
          Application.MessageBox('O valor digitado estß incorreto. Tente mais tarde', PChar(Msg_Title), mb_IconWarning);
      end;
    end;


    if (Copy(DateToStr(date), 4, 2) = '12') and (DecryptMsg(Licenca.Fields[7].AsString, 65) <> LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA331/12/' + Copy(DateToStr(date), 7, 4) + SerialNum('C'))))) then
    begin
      if Application.MessageBox(Pchar('A validade do software expira no fim deste mĻs. VocĻ jß possui o c¾digo de liberańŃo?'+ ' (Informe ao Suporte! HD: ' + SerialNum('C') + ')'), PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin
        InputString := InputBox(PChar(Msg_Title), 'Licenńa (' + SerialNum('C') + ')' , '');

        if InputString = LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA331/12/' + Copy(DateToStr(date), 7, 4) + SerialNum('C')))) then
        begin
          QRel.Sql.Clear;
          QRel.Sql.Add('UPDATE LICENCA SET DEZEMBRO = :DEZEMBRO, VALIDADE = :VALIDADE');
          QRel.Sql.Add('WHERE');
          QRel.Sql.Add('(SERIAL = :SERIAL)');

          QRel.ParamByName('DEZEMBRO').AsString := EncryptMsg(InputString, 65);
          QRel.ParamByName('VALIDADE').AsString := EncryptMsg('31/03/' + IntToStr(StrToInt(Copy(DateToStr(date), 7, 4)) + 1), 65);
          QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

          QRel.Prepare;
          QRel.ExecSql;



          Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
          Application.Terminate;
        end
        else
          Application.MessageBox('O valor digitado estß incorreto. Tente mais tarde', PChar(Msg_Title), mb_IconWarning);
      end;
    end;

    if date > StrToDate(DecryptMsg(Licenca.Fields[8].AsString, 65)) then
    begin
      Ult_Val := Licenca.Fields[8].AsString;

      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE LICENCA SET DT_ACESSO = :DT_ACESSO');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(SERIAL = :SERIAL)');

      QRel.ParamByName('DT_ACESSO').AsString := EncryptMsg(DateToStr(date), 65);
      QRel.ParamByName('SERIAL').AsString    := SerialNum('C');

      QRel.Prepare;
      QRel.ExecSql;


      if Application.MessageBox(PChar('A validade do software estß expirada (' + DecryptMsg(Ult_Val, 65) + '). VocĻ jß possui a nova licenńa? (' + 'Informe ao Suporte! HD: '+ SerialNum('C') + ')'), PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin
        InputString := InputBox(PChar(Msg_Title), 'Licenńa (' + SerialNum('C') + ')' , '');

        if InputString = LowerCase(LogEntry('', '', MD5.HashStringAsHex('AMO A DEUS E MINHA FAMILIA3' + DecryptMsg(Ult_Val, 65) + SerialNum('C')))) then
        begin
          if Copy(DecryptMsg(Ult_Val, 65), 1, 5) = '31/03' then
          begin
            QRel.Sql.Clear;
            QRel.Sql.Add('UPDATE LICENCA SET MARCO = :MARCO, VALIDADE = :VALIDADE');
            QRel.Sql.Add('WHERE');
            QRel.Sql.Add('(SERIAL = :SERIAL)');

            QRel.ParamByName('MARCO').AsString    := EncryptMsg(InputString, 65);
            QRel.ParamByName('VALIDADE').AsString := EncryptMsg('30/06/' + Copy(DecryptMsg(Ult_Val, 65), 7, 4), 65);
            QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

            QRel.Prepare;
            QRel.ExecSql;



            Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
            Application.Terminate;
          end;

          if Copy(DecryptMsg(Ult_Val, 65), 1, 5) = '30/06' then
          begin
            QRel.Sql.Clear;
            QRel.Sql.Add('UPDATE LICENCA SET JUNHO = :JUNHO, VALIDADE = :VALIDADE');
            QRel.Sql.Add('WHERE');
            QRel.Sql.Add('(SERIAL = :SERIAL)');

            QRel.ParamByName('JUNHO').AsString    := EncryptMsg(InputString, 65);
            QRel.ParamByName('VALIDADE').AsString := EncryptMsg('30/09/' + Copy(DecryptMsg(Ult_Val, 65), 7, 4), 65);
            QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

            QRel.Prepare;
            QRel.ExecSql;

            Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
            Application.Terminate;
          end;

          if Copy(DecryptMsg(Ult_Val, 65), 1, 5) = '30/09' then
          begin
            QRel.Sql.Clear;
            QRel.Sql.Add('UPDATE LICENCA SET SETEMBRO = :SETEMBRO, VALIDADE = :VALIDADE');
            QRel.Sql.Add('WHERE');
            QRel.Sql.Add('(SERIAL = :SERIAL)');

            QRel.ParamByName('SETEMBRO').AsString := EncryptMsg(InputString, 65);
            QRel.ParamByName('VALIDADE').AsString := EncryptMsg('31/12/' + Copy(DecryptMsg(Ult_Val, 65), 7, 4), 65);
            QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

            QRel.Prepare;
            QRel.ExecSql;



            Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
            Application.Terminate;
          end;

          if Copy(DecryptMsg(Ult_Val, 65), 1, 5) = '31/12' then
          begin
            QRel.Sql.Clear;
            QRel.Sql.Add('UPDATE LICENCA SET DEZEMBRO = :DEZEMBRO, VALIDADE = :VALIDADE');
            QRel.Sql.Add('WHERE');
            QRel.Sql.Add('(SERIAL = :SERIAL)');

            QRel.ParamByName('DEZEMBRO').AsString := EncryptMsg(InputString, 65);
            QRel.ParamByName('VALIDADE').AsString := EncryptMsg('31/03/' + IntToStr(StrToInt(Copy(DecryptMsg(Ult_Val, 65), 7, 4)) + 1), 65);
            QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

            QRel.Prepare;
            QRel.ExecSql;



            Application.MessageBox('O Sistema serß reinicializado', PChar(Msg_Title), mb_IconStop);
            Application.Terminate;
          end;
        end
        else
        begin
          Application.MessageBox('O valor digitado estß incorreto. Tente mais tarde', PChar(Msg_Title), mb_IconWarning);
          Application.Terminate;
         end;
      end
      else
      begin
        Application.MessageBox('Validade da c¾pia expirada', PChar(Msg_Title), mb_IconStop);

        QRel.Sql.Clear;
        QRel.Sql.Add('UPDATE LICENCA SET REGISTRO = :REGISTRO ');
        QRel.Sql.Add('WHERE');
        QRel.Sql.Add('(SERIAL = :SERIAL)');

        QRel.ParamByName('REGISTRO').AsString := '';
        QRel.ParamByName('SERIAL').AsString   := SerialNum('C');

        QRel.Prepare;
        QRel.ExecSql;



        Application.Terminate;
      end;
    end;

    if Licenca.Fields[9].AsString <> '' then
    begin
      if date < StrToDate(DecryptMsg(Licenca.Fields[9].AsString, 65)) then
      begin
        Application.MessageBox(PChar('Tentativa de violańŃo do Sistema. A data foi alterada e nŃo pode ser menor que ' + DecryptMsg(Licenca.Fields[9].AsString, 65)), PChar(Msg_Title), mb_IconStop);
        Application.Terminate;
      end;
    end;
  end;
end;

procedure TFrmPrincipal.FormCloseQuery(Sender: TObject; var CanClose: Boolean);
begin
  if MDIChildCount = 0 then
  begin
    if Application.MessageBox('Deseja realmente encerrar a aplicańŃo?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
    begin
      CanClose := True;

      Application.MessageBox('NŃo esqueńa de fazer CėPIA DE SEGURANŪA do Banco de Dados. Desconsidere se jß tiver feito. Obrigado!', PChar(Msg_Title), mb_IconWarning);
      EnDecryptFile( Arq_ini , ExtractFilePath(ParamStr(0)) + 'Eficaz.ini' ,39);
      //DeleteFile(Arq_ini);
    end
    else
      CanClose := False;
  end
  else
  begin
    if MDIChildCount = 1 then
      Application.MessageBox('Existe janela aberta. Seria melhor fechß-la antes de encerrar', PChar(Msg_Title), mb_IconStop)
    else
      Application.MessageBox('Existem janelas abertas. Seria melhor fechß-las antes de encerrar', PChar(Msg_Title), mb_IconStop);

    CanClose := False;
  end;
end;

procedure TFrmPrincipal.FormCreate(Sender: TObject);
VAR
S :TformatSettings;
ShortDate:string;
begin

   S := TFormatSettings.Create('');
   ShortDate := S.ShortDateFormat;
   Md5 :=  TIdHashMessageDigest5.Create;

  if (Pos('dd', ShortDate) = 0) then
    Application.MessageBox('O formato da data precisa ser dd/MM/aaaa. Altere por favor na Painel de Controle', PChar(Msg_Title), mb_IconStop);

  if (Pos('MM', ShortDate) = 0) then
    Application.MessageBox('O formato da data precisa ser dd/MM/aaaa. Altere por favor na Painel de Controle', PChar(Msg_Title), mb_IconStop);

  if (Pos('yyyy', ShortDate) = 0) then
    Application.MessageBox('O formato da data precisa ser dd/MM/aaaa. Altere por favor na Painel de Controle', PChar(Msg_Title), mb_IconStop);


  // Arq_Ini        := 'c:\Windows\system32\' + DateToStr(date)+ '.Ini';
  Senha_suporte    := LowerCase(LogEntry('', '', MD5.HashStringAsHex('suporte arilmaq eficaz' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 7, 4))));
  senha_sped       := LogEntry('', '', MD5.HashStringAsHex(EncryptMsg('vamos unificar este sped' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 7, 4) ,39)));
  //MessageDlg(Senha_Suporte,mtinformation,[mbok],0);
  Msg_Title        := 'Eficaz';
  Title_Report     := 'Eficaz - Sist. Integ. de Adm. de Empresas';
  Mostrou_Lembrete := False;

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'NFe') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'NFe');

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'Pdf') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'PDf');

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'Can') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'Can');

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'CCe') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'CCe');

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'DPEC') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'DPEC');

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'Inu') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'Inu');

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'Evento') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'Evento');

    if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'Temp') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'Temp');

  if not DirectoryExists(ExtractFilePath(ParamStr(0)) + 'Temp') then
    CreateDir(ExtractFilePath(ParamStr(0)) + 'MDFe');

  if LeIni(Arq_Ini, 'IntegrańŃo', 'Loja') <> '' then
    Software_Terceiros.Visible := True
  else
    Software_Terceiros.Visible := False;

  Application.HintPause     := 500; // meio segundo para mostrar o hint
  Application.HintHidePause := 30000; // tempo de durańŃo = 10 segundos

  if FileExists(ExtractFilePath(ParamStr(0)) + 'Eficaz.Jpg') then
    Logo.Picture.LoadFromFile(ExtractFilePath(ParamStr(0)) + 'Eficaz.Jpg');

  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT * FROM VERSAO');

  QRel.Prepare;
  QRel.Open;

  frmSplash := TfrmSplash.Create(Application);
  frmSplash.Show;
  FrmSplash.Versao.Caption := 'VersŃo     : ' + QRel.FieldByName('VERSAO').AsString;
  FrmSplash.Data.Caption   := 'Data build(v) : '+ DecryptMsg(QRel.FieldByName('DATA').AsString ,39);
  frmSplash.Refresh;

  frmSplash.Progresso.Position := 1;
  Sleep(200);
  frmSplash.Progresso.Position:= 5;
  Sleep(200);
  Sleep(200);
  frmSplash.Progresso.Position:= 40;
  Sleep(200);
  frmSplash.Progresso.Position:= 50;
  Sleep(200);
  frmSplash.Progresso.Position:= 90;
  Sleep(200);
  frmSplash.Progresso.Position:= 100;
  Sleep(200);
  frmSplash.Hide;
  frmSplash.Free;


 // VerificaPagamento;
end;

procedure TFrmPrincipal.FormPaint(Sender: TObject);
var
Altura, Coluna: Word;
begin
  Altura := (ClientHeight + 255) div 256;

  for Coluna := 0 to 255 do
  begin
    with Canvas do
    begin
      Brush.Color := RGB(0, 0, Coluna);
      FillRect(Rect(0, Coluna * Altura, ClientWidth, (Coluna + 1) * Altura)) ;
    end;
  end;
end;

procedure TFrmPrincipal.FormShow(Sender: TObject);
var
Gerencial: Boolean;
IP                : TIdHTTP;
Temporario,Endereco,Result        : String;
X                 : Integer;

begin
  try
    if LeIni(Arq_Ini, 'ConexŃo Postgres', 'Server Name') = '' then
    begin
      CopyFile(PChar(ExtractFilePath(ParamStr(0)) + 'Eficaz.ini'), PChar(ExtractFilePath(ParamStr(0)) + 'Eficaz_' + Copy(DateToStr(date),1,2) + Copy(DateToStr(date),4,2) + Copy(DateToStr(date),7,4)+ '.old' ),True);
      DeleteFile(ExtractFilePath(ParamStr(0)) + 'Eficaz.ini');
      CopyFile(PChar(Arq_Ini), PChar(ExtractFilePath(ParamStr(0)) + 'Eficaz.ini' ),True);
      Application.MessageBox('Arquivo Eficaz.ini Criptografado com sucesso favor reiniciar o sistema', PChar(Msg_Title), MB_ICONINFORMATION);

      {try
        if FrmServidor.ShowModal = mrOK then
        begin
          FrmData.DB_Eficaz.DatabaseName := FrmServidor.Nm_Server.Text + ':' + FrmServidor.Nm_DB.Text;

          FrmData.DB_Eficaz.Params.Clear;
          FrmData.DB_Eficaz.Params.Add('user_name=' + FrmServidor.Nm_User.Text);
          FrmData.DB_Eficaz.Params.Add('password=' + FrmServidor.Password.Text);
        end;
      finally
        FrmServidor.Release;
      end;}
    end;

    //Showmessage(GetFileDate(ExtractFilePath(ParamStr(0))+'Eficaz.Exe'));




    Verifica_Licenca;
    Atualiza_Banco;
    Acesso_Sistema;

    Config.Open;

    if config.IsEmpty then
    MessageDlg('Sistema sem tabela de configurańŃo favor verificar tabela CONFIG !!!',mtinformation,[mbok],0);


   // Habilita_Menu;

    Gerencial := True;


    try
      QRel.Sql.Clear;
      QRel.Sql.Add('SELECT TPCTB');
      QRel.Sql.Add('FROM TRANSITENS');

      QRel.Prepare;
      QRel.Open;
      except
      { on e:Exception do
        begin
          Application.MessageBox(PChar('Erro ao gerar arquivo TESTE1!' + #13 +
            'Erro: ' + e.Message), PChar(Msg_Title), mb_IconStop + mb_TaskModal);
        Gerencial := False;
