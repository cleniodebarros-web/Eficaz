procedure TFrmPrincipal.Consultar_CadastroClick(Sender: TObject);
var
UF, Documento: String;
begin
  try
    if not(InputQuery('WebServices Consulta Cadastro ', 'UF do Documento a ser Consultado:', UF)) then
      exit;

    if not(InputQuery('WebServices Consulta Cadastro ', 'Documento(CPF/CNPJ)', Documento)) then
      exit;

    Documento := Alltrim(SemMascara(Documento));

    ACBrNFe1.WebServices.ConsultaCadastro.UF := UpperCase(UF);

    if Length(Documento) > 11 then
       ACBrNFe1.WebServices.ConsultaCadastro.CNPJ := Documento
    else
       ACBrNFe1.WebServices.ConsultaCadastro.CPF := Documento;

    ACBrNFe1.WebServices.ConsultaCadastro.Executar;

    Application.MessageBox(PChar(ACBrNFe1.WebServices.ConsultaCadastro.xMotivo), PChar(Msg_Title), mb_IconInformation);
    Application.MessageBox(PChar('Nome do Contribuinte: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].xNome + #13 +
                                 'Fantasia: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].xFant + #13 +
                                 'CNPJ: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].CNPJ + #13 +
                                 'CPF: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].CPF + #13 +
                                 'Inscr. Estadual: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].IE + #13 +
                                 'Endereńo: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].xLgr + #13 +
                                 'N·mero: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].nro + #13 +
                                 'Compl.: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].xCpl + #13 +
                                 'Bairro: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].xBairro + #13 +
                                 'IBGE Mun.: ' + IntToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].cMun) + #13 +
                                 'MunicĒpio: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].xMun + #13 +
                                 'CEP: ' + IntToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].CEP) + #13 +
                                 'UF: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].UF + #13 +
                                 'SituańŃo: ' + IntToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].cSit) + #13 +
                                 'Cred.NFe: ' + IntToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].indCredNFe) + #13 +
                                 'Cred. CTe: ' + IntToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].indCredCTe) + #13 +
                                 'Reg. ApurańŃo: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].xRegApur + #13 +
                                 'CNAE: ' + IntToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].CNAE) + #13 +
                                 'Ini. Ativ.: ' + DateToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].dIniAtiv) + #13 +
                                 '┌lt. SituańŃo: ' + DateToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].dUltSit) + #13 +
                                 'Dt. Baixa: ' + DateToStr(ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].dBaixa) + #13 +
                                 'IE ┌nica: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].IEUnica + #13 +
                                 'IE Atual: ' + ACBrNFe1.WebServices.ConsultaCadastro.RetConsCad.InfCad.Items[0].IEAtual), PChar(Msg_Title), mb_IconInformation);
  except
    Application.MessageBox('Ocorreu um erro ao realizar a consulta', PChar(Msg_Title), mb_IconInformation);
  end;
end;

