    if FileExists(Rx + 'Precf.' + Cx) then
    begin
      AssignFile(F1, Rx + 'Precf.' + Cx);
      Reset(F1);

      while not Eof(F1) do
      begin
        ReadLn(F1, S);

        QCarga.Sql.Clear;
        QCarga.Sql.Add('SELECT * FROM LICENCA_IF');
        QCarga.Sql.Add('WHERE');
        QCarga.Sql.Add('(SERIAL = :SERIAL)');

        QCarga.ParamByName('SERIAL').AsString := Alltrim(Copy(S, 1, 30));

        QCarga.Prepare;
        QCarga.Open;

        if QCarga.IsEmpty then
        begin
          QCarga.Sql.Clear;
          QCarga.Sql.Add('INSERT INTO LICENCA_IF(' +
                                                 'SERIAL,       MF_ADICIONAL,     TIPO_ECF,      MARCA_ECF, ' +
                                                 'MODELO,       CNI,              VERSAO_SB,     DT_INST_SB, ' +
                                                 'HR_INST_SB,   NUM_ECF,          NUM_VERSAO,    CNPJ, ' +
                                                 'IE,           LICENCA,          GRANDE_TOTAL,  MD5) VALUES(' +
                                                 ':SERIAL,      :MF_ADICIONAL,    :TIPO_ECF,     :MARCA_ECF, ' +
                                                 ':MODELO,      :CNI,             :VERSAO_SB,    :DT_INST_SB, ' +
                                                 ':HR_INST_SB,  :NUM_ECF,         :NUM_VERSAO,   :CNPJ, ' +
                                                 ':IE,          :LICENCA,         :GRANDE_TOTAL, :MD5)');

          QCarga.ParamByName('SERIAL').AsString       := Alltrim(Copy(S, 1, 30));
          QCarga.ParamByName('MF_ADICIONAL').AsString := Alltrim(Copy(S, 31, 1));
          QCarga.ParamByName('TIPO_ECF').AsString     := Alltrim(Copy(S, 32, 15));
          QCarga.ParamByName('MARCA_ECF').AsString    := Alltrim(Copy(S, 47, 30));
          QCarga.ParamByName('MODELO').AsString       := Alltrim(Copy(S, 77, 20));
          QCarga.ParamByName('CNI').AsString          := Alltrim(Copy(S, 97, 6));
          QCarga.ParamByName('VERSAO_SB').AsString    := Alltrim(Copy(S, 103, 20));
          QCarga.ParamByName('DT_INST_SB').AsDateTime := StrToDate(Copy(S, 123, 10));
          QCarga.ParamByName('HR_INST_SB').AsString   := Copy(S, 133, 8);
          QCarga.ParamByName('NUM_ECF').AsString      := Alltrim(Copy(S, 141, 3));
          QCarga.ParamByName('NUM_VERSAO').AsString   := Alltrim(Copy(S, 144, 10));
          QCarga.ParamByName('CNPJ').AsString         := Alltrim(Copy(S, 154, 18));
          QCarga.ParamByName('IE').AsString           := Alltrim(Copy(S, 172, 20));
          QCarga.ParamByName('LICENCA').AsString      := Alltrim(Copy(S, 192, 32));
          QCarga.ParamByName('GRANDE_TOTAL').AsFloat  := (StrToFloat(Copy(S, 224, 12)) / 100);
          QCarga.ParamByName('MD5').AsString          := Alltrim(Copy(S, 236, 32));

          QCarga.Prepare;
          QCarga.ExecSql;


        end
        else
        begin
          QCarga.Sql.Clear;
          QCarga.Sql.Add('UPDATE LICENCA_IF SET ' +
                                                'MF_ADICIONAL = :MF_ADICIONAL, TIPO_ECF   = :TIPO_ECF,   MARCA_ECF    = :MARCA_ECF, ' +
                                                'MODELO       = :MODELO,       CNI        = :CNI,        VERSAO_SB    = :VERSAO_SB, ' +
                                                'DT_INST_SB   = :DT_INST_SB,   HR_INST_SB = :HR_INST_SB, ' +
                                                'NUM_ECF      = :NUM_ECF,      NUM_VERSAO = :NUM_VERSAO, CNPJ         = :CNPJ, ' +
                                                'IE           = :IE,           LICENCA    = :LICENCA,    GRANDE_TOTAL = :GRANDE_TOTAL, ' +
                                                'MD5          = :MD5 ' +
                                                'WHERE ' +
                                                '(SERIAL = :SERIAL)');

          QCarga.ParamByName('MF_ADICIONAL').AsString := Alltrim(Copy(S, 31, 1));
          QCarga.ParamByName('TIPO_ECF').AsString     := Alltrim(Copy(S, 32, 15));
          QCarga.ParamByName('MARCA_ECF').AsString    := Alltrim(Copy(S, 47, 30));
          QCarga.ParamByName('MODELO').AsString       := Alltrim(Copy(S, 77, 20));
          QCarga.ParamByName('CNI').AsString          := Alltrim(Copy(S, 97, 6));
          QCarga.ParamByName('VERSAO_SB').AsString    := Alltrim(Copy(S, 103, 20));
          QCarga.ParamByName('DT_INST_SB').AsDateTime := StrToDate(Copy(S, 123, 10));
          QCarga.ParamByName('HR_INST_SB').AsString   := Copy(S, 133, 8);
          QCarga.ParamByName('NUM_ECF').AsString      := Alltrim(Copy(S, 141, 3));
          QCarga.ParamByName('NUM_VERSAO').AsString   := Alltrim(Copy(S, 144, 10));
          QCarga.ParamByName('CNPJ').AsString         := Alltrim(Copy(S, 154, 18));
          QCarga.ParamByName('IE').AsString           := Alltrim(Copy(S, 172, 20));
          QCarga.ParamByName('LICENCA').AsString      := Alltrim(Copy(S, 192, 32));
          QCarga.ParamByName('GRANDE_TOTAL').AsFloat  := (StrToFloat(Copy(S, 224, 12)) / 100);
          QCarga.ParamByName('MD5').AsString          := Alltrim(Copy(S, 236, 32));
          QCarga.ParamByName('SERIAL').AsString       := Alltrim(Copy(S, 1, 30));

          QCarga.Prepare;
          QCarga.ExecSql;


        end;

        Application.ProcessMessages;
      end;

      CloseFile(F1);
      DeleteFile(Rx + 'Precf.' + Cx);
    end;
    except
      DeleteFile(Rx + 'Precf.' + Cx);
    end;
    StatusBar.Panels[4].Text := Status_Temp;
end;






procedure Carga_PDV_Off_Line(Produto, Cliente: Integer);
var
Caminho_Tx, Promo_Ini, Promo_Fim, Neg_Pos_C, Neg_Pos_G, Nm_Arq: String;
Aliq_ICMS, Saldo,saldo_cheque: Real;
Y: Integer;
F1: TextFile;
begin
  Caminho_Tx := LeIni(Arq_Ini, 'TCPPDV', 'Path Tx');
  Nm_Arq     := Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(TimeToStr(time), 1, 2) + Copy(TimeToStr(time), 4, 2) + Copy(TimeToStr(time), 7, 2);

  if Produto > 0 then
  begin
    try
      AssignFile(F1, Caminho_Tx + 'Prprd');
      Rewrite(F1);

      FrmPrincipal.QTabela.Sql.Clear;
      FrmPrincipal.QTabela.Sql.Add('SELECT PRODUTOS.*, TRIBUTOS.CODIGO_ECF');
      FrmPrincipal.QTabela.Sql.Add('FROM PRODUTOS');
      FrmPrincipal.QTabela.Sql.Add('INNER JOIN TRIBUTOS');
      FrmPrincipal.QTabela.Sql.Add('ON (PRODUTOS.TRIBUTO_ID = TRIBUTOS.TRIBUTO_ID)');
      FrmPrincipal.QTabela.Sql.Add('WHERE');
      FrmPrincipal.QTabela.Sql.Add('(PRODUTOS.PRODUTO_ID = :PRODUTO_ID)');

      FrmPrincipal.QTabela.ParamByName('PRODUTO_ID').AsInteger := Produto;

      FrmPrincipal.QTabela.Prepare;
      FrmPrincipal.QTabela.Open;

      FrmPrincipal.QTabela.First;
      while not FrmPrincipal.QTabela.Eof do
      begin
        if FrmPrincipal.QTabela.FieldByName('PROMO_INICIAL').AsString = '' then
          Promo_Ini := '30/12/1899'
        else
          Promo_Ini := FrmPrincipal.QTabela.FieldByName('PROMO_INICIAL').AsString;

        if FrmPrincipal.QTabela.FieldByName('PROMO_FINAL').AsString = '' then
          Promo_Fim := '30/12/1899'
        else
          Promo_Fim := FrmPrincipal.QTabela.FieldByName('PROMO_FINAL').AsString;

        if FrmPrincipal.QTabela.FieldByName('QUANTIDADE_C').AsFloat < 0 then
          Neg_Pos_C := 'N'
        else
          Neg_Pos_C := 'P';

        if FrmPrincipal.QTabela.FieldByName('QUANTIDADE_G').AsFloat < 0 then
          Neg_Pos_G := 'N'
        else
          Neg_Pos_G := 'P';

        if LeIni(Arq_Ini, 'Sistema', 'Carga de Produtos p/ C¾d. ECF') = 'True' then
        begin
          if (Copy(FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsString, 1, 1) <> 'I') and (Copy(FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsString, 1, 1) <> 'F') and (Copy(FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsString, 1, 1) <> 'N') then
            Aliq_ICMS := FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsFloat
          else
            Aliq_ICMS := FrmPrincipal.QTabela.FieldByName('ALIQUOTA_ICMS').AsFloat;
        end
        else
          Aliq_ICMS := FrmPrincipal.QTabela.FieldByName('ALIQUOTA_ICMS').AsFloat;

        WriteLn(F1, StrZero(FrmPrincipal.QTabela.FieldByName('PRODUTO_ID').AsString, 6, 0) +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA').AsString, 14, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CAD_SIMPLES').AsString, 1, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('NCM').AsString, 8, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CODRED').AsString, 7, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('DESCRICAO').AsString, 40, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('FANTASIA').AsString, 24, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('SUPERVISOR').AsString, 3, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('PROVQT').AsString, 3, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('UNIDADE').AsString, 6, ' ') +
                    StrZero(FrmPrincipal.QTabela.FieldByName('EMBALAGEM').AsString, 9, 2) +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('UNIDADE_VENDA').AsString, 6, ' ') +
                    StrZero(FrmPrincipal.QTabela.FieldByName('FRACAO_VENDA').AsString, 9, 2) +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('IAT').AsString, 1, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('IPPT').AsString, 1, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('PESAVEL').AsString, 3, ' ') +
                    StrZero(FrmPrincipal.QTabela.FieldByName('ETIQUETA').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('BALTECLA').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('BALDPT').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('BALTIPO').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('VALIDADE').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('EMPRESA_ID').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('GRUPO_ID').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('SUBTIPO_ID').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('LOCALIZACAO_ID').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('TRIBUTO_ID').AsString, 5, 0) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('FAMILIA_ID').AsString, 5, 0) +
                    StrZero(FloatToStr(Aliq_ICMS), 12, 2) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_VAREJO').AsString, 12, 2) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_ATACADO').AsString, 12, 2) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_PROMOCAO').AsString, 12, 2) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_PRAZO').AsString, 12, 2) +
                    Promo_Ini +
                    Promo_Fim +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('STATUS').AsString, 1, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX1').AsString, 14, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX2').AsString, 14, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX3').AsString, 14, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX4').AsString, 14, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_ORIGINAL').AsString, 20, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('REFERENCIA').AsString, 13, ' ') +
                    StrZero(FloatToStr(Abs(FrmPrincipal.QTabela.FieldByName('QUANTIDADE_C').AsFloat)), 12, 2) +
                    Neg_Pos_C +
                    StrZero(FloatToStr(Abs(FrmPrincipal.QTabela.FieldByName('QUANTIDADE_G').AsFloat)), 12, 2) +
                    Neg_Pos_G);

        Application.ProcessMessages;
        FrmPrincipal.QTabela.Next;
      end;

      CloseFile(F1);

      for Y := 1 to 40 do
      begin
        if LeIni(Arq_Ini, 'Caixas', 'Caixa ' + StrZero(IntToStr(Y), 2, 0)) <> '' then
          CopyFile(PChar(Caminho_Tx + 'Prprd'), PChar(Caminho_Tx + 'Prprd' + Nm_Arq + '.0' + StrZero(IntToStr(Y), 2, 0)), False);
      end;
    except

    end;

    DeleteFile(Caminho_Tx + 'Prprd');
  end;

  if Cliente > 0 then
  begin
    try
      AssignFile(F1, Caminho_Tx + 'Prcli');
      Rewrite(F1);

      FrmPrincipal.QTabela.Sql.Clear;
      FrmPrincipal.QTabela.Sql.Add('SELECT * FROM CLIENTES');
      FrmPrincipal.QTabela.Sql.Add('WHERE');
      FrmPrincipal.QTabela.Sql.Add('(CLIENTE_ID = :CLIENTE_ID)');

      FrmPrincipal.QTabela.ParamByName('CLIENTE_ID').AsInteger := Cliente;

      FrmPrincipal.QTabela.Prepare;
      FrmPrincipal.QTabela.Open;

      FrmPrincipal.QTabela.First;
      while not FrmPrincipal.QTabela.Eof do
      begin
        FrmPrincipal.QCarga.Sql.Clear;
        FrmPrincipal.QCarga.Sql.Add('SELECT SUM(TRANSPARCELAS.VALOR) AS VALOR');
        FrmPrincipal.QCarga.Sql.Add('FROM TRANSPARCELAS');
        FrmPrincipal.QCarga.Sql.Add('INNER JOIN TRANSACOES');
        FrmPrincipal.QCarga.Sql.Add('ON (TRANSPARCELAS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
        FrmPrincipal.QCarga.Sql.Add('INNER JOIN CLIENTES');
        FrmPrincipal.QCarga.Sql.Add('ON (TRANSACOES.CLIENTE_ID = CLIENTES.CLIENTE_ID)');
        FrmPrincipal.QCarga.Sql.Add('WHERE');
        FrmPrincipal.QCarga.Sql.Add('(TRANSPARCELAS.TIPO_TRANSACAO = :TIPO_TRANSACAO)');
        FrmPrincipal.QCarga.Sql.Add('AND ((TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL))');
        FrmPrincipal.QCarga.Sql.Add('AND (TRANSPARCELAS.VALOR > 0)');
        FrmPrincipal.QCarga.Sql.Add('AND (TRANSPARCELAS.BANCO_ID = 0)');
        FrmPrincipal.QCarga.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
        FrmPrincipal.QCarga.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
        FrmPrincipal.QCarga.Sql.Add('AND (TRANSACOES.COND_PAGTO = :COND_PAGTO)');
        FrmPrincipal.QCarga.Sql.Add('AND (TRANSACOES.CLIENTE_ID = :CLIENTE_ID)');

        FrmPrincipal.QCarga.ParamByName('TIPO_TRANSACAO').AsString := 'T';
        FrmPrincipal.QCarga.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
        FrmPrincipal.QCarga.ParamByName('CONDUTA').AsString        := '01';
        FrmPrincipal.QCarga.ParamByName('COND_PAGTO').AsString     := 'A PRAZO';
        FrmPrincipal.QCarga.ParamByName('CLIENTE_ID').AsInteger    := FrmPrincipal.QTabela.FieldByName('CLIENTE_ID').AsInteger;

        FrmPrincipal.QCarga.Prepare;
        FrmPrincipal.QCarga.Open;

        Saldo := FrmPrincipal.QCarga.FieldByName('VALOR').AsFloat;


        FrmPrincipal.QCarga.Sql.Clear;
        FrmPrincipal.QCarga.Sql.Add('SELECT SUM(CHEQUES_RECEBIDOS.VALOR) AS VALOR');
        FrmPrincipal.QCarga.Sql.Add('FROM CHEQUES_RECEBIDOS');
        FrmPrincipal.QCarga.Sql.Add('INNER JOIN CLIENTES');
        FrmPrincipal.QCarga.Sql.Add('ON (CHEQUES_RECEBIDOS.CLIENTE_ID = CLIENTES.CLIENTE_ID)');
        FrmPrincipal.QCarga.Sql.Add('WHERE');
        FrmPrincipal.QCarga.Sql.Add('(CLIENTES.CLIENTE_ID = :CLIENTE_ID)');
        FrmPrincipal.QCarga.Sql.Add('AND ((BANCO_ID = 0) OR (BANCO_ID IS NULL))');

        FrmPrincipal.QCarga.ParamByName('CLIENTE_ID').AsInteger    := FrmPrincipal.QTabela.FieldByName('CLIENTE_ID').AsInteger;

        FrmPrincipal.QCarga.Prepare;
        FrmPrincipal.QCarga.Open;

        Saldo_Cheque := FrmPrincipal.QCarga.FieldByName('VALOR').AsFloat;


        FrmPrincipal.QVencimento.Sql.Clear;
        FrmPrincipal.QVencimento.Sql.Add('SELECT CLIENTES.CLIENTE_ID, TRANSPARCELAS.DT_VENCIMENTO,TRANSPARCELAS.VALOR');
        FrmPrincipal.QVencimento.Sql.Add('FROM CLIENTES CLIENTES');
        FrmPrincipal.QVencimento.Sql.Add('INNER JOIN TRANSACOES TRANSACOES');
        FrmPrincipal.QVencimento.Sql.Add('ON (CLIENTES.CLIENTE_ID = TRANSACOES.CLIENTE_ID)');
        FrmPrincipal.QVencimento.Sql.Add('INNER JOIN TRANSPARCELAS TRANSPARCELAS');
        FrmPrincipal.QVencimento.Sql.Add('ON (TRANSACOES.TRANSACAO_ID = TRANSPARCELAS.TRANSACAO_ID)');
        FrmPrincipal.QVencimento.Sql.Add('WHERE (CLIENTES.CLIENTE_ID = :CLIENTE_ID)');
        FrmPrincipal.QVencimento.Sql.Add('AND (TRANSPARCELAS.DT_VENCIMENTO <= :DT_VENCIMENTO)');
        FrmPrincipal.QVencimento.Sql.Add('AND ((TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL))');
        FrmPrincipal.QVencimento.Sql.Add('AND (TRANSPARCELAS.VALOR > 0)');
        FrmPrincipal.QVencimento.Sql.Add('AND (TRANSPARCELAS.BANCO_ID = 0)');
        FrmPrincipal.QVencimento.Sql.Add('AND (TRANSPARCELAS.TIPO_TRANSACAO = :TIPO_TRANSACAO)');
        FrmPrincipal.QVencimento.Sql.Add('AND (TRANSACOES.COND_PAGTO = :COND_PAGTO)');
        FrmPrincipal.QVencimento.Sql.Add('ORDER BY DT_VENCIMENTO');

        FrmPrincipal.QVencimento.ParamByName('TIPO_TRANSACAO').AsString  := 'T';
        FrmPrincipal.QVencimento.ParamByName('COND_PAGTO').AsString      := 'A PRAZO';
        FrmPrincipal.QVencimento.ParamByName('CLIENTE_ID').AsInteger     := FrmPrincipal.QTabela.FieldByName('CLIENTE_ID').AsInteger;
        FrmPrincipal.QVencimento.ParamByName('DT_VENCIMENTO').AsDateTime := date - (FrmPrincipal.Config.FieldByName('CARENCIA').AsInteger + 1);

        FrmPrincipal.QVencimento.Prepare;
        FrmPrincipal.QVencimento.open;



        WriteLn(F1, StrZero(FrmPrincipal.QTabela.FieldByName('CLIENTE_ID').AsString, 5, 0) +
                    ForcaComprimento(Copy(FrmPrincipal.QTabela.FieldByName('NOME').AsString, 1, 70), 70, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CNPJ').AsString, 18, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('ENDERECO').AsString, 60, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('BAIRRO').AsString, 40, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('MUNICIPIO').AsString, 30, ' ') +
                    StrZero(FrmPrincipal.QTabela.FieldByName('LIMITE').AsString, 12, 2) +
                    StrZero(FloatToStr(Saldo), 12, 2) +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('BLOQUEADO').AsString, 3, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('STATUS').AsString, 1, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CARTAO_IDENT1').AsString, 13, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CARTAO_IDENT2').AsString, 13, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CARTAO_IDENT3').AsString, 13, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CARTAO_IDENT4').AsString, 13, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('SENHA').AsString, 9, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('OBSERVACAO').AsString, 150, ' ') +
                    ForcaComprimento(FrmPrincipal.QTabela.FieldByName('BLOQ_CHEQUE').AsString, 3, ' ') +
                    ForcaComprimento(FrmPrincipal.QVencimento.FieldByName('DT_VENCIMENTO').AsString, 10, ' ') +
                    StrZero(FrmPrincipal.QVencimento.FieldByName('VALOR').AsString, 12, 2) +
                    StrZero(FrmPrincipal.QTabela.FieldByName('LIMITE_CHEQUE').AsString, 12, 2) +
                    StrZero(FloatToStr(Saldo_Cheque), 12, 2));

        Application.ProcessMessages;
        FrmPrincipal.QTabela.Next;
      end;

      CloseFile(F1);

      for Y := 1 to 40 do
      begin
        if LeIni(Arq_Ini, 'Caixas', 'Caixa ' + StrZero(IntToStr(Y), 2, 0)) <> '' then
          CopyFile(PChar(Caminho_Tx + 'Prcli'), PChar(Caminho_Tx + 'Prcli' + Nm_Arq + '.0' + StrZero(IntToStr(Y), 2, 0)), False);
      end;
    except

    end;
    DeleteFile(Caminho_Tx + 'Prcli');
  end;
end;

procedure Carga_PDV_Movimento(Transacao: Integer);
var
Caminho_Tx, Promo_Ini, Promo_Fim, Neg_Pos_C, Neg_Pos_G, Nm_Arq: String;
Aliq_ICMS: Real;
Y: Integer;
F1: TextFile;
begin
  Caminho_Tx := LeIni(Arq_Ini, 'TCPPDV', 'Path Tx');
  Nm_Arq     := Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) +  Copy(TimeToStr(time), 1, 2) + Copy(TimeToStr(time), 4, 2) + Copy(TimeToStr(time), 7, 2);

  try
    AssignFile(F1, Caminho_Tx + 'Prprd');
    Rewrite(F1);

    FrmPrincipal.QTabela.Sql.Clear;
    FrmPrincipal.QTabela.Sql.Add('SELECT PRODUTOS.*, TRIBUTOS.CODIGO_ECF');
    FrmPrincipal.QTabela.Sql.Add('FROM TRANSITENS');
    FrmPrincipal.QTabela.Sql.Add('INNER JOIN PRODUTOS');
    FrmPrincipal.QTabela.Sql.Add('ON (TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID)');
    FrmPrincipal.QTabela.Sql.Add('INNER JOIN TRIBUTOS');
    FrmPrincipal.QTabela.Sql.Add('ON (PRODUTOS.TRIBUTO_ID = TRIBUTOS.TRIBUTO_ID)');
    FrmPrincipal.QTabela.Sql.Add('WHERE');
    FrmPrincipal.QTabela.Sql.Add('(TRANSITENS.TRANSACAO_ID = :TRANSACAO_ID)');

    FrmPrincipal.QTabela.ParamByName('TRANSACAO_ID').AsInteger := Transacao;

    FrmPrincipal.QTabela.Prepare;
    FrmPrincipal.QTabela.Open;

    FrmPrincipal.QTabela.First;
    while not FrmPrincipal.QTabela.Eof do
    begin
      if FrmPrincipal.QTabela.FieldByName('PROMO_INICIAL').AsString = '' then
        Promo_Ini := '30/12/1899'
      else
        Promo_Ini := FrmPrincipal.QTabela.FieldByName('PROMO_INICIAL').AsString;

      if FrmPrincipal.QTabela.FieldByName('PROMO_FINAL').AsString = '' then
        Promo_Fim := '30/12/1899'
      else
        Promo_Fim := FrmPrincipal.QTabela.FieldByName('PROMO_FINAL').AsString;

      if FrmPrincipal.QTabela.FieldByName('QUANTIDADE_C').AsFloat < 0 then
        Neg_Pos_C := 'N'
      else
        Neg_Pos_C := 'P';

      if FrmPrincipal.QTabela.FieldByName('QUANTIDADE_G').AsFloat < 0 then
        Neg_Pos_G := 'N'
      else
        Neg_Pos_G := 'P';

      if LeIni(Arq_Ini, 'Sistema', 'Carga de Produtos p/ C¾d. ECF') = 'True' then
      begin
        if (Copy(FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsString, 1, 1) <> 'I') and (Copy(FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsString, 1, 1) <> 'F') and (Copy(FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsString, 1, 1) <> 'N') then
          Aliq_ICMS := FrmPrincipal.QTabela.FieldByName('CODIGO_ECF').AsFloat
        else
          Aliq_ICMS := FrmPrincipal.QTabela.FieldByName('ALIQUOTA_ICMS').AsFloat;
      end
      else
        Aliq_ICMS := FrmPrincipal.QTabela.FieldByName('ALIQUOTA_ICMS').AsFloat;

      WriteLn(F1, StrZero(FrmPrincipal.QTabela.FieldByName('PRODUTO_ID').AsString, 6, 0) +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA').AsString, 14, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CAD_SIMPLES').AsString, 1, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('NCM').AsString, 8, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('CODRED').AsString, 7, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('DESCRICAO').AsString, 40, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('FANTASIA').AsString, 24, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('SUPERVISOR').AsString, 3, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('PROVQT').AsString, 3, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('UNIDADE').AsString, 6, ' ') +
                  StrZero(FrmPrincipal.QTabela.FieldByName('EMBALAGEM').AsString, 9, 2) +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('UNIDADE_VENDA').AsString, 6, ' ') +
                  StrZero(FrmPrincipal.QTabela.FieldByName('FRACAO_VENDA').AsString, 9, 2) +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('IAT').AsString, 1, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('IPPT').AsString, 1, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('PESAVEL').AsString, 3, ' ') +
                  StrZero(FrmPrincipal.QTabela.FieldByName('ETIQUETA').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('BALTECLA').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('BALDPT').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('BALTIPO').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('VALIDADE').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('EMPRESA_ID').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('GRUPO_ID').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('SUBTIPO_ID').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('LOCALIZACAO_ID').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('TRIBUTO_ID').AsString, 5, 0) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('FAMILIA_ID').AsString, 5, 0) +
                  StrZero(FloatToStr(Aliq_ICMS), 12, 2) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_VAREJO').AsString, 12, 2) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_ATACADO').AsString, 12, 2) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_PROMOCAO').AsString, 12, 2) +
                  StrZero(FrmPrincipal.QTabela.FieldByName('PRECO_PRAZO').AsString, 12, 2) +
                  Promo_Ini +
                  Promo_Fim +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('STATUS').AsString, 1, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX1').AsString, 14, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX2').AsString, 14, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX3').AsString, 14, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_BARRA_AUX4').AsString, 14, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('COD_ORIGINAL').AsString, 20, ' ') +
                  ForcaComprimento(FrmPrincipal.QTabela.FieldByName('REFERENCIA').AsString, 13, ' ') +
                  StrZero(FloatToStr(Abs(FrmPrincipal.QTabela.FieldByName('QUANTIDADE_C').AsFloat)), 12, 2) +
                  Neg_Pos_C +
                  StrZero(FloatToStr(Abs(FrmPrincipal.QTabela.FieldByName('QUANTIDADE_G').AsFloat)), 12, 2) +
                  Neg_Pos_G);
                  //EncryptMsg(IntToStr(StrToInt(Copy(DecryptMsg(FrmPrincipal.QEmpresa.FieldByName('LICENCA').AsString,65),27,3)) - Usuarios ),65)
      Application.ProcessMessages;
      FrmPrincipal.QTabela.Next;
    end;

    CloseFile(F1);

    for Y := 1 to 40 do
    begin
      if LeIni(Arq_Ini, 'Caixas', 'Caixa ' + StrZero(IntToStr(Y), 2, 0)) <> '' then
        CopyFile(PChar(Caminho_Tx + 'Prprd'), PChar(Caminho_Tx + 'Prprd' + Nm_Arq + '.0' + StrZero(IntToStr(Y), 2, 0)), False);
    end;
  except

  end;

  DeleteFile(Caminho_Tx + 'Prprd');
end;

end.
