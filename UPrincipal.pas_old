procedure TFrmPrincipal.EnviarCTe_emailClick(Sender: TObject);
var
IniFile, edtSmtpHost, edtSmtpPort, edtSmtpUser, edtSmtpPass, edtEmailAssunto: String;
cbEmailSSL,e_mail: Boolean;
Ini: TIniFile;
StreamMemo: TMemoryStream;
begin
  OpenDialog1.Title      := 'Selecione a CTE';
  OpenDialog1.DefaultExt := '*-cte.XML';
  OpenDialog1.Filter     := 'Arquivos CTE (*-nfe.XML)|*-cte.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrCTe1.Configuracoes.Arquivos.PathSalvar;

  if OpenDialog1.Execute then
  begin
    IniFile := ChangeFileExt(ExtractFilePath(ParamStr(0)) + 'NFe', '.Ini');

    Ini := TIniFile.Create(IniFile);
    try
      edtSmtpHost     := Ini.ReadString('Email', 'Host',    '');
      edtSmtpPort     := Ini.ReadString('Email', 'Port',    '');
      edtSmtpUser     := Ini.ReadString('Email', 'User',    '');
      edtSmtpPass     := Ini.ReadString('Email', 'Pass',    '');
      edtSmtpPass     := DecryptMsg(edtSmtpPass, 65);
      edtEmailAssunto := Ini.ReadString('Email', 'Assunto', '');
      cbEmailSSL      := Ini.ReadBool('Email', 'SSL', False);
      StreamMemo      := TMemoryStream.Create;

      Ini.ReadBinaryStream('Email', 'Mensagem', StreamMemo);
      MemoResp.Lines.LoadFromStream(StreamMemo);
      StreamMemo.Free;
    finally
      Ini.Free;
    end;

    ACBrCTe1.Conhecimentos.Clear;
    ACBrCTe1.Conhecimentos.LoadFromFile(OpenDialog1.FileName);

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT * FROM TRANSACOES');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(NUM_DOC = :NUM_DOC)');
    QRel.Sql.Add('AND (MODELO = :MODELO)');


    QRel.ParamByName('NUM_DOC').AsString := StrZero(IntToStr(ACBrCTe1.Conhecimentos.Items[0].CTe.Ide.nCT), 9, 0);
    QRel.ParamByName('MODELO').AsString  :='57';

    QRel.Prepare;
    QRel.Open;

    if QRel.IsEmpty then
    begin
      Application.MessageBox('Conhecimento Eletr¶nico nŃo localizada no Banco de Dados', PChar(Msg_Title), mb_IconStop);
      abort;
    end
    Else
    begin
     IQuery.SQL.Clear;
     IQuery.SQL.Add('SELECT * FROM COMPL_CTEFISCAL WHERE TRANSACAO_ID = :TRANSACAO_ID');
     IQuery.ParamByName('TRANSACAO_ID').AsInteger := Qrel.FieldByName('TRANSACAO_ID').AsInteger;
     IQuery.Prepare;
     IQuery.Open;
    end;


    if not IQuery.IsEmpty then
    begin
      if IQuery.FieldByName('EMAIL_TRANSPORTADOR').AsString = '' then
        Application.MessageBox('O e-mail cadastrado para este cliente ķ invßlido', PChar(Msg_Title), mb_IconStop)
      else
        Begin
         try
               if edtEmailAssunto = '' then
                edtEmailAssunto := FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString + ' CT-e: ' + StrZero(IQuery.FieldByName('NO_DOC_FISCAL').AsString, 9, 0) + ' Data: ' + DateToStr(IQuery.FieldByName('DT_SAIDA').AsDateTime);

                FrmPrincipal.MemoResp.Lines.Add('Segue em anexo : CT-e N║: ' + StrZero(IQuery.FieldByName('NO_DOC_FISCAL').AsString, 9, 0));
                FrmPrincipal.MemoResp.Lines.Add('');
                FrmPrincipal.MemoResp.Lines.Add('Empresa: ' + FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString + ' CNPJ: ' + FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString );
                FrmPrincipal.MemoResp.Lines.Add('');
                FrmPrincipal.MemoResp.Lines.Add('Cliente: ' + IQuery.FieldByName('NOME_TRANSPORTADOR').AsString + ' CNPJ/CPF: ' + IQuery.FieldByName('CNPJ_TRANSPORTADOR').AsString);
                FrmPrincipal.MemoResp.Lines.Add('');
                FrmPrincipal.MemoResp.Lines.Add('Chave da CT-e: ' + FrmPrincipal.ACBrCTe1.WebServices.Retorno.ChaveCTe);
                FrmPrincipal.MemoResp.Lines.Add('');
                FrmPrincipal.MemoResp.Lines.Add('');
                FrmPrincipal.MemoResp.Lines.Add('');
                FrmPrincipal.MemoResp.Lines.Add('**********************Sistema Eficaz(38)37411478**********************');

                FrmPrincipal.ACBrMail1.Host      := edtSmtpHost;
                FrmPrincipal.ACBrMail1.Port      := edtSmtpPort;
                FrmPrincipal.ACBrMail1.Username  := edtSmtpUser;
                FrmPrincipal.ACBrMail1.Password  := edtSmtpPass;
                FrmPrincipal.ACBrMail1.From      := edtSmtpUser;
                FrmPrincipal.ACBrMail1.SetSSL    := cbEmailSSL; // SSL - Conex├Żo Segura
                FrmPrincipal.ACBrMail1.SetTLS    := True; // Auto TLS
                FrmPrincipal.ACBrMail1.ReadingConfirmation := False; //Pede confirma├¦├Żo de leitura do email
                FrmPrincipal.ACBrMail1.UseThread := True;           //Aguarda Envio do Email(n├Żo usa thread)
                FrmPrincipal.ACBrMail1.FromName  := 'Sistema Eficaz AutomańŃo Ltda';

                FrmPrincipal.ACBrCTe1.Conhecimentos.Items[0].EnviarEmail(IQuery.FieldByName('EMAIL_TRANSPORTADOR').AsString , edtEmailAssunto ,
                                                         FrmPrincipal.MemoResp.Lines
                                                         , True  // Enviar PDF junto
                                                         ,nil //CC  Lista com emails que ser├Żo enviado c├│pias - TStrings
                                                         ,nil); // Lista de anexos - TStrings



              // FrmPrincipal.ACBrCTe1.Conhecimentos.Items[0].EnviarEmail(edtSmtpHost, edtSmtpPort, edtSmtpUser, edtSmtpPass, edtSmtpUser, IQuery.FieldByName('EMAIL_TRANSPORTADOR').AsString , edtEmailAssunto, FrmPrincipal.MemoResp.Lines, cbEmailSSL,True //Enviar PDF junto
              //  , nil {Lista com emails que serŃo enviado c¾pias - TStrings}
              //  , nil { Lista de anexos - TStrings}
              //  , False {Pede confirmańŃo de leitura do email}
              //  , True  {Aguarda Envio do Email(nŃo usa thread)}
              //  , FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString //NOME do Rementente}
              //  , True ); // Auto TLS););

                FrmPrincipal.MemoResp.Lines.Clear;
                E_mail := True;
         except
              Application.MessageBox('NŃo foi possĒvel enviar o email verifique as configurań§es.', PChar(Msg_Title), mb_IconInformation);
              e_mail := False;
         end;

         if e_mail then
            Application.MessageBox(Pchar('E-mail enviado com sucesso para: ' + IQuery.FieldByName('EMAIL_TRANSPORTADOR').AsString), PChar(Msg_Title), mb_IconInformation);

        End;
    end
    else
      Application.MessageBox('Destinatßrio nŃo localizado no Banco de Dados', PChar(Msg_Title), mb_IconStop);

    MemoResp.Lines.Clear;
  end;

end;

procedure TFrmPrincipal.EnviarNFe_emailClick(Sender: TObject);
var
IniFile, edtSmtpHost, edtSmtpPort, edtSmtpUser, edtSmtpPass, edtEmailAssunto: String;
cbEmailSSL,E_MAIL: Boolean;
Ini: TIniFile;
StreamMemo: TMemoryStream;
begin
  OpenDialog1.Title      := 'Selecione a NFE';
  OpenDialog1.DefaultExt := '*-nfe.XML';
  OpenDialog1.Filter     := 'Arquivos NFE (*-nfe.XML)|*-nfe.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrNFe1.Configuracoes.Arquivos.GetPathNFe;

  if OpenDialog1.Execute then
  begin
    IniFile := ChangeFileExt(ExtractFilePath(ParamStr(0)) + 'NFe', '.Ini');

    Ini := TIniFile.Create(IniFile);
    try
      edtSmtpHost     := Ini.ReadString('Email', 'Host',    '');
      edtSmtpPort     := Ini.ReadString('Email', 'Port',    '');
      edtSmtpUser     := Ini.ReadString('Email', 'User',    '');
      edtSmtpPass     := Ini.ReadString('Email', 'Pass',    '');
      edtSmtpPass     := DecryptMsg(edtSmtpPass, 65);
      edtEmailAssunto := Ini.ReadString('Email', 'Assunto', '');
      cbEmailSSL      := Ini.ReadBool('Email', 'SSL', False);
      StreamMemo      := TMemoryStream.Create;

      Ini.ReadBinaryStream('Email', 'Mensagem', StreamMemo);
      MemoResp.Lines.LoadFromStream(StreamMemo);
      StreamMemo.Free;
    finally
      Ini.Free;
    end;

    ACBrNFe1.NotasFiscais.Clear;
    ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT * FROM TRANSACOES');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(NUM_DOC = :NUM_DOC)');
    QRel.Sql.Add('AND (CONDUTA = :CONDUTA)');
    QRel.Sql.Add('AND ((DEPTO   = :DEPTO) OR (DEPTO = :DEPTO_DEV))');

    QRel.ParamByName('NUM_DOC').AsString   := StrZero(IntToStr(ACBrNFe1.NotasFiscais.Items[0].NFe.Ide.nNF), 9, 0);
    QRel.ParamByName('CONDUTA').AsString   := '01';
    QRel.ParamByName('DEPTO').AsString     := '07';
    QRel.ParamByName('DEPTO_DEV').AsString := '10';


    QRel.Prepare;
    QRel.Open;

    if QRel.IsEmpty then
    begin
      Application.MessageBox('Nota Fiscal nŃo localizada no Banco de Dados.' +#13 + '  Envio de e-mail somente para Saidas ou Devoluń§es de Compra.', PChar(Msg_Title), mb_IconStop);
      abort;
    end
    else
    begin

    end;
   try
    if (QRel.FieldByName('CONDUTA').AsString = '01') and (QRel.FieldByName('DEPTO').AsString = '07') then
    begin
      IQuery.Sql.Clear;
      IQuery.Sql.Add('SELECT * FROM CLIENTES');
      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(CNPJ = :CNPJ)');

      if length(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF) = 14 then
        IQuery.ParamByName('CNPJ').AsString := Formata_CNPJ(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF)
      else
        IQuery.ParamByName('CNPJ').AsString := Formata_CPF(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF);

      IQuery.Prepare;
      IQuery.Open;
    end
    else if (QRel.FieldByName('CONDUTA').AsString = '01') and (QRel.FieldByName('DEPTO').AsString = '10') then
    begin
      IQuery.Sql.Clear;
      IQuery.Sql.Add('SELECT * FROM FORNECEDORES');
      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(CNPJ = :CNPJ)');

      if length(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF) = 14 then
        IQuery.ParamByName('CNPJ').AsString := Formata_CNPJ(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF)
      else
        IQuery.ParamByName('CNPJ').AsString := Formata_CPF(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF);

      IQuery.Prepare;
      IQuery.Open;
    end
    else if (QRel.FieldByName('CONDUTA').AsString = '20') and (QRel.FieldByName('DEPTO').AsString = '07') then
    begin
      IQuery.Sql.Clear;
      IQuery.Sql.Add('SELECT * FROM EMPRESAS');
      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(CNPJ = :CNPJ)');

      if length(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF) = 14 then
        IQuery.ParamByName('CNPJ').AsString := Formata_CNPJ(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF)
      else
        IQuery.ParamByName('CNPJ').AsString := Formata_CPF(ACBrNFe1.NotasFiscais.Items[0].NFe.Dest.CNPJCPF);

      IQuery.Prepare;
      IQuery.Open;
    end;

    if not IQuery.IsEmpty then
    begin
      if IQuery.FieldByName('EMAIL').AsString = '' then
        Application.MessageBox('O e-mail cadastrado para este cliente ķ invßlido', PChar(Msg_Title), mb_IconStop)
      else
       Begin
        Try
        if edtEmailAssunto = '' then
        edtEmailAssunto := QEmpresa.FieldByName('RAZAO').AsString + ' Nfe: ' + QRel.FieldByName('NUM_DOC').AsString + ' Data: ' + DateToStr(QRel.FieldByName('DT_ENT_SAI').AsDateTime);

        MemoResp.Lines.Add('Segue em anexo : Nfe N║: ' + QRel.FieldByName('NUM_DOC').AsString);
        MemoResp.Lines.Add('');
        MemoResp.Lines.Add('Empresa: ' + QEmpresa.FieldByName('RAZAO').AsString + ' CNPJ: ' + IQuery.FieldByName('CNPJ').AsString );
        MemoResp.Lines.Add('');
        MemoResp.Lines.Add('Cliente: ' + IQuery.FieldByName('NOME').AsString + ' CNPJ/CPF: ' + IQuery.FieldByName('CNPJ').AsString  );
        MemoResp.Lines.Add('');
        MemoResp.Lines.Add('Chave da NFe: ' + QRel.FieldByName('CHAVE_NFE').AsString);
        MemoResp.Lines.Add('');
        MemoResp.Lines.Add('');
        MemoResp.Lines.Add('');
        MemoResp.Lines.Add('**********************Sistema Eficaz(38)37411478**********************');

                FrmPrincipal.ACBrMail1.Host      := edtSmtpHost;
                FrmPrincipal.ACBrMail1.Port      := edtSmtpPort;
                FrmPrincipal.ACBrMail1.Username  := edtSmtpUser;
                FrmPrincipal.ACBrMail1.Password  := edtSmtpPass;
                FrmPrincipal.ACBrMail1.From      := edtSmtpUser;
                FrmPrincipal.ACBrMail1.SetSSL    := cbEmailSSL; // SSL - Conex├Żo Segura
                FrmPrincipal.ACBrMail1.SetTLS    := True; // Auto TLS
                FrmPrincipal.ACBrMail1.ReadingConfirmation := False; //Pede confirma├¦├Żo de leitura do email
                FrmPrincipal.ACBrMail1.UseThread := False;           //Aguarda Envio do Email(n├Żo usa thread)
                FrmPrincipal.ACBrMail1.FromName  := 'Sistema Eficaz AutomańŃo Ltda';

                FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].EnviarEmail(IQuery.FieldByName('EMAIL').AsString , edtEmailAssunto ,
                                                         FrmPrincipal.MemoResp.Lines
                                                         ,True  // Enviar PDF junto
                                                         ,nil //CC  Lista com emails que ser├Żo enviado c├│pias - TStrings
                                                         ,nil); // Lista de anexos - TStrings










        //ACBrNFe1.NotasFiscais.Items[0].EnviarEmail(edtSmtpHost, edtSmtpPort, edtSmtpUser, edtSmtpPass, edtSmtpUser,
        //IQuery.FieldByName('EMAIL').AsString, edtEmailAssunto, MemoResp.Lines, cbEmailSSL, True //Enviar PDF junto
        //, nil {Lista com emails que serŃo enviado c¾pias - TStrings}
        //, nil { Lista de anexos - TStrings}
        //, False {Pede confirmańŃo de leitura do email}
        //, True  {Aguarda Envio do Email(nŃo usa thread)}
        //, QEmpresa.FieldByName('RAZAO').AsString //NOME do Rementente}
        //, True ); // Auto TLS);

         FrmPrincipal.MemoResp.Lines.Clear;


            E_mail := True;

        except
              Application.MessageBox('NŃo foi possĒvel enviar o email verifique as configurań§es.', PChar(Msg_Title), mb_IconInformation);
              e_mail := False;
        End;

        if e_mail then
          Application.MessageBox(Pchar('E-mail enviado com sucesso para :' + IQuery.FieldByName('EMAIL').AsString), PChar(Msg_Title), mb_IconInformation);

       End;

    end
    else
      Application.MessageBox('Cliente ou Fornecedor nŃo localizado no Banco de Dados', PChar(Msg_Title), mb_IconStop);

    MemoResp.Lines.Clear;
   Except
   on e:Exception do
       {on e:Exception do
        begin
          Application.MessageBox(PChar('Erro ao enviar email!' + #13 +
            'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
        end; }

      begin
        Application.MessageBox(PChar('Dados do Cliente/Fornecedor nŃo conferem com os dados da Nfe!'), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
      end;
   end;
