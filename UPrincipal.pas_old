procedure TFrmPrincipal.Carga_Bd;
var
SR: TSearchRec;
I_Arq: Integer;
Rx, Tx, Cx, S, Resu, Status_Temp: String;
F1: TextFile;
Multiplicador, X , I: Integer;
lista : TStringList;
begin
    Status_Temp := StatusBar.Panels[4].Text;

    Rx := LeIni(Arq_Ini, 'TCPPDV', 'Path Rx');
    Tx := LeIni(Arq_Ini, 'TCPPDV', 'Path Tx');
    Cx := StrZero(LeIni(Arq_Ini, 'Sistema', 'Caixa'), 3, 0);

    I_Arq := FindFirst(Rx + 'Prprd*.0??', faAnyFile, SR);

    try
     while I_Arq = 0 do
     begin

      AssignFile(F1, Rx + SR.Name);
      Reset(F1);
      X:=0;

      QRel.Sql.Clear;
      QRel.Sql.Add('ALTER TRIGGER PRODUTOS_UP INACTIVE');

      QRel.Prepare;
      QRel.ExecSql;




      while not Eof(F1) do
      begin
        ReadLn(F1, S);
        lista := TStringList.Create;

        { Controle nao aprovado por Regivaldo 11/12/13
        if StrToInt(DecryptMsg(Copy(S,393,1),65)) <= 4 then
        Begin
         Application.MessageBox('Limite de conexń§es ao servidor atingido favor entrar em contato com o Suporte!', 'PDVEficaz', MB_IconStop + MB_OK);
         Gauge1.Visible := False;
         Label2.Visible := False;
         CloseFile(F1);
         DeleteFile(Rx + SR.Name);
         Application.Terminate;
        End;}



        Try
          Lista.LoadFromFile(Rx + SR.Name);
          I := Lista.Count;
          Finally
          Lista.Free;
          End;

        QCarga.Sql.Clear;
        QCarga.Sql.Add('SELECT * FROM Produtos');
        QCarga.Sql.Add('WHERE');
        QCarga.Sql.Add('(PRODUTO_ID = :PRODUTO_ID)');

        QCarga.ParamByName('PRODUTO_ID').AsInteger := StrToInt(Copy(S, 1, 6));

        QCarga.Prepare;
        QCarga.Open;


        if QCarga.IsEmpty then
        begin
          QCarga.Sql.Clear;
          QCarga.Sql.Add('INSERT INTO PRODUTOS(' +
                                               'PRODUTO_ID,            COD_BARRA,              CAD_SIMPLES,         NCM,                 CODRED, ' +
                                               'DESCRICAO,             FANTASIA,               SUPERVISOR,          PROVQT, ' +
                                               'UNIDADE,               EMBALAGEM,              UNIDADE_VENDA,       FRACAO_VENDA, ' +
                                               'IAT,                   IPPT,                   PESAVEL,             ETIQUETA, ' +
                                               'BALTECLA,              BALDPT,                 BALTIPO,             VALIDADE, ' +
                                               'EMPRESA_ID,            GRUPO_ID,               SUBTIPO_ID,          LOCALIZACAO_ID, ' +
                                               'TRIBUTO_ID,            FAMILIA_ID,             ALIQUOTA_ICMS,       PRECO_VAREJO, ' +
                                               'PRECO_ATACADO,         PRECO_PROMOCAO,         PRECO_PRAZO,         MOD_ICMS,            STATUS, ' +
                                               'PROMO_INICIAL,         PROMO_FINAL,            COD_BARRA_AUX1,      COD_BARRA_AUX2, ' +
                                               'COD_BARRA_AUX3,        COD_BARRA_AUX4,         COD_ORIGINAL,        REFERENCIA, ' +
                                               'QUANTIDADE_C,          QUANTIDADE_G) VALUES(' +
                                               ':PRODUTO_ID,           :COD_BARRA,             :CAD_SIMPLES,        :NCM,                :CODRED, ' +
                                               ':DESCRICAO,            :FANTASIA,              :SUPERVISOR,         :PROVQT, ' +
                                               ':UNIDADE,              :EMBALAGEM,             :UNIDADE_VENDA,      :FRACAO_VENDA, ' +
                                               ':IAT,                  :IPPT,                  :PESAVEL,            :ETIQUETA, ' +
                                               ':BALTECLA,             :BALDPT,                :BALTIPO,            :VALIDADE, ' +
                                               ':EMPRESA_ID,           :GRUPO_ID,              :SUBTIPO_ID,         :LOCALIZACAO_ID, ' +
                                               ':TRIBUTO_ID,           :FAMILIA_ID,            :ALIQUOTA_ICMS,      :PRECO_VAREJO, ' +
                                               ':PRECO_ATACADO,        :PRECO_PROMOCAO,        :PRECO_PRAZO,        :MOD_ICMS,           :STATUS, ' +
                                               ':PROMO_INICIAL,        :PROMO_FINAL,           :COD_BARRA_AUX1,     :COD_BARRA_AUX2, ' +
                                               ':COD_BARRA_AUX3,       :COD_BARRA_AUX4,        :COD_ORIGINAL,       :REFERENCIA, ' +
                                               ':QUANTIDADE_C,         :QUANTIDADE_G)');

          QCarga.ParamByName('PRODUTO_ID').AsInteger     := StrToInt(Copy(S, 1, 6));
          QCarga.ParamByName('COD_BARRA').AsString       := Alltrim(Copy(S, 7, 14));
          QCarga.ParamByName('CAD_SIMPLES').AsString     := Alltrim(Copy(S, 21, 1));
