  begin
    if not ThereIs('Orńamento') then
      TFrmOrcamento_Rapido.Create(Application);
  end
  else if LeIni(Arq_Ini, 'Sistema', 'Mod. Orńamento') = '3'  then
  begin
     if not ThereIs('Orńamento') then
      TFrmOrcamento_Rapido_2.Create(Application);
  end
  else if LeIni(Arq_Ini, 'Sistema', 'Mod. Orńamento') = '4'  then
  begin
     if not ThereIs('Orńamento') then
      TFrmOrcamento_2.Create(Application);
  end
  Else
  begin
    if not ThereIs('Trans. de Estoque - Orńamento') then
      TFrmOrcamento.Create(Application);
  end;

  if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
      Cascade;
end;

