procedure TFrmPrincipal.Mapa_Credores_2Click(Sender: TObject);
begin
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT FORNECEDORES.FORNECEDOR_ID,FORNECEDORES.NOME, FORNECEDORES.DDD, FORNECEDORES.TELEFONE_1, FORNECEDORES.TELEFONE_2, FORNECEDORES.CNPJ, SUM(TRANSPARCELAS.VALOR) AS VALOR');
  QRel.Sql.Add('FROM TRANSPARCELAS');
  QRel.Sql.Add('INNER JOIN TRANSACOES');
  QRel.Sql.Add('ON (TRANSPARCELAS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
  QRel.Sql.Add('INNER JOIN FORNECEDORES');
  QRel.Sql.Add('ON (TRANSACOES.FORNECEDOR_ID = FORNECEDORES.FORNECEDOR_ID)');
  QRel.Sql.Add('WHERE');
  QRel.Sql.Add('(TRANSPARCELAS.TIPO_TRANSACAO = :TIPO_TRANSACAO)');
  QRel.Sql.Add('AND ((TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL))');
  QRel.Sql.Add('AND (TRANSPARCELAS.VALOR > 0)');
  QRel.Sql.Add('AND (TRANSPARCELAS.BANCO_ID = 0)');
  QRel.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
  QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
  QRel.Sql.Add('AND (TRANSACOES.COND_PAGTO = :COND_PAGTO)');
  QRel.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB)');
  QRel.Sql.Add('GROUP BY FORNECEDORES.NOME, FORNECEDORES.DDD, FORNECEDORES.TELEFONE_1, FORNECEDORES.TELEFONE_2, FORNECEDORES.CNPJ,FORNECEDORES.FORNECEDOR_ID');

  QRel.ParamByName('TIPO_TRANSACAO').AsString := 'T';
  QRel.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QRel.ParamByName('CONDUTA').AsString        := '02';
  QRel.ParamByName('COND_PAGTO').AsString     := 'A PRAZO';
  QRel.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;

  QRel.Prepare;
  QRel.Open;

  QRLabel3.Caption := '*** MAPA DE CREDORES ***';

  if QRel.IsEmpty then
    Application.MessageBox('NŃo hß dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
  else
    Credores_Devedores.PreviewModal;
end;

procedure TFrmPrincipal.Mapa_Devedores_2Click(Sender: TObject);
begin
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT CLIENTES.CLIENTE_ID CODIGO,CLIENTES.NOME, CLIENTES.DDD, CLIENTES.TELEFONE_1, CLIENTES.TELEFONE_2, CLIENTES.CNPJ, SUM(TRANSPARCELAS.VALOR) AS VALOR');
  QRel.Sql.Add('FROM TRANSPARCELAS');
  QRel.Sql.Add('INNER JOIN TRANSACOES');
  QRel.Sql.Add('ON (TRANSPARCELAS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
  QRel.Sql.Add('INNER JOIN CLIENTES');
  QRel.Sql.Add('ON (TRANSACOES.CLIENTE_ID = CLIENTES.CLIENTE_ID)');
  QRel.Sql.Add('WHERE');
  QRel.Sql.Add('(TRANSPARCELAS.TIPO_TRANSACAO = :TIPO_TRANSACAO)');
  QRel.Sql.Add('AND ((TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL))');
  QRel.Sql.Add('AND (TRANSPARCELAS.VALOR > 0)');
  QRel.Sql.Add('AND (TRANSPARCELAS.BANCO_ID = 0)');
  QRel.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
  QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
  QRel.Sql.Add('AND (TRANSACOES.COND_PAGTO = :COND_PAGTO)');
  QRel.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB)');
  QRel.Sql.Add('GROUP BY CLIENTES.NOME, CLIENTES.DDD, CLIENTES.TELEFONE_1, CLIENTES.TELEFONE_2, CLIENTES.CNPJ,CLIENTES.CLIENTE_ID');

  QRel.ParamByName('TIPO_TRANSACAO').AsString := 'T';
  QRel.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QRel.ParamByName('CONDUTA').AsString        := '01';
  QRel.ParamByName('COND_PAGTO').AsString     := 'A PRAZO';
  QRel.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;

  QRel.Open;

  QRLabel3.Caption := '*** MAPA DE DEVEDORES ***';

  if QRel.IsEmpty then
    Application.MessageBox('NŃo hß dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
  else
    Credores_Devedores.PreviewModal;
end;

