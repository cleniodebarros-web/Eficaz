procedure TFrmPrincipal.Cancelamento_mdfeClick(Sender: TObject);
var
VAux:string;
ID:Integer;
begin
  OpenDialog1.Title        := 'Selecione MDFe';
  OpenDialog1.DefaultExt := '*-mdfe.XML';
  OpenDialog1.Filter     := 'Arquivos MDF (*-mdfe.XML)|*-mdfe.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrMDFe1.Configuracoes.Arquivos.GetPathMDFe();

  if OpenDialog1.Execute then
  begin
   ACBrMDFe1.Manifestos.Clear;
   ACBrMDFe1.Manifestos.LoadFromFile(OpenDialog1.FileName);


    QCancelamento.Sql.Clear;
    QCancelamento.Sql.Add('SELECT * FROM COMPL_MDEFISCAL');
    QCancelamento.Sql.Add('WHERE');
    QCancelamento.Sql.Add('(NO_DOC_FISCAL = :NO_DOC_FISCAL)');


    QCancelamento.ParamByName('NO_DOC_FISCAL').AsInteger := (ACBrMDFe1.Manifestos.Items[0].MDFe.Ide.nMDF);

    QCancelamento.Prepare;
    QCancelamento.Open;

    if QCancelamento.IsEmpty then
    begin
      Application.MessageBox('Nota Fiscal nŃo localizada no Banco de Dados', PChar(Msg_Title), mb_IconStop);
      abort
    end
    else
    begin


      ID   := QCancelamento.FieldByName('MDEFISCAL_ID').AsInteger;

      ACBrMDFe1.EventoMDFe.Evento.Clear;

      if not(InputQuery('MDF-e Cancelamento motivo:', 'Justificativa', vAux)) then
           exit
      Else
      Begin

        with ACBrMDFe1.EventoMDFe.Evento.Add do
        begin

         infEvento.chMDFe   := Copy(ACBrMDFe1.Manifestos.Items[0].MDFe.infMDFe.ID, 5, 44);
         infEvento.CNPJ     := FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString;
         infEvento.dhEvento := now;
    //  TpcnTpEvento = (teCCe, teCancelamento, teManifDestConfirmacao, teManifDestCiencia,
    //                  teManifDestDesconhecimento, teManifDestOperNaoRealizada,
    //                  teEncerramento);
         infEvento.tpEvento   := teCancelamento;
         infEvento.nSeqEvento := 1;

         infEvento.detEvento.nProt := ACBrMDFe1.Manifestos.Items[0].MDFe.procMDFe.nProt;
         infEvento.detEvento.xJust := trim(vAux);
         infEvento.detEvento.dtEnc := Date;
         infEvento.detEvento.cUF   := StrToInt(Copy(IntToStr(ACBrMDFe1.Manifestos.Items[0].MDFe.infDoc.infMunDescarga.Items[0].cMunDescarga),1,2));
         infEvento.detEvento.cMun  := ACBrMDFe1.Manifestos.Items[0].MDFe.infDoc.infMunDescarga.Items[0].cMunDescarga;
        end;

       if ACBrMDFe1.EnviarEvento(1) then
       begin
          with ACBrMDFe1.WebServices.EnvEvento do
          begin

           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 135) OR (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 136) then
           begin

            QRel.Sql.Clear;
            QRel.Sql.Add('UPDATE COMPL_MDEFISCAL SET STATUS =:STATUS');
            QRel.Sql.Add('WHERE');
            QRel.Sql.Add('(MDEFISCAL_ID = :MDEFISCAL_ID)');

            QRel.ParamByName('MDEFISCAL_ID').AsInteger := ID;
            QRel.ParamByName('STATUS').AsString        := 'CANCELADO';

            QRel.Prepare;
            QRel.ExecSql;



           end;

           Application.MessageBox(PChar('Status: ' + IntToStr(EventoRetorno.retEvento.Items[0].RetInfEvento.cStat)), PChar(Msg_Title), mb_IconInformation);
           Application.MessageBox(PChar('N║ do Protocolo: ' + EventoRetorno.retEvento.Items[0].RetInfEvento.nProt), PChar(Msg_Title), mb_IconInformation);

          end;
       end;
      End;
    end;
  end;
end;

procedure TFrmPrincipal.Cancelar_CTeClick(Sender: TObject);
var
vAux, Cond_Origem, Dpt_Origem,CodEv: String;
ID, Id_Trans,IdEv: Integer;
Vl_Trans: Real;
Gerencial: Boolean;
begin
  OpenDialog1.Title      := 'Selecione a CT-e';
  OpenDialog1.DefaultExt := '*-CTe.XML';
  OpenDialog1.Filter     := 'Arquivos CTe (*-CTe.XML)|*-cte.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrCTe1.Configuracoes.Arquivos.PathSalvar;

  if OpenDialog1.Execute then
  begin
    ACBrCTe1.Conhecimentos.Clear;
    ACBrCTe1.Conhecimentos.LoadFromFile(OpenDialog1.FileName);

    QCancelamento.Sql.Clear;
    QCancelamento.Sql.Add('SELECT * FROM TRANSACOES');
    QCancelamento.Sql.Add('WHERE');
    QCancelamento.Sql.Add('(NUM_DOC = :NUM_DOC)');
    QCancelamento.Sql.Add('AND (CONDUTA = :CONDUTA)');


    QCancelamento.ParamByName('NUM_DOC').AsString := StrZero(IntToStr(ACBrCTe1.Conhecimentos.Items[0].CTe.Ide.nCT), 9, 0);
    QCancelamento.ParamByName('CONDUTA').AsString :=  '01';


    QCancelamento.Prepare;
    QCancelamento.Open;

    if QCancelamento.IsEmpty then
    begin
      Application.MessageBox('Conhecimento Eletr¶nico nŃo localizada no Banco de Dados', PChar(Msg_Title), mb_IconStop);
      abort
    end
    else
    begin
      ID          := QCancelamento.FieldByName('TRANSACAO_ID').AsInteger;
      Vl_Trans    := QCancelamento.FieldByName('VALOR').AsFloat;
      Cond_origem := QCancelamento.FieldByName('CONDUTA').AsString;
      Dpt_origem  := QCancelamento.FieldByName('DEPTO').AsString;

      if not(InputQuery('WebServices Cancelamento Por Evento', 'Justificativa', vAux)) then
         exit
      Else
      Begin
      ACBrCTe1.EventoCTe.Evento.Clear;
      ACBrCte1.EventoCTe.idLote := ID;

      CodEv := IntToStr(1);
      if not(InputQuery('WebServices Cancelamento Por Evento', 'SequĻncia do Evento', CodEv)) then
      IdEv := 1
      Else
      IdEv := StrToINT(CodEv);

      with ACBrCTe1.EventoCTe.Evento.Add do
      Begin
      infEvento.dhEvento        := Now;
      infEvento.tpEvento        := teCancelamento;
      infEvento.detEvento.xJust := vAux;
      infEvento.nSeqEvento      := IdEv;
      end;

        if ACBrCTe1.EnviarEvento(ID) then
        begin
          with ACBrCTe1.WebServices.EnvEvento do
          begin
           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat <> 135) then
           begin
            raise Exception.CreateFmt(
            'Ocorreu o seguinte erro ao cancelar o Conhecimento Eletr¶nico:'  + sLineBreak +
            'C¾digo:%d' + sLineBreak +
            'Motivo: %s', [
             EventoRetorno.retEvento.Items[0].RetInfEvento.cStat,
             EventoRetorno.retEvento.Items[0].RetInfEvento.xMotivo ]);
           end;

           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 135) OR (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 136) then
           begin


              if QCancelamento.FieldByName('TIPO_IMP').AsInteger = 1 then
              Begin
              IQuery.Sql.Clear;
              IQuery.Sql.Add('UPDATE PEDIDOS SET STATUS = :STATUS , TRANSACAO_ID = 0');
              IQuery.Sql.Add('WHERE');
              IQuery.Sql.Add('(PEDIDO_ID = :PEDIDO_ID)');
              IQuery.ParamByName('PEDIDO_ID').AsInteger := QCancelamento.FieldByName('PEDIDO_ID').AsInteger;
              IQuery.ParamByName('STATUS').AsString   := 'NORMAL';

              IQuery.Prepare;
              IQuery.ExecSql;


              End;

              if QCancelamento.FieldByName('TIPO_IMP').AsInteger = 2 then
              Begin
              IQuery.Sql.Clear;
              IQuery.Sql.Add('UPDATE ORDEM_SERVICO SET STATUS = :STATUS, TRANSACAO_ID = 0');
              IQuery.Sql.Add('WHERE');
              IQuery.Sql.Add('(ORDEM_ID = :ORDEM_ID)');

              IQuery.ParamByName('ORDEM_ID').AsInteger := QCancelamento.FieldByName('PEDIDO_ID').AsInteger;
              IQuery.ParamByName('STATUS').AsString   := 'EXECUTADA';

              IQuery.Prepare;
              IQuery.ExecSql;



              End;

             try
              QRel.Sql.Clear;
              QRel.Sql.Add('INSERT INTO CTES_CANCELADAS(TRANSACAO_ID, EMPRESA_ID, NO_DOC_FISCAL, DT_SAIDA, HR_SAIDA, CFOP_COMPL, RESP_FRETE, NOME_TRANSPORTADOR, CNPJ_TRANSPORTADOR, ' +
                           'PLACA_VEICULO, ENDERECO_TRANSPORTADOR, MUNICIPIO_TRANSPORTADOR, UF_TRANSPORTADOR, INSCRICAO_TRANSPORTADOR, QUANTIDADE_VOLUMES, ESPECIE_VOLUMES, ' +
                           'MARCA_VOLUMES, NUMERO_VOLUMES, PESO_BRUTO, PESO_LIQUIDO, INSTRUCOES, RECIBO, PROTOCOLO, CHAVE_NFE)');
              QRel.Sql.Add('SELECT TRANSACAO_ID, EMPRESA_ID, NO_DOC_FISCAL, DT_SAIDA, HR_SAIDA, CFOP_COMPL, RESP_FRETE, NOME_TRANSPORTADOR, CNPJ_TRANSPORTADOR, ' +
                           'PLACA_VEICULO, ENDERECO_TRANSPORTADOR, MUNICIPIO_TRANSPORTADOR, UF_TRANSPORTADOR, INSCRICAO_TRANSPORTADOR, QUANTIDADE_VOLUMES, ESPECIE_VOLUMES, ' +
                           'MARCA_VOLUMES, NUMERO_VOLUMES, PESO_BRUTO, PESO_LIQUIDO, INSTRUCOES, RECIBO, PROTOCOLO, CHAVE_NFE');
              QRel.Sql.Add('FROM COMPL_CTEFISCAL');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;

              QRel.Sql.Clear;
              QRel.Sql.Add('DELETE FROM COMPL_CTEFISCAL');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;



              QRel.Sql.Clear;
              QRel.Sql.Add('UPDATE TRANSPARCELAS SET AGRUPAMENTO = 989898');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;



              IQuery.SQL.Clear;
              IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
              IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';

              IQuery.Prepare;
              IQuery.Open;

              Id_Trans := IQuery.FieldByName('ID').AsInteger;



              if QCancelamento.FieldByName('TIPO_VENDA').AsString <> 'REMESSA' then
              Begin
                QArq.Sql.Clear;
                QArq.Sql.Add('INSERT INTO TRANSACOES( ' +
                             'TRANSACAO_ID, DT_TRANS,   DT_MOVIMENTO, CONDUTA, ' +
                             'DEPTO,        EMPRESA_ID, CONTA_ID,     C_CUSTO_ID, BANCO_ID, ' +
                             'VALOR,        TPCTB,      AUTORIZ_ID,   HISTORICO, ' +
                             'CONTAAUX_ID) VALUES(' +
                             ':TRANSACAO_ID, :DT_TRANS,   :DT_MOVIMENTO, :CONDUTA, :DEPTO,      :EMPRESA_ID, ' +
                             ':CONTA_ID,     :C_CUSTO_ID, :BANCO_ID, :VALOR,        :TPCTB,   :AUTORIZ_ID, :HISTORICO, ' +
                             ':CONTAAUX_ID)');

                QArq.ParamByName('TRANSACAO_ID').AsInteger  := Id_Trans;
                QArq.ParamByName('DT_TRANS').AsDateTime     := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
                QArq.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

                if ((Cond_Origem = '01') and (Dpt_Origem = '07')) or ((Cond_Origem = '01') and (Dpt_Origem = '10')) then
                begin
                  QArq.ParamByName('CONDUTA').AsString := '18';
                  QArq.ParamByName('DEPTO').AsString   := '07';
                end;

                if ((Cond_Origem = '02') and (Dpt_Origem = '07')) or ((Cond_Origem = '02') and (Dpt_Origem = '10')) then
                begin
                  QArq.ParamByName('CONDUTA').AsString := '17';
                  QArq.ParamByName('DEPTO').AsString   := '07';
                end;

                QArq.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
                QArq.ParamByName('CONTA_ID').AsInteger    := FrmPrincipal.Config.FieldByName('CONTA_ESTOQUE').AsInteger;
                QArq.ParamByName('C_CUSTO_ID').AsInteger  := 1;
                QArq.ParamByName('VALOR').AsFloat         := Vl_Trans;
                QArq.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;
                QArq.ParamByName('AUTORIZ_ID').AsInteger  := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
                QArq.ParamByName('HISTORICO').AsString    := 'CANCELAMENTO CTe ' + StrZero(IntToStr(ACBrCTe1.Conhecimentos.Items[0].CTe.Ide.nCT), 6, 0);
                QArq.ParamByName('CONTAAUX_ID').AsInteger := 0;
                QArq.ParamByName('BANCO_ID').AsInteger    := QCancelamento.FieldByName('BANCO_ID').AsInteger;

                QArq.Prepare;
                QArq.ExecSql;



                Gerencial := True;


                  QRel.Sql.Clear;
                  QRel.Sql.Add('INSERT INTO TRANSITENS(TRANSACAO_ID, PRODUTO_ID, CONTA_ID, TP_PROD_SERV, CFOP, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL)');
                  QRel.Sql.Add('SELECT :ID_TRANS, PRODUTO_ID, CONTA_ID, TP_PROD_SERV, :CFOP, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL');
                  QRel.Sql.Add('FROM TRANSITENS');
                  QRel.Sql.Add('WHERE');
                  QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

                  QRel.ParamByName('ID_TRANS').AsInteger     := Id_Trans;
                  QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

                  if ((Cond_Origem = '01') and (Dpt_Origem = '07')) or ((Cond_Origem = '01') and (Dpt_Origem = '10')) then
                  QRel.ParamByName('CFOP').AsString         := '5556';

                  if ((Cond_Origem = '02') and (Dpt_Origem = '07')) or ((Cond_Origem = '02') and (Dpt_Origem = '10')) then
                  QRel.ParamByName('CFOP').AsString         := '1556';

                  QRel.Prepare;
                  QRel.ExecSql;




                QRel.Sql.Clear;
                QRel.Sql.Add('UPDATE TRANSACOES SET TPCTB = :TPCTB WHERE TRANSACAO_ID = :ID_TRANS');

                QRel.ParamByName('ID_TRANS').AsInteger     := Id_Trans;
                QRel.ParamByName('TPCTB').AsString         := FrmData.QAcesso.FieldByName('TPCTB').AsString;

                QRel.Prepare;
                QRel.ExecSql;



                if QCancelamento.FieldByName('BALANCO').AsString ='AGRUPADO' then
                  Begin
                  IQuery.SQL.Clear;
                  IQuery.SQl.Add('ALTER TRIGGER TRANSACOES_UP INACTIVE');
                  IQuery.Prepare;
                  IQuery.ExecSQL;



                  IQuery.Sql.Clear;
                  IQuery.Sql.Add('UPDATE TRANSACOES SET COD_CONT = 0');
                  IQuery.Sql.Add('WHERE');
                  IQuery.Sql.Add('(COD_CONT = :COD_CONT)');

                  IQuery.ParamByName('COD_CONT').AsString := IntToStr(QCancelamento.FieldByName('TRANSACAO_ID').AsInteger);

                  IQuery.Prepare;
                  IQuery.ExecSql;



                  IQuery.SQL.Clear;
                  IQuery.SQl.Add('ALTER TRIGGER TRANSACOES_UP ACTIVE');
                  IQuery.Prepare;
                  IQuery.ExecSQL;


                  End;
              End;
              except
              on e:Exception do
              begin
                Application.MessageBox(PChar('Erro:' + #13 +
                  'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
              end;

             end;
           end;
             Application.MessageBox(PChar('Status: ' + IntToStr(EventoRetorno.retEvento.Items[0].RetInfEvento.cStat)), PChar(Msg_Title), mb_IconInformation);
             Application.MessageBox(PChar('N║ do Protocolo: ' + EventoRetorno.retEvento.Items[0].RetInfEvento.nProt), PChar(Msg_Title), mb_IconInformation);
          end;
        end
        else
        begin
              with ACBrCTe1.WebServices.EnvEvento do
              begin
                raise Exception.Create(
                  'Ocorreram erros ao tentar efetuar o cancelamento:' + sLineBreak +
                  'Lote: '     + IntToStr(EventoRetorno.idLote) + sLineBreak +
                  'Ambiente: ' + TpAmbToStr(EventoRetorno.tpAmb) + sLineBreak +
                  'Orgao: '    + IntToStr(EventoRetorno.cOrgao) + sLineBreak +
                  sLineBreak +
                  'Status: '   + IntToStr(EventoRetorno.cStat) + sLineBreak +
                  'Motivo: '   + EventoRetorno.xMotivo
                );
              end;
        end;
       // Application.MessageBox(PChar('Status: ' + IntToStr(ACBrNFe1.WebServices.Cancelamento.cStat)), PChar(Msg_Title), mb_IconInformation);
       // Application.MessageBox(PChar('N║ do Protocolo: ' + ACBrNFe1.WebServices.Cancelamento.Protocolo), PChar(Msg_Title), mb_IconInformation);
      end;
    end;
  end;
end;


procedure TFrmPrincipal.Cancelar_NFClick(Sender: TObject);
var
vAux, Cond_Origem, Dpt_Origem,CodEv: String;
ID, Id_Trans,IdEv: Integer;
Vl_Trans: Real;
Gerencial: Boolean;
begin


  OpenDialog1.Title      := 'Selecione a NFE';
  OpenDialog1.DefaultExt := '*-nfe.XML';
  OpenDialog1.Filter     := 'Arquivos NFE (*-nfe.XML)|*-nfe.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrNFe1.Configuracoes.Arquivos.GetPathNFe;

  if OpenDialog1.Execute then
  begin
    ACBrNFe1.NotasFiscais.Clear;
    ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);


    QCancelamento.Sql.Clear;
    QCancelamento.Sql.Add('SELECT * FROM TRANSACOES');
    QCancelamento.Sql.Add('WHERE');
    QCancelamento.Sql.Add('(NUM_DOC = :NUM_DOC)');
    QCancelamento.Sql.Add('AND (CONDUTA = :CONDUTA)');

    QCancelamento.ParamByName('NUM_DOC').AsString := StrZero(IntToStr(ACBrNFe1.NotasFiscais.Items[0].NFe.Ide.nNF), 9, 0);
    QCancelamento.ParamByName('CONDUTA').AsString :=  '01';


    QCancelamento.Prepare;
    QCancelamento.Open;

    if QCancelamento.IsEmpty then
    begin
      Application.MessageBox('Nota Fiscal nŃo localizada no Banco de Dados', PChar(Msg_Title), mb_IconStop);
      abort
    end
    else
    begin
      ID          := QCancelamento.FieldByName('TRANSACAO_ID').AsInteger;
      Vl_Trans    := QCancelamento.FieldByName('VALOR').AsFloat;
      Cond_origem := QCancelamento.FieldByName('CONDUTA').AsString;
      Dpt_origem  := QCancelamento.FieldByName('DEPTO').AsString;

      if not(InputQuery('WebServices Cancelamento Por Evento', 'Justificativa', vAux)) then
         exit
      Else
      Begin
      ACBrNFe1.EventoNFe.Evento.Clear;
      ACBrNFe1.EventoNFe.idLote := ID;

      CodEv := IntToStr(1);
      if not(InputQuery('WebServices Cancelamento Por Evento', 'SequĻncia do Evento', CodEv)) then
      IdEv := 1
      Else
      IdEv := StrToINT(CodEv);

      with ACBrNFe1.EventoNFe.Evento.Add do
      begin
      infEvento.dhEvento        := Now;
      infEvento.tpEvento        := teCancelamento;
      infEvento.detEvento.xJust := vAux;
      infEvento.nSeqEvento      := IdEv;
      end;

        if ACBrNFe1.EnviarEvento(ID) then
        begin
          with ACBrNFe1.WebServices.EnvEvento do
          begin
           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 573) Then
           begin
             FrmPrincipal.ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);
             FrmPrincipal.ACBrNFe1.Consultar;
             MoveFile(PChar(FrmPrincipal.ACBrNFe1.Configuracoes.Arquivos.GetPathNFe + '\' + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'));
             MoveFile(PChar(OpenDialog1.FileName), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfe.xml'));
           end;

           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat <> 135) then
           begin
            raise Exception.CreateFmt(
            'Ocorreu o seguinte erro ao cancelar a nota fiscal eletr¶nica:'  + sLineBreak +
            'C¾digo:%d' + sLineBreak +
            'Motivo: %s', [
             EventoRetorno.retEvento.Items[0].RetInfEvento.cStat,
             EventoRetorno.retEvento.Items[0].RetInfEvento.xMotivo ]);
           end;

           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 135) OR (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 136) then
           begin
              if QCancelamento.FieldByName('TIPO_IMP').AsInteger = 1 then
              Begin
              IQuery.Sql.Clear;
              IQuery.Sql.Add('UPDATE PEDIDOS SET STATUS = :STATUS , TRANSACAO_ID = 0');
              IQuery.Sql.Add('WHERE');
              IQuery.Sql.Add('(PEDIDO_ID = :PEDIDO_ID)');
              IQuery.ParamByName('PEDIDO_ID').AsInteger := QCancelamento.FieldByName('PEDIDO_ID').AsInteger;
              IQuery.ParamByName('STATUS').AsString   := 'NORMAL';

              IQuery.Prepare;
              IQuery.ExecSql;


              End;

              if QCancelamento.FieldByName('TIPO_IMP').AsInteger = 2 then
              Begin
              IQuery.Sql.Clear;
              IQuery.Sql.Add('UPDATE ORDEM_SERVICO SET STATUS = :STATUS, TRANSACAO_ID = 0');
              IQuery.Sql.Add('WHERE');
              IQuery.Sql.Add('(ORDEM_ID = :ORDEM_ID)');

              IQuery.ParamByName('ORDEM_ID').AsInteger := QCancelamento.FieldByName('PEDIDO_ID').AsInteger;
              IQuery.ParamByName('STATUS').AsString   := 'EXECUTADA';

              IQuery.Prepare;
              IQuery.ExecSql;

              End;

              QRel.Sql.Clear;
              QRel.Sql.Add('INSERT INTO NOTAS_CANCELADAS(TRANSACAO_ID, EMPRESA_ID, NO_DOC_FISCAL, SERIE, DT_SAIDA, HR_SAIDA, CFOP_COMPL, RESP_FRETE, NOME_TRANSPORTADOR, CNPJ_TRANSPORTADOR, ' +
                           'PLACA_VEICULO, ENDERECO_TRANSPORTADOR, MUNICIPIO_TRANSPORTADOR, UF_TRANSPORTADOR, INSCRICAO_TRANSPORTADOR, QUANTIDADE_VOLUMES, ESPECIE_VOLUMES, ' +
                           'MARCA_VOLUMES, NUMERO_VOLUMES, PESO_BRUTO, PESO_LIQUIDO, INSTRUCOES, RECIBO, PROTOCOLO, CHAVE_NFE)');
              QRel.Sql.Add('SELECT TRANSACAO_ID, EMPRESA_ID, NO_DOC_FISCAL, SERIE, DT_SAIDA, HR_SAIDA, CFOP_COMPL, RESP_FRETE, NOME_TRANSPORTADOR, CNPJ_TRANSPORTADOR, ' +
                           'PLACA_VEICULO, ENDERECO_TRANSPORTADOR, MUNICIPIO_TRANSPORTADOR, UF_TRANSPORTADOR, INSCRICAO_TRANSPORTADOR, QUANTIDADE_VOLUMES, ESPECIE_VOLUMES, ' +
                           'MARCA_VOLUMES, NUMERO_VOLUMES, PESO_BRUTO, PESO_LIQUIDO, INSTRUCOES, RECIBO, PROTOCOLO, CHAVE_NFE');
              QRel.Sql.Add('FROM COMPL_NFISCAL');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;


              QRel.Sql.Clear;
              QRel.Sql.Add('DELETE FROM COMPL_NFISCAL');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;



              QRel.Sql.Clear;
              QRel.Sql.Add('UPDATE TRANSPARCELAS SET AGRUPAMENTO = 989898');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;



              IQuery.SQL.Clear;
              IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
              IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';

              IQuery.Prepare;
              IQuery.Open;

              Id_Trans := IQuery.FieldByName('ID').AsInteger;



            if QCancelamento.FieldByName('TIPO_VENDA').AsString <> 'REMESSA' then
            Begin
              QArq.Sql.Clear;
              QArq.Sql.Add('INSERT INTO TRANSACOES( ' +
                           'TRANSACAO_ID, DT_TRANS,   DT_MOVIMENTO, CONDUTA, ' +
                           'DEPTO,        EMPRESA_ID, CONTA_ID,     C_CUSTO_ID, BANCO_ID, ' +
                           'VALOR,        TPCTB,      AUTORIZ_ID,   HISTORICO, ' +
                           'CONTAAUX_ID) VALUES(' +
                           ':TRANSACAO_ID, :DT_TRANS,   :DT_MOVIMENTO, :CONDUTA, :DEPTO,      :EMPRESA_ID, ' +
                           ':CONTA_ID,     :C_CUSTO_ID, :BANCO_ID, :VALOR,        :TPCTB,   :AUTORIZ_ID, :HISTORICO, ' +
                           ':CONTAAUX_ID)');

              QArq.ParamByName('TRANSACAO_ID').AsInteger  := Id_Trans;
              QArq.ParamByName('DT_TRANS').AsDateTime     := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
              QArq.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

              if ((Cond_Origem = '01') and (Dpt_Origem = '07')) or ((Cond_Origem = '01') and (Dpt_Origem = '10')) then
              begin
                QArq.ParamByName('CONDUTA').AsString := '18';
                QArq.ParamByName('DEPTO').AsString   := '07';
              end;

              if ((Cond_Origem = '02') and (Dpt_Origem = '07')) or ((Cond_Origem = '02') and (Dpt_Origem = '10')) then
              begin
                QArq.ParamByName('CONDUTA').AsString := '17';
                QArq.ParamByName('DEPTO').AsString   := '07';
              end;

              QArq.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
              QArq.ParamByName('CONTA_ID').AsInteger    := FrmPrincipal.Config.FieldByName('CONTA_ESTOQUE').AsInteger;
              QArq.ParamByName('C_CUSTO_ID').AsInteger  := 1;
              QArq.ParamByName('VALOR').AsFloat         := Vl_Trans;
              QArq.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;
              QArq.ParamByName('AUTORIZ_ID').AsInteger  := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
              QArq.ParamByName('HISTORICO').AsString    := 'CANCELAMENTO NFe ' + StrZero(IntToStr(ACBrNFe1.NotasFiscais.Items[0].NFe.Ide.nNF), 6, 0);
              QArq.ParamByName('CONTAAUX_ID').AsInteger := 0;
              QArq.ParamByName('BANCO_ID').AsInteger    := QCancelamento.FieldByName('BANCO_ID').AsInteger;

              QArq.Prepare;
              QArq.ExecSql;

              Gerencial := True;

              {try
                QRel.Sql.Clear;
                QRel.Sql.Add('SELECT TPCTB');
                QRel.Sql.Add('FROM TRANSITENS');

                QRel.Prepare;
                QRel.Open;
              except
                Gerencial := False;
              end;

              if not Gerencial then  // nŃo ķ Comercial Cataluna
              begin}

                QRel.Sql.Clear;
                QRel.Sql.Add('INSERT INTO TRANSITENS(TRANSACAO_ID, PRODUTO_ID, CONTA_ID, TP_PROD_SERV, CFOP, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL)');
                QRel.Sql.Add('SELECT :ID_TRANS, PRODUTO_ID, CONTA_ID, TP_PROD_SERV, :CFOP, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL');
                QRel.Sql.Add('FROM TRANSITENS');
                QRel.Sql.Add('WHERE');
                QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

                QRel.ParamByName('ID_TRANS').AsInteger     := Id_Trans;
                QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

                if ((Cond_Origem = '01') and (Dpt_Origem = '07')) or ((Cond_Origem = '01') and (Dpt_Origem = '10')) then
                QRel.ParamByName('CFOP').AsString         := '5556';

                if ((Cond_Origem = '02') and (Dpt_Origem = '07')) or ((Cond_Origem = '02') and (Dpt_Origem = '10')) then
                QRel.ParamByName('CFOP').AsString         := '1556';

                QRel.Prepare;
                QRel.ExecSql;


             { end
              else
              begin
                QRel.Sql.Clear;
                QRel.Sql.Add('INSERT INTO TRANSITENS(TRANSACAO_ID, PRODUTO_ID, CONTA_ID, TP_PROD_SERV, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL, TPCTB)');
                QRel.Sql.Add('SELECT :ID_TRANS, PRODUTO_ID, CONTA_ID, TP_PROD_SERV,:CFOP, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL, TPCTB');
                QRel.Sql.Add('FROM TRANSITENS');
                QRel.Sql.Add('WHERE');
                QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

                QRel.ParamByName('ID_TRANS').AsInteger     := Id_Trans;
                QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

                if ((Cond_Origem = '01') and (Dpt_Origem = '07')) or ((Cond_Origem = '01') and (Dpt_Origem = '10')) then
                QRel.ParamByName('CFOP').AsString         := '5556';

                if ((Cond_Origem = '02') and (Dpt_Origem = '07')) or ((Cond_Origem = '02') and (Dpt_Origem = '10')) then
                QRel.ParamByName('CFOP').AsString         := '1556';


                QRel.Prepare;
                QRel.ExecSql;


              end;}

              QRel.Sql.Clear;
              QRel.Sql.Add('UPDATE TRANSACOES SET TPCTB = :TPCTB WHERE TRANSACAO_ID = :ID_TRANS');

              QRel.ParamByName('ID_TRANS').AsInteger     := Id_Trans;
              QRel.ParamByName('TPCTB').AsString         := FrmData.QAcesso.FieldByName('TPCTB').AsString;

              QRel.Prepare;
              QRel.ExecSql;



              if QCancelamento.FieldByName('BALANCO').AsString ='AGRUPADO' then
                Begin
                IQuery.SQL.Clear;
                IQuery.SQl.Add('ALTER TRIGGER TRANSACOES_UP INACTIVE');
                IQuery.Prepare;
                IQuery.ExecSQL;


                IQuery.Sql.Clear;
                IQuery.Sql.Add('UPDATE TRANSACOES SET COD_CONT = :ZERO');
                IQuery.Sql.Add('WHERE');
                IQuery.Sql.Add('(COD_CONT = :COD_CONT)');

                IQuery.ParamByName('COD_CONT').AsString := IntToStr(QCancelamento.FieldByName('TRANSACAO_ID').AsInteger);
                IQuery.ParamByName('ZERO').AsString     := '0';

                IQuery.Prepare;
                IQuery.ExecSql;

                IQuery.SQL.Clear;
                IQuery.SQl.Add('ALTER TRIGGER TRANSACOES_UP ACTIVE');
                IQuery.Prepare;
                IQuery.ExecSQL;
                End;
            End;
            FrmPrincipal.ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);
            FrmPrincipal.ACBrNFe1.Consultar;

            MoveFile(PChar(FrmPrincipal.ACBrNFe1.Configuracoes.Arquivos.GetPathNFe + '\' + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'));
            MoveFile(PChar(OpenDialog1.FileName), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfe.xml'));

           end;


           Application.MessageBox(PChar('Status: ' + IntToStr(EventoRetorno.retEvento.Items[0].RetInfEvento.cStat)), PChar(Msg_Title), mb_IconInformation);
           Application.MessageBox(PChar('N║ do Protocolo: ' + EventoRetorno.retEvento.Items[0].RetInfEvento.nProt), PChar(Msg_Title), mb_IconInformation);

          end;
        end
        else
        begin
          with ACBrNFe1.WebServices.EnvEvento do
          begin
            raise Exception.Create(
              'Ocorreram erros ao tentar efetuar o cancelamento:' + sLineBreak +
              'Lote: '     + IntToStr(EventoRetorno.idLote) + sLineBreak +
              'Ambiente: ' + TpAmbToStr(EventoRetorno.tpAmb) + sLineBreak +
              'Orgao: '    + IntToStr(EventoRetorno.cOrgao) + sLineBreak +
              sLineBreak +
              'Status: '   + IntToStr(EventoRetorno.cStat) + sLineBreak +
              'Motivo: '   + EventoRetorno.xMotivo
            );
          end;

        end;
       // Application.MessageBox(PChar('Status: ' + IntToStr(ACBrNFe1.WebServices.Cancelamento.cStat)), PChar(Msg_Title), mb_IconInformation);
       // Application.MessageBox(PChar('N║ do Protocolo: ' + ACBrNFe1.WebServices.Cancelamento.Protocolo), PChar(Msg_Title), mb_IconInformation);
      end;
    end;
  end;
end;

procedure TFrmPrincipal.Cancelar_NFe_ChaveClick(Sender: TObject);
var
Chave, Protocolo, Justificativa: String;
begin
  if not(InputQuery('WebServices Cancelamento', 'Chave da NF-e', Chave)) then
    exit;

  if not(InputQuery('WebServices Cancelamento', 'Protocolo de AutorizańŃo', Protocolo)) then
    exit;

  if not(InputQuery('WebServices Cancelamento', 'Justificativa', Justificativa)) then
    exit;

 { ACBrNFe1.WebServices.Cancelamento.NFeChave      := Chave;
  ACBrNFe1.WebServices.Cancelamento.Protocolo     := Protocolo;
  ACBrNFe1.WebServices.Cancelamento.Justificativa := Justificativa;

  ACBrNFe1.WebServices.Cancelamento.Executar;

  Application.MessageBox(PChar('Status: ' + ACBrNFe1.WebServices.Cancelamento.RetWS), PChar(Msg_Title), mb_IconInformation);
  Application.MessageBox(PChar('N║ do Protocolo: ' + ACBrNFe1.WebServices.Cancelamento.Protocolo), PChar(Msg_Title), mb_IconInformation);}
end;

procedure TFrmPrincipal.Cancelar_Nf_EntradaClick(Sender: TObject);
var
vAux, Cond_Origem, Dpt_Origem,CodEv: String;
ID, Id_Trans,IdEv: Integer;
Vl_Trans: Real;
Gerencial: Boolean;
begin
  OpenDialog1.Title      := 'Selecione a NFE';
  OpenDialog1.DefaultExt := '*-nfe.XML';
  OpenDialog1.Filter     := 'Arquivos NFE (*-nfe.XML)|*-nfe.XML|Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
  OpenDialog1.InitialDir := ACBrNFe1.Configuracoes.Arquivos.GetPathNFe;

  if OpenDialog1.Execute then
  begin
    ACBrNFe1.NotasFiscais.Clear;
    ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);

    QCancelamento.Sql.Clear;
    QCancelamento.Sql.Add('SELECT * FROM TRANSACOES');
    QCancelamento.Sql.Add('WHERE');
    QCancelamento.Sql.Add('(NUM_DOC = :NUM_DOC)');
    QCancelamento.Sql.Add('AND (CONDUTA = :CONDUTA) AND (SUB_SERIE = :SUB_SERIE)');

    QCancelamento.ParamByName('NUM_DOC').AsString   := StrZero(IntToStr(ACBrNFe1.NotasFiscais.Items[0].NFe.Ide.nNF), 9, 0);
    QCancelamento.ParamByName('CONDUTA').AsString   :=  '02';
    QCancelamento.ParamByName('SUB_SERIE').AsString :=  'P';


    QCancelamento.Prepare;
    QCancelamento.Open;

    if QCancelamento.IsEmpty then
    begin
      Application.MessageBox('Nota Fiscal nŃo localizada no Banco de Dados', PChar(Msg_Title), mb_IconStop);
      abort
    end
    else
    begin
      ID          := QCancelamento.FieldByName('TRANSACAO_ID').AsInteger;
      Vl_Trans    := QCancelamento.FieldByName('VALOR').AsFloat;
      Cond_origem := QCancelamento.FieldByName('CONDUTA').AsString;
      Dpt_origem  := QCancelamento.FieldByName('DEPTO').AsString;

     if not(InputQuery('WebServices Cancelamento Por Evento', 'Justificativa', vAux)) then
        exit
     Else
     Begin
          ACBrNFe1.EventoNFe.Evento.Clear;
          ACBrNFe1.EventoNFe.idLote := ID;

          CodEv := IntToStr(1);
          if not(InputQuery('WebServices Cancelamento Por Evento', 'SequĻncia do Evento', CodEv)) then
          IdEv := 1
          Else
          IdEv := StrToINT(CodEv);

          with ACBrNFe1.EventoNFe.Evento.Add do
          begin
          infEvento.dhEvento        := Now;
          infEvento.tpEvento        := teCancelamento;
          infEvento.detEvento.xJust := vAux;
          infEvento.nSeqEvento      := IdEv;
          end;

      if ACBrNFe1.EnviarEvento(ID) then
      begin
        with ACBrNFe1.WebServices.EnvEvento do
        begin

           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 573) Then
           begin
             FrmPrincipal.ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);
             FrmPrincipal.ACBrNFe1.Consultar;
             MoveFile(PChar(FrmPrincipal.ACBrNFe1.Configuracoes.Arquivos.GetPathNFe + '\' + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'));
             MoveFile(PChar(OpenDialog1.FileName), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfe.xml'));
           end;

           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat <> 135) then
           begin
            raise Exception.CreateFmt(
            'Ocorreu o seguinte erro ao cancelar a nota fiscal eletr¶nica:'  + sLineBreak +
            'C¾digo:%d' + sLineBreak +
            'Motivo: %s', [
             EventoRetorno.retEvento.Items[0].RetInfEvento.cStat,
             EventoRetorno.retEvento.Items[0].RetInfEvento.xMotivo ]);
           end;


           if (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 135) OR (EventoRetorno.retEvento.Items[0].RetInfEvento.cStat = 136) then
           begin
              if QCancelamento.FieldByName('TIPO_IMP').AsInteger = 1 then
              Begin
              IQuery.Sql.Clear;
              IQuery.Sql.Add('UPDATE PEDIDOS SET STATUS = :STATUS , TRANSACAO_ID = 0');
              IQuery.Sql.Add('WHERE');
              IQuery.Sql.Add('(PEDIDO_ID = :PEDIDO_ID)');
              IQuery.ParamByName('PEDIDO_ID').AsInteger := QCancelamento.FieldByName('PEDIDO_ID').AsInteger;
              IQuery.ParamByName('STATUS').AsString   := 'NORMAL';

              IQuery.Prepare;
              IQuery.ExecSql;
              End;

              if QCancelamento.FieldByName('TIPO_IMP').AsInteger = 2 then
              Begin
              IQuery.Sql.Clear;
              IQuery.Sql.Add('UPDATE ORDEM_SERVICO SET STATUS = :STATUS, TRANSACAO_ID = 0');
              IQuery.Sql.Add('WHERE');
              IQuery.Sql.Add('(ORDEM_ID = :ORDEM_ID)');

              IQuery.ParamByName('ORDEM_ID').AsInteger := QCancelamento.FieldByName('PEDIDO_ID').AsInteger;
              IQuery.ParamByName('STATUS').AsString   := 'EXECUTADA';

              IQuery.Prepare;
              IQuery.ExecSql;
              End;

              try
               ShowMessage(IntToStr(ID));

              QRel.Sql.Clear;
              QRel.Sql.Add('INSERT INTO NOTAS_CANCELADAS(TRANSACAO_ID, EMPRESA_ID, NO_DOC_FISCAL, SERIE, DT_SAIDA, HR_SAIDA, CFOP_COMPL, RESP_FRETE, NOME_TRANSPORTADOR, CNPJ_TRANSPORTADOR, ' +
                           'PLACA_VEICULO, ENDERECO_TRANSPORTADOR, MUNICIPIO_TRANSPORTADOR, UF_TRANSPORTADOR, INSCRICAO_TRANSPORTADOR, QUANTIDADE_VOLUMES, ESPECIE_VOLUMES, ' +
                           'MARCA_VOLUMES, NUMERO_VOLUMES, PESO_BRUTO, PESO_LIQUIDO, INSTRUCOES, RECIBO, PROTOCOLO, CHAVE_NFE)');
              QRel.Sql.Add('SELECT TRANSACAO_ID, EMPRESA_ID, NO_DOC_FISCAL, SERIE, DT_SAIDA, HR_SAIDA, CFOP_COMPL, RESP_FRETE, NOME_TRANSPORTADOR, CNPJ_TRANSPORTADOR, ' +
                           'PLACA_VEICULO, ENDERECO_TRANSPORTADOR, MUNICIPIO_TRANSPORTADOR, UF_TRANSPORTADOR, INSCRICAO_TRANSPORTADOR, QUANTIDADE_VOLUMES, ESPECIE_VOLUMES, ' +
                           'MARCA_VOLUMES, NUMERO_VOLUMES, PESO_BRUTO, PESO_LIQUIDO, INSTRUCOES, RECIBO, PROTOCOLO, CHAVE_NFE');
              QRel.Sql.Add('FROM COMPL_NFISCAL');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;



              QRel.Sql.Clear;
              QRel.Sql.Add('DELETE FROM COMPL_NFISCAL');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;

              except

                  on e:Exception do
                  begin
                    Application.MessageBox(PChar('Erro:' + #13 +
                      'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
                  end;

              end;


              QRel.Sql.Clear;
              QRel.Sql.Add('UPDATE TRANSPARCELAS SET AGRUPAMENTO = 989898');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

              QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

              QRel.Prepare;
              QRel.ExecSql;



              IQuery.SQL.Clear;
              IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
              IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';

              IQuery.Prepare;
              IQuery.Open;

              Id_Trans := IQuery.FieldByName('ID').AsInteger;


            if QCancelamento.FieldByName('TIPO_VENDA').AsString <> 'REMESSA' then
            Begin
              QArq.Sql.Clear;
              QArq.Sql.Add('INSERT INTO TRANSACOES( ' +
                           'TRANSACAO_ID, DT_TRANS,   DT_MOVIMENTO, CONDUTA, ' +
                           'DEPTO,        EMPRESA_ID, CONTA_ID,     C_CUSTO_ID, BANCO_ID, ' +
                           'VALOR,        TPCTB,      AUTORIZ_ID,   HISTORICO, ' +
                           'CONTAAUX_ID) VALUES(' +
                           ':TRANSACAO_ID, :DT_TRANS,   :DT_MOVIMENTO, :CONDUTA, :DEPTO,      :EMPRESA_ID, ' +
                           ':CONTA_ID,     :C_CUSTO_ID, :BANCO_ID, :VALOR,        :TPCTB,   :AUTORIZ_ID, :HISTORICO, ' +
                           ':CONTAAUX_ID)');

              QArq.ParamByName('TRANSACAO_ID').AsInteger  := Id_Trans;
              QArq.ParamByName('DT_TRANS').AsDateTime     := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
              QArq.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

              if ((Cond_Origem = '01') and (Dpt_Origem = '07')) or ((Cond_Origem = '01') and (Dpt_Origem = '10')) then
              begin
                QArq.ParamByName('CONDUTA').AsString := '18';
                QArq.ParamByName('DEPTO').AsString   := '07';
              end;

              if ((Cond_Origem = '02') and (Dpt_Origem = '07')) or ((Cond_Origem = '02') and (Dpt_Origem = '10')) then
              begin
                QArq.ParamByName('CONDUTA').AsString := '17';
                QArq.ParamByName('DEPTO').AsString   := '07';
              end;

              QArq.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
              QArq.ParamByName('CONTA_ID').AsInteger    := FrmPrincipal.Config.FieldByName('CONTA_ESTOQUE').AsInteger;
              QArq.ParamByName('C_CUSTO_ID').AsInteger  := 1;
              QArq.ParamByName('VALOR').AsFloat         := Vl_Trans;
              QArq.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;
              QArq.ParamByName('AUTORIZ_ID').AsInteger  := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
              QArq.ParamByName('HISTORICO').AsString    := 'CANCELAMENTO NFe ' + StrZero(IntToStr(ACBrNFe1.NotasFiscais.Items[0].NFe.Ide.nNF), 6, 0);
              QArq.ParamByName('CONTAAUX_ID').AsInteger := 0;
              QArq.ParamByName('BANCO_ID').AsInteger    := QCancelamento.FieldByName('BANCO_ID').AsInteger;

              QArq.Prepare;
              QArq.ExecSql;



              Gerencial := True;



                QRel.Sql.Clear;
                QRel.Sql.Add('INSERT INTO TRANSITENS(TRANSACAO_ID, PRODUTO_ID, CONTA_ID, TP_PROD_SERV, CFOP, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL)');
                QRel.Sql.Add('SELECT :ID_TRANS, PRODUTO_ID, CONTA_ID, TP_PROD_SERV, :CFOP, DESCRICAO, TRIBUTO_ID, QUANTIDADE, VR_UNITARIO, VR_DESCONTO, VR_TOTAL');
                QRel.Sql.Add('FROM TRANSITENS');
                QRel.Sql.Add('WHERE');
                QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

                QRel.ParamByName('ID_TRANS').AsInteger     := Id_Trans;
                QRel.ParamByName('TRANSACAO_ID').AsInteger := ID;

                if ((Cond_Origem = '01') and (Dpt_Origem = '07')) or ((Cond_Origem = '01') and (Dpt_Origem = '10')) then
                QRel.ParamByName('CFOP').AsString         := '5556';

                if ((Cond_Origem = '02') and (Dpt_Origem = '07')) or ((Cond_Origem = '02') and (Dpt_Origem = '10')) then
                QRel.ParamByName('CFOP').AsString         := '1556';

                QRel.Prepare;
                QRel.ExecSql;


              QRel.Sql.Clear;
              QRel.Sql.Add('UPDATE TRANSACOES SET TPCTB = :TPCTB WHERE TRANSACAO_ID = :ID_TRANS');

              QRel.ParamByName('ID_TRANS').AsInteger     := Id_Trans;
              QRel.ParamByName('TPCTB').AsString         := FrmData.QAcesso.FieldByName('TPCTB').AsString;

              QRel.Prepare;
              QRel.ExecSql;

                if QCancelamento.FieldByName('BALANCO').AsString ='AGRUPADO' then
                Begin
                IQuery.SQL.Clear;
                IQuery.SQl.Add('ALTER TABLE TRANSACOES DISABLE TRIGGER TRANSACOES_UP');
                IQuery.Prepare;
                IQuery.ExecSQL;

                IQuery.Sql.Clear;
                IQuery.Sql.Add('UPDATE TRANSACOES SET COD_CONT = :ZERO');
                IQuery.Sql.Add('WHERE');
                IQuery.Sql.Add('(COD_CONT = :COD_CONT)');

                IQuery.ParamByName('COD_CONT').AsString := IntToStr(QCancelamento.FieldByName('TRANSACAO_ID').AsInteger);
                IQuery.ParamByName('ZERO').AsString     := '0';

                IQuery.Prepare;
                IQuery.ExecSql;


                IQuery.SQL.Clear;
                IQuery.SQl.Add('ALTER TABLE TRANSACOES ENABLE TRIGGER TRANSACOES_UP');
                IQuery.Prepare;
                IQuery.ExecSQL;
                End;

            End;
            FrmPrincipal.ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);
            FrmPrincipal.ACBrNFe1.Consultar;

            MoveFile(PChar(FrmPrincipal.ACBrNFe1.Configuracoes.Arquivos.GetPathNFe + '\' + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfeDFe.xml'));
            MoveFile(PChar(OpenDialog1.FileName), PChar(ExtractFilePath(ParamStr(0)) + '\Can\'  + Copy(FrmPrincipal.ACBrNFe1.NotasFiscais.Items[0].NFe.infNFe.ID, 4, 44)+'-nfe.xml'));

           end;
           Application.MessageBox(PChar('Status: ' + IntToStr(EventoRetorno.retEvento.Items[0].RetInfEvento.cStat)), PChar(Msg_Title), mb_IconInformation);
           Application.MessageBox(PChar('N║ do Protocolo: ' + EventoRetorno.retEvento.Items[0].RetInfEvento.nProt), PChar(Msg_Title), mb_IconInformation);

        end;
      end
      else
      begin
        with ACBrNFe1.WebServices.EnvEvento do
        begin
          raise Exception.Create(
            'Ocorreram erros ao tentar efetuar o cancelamento:' + sLineBreak +
            'Lote: '     + IntToStr(EventoRetorno.idLote) + sLineBreak +
            'Ambiente: ' + TpAmbToStr(EventoRetorno.tpAmb) + sLineBreak +
            'Orgao: '    + IntToStr(EventoRetorno.cOrgao) + sLineBreak +
            sLineBreak +
            'Status: '   + IntToStr(EventoRetorno.cStat) + sLineBreak +
            'Motivo: '   + EventoRetorno.xMotivo
          );
        end;

      end;
       // Application.MessageBox(PChar('Status: ' + IntToStr(ACBrNFe1.WebServices.Cancelamento.cStat)), PChar(Msg_Title), mb_IconInformation);
       // Application.MessageBox(PChar('N║ do Protocolo: ' + ACBrNFe1.WebServices.Cancelamento.Protocolo), PChar(Msg_Title), mb_IconInformation);
     end;
    end;
  end;
end;

