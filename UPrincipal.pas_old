procedure TFrmPrincipal.Inutilizar_CTeClick(Sender: TObject);
var
Modelo, Serie, Ano, NumeroInicial, NumeroFinal, Justificativa: String;
Id_Trans : Integer;
begin
  Ano:=  Copy (DateToStr(date),7,4);
  Modelo := '57';
  Serie := '001';

  if not(InputQuery('WebServices InutilizańŃo ', 'Ano',    Ano)) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'Modelo', Modelo)) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'Serie',  Serie)) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'N·mero Inicial', NumeroInicial)) then
    exit;

    NumeroFinal := NumeroInicial;

  if not(InputQuery('WebServices InutilizańŃo ', 'N·mero Final', NumeroFinal )) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'Justificativa', Justificativa)) then
    exit;

    ACBrCTe1.WebServices.Inutiliza(SemMascara(QEmpresa.FieldByName('CNPJ').AsString), Justificativa, StrToInt(Ano), StrToInt(Modelo), StrToInt(Serie), StrToInt(NumeroInicial), StrToInt(NumeroFinal));


  Try
    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
    IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';

    IQuery.Prepare;
    IQuery.Open;

    Id_Trans := IQuery.FieldByName('ID').AsInteger;



    QArq.Sql.Clear;
    QArq.Sql.Add('INSERT INTO TRANSACOES( ' +
                 'TRANSACAO_ID, DT_TRANS,   DT_MOVIMENTO, DT_ENT_SAI, NUM_DOC, MODELO, SERIE, ' +
                 'EMPRESA_ID, CONTA_ID,     C_CUSTO_ID, CONDUTA, DEPTO, ' +
                 'VALOR,        TPCTB,      AUTORIZ_ID,   HISTORICO,COMPLEMENTO,OBSERVACAO, ' +
                 'CONTAAUX_ID, HORA,TIPO_VENDA) VALUES(' +
                 ':TRANSACAO_ID, :DT_TRANS,   :DT_MOVIMENTO, :DT_ENT_SAI, :NUM_DOC, :MODELO,  :SERIE,      :EMPRESA_ID, ' +
                 ':CONTA_ID,     :C_CUSTO_ID, :CONDUTA, :DEPTO ,:VALOR,  :TPCTB,   :AUTORIZ_ID, :HISTORICO, :COMPLEMENTO, :OBSERVACAO, ' +
                 ':CONTAAUX_ID, :HORA,:TIPO_VENDA)');

    QArq.ParamByName('TRANSACAO_ID').AsInteger  := Id_Trans;
    QArq.ParamByName('DT_TRANS').AsDateTime     := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
    QArq.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
    QArq.ParamByName('DT_ENT_SAI').AsDateTime   := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
    QArq.ParamByName('NUM_DOC').AsString        := StrZero(NumeroInicial,9,0);
    QArq.ParamByName('MODELO').AsString         := Modelo;
    QArq.ParamByName('SERIE').AsString          := Serie;
    QArq.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QArq.ParamByName('CONTA_ID').AsInteger      := FrmPrincipal.Config.FieldByName('CONTA_ESTOQUE').AsInteger;
    QArq.ParamByName('C_CUSTO_ID').AsInteger    := 1;
    QArq.ParamByName('VALOR').AsFloat           := 0;
    QArq.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;
    QArq.ParamByName('AUTORIZ_ID').AsInteger    := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
    QArq.ParamByName('HISTORICO').AsString      := Justificativa;
    QArq.ParamByName('COMPLEMENTO').AsString    := 'INUTILIZADA';
    QArq.ParamByName('OBSERVACAO').AsString     := 'INUTILIZADA';
    QArq.ParamByName('CONTAAUX_ID').AsInteger   := 0;
    QArq.ParamByName('CONDUTA').AsString        := '01';
    QArq.ParamByName('DEPTO').AsString          := '07';
    QArq.ParamByName('HORA').AsString           := TimeToStr(Time);
    QArq.ParamByName('TIPO_VENDA').AsString     := 'VENDA';


    QArq.Prepare;
    QArq.ExecSql;



    QRel.Sql.Clear;
    QRel.Sql.Add('INSERT INTO CTES_CANCELADAS(TRANSACAO_ID,EMPRESA_ID, NO_DOC_FISCAL, DT_SAIDA,  '  +
                 'RECIBO, HR_SAIDA)');
    QRel.Sql.Add('SELECT TRANSACAO_ID,EMPRESA_ID, NUM_DOC, DT_TRANS, '  +
                 ':RECIBO, :HR_SAIDA');
    QRel.Sql.Add('FROM TRANSACOES');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

    QRel.ParamByName('TRANSACAO_ID').AsInteger   := Id_trans;
    QRel.ParamByName('RECIBO').AsString          := 'INUTILIZADA';
    QRel.ParamByName('HR_SAIDA').AsString        := Copy(TimeToStr(TIME),1,5);

    QRel.Prepare;
    QRel.ExecSql;


  finally


  End;

    Application.MessageBox('Conhecimento Eletr¶nico inutilizado com sucesso!', PChar(Msg_Title), mb_IconInformation)
end;

procedure TFrmPrincipal.Inutilizar_NFeClick(Sender: TObject);
var
Modelo, Serie, Ano, NumeroInicial, NumeroFinal, Justificativa: String;
Id_Trans : Integer;
begin
  Ano:=  Copy (DateToStr(date),7,4);
  Modelo := '55';
  Serie := '001';

  if not(InputQuery('WebServices InutilizańŃo ', 'Ano',    Ano)) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'Modelo', Modelo)) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'Serie',  Serie)) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'N·mero Inicial', NumeroInicial)) then
    exit;

   NumeroFinal := NumeroInicial;

  if not(InputQuery('WebServices InutilizańŃo ', 'N·mero Final', NumeroFinal)) then
    exit;

  if not(InputQuery('WebServices InutilizańŃo ', 'Justificativa', Justificativa)) then
    exit;


   try
    ACBrNFe1.WebServices.Inutiliza(SemMascara(QEmpresa.FieldByName('CNPJ').AsString), Justificativa, StrToInt(Ano), StrToInt(Modelo), StrToInt(Serie), StrToInt(NumeroInicial), StrToInt(NumeroFinal));

    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT * FROM TRANSACOES WHERE NUM_DOC = :NUM_DOC AND MODELO = :MODELO AND CONDUTA = :CONDUTA');
    IQuery.ParamByName('NUM_DOC').AsString := StrZero(NumeroInicial,9,0);
    IQuery.ParamByName('MODELO').AsString  :='55';
    IQuery.ParamByName('CONDUTA').AsString :='01';
    IQuery.prepare;
    IQuery.Open;

    if IQuery.IsEmpty then
    Begin

    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
    IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';

    IQuery.Prepare;
    IQuery.Open;

    Id_Trans := IQuery.FieldByName('ID').AsInteger;



      QArq.Sql.Clear;
      QArq.Sql.Add('INSERT INTO TRANSACOES( ' +
                   'TRANSACAO_ID, DT_TRANS,   DT_MOVIMENTO, DT_ENT_SAI, NUM_DOC, MODELO, SERIE, ' +
                   'EMPRESA_ID, CONTA_ID,     C_CUSTO_ID, CONDUTA, DEPTO, ' +
                   'VALOR,        TPCTB,      AUTORIZ_ID,   HISTORICO,COMPLEMENTO, ' +
                   'CONTAAUX_ID, HORA,TIPO_VENDA) VALUES(' +
                   ':TRANSACAO_ID, :DT_TRANS,   :DT_MOVIMENTO, :DT_ENT_SAI, :NUM_DOC, :MODELO,  :SERIE,      :EMPRESA_ID, ' +
                   ':CONTA_ID,     :C_CUSTO_ID, :CONDUTA, :DEPTO ,:VALOR,  :TPCTB,   :AUTORIZ_ID, :HISTORICO, :COMPLEMENTO,  ' +
                   ':CONTAAUX_ID, :HORA,:TIPO_VENDA)');

      QArq.ParamByName('TRANSACAO_ID').AsInteger  := Id_Trans;
      QArq.ParamByName('DT_TRANS').AsDateTime     := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      QArq.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      QArq.ParamByName('DT_ENT_SAI').AsDateTime   := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      QArq.ParamByName('NUM_DOC').AsString        := StrZero(NumeroInicial,9,0);
      QArq.ParamByName('MODELO').AsString         := Modelo;
      QArq.ParamByName('SERIE').AsString          := Serie;
      QArq.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
      QArq.ParamByName('CONTA_ID').AsInteger      := FrmPrincipal.Config.FieldByName('CONTA_ESTOQUE').AsInteger;
      QArq.ParamByName('C_CUSTO_ID').AsInteger    := 1;
      QArq.ParamByName('VALOR').AsFloat           := 0;
      QArq.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;
      QArq.ParamByName('AUTORIZ_ID').AsInteger    := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
      QArq.ParamByName('HISTORICO').AsString      := Justificativa;
      QArq.ParamByName('COMPLEMENTO').AsString    := 'INUTILIZADA';
      QArq.ParamByName('CONTAAUX_ID').AsInteger   := 0;
      QArq.ParamByName('CONDUTA').AsString        := '01';
      QArq.ParamByName('DEPTO').AsString          := '07';
      QArq.ParamByName('HORA').AsString           := TimeToStr(Time);
      QArq.ParamByName('TIPO_VENDA').AsString     := 'VENDA';


      QArq.Prepare;
      QArq.ExecSql;



      QRel.Sql.Clear;
      QRel.Sql.Add('INSERT INTO NOTAS_CANCELADAS(TRANSACAO_ID,EMPRESA_ID, NO_DOC_FISCAL, DT_SAIDA,  '  +
                   'RECIBO, HR_SAIDA)');
      QRel.Sql.Add('SELECT TRANSACAO_ID,EMPRESA_ID, NUM_DOC, DT_TRANS, '  +
                   ':RECIBO, HORA');
      QRel.Sql.Add('FROM TRANSACOES');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

      QRel.ParamByName('TRANSACAO_ID').AsInteger   := Id_Trans;
      QRel.ParamByName('RECIBO').AsString          := 'INUTILIZADA';

      QRel.Prepare;
      QRel.ExecSql;

    End
    Else
    Begin
      QArq.SQL.Clear;
      QArq.SQL.Add('UPDATE TRANSACOES SET COMPLEMENTO = :INUTILIZADA, OBSERVACAO = :INUTILIZADA, HISTORICO = :HISTORICO, DT_MOVIMENTO = :DT_MOVIMENTO');
      QArq.SQL.Add('WHERE TRANSACAO_ID =:TRANSACAO_ID');
      QArq.ParamByName('INUTILIZADA').AsString     := 'INUTILIZADA';
      QArq.ParamByName('HISTORICO').AsString      := Justificativa;
      QArq.ParamByName('DT_MOVIMENTO').AsDateTime := Date;

      QArq.Prepare;
      QArq.ExecSQL;



      QRel.Sql.Clear;
      QRel.Sql.Add('INSERT INTO NOTAS_CANCELADAS(TRANSACAO_ID,EMPRESA_ID, NO_DOC_FISCAL, DT_SAIDA,  '  +
                   'RECIBO, HR_SAIDA)');
      QRel.Sql.Add('SELECT TRANSACAO_ID,EMPRESA_ID, NUM_DOC, DT_TRANS, '  +
                   ':RECIBO, HORA');
      QRel.Sql.Add('FROM TRANSACOES');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

      QRel.ParamByName('TRANSACAO_ID').AsInteger   := IQuery.FieldByName('TRANSACAO_ID').AsInteger;
      QRel.ParamByName('RECIBO').AsString          := 'INUTILIZADA';

      QRel.Prepare;
      QRel.ExecSql;



      QRel.SQL.Clear;
      QRel.SQL.Add('DELETE FROM COMPL_NFISCAL WHERE TRANSACAO_ID = :TRANSACAO_ID');

      QRel.ParamByName('TRANSACAO_ID').AsInteger := IQuery.FieldByName('TRANSACAO_ID').AsInteger;
      QRel.Prepare;
      QRel.ExecSQL;




    End;

   Finally

   end; 
    Application.MessageBox('Nota inutilizada com sucesso!', PChar(Msg_Title), mb_IconInformation)
  end;

procedure TFrmPrincipal.FrmItens_Minimo_2Click(Sender: TObject);
begin
  if not ThereIs('Itens Abaixo do MĒmimo ') then
    TFrmItensAbaixoDoMinimoRDP.Create(Application);

  if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
    Cascade;

{  QRel.Sql.Clear;

  if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
  begin
    QRel.Sql.Add('SELECT PRODUTO_ID, COD_BARRA, DESCRICAO, QUANTIDADE_C AS QUANTIDADE, QUANT_MINIMA, CUSTO_COMPRA, DT_COMPRA');
    QRel.Sql.Add('FROM PRODUTOS');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(EMPRESA_ID = :EMPRESA_ID)');
    QRel.Sql.Add('AND (QUANTIDADE_C < QUANT_MINIMA)');
    QRel.Sql.Add('AND (STATUS = :STATUS)');

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo')) > 0 then
    begin
      QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo'));
    end;

  end
  else
  begin
    QRel.Sql.Add('SELECT PRODUTO_ID, COD_BARRA, DESCRICAO, QUANTIDADE_G AS QUANTIDADE, QUANT_MINIMA, CUSTO_COMPRA, DT_COMPRA');
    QRel.Sql.Add('FROM PRODUTOS');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(EMPRESA_ID = :EMPRESA_ID)');
    QRel.Sql.Add('AND (QUANTIDADE_G < QUANT_MINIMA)');
    QRel.Sql.Add('AND (STATUS = :STATUS)');

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo')) > 0 then
    begin
      QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo'));
    end;
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Fornecedor')) > 0 then
  begin
    QRel.Sql.Add('AND (FORNECEDOR_ID = :FORNECEDOR_ID)');

    QRel.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Fornecedor'));
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo')) > 0 then
  begin
    QRel.Sql.Add('AND (GRUPO_ID = :GRUPO_ID)');

    QRel.ParamByName('GRUPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo'));
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo')) > 0 then
  begin
    QRel.Sql.Add('AND (SUBTIPO_ID = :SUBTIPO_ID)');

    QRel.ParamByName('SUBTIPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo'));
  end;

  if StrToInt(LeIni(Arq_Ini, 'Sistema', 'LocalizańŃo')) = 0 then
  begin
    if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo')) > 0 then
    begin
      QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo'));
    end;
  end;

  if StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Produto Inicial')) > 0 then
  begin
    QRel.Sql.Add('AND (PRODUTO_ID BETWEEN :PRODUTO_INICIAL AND :PRODUTO_FINAL)');

    QRel.ParamByName('PRODUTO_INICIAL').AsInteger := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Produto Inicial'));
    QRel.ParamByName('PRODUTO_FINAL').AsInteger   := StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Produto Final'));
  end;

  QRel.Sql.Add('ORDER BY DESCRICAO');

  QRel.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QRel.ParamByName('STATUS').AsString      := 'A';

  QRel.Prepare;
  QRel.Open;

  if LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo') = '0' then
    QRLabel28.Caption := 'Grupo: TODOS'
  else
    QRLabel28.Caption := 'Grupo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'Grupo')), '7');

  if LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo') = '0' then
    QRLabel29.Caption := 'Sub-Tipo: TODOS'
  else
    QRLabel29.Caption := 'Sub-Tipo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'SubTipo')), '5');

  if LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo') = '0' then
    QRLabel30.Caption := 'LocalizańŃo: TODAS'
  else
    QRLabel30.Caption := 'LocalizańŃo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'ParŌmetros Estoque', 'LocalizańŃo')), '8');

  if QRel.IsEmpty then
    Application.MessageBox('NŃo hß dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
  else
    Abaixo_Minimo.PreviewModal;}
end;

