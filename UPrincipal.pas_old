procedure TFrmPrincipal.c4Click(Sender: TObject);
var
chave :string;
begin

if not(InputQuery('WebServices Consulta NFe pela Chave ', 'Chave a ser consultada:                           ', chave)) then
      exit;

     try
      Chave := Alltrim(SemMascara(Chave));

      if not Verifica_ChaveNfe(Chave) then
      Begin
      Application.MessageBox('Favor verificar a Chave Nfe Digitada!', PChar(Msg_Title), mb_IconStop);
      abort;
      End;

       ACBrNFe1.WebServices.Consulta.NFeChave := chave;
       ACBrNFe1.WebServices.Consulta.Executar;
     except
      Application.MessageBox('Ocorreu um erro ao realizar a consulta', PChar(Msg_Title), mb_IconInformation);

     end;


end;

