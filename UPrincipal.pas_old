procedure TFrmPrincipal.Imprimir_EventoClick(Sender: TObject);
begin
  try
    ACBrNFe1.DANFE := ACBrNFeDANFeRL1;

    OpenDialog1.Title      := 'Selecione a NFE';
    OpenDialog1.DefaultExt := '*.XML';
    OpenDialog1.Filter     := 'Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';

    OpenDialog1.InitialDir := ACBrNFe1.Configuracoes.Arquivos.GetPathNfe;

    if OpenDialog1.Execute then
    begin
      ACBrNFe1.NotasFiscais.Clear;
      ACBrNFe1.NotasFiscais.LoadFromFile(OpenDialog1.FileName);
    end;

    OpenDialog1.Title      := 'Selecione o Evento';
    OpenDialog1.DefaultExt := '*.XML';
    OpenDialog1.Filter     := 'Arquivos XML (*.XML)|*.XML|Todos os Arquivos (*.*)|*.*';
    OpenDialog1.InitialDir := ACBrNFe1.Configuracoes.Arquivos.PathEvento;

    if OpenDialog1.Execute then
    begin
      ACBrNFe1.EventoNFe.Evento.Clear;
      ACBrNFe1.EventoNFe.LerXML(OpenDialog1.FileName) ;
      ACBrNFe1.ImprimirEvento;
    end;
  finally
    ACBrNFe1.DANFE := ACBrNFeDANFeRL1;
  end;
end;

