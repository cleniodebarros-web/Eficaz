  object QRel: TFDQuery
    Connection = FrmData.DbF_Eficaz
    FetchOptions.AssignedValues = [evItems, evRecsMax, evRowsetSize, evCache, evCursorKind, evAutoFetchAll]
    FetchOptions.CursorKind = ckDefault
    FetchOptions.RowsetSize = 1000
    FetchOptions.AutoFetchAll = afDisable
    SQL.Strings = (
      
        'SELECT TRANSITENS.TRANSACAO_ID,TRANSITENS.PRODUTO_ID,  TRANSITEN' +
        'S.DESCRICAO AS DESCRICAO_PRODUTO, NCM, CEST, '
      '      TRANSITENS.CFOP, PRODUTOS.NAT_REC,'
      
        '      TRANSITENS.CST_PIS,  TRANSITENS.CST_COFINS , TRANSITENS.AL' +
        'IQUOTA_ICMS ALIQUOTA, BASE_CALC_ICMS ,VALOR_ICMS, '
      
        '      TRANSITENS.VR_UNITARIO  , TRANSITENS.QUANTIDADE,TRANSITENS' +
        '.DESC_RODAPE DESCONTO,(TRANSITENS.VR_TOTAL + '
      
        '      TRANSITENS.VALOR_ICMS_ST + TRANSITENS.VR_FRETE + TRANSITEN' +
        'S.VR_ACRESCIMO + TRANSITENS.VR_IPI - '
      '      TRANSITENS.DESC_RODAPE) VALOR '
      '      FROM TRANSITENS '
      
        '      INNER JOIN TRANSACOES ON TRANSACOES.TRANSACAO_ID = TRANSIT' +
        'ENS.TRANSACAO_ID '
      
        '      INNER JOIN PRODUTOS ON PRODUTOS.PRODUTO_ID = TRANSITENS.PR' +
        'ODUTO_ID '
      
        '      INNER JOIN TRIBUTOS ON TRIBUTOS.TRIBUTO_ID = PRODUTOS.TRIB' +
        'UTO_ID '
      '      WHERE DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL '
      
        '      AND TRANSACOES.EMPRESA_ID = :EMPRESA_ID AND TPCTB = :TPCTB' +
        ' '
      '      AND CONDUTA = '#39'01'#39' AND DEPTO = '#39'07'#39'  '
      '      AND TIPO_VENDA = '#39'VENDA'#39' AND TRANSITENS.CST_PIS = '#39'04'#39' '
      
        '      AND (TRANSACOES.TRANSACAO_ID NOT IN(SELECT TRANSACAO_ID FR' +
        'OM NOTAS_CANCELADAS_NFCE))'
      
        '      AND (TRANSACOES.TRANSACAO_ID NOT IN(SELECT TRANSACAO_ID FR' +
        'OM NOTAS_CANCELADAS)) ')
    Left = 48
    Top = 256
    ParamData = <
      item
        Name = 'DT_INICIAL'
        DataType = ftDate
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'DT_FINAL'
        DataType = ftDate
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'EMPRESA_ID'
        DataType = ftInteger
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'TPCTB'
        DataType = ftString
        ParamType = ptInput
        Value = Null
      end>
  end
