  // 255, 325
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT ORCAMENTOS.*, FUNCIONARIOS.NOME');
  QRel.Sql.Add('FROM ORCAMENTOS');

  if Modelo.Text = 'Vendedor' then
  begin
    QRel.Sql.Add('INNER JOIN FUNCIONARIOS');
    QRel.Sql.Add('ON (ORCAMENTOS.VENDEDOR_ID = FUNCIONARIOS.FUNCIONARIO_ID)');
  end
  else
  begin
    QRel.Sql.Add('INNER JOIN FUNCIONARIOS');
    QRel.Sql.Add('ON (ORCAMENTOS.VENDEDOR_ID_2 = FUNCIONARIOS.FUNCIONARIO_ID)');
  end;

  QRel.Sql.Add('WHERE');


  QRel.Sql.Add('(ORCAMENTOS.DT_ORCAMENTO BETWEEN :DT_INICIAL AND :DT_FINAL)');


  if Atendente.Value > 0 then
  begin
    QRel.Sql.Add('AND (ORCAMENTOS.VENDEDOR_ID = :ATENDENTE)');
    QRel.ParamByName('ATENDENTE').AsInteger := StrToInt(Atendente.Text);
  end;

  if Status.Text <> '' then
  begin
    if Status.Text = 'Faturado' then
    begin
      QRel.Sql.Add('AND (ORCAMENTOS.TRANSACAO_ID > 0)');
     // QRel.ParamByName('STATUS').AsString := Status.Text;
    end
    Else
    QRel.Sql.Add('AND ((ORCAMENTOS.TRANSACAO_ID = 0) or (ORCAMENTOS.TRANSACAO_ID IS NULL))');
  end;


  if edt_cliente.Value > 0 then
  begin
    QRel.Sql.Add('AND (ORCAMENTOS.CLIENTE_ID =:CLIENTE_ID)');
    QRel.ParamByName('CLIENTE_ID').AsInteger := StrToInt(edt_cliente.Text);
  end;


    QRel.Sql.Add('ORDER BY FUNCIONARIOS.NOME, ORCAMENTOS.ORCAMENTO_ID, ORCAMENTOS.DT_ORCAMENTO,ORCAMENTOS.TRANSACAO_ID');

