       // Table_agenda.FieldByName('TRANSACAO_ID').AsInteger    := QRel.FieldByName('TRANSACAO_ID').AsInteger;
        Table_agenda.FieldByName('CLIENTE_ID').AsInteger      := QRel.FieldByName('CLIENTE_ID').AsInteger;
