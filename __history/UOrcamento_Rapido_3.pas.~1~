end;

procedure TFrmOrcamento_Rapido.Cond_Pagto;
var
Saldo_Orcamento : Real;
begin
  if QLog_Orcamento.IsEmpty then
  begin
    if Pagto = '' then
    begin
      Application.CreateForm(TFrmConsulta_Cliente, FrmConsulta_Cliente);
      try
        FrmConsulta_Cliente.ShowModal;

        if FrmConsulta_Cliente.Cond_Pagto.Text = 'A PRAZO' then
        begin
          if FrmConsulta_Cliente.QCliente.IsEmpty then
          begin
            Application.MessageBox('Para condiçăo a prazo é necessário informar o cliente', PChar(Msg_Title), mb_IconStop);
            Cod_Produto.SetFocus;
            abort;
          end;

          if FrmConsulta_Cliente.QCliente.FieldByName('BLOQUEADO').AsString = 'SIM' then
          begin
            Application.MessageBox(PChar('Cliente bloqueado. Procurar a administraçăo'), PChar(Msg_Title), mb_IconStop);
            Cod_Produto.SetFocus;
            abort;
          end;

          if FrmConsulta_Cliente.QCliente.FieldByName('LIMITE').AsFloat > 0 then
          begin
            QLimite.Close;

            QLimite.ParamByName('CLIENTE_ID').AsInteger     := StrToInt(FrmConsulta_Cliente.Cliente.Text);
            QLimite.ParamByName('DT_VENCIMENTO').AsDateTime := StrToDate('31/12/2026');

            QLimite.Prepare;
            QLimite.Open;

            QSaldo_Orcamento.Close;

            QSaldo_Orcamento.ParamByName('CLIENTE_ID').AsInteger     := StrToInt(FrmConsulta_Cliente.Cliente.Text);
            QSaldo_Orcamento.ParamByName('DT_VENCIMENTO').AsDateTime := StrToDate('31/12/2026');

            QSaldo_Orcamento.Prepare;
            QSaldo_Orcamento.Open;

            if LeIni(Arq_Ini, 'Sistema', 'Limite Saldo Orçamento') = 'True' then
            Saldo_Orcamento := QSaldo_Orcamento.FieldByName('DEBITO').AsFloat
            Else
            Saldo_Orcamento := 0;
           
            if (QLimite.FieldByName('DEBITO').AsFloat + Saldo_Orcamento + Total_Item.Value + Total_Orcamento.Value) > FrmConsulta_Cliente.QCliente.FieldByName('LIMITE').AsFloat then
            begin
              Application.MessageBox(PChar('Valor da compra maior do que o limite do cliente. Necessário autorizaçăo do supervisor' + #13 +
                                     'Limite do Cliente: ' + FormatFloat('#,##0.00', FrmConsulta_Cliente.QCliente.FieldByName('LIMITE').AsFloat) + #13 +
                                     'Valor da Compra: ' + FormatFloat('#,##0.00', (Total_Item.Value + Total_Orcamento.Value)) + #13 +
                                     'Saldo Devedor: ' + FormatFloat('#,##0.00', (QLimite.FieldByName('DEBITO').AsFloat + Saldo_Orcamento))), PChar(Msg_Title), MB_IconStop + MB_OK);

              Application.CreateForm(TFrmPasswordDlg, FrmPasswordDlg);
              try
                if FrmPasswordDlg.ShowModal = mrOk then
                begin
                  QInsert.Sql.Clear;
                  QInsert.Sql.Add('SELECT * FROM OPERADORES');
                  QInsert.Sql.Add('WHERE');
                  QInsert.Sql.Add('(OPERADOR_ID = :OPERADOR_ID)');

                  QInsert.ParamByName('OPERADOR_ID').AsString := StrZero(FrmPasswordDlg.Password.Text, 14, 0);

                  QInsert.Prepare;
                  QInsert.Open;

                  if (QInsert.FieldByName('LIMITE_APROVA').AsFloat + FrmConsulta_Cliente.QCliente.FieldByName('LIMITE').AsFloat) < (QLimite.FieldByName('DEBITO').AsFloat + Saldo_Orcamento + Total_Item.Value + Total_Orcamento.Value) then
                  begin
                    Application.MessageBox('Supervisor sem privilégio para liberar venda', PChar(Msg_Title), mb_IconStop);
                    abort;
                  end
                  else
                    Autoriz_Por := 'VENDA AUTORIZADA POR ' + QInsert.FieldByName('NOME').AsString + #13 +
                                   'Limite do Cliente: ' + FormatFloat('#,##0.00', FrmConsulta_Cliente.QCliente.FieldByName('LIMITE').AsFloat) + #13 +
                                   'Valor da Compra: ' + FormatFloat('#,##0.00', (Total_Item.Value + Total_Orcamento.Value)) + #13 +
                                   'Saldo Devedor: ' + FormatFloat('#,##0.00', (QLimite.FieldByName('DEBITO').AsFloat + Saldo_Orcamento));
                end
                else
                  abort;
              finally
                FrmPasswordDlg.Release;
              end;
            end;

          end;
          Finalizadora := FrmConsulta_Cliente.FINALIZADORA_ID.KeyValue;
          Pagto        := FrmConsulta_Cliente.Cond_Pagto.Text;
          Cliente      := StrToInt(FrmConsulta_Cliente.Cliente.Text);
        end
        else
        begin

          Finalizadora := FrmConsulta_Cliente.FINALIZADORA_ID.KeyValue;
          Pagto        := FrmConsulta_Cliente.Cond_Pagto.Text;
          Cliente     := StrToInt(FrmConsulta_Cliente.Cliente.Text);
          Autoriz_Por := '';

         if Pagto = '' Then
         Begin
          Pagto       := 'A VISTA';
          Finalizadora := 1;
          Cliente     := StrToInt(FrmConsulta_Cliente.Cliente.Text);
          Autoriz_Por := '';
         End;
        end;

        Label8.Caption := 'Cond. Pagto.: ' + FrmConsulta_Cliente.Cond_Pagto.Text;

        if FrmConsulta_Cliente.Cond_Pagto.Text = 'A PRAZO' then
          Label9.Caption := 'Cliente: ' + FrmConsulta_Cliente.QCliente.FieldByName('NOME').AsString
        else
          Label9.Caption := '';
      finally
        FrmConsulta_Cliente.Release;
      end;
    end;
  end;
end;

procedure TFrmOrcamento_Rapido.btnExecutaClick(Sender: TObject);
var
Promocao,Result: Boolean;
Vr_Produto,Desc_Por, Vr_total: Real;
Cod_Alternativo, Cod_Reduzido: String;

begin
  if (Cod_Produto.Text <> '')  then
  begin

     // validacao;

     // showmessage('passei');

    Promocao     := False;



    Cod_Alternativo := Cod_Produto.Text;
    Cod_Reduzido    := Cod_Produto.Text;

    Vr_Produto := 0;

    if (Copy(Cod_Produto.Text, 1, 1) = '2') and (FrmPrincipal.Config.FieldByName('TEM_BALANCA').AsString = 'True') then
    begin
      Vr_Produto       := StrToFloat(Copy(Cod_Produto.Text, 8, 3) + ',' + Copy(Cod_Produto.Text, 11, 2));
      Cod_Produto.Text := Copy(Cod_Produto.Text, 2, FrmPrincipal.Config.FieldByName('TAM_PESAVEIS').AsInteger);

      if FrmPrincipal.Config.FieldByName('GERA_DIGITO').AsString = 'True' then
        Cod_Produto.Text := Dig(Cod_Produto.Text);

      Cod_Produto.Text := StrZero(Cod_Produto.Text, FrmPrincipal.Config.FieldByName('TAM_BARRAS').AsInteger, 0);
    end;

    Cod_Produto.Text := StrZero(Cod_Produto.Text, FrmPrincipal.Config.FieldByName('TAM_BARRAS').AsInteger, 0);

    QProduto.Sql.Clear;
    QProduto.Sql.Add('SELECT PRODUTOS.*, TRIBUTOS.CODIGO_ECF, TRIBUTOS.ORIGEM, TRIBUTOS.TRIBUTACAO, TRIBUTOS.CFOP');
    QProduto.Sql.Add('FROM PRODUTOS');
    QProduto.Sql.Add('INNER JOIN TRIBUTOS');
    QProduto.Sql.Add('ON (PRODUTOS.TRIBUTO_ID = TRIBUTOS.TRIBUTO_ID)');
    QProduto.Sql.Add('WHERE');
    QProduto.Sql.Add('(PRODUTOS.COD_BARRA = :COD_BARRA OR PRODUTOS.COD_BARRA_AUX1 = :COD_BARRA OR PRODUTOS.COD_BARRA_AUX2 = :COD_BARRA OR ' +
                     'PRODUTOS.COD_BARRA_AUX3 = :COD_BARRA OR PRODUTOS.COD_BARRA_AUX4 = :COD_BARRA OR PRODUTOS.COD_ORIGINAL = :ALTERNATIVO OR PRODUTOS.REFERENCIA = :ALTERNATIVO OR PRODUTOS.CODRED = :CODRED)');
    QProduto.Sql.Add('AND (PRODUTOS.EMPRESA_ID = :EMPRESA_ID)');
    QProduto.Sql.Add('AND (PRODUTOS.STATUS = :STATUS)');

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
    begin
      QProduto.Sql.Add('AND (PRODUTOS.LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QProduto.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
    end;

    QProduto.ParamByName('COD_BARRA').AsString   := StrZero(Cod_Produto.Text, FrmPrincipal.Config.FieldByName('TAM_BARRAS').AsInteger, 0);
    QProduto.ParamByName('ALTERNATIVO').AsString := Cod_Alternativo;
    QProduto.ParamByName('CODRED').AsString      := StrZero(Copy(Cod_Reduzido, 1, FrmPrincipal.Config.FieldByName('TAM_PESAVEIS').AsInteger), FrmPrincipal.Config.FieldByName('TAM_PESAVEIS').AsInteger, 0);
    QProduto.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QProduto.ParamByName('STATUS').AsString      := 'A';

    QProduto.Prepare;
    QProduto.Open;

    if QProduto.IsEmpty then
    begin
      Application.MessageBox('Produto inexistente', PChar(Msg_Title), mb_IconStop);
      abort;
    end;

    if Vr_Produto > 0 then
    begin
      if (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime >= QProduto.FieldByName('PROMO_INICIAL').AsDateTime) and (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime <= QProduto.FieldByName('PROMO_FINAL').AsDateTime) then
        Quantidade.Value := (Vr_Produto / QProduto.FieldByName('PRECO_PROMOCAO').AsFloat)
      else
        Quantidade.Value := (Vr_Produto / QProduto.FieldByName('PRECO_VAREJO').AsFloat);

      Total_Item.Value := Vr_Produto;
    end;

    if (Quantidade.Value <= 0) or (Quantidade.Value > 9999) then
    begin
      Application.MessageBox('Quantidade inválida', PChar(Msg_Title), mb_IconStop);
      abort;
    end;

    if Preco.Value <= 0 then
    begin
      Application.MessageBox('Vr. Unitário inválido', PChar(Msg_Title), mb_IconStop);
      abort;
    end;

    if (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime >= QProduto.FieldByName('PROMO_INICIAL').AsDateTime) and (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime <= QProduto.FieldByName('PROMO_FINAL').AsDateTime) then
    begin
      Promocao := True;

      if (Preco.Value <> QProduto.FieldByName('PRECO_PROMOCAO').AsFloat) then
      begin
        Application.MessageBox('Preço inválido. Produto em promoçăo', PChar(Msg_Title), mb_IconStop);
        abort;
      end;
    end;

    if (QProduto.FieldByName('PRECO_ATACADO').AsFloat > 0.01) and (QProduto.FieldByName('PRECO_ATACADO').AsFloat < QProduto.FieldByName('PRECO_VAREJO').AsFloat) and (LeIni(Arq_Ini, 'Sistema', 'Comparar Preço Atacado x Preço Varejo') = 'True') and (not Promocao) then
    begin


      if (Preco.Value < QProduto.FieldByName('PRECO_ATACADO').AsFloat) or (Preco.Value > QProduto.FieldByName('PRECO_VAREJO').AsFloat) then
      begin
        Application.MessageBox('Preço fora da faixa determinado pelo Sistema', PChar(Msg_Title), mb_IconStop);
        preco.setfocus;
        abort;
      end;
    end;

    if  (RoundTo(Preco.Value, -2) < RoundTo(QProduto.FieldByName('PRECO_VAREJO').AsFloat, -2)) AND (not precoatacado) then
      begin
        Application.MessageBox('Preço fora da faixa determinado pelo Sistema', PChar(Msg_Title), mb_IconStop);
        preco.setfocus;
        abort;
      end;

    if (Desconto.Value < 0) or (((Preco.Value * Desconto.Value) / 100) > Preco.Value) then
    begin
      Application.MessageBox('Vr. Desconto inválido', PChar(Msg_Title), mb_IconStop);
      abort;
    end;

    if (Promocao) and (Desconto.Value > 0) then
    begin

      Application.MessageBox('Vr. Desconto inválido. Produto em promoçăo', PChar(Msg_Title), mb_IconStop);
      abort;

    end;

    if (QProduto.FieldByName('DESC_MAXIMO').AsFloat > 0) and (Desconto.Value > QProduto.FieldByName('DESC_MAXIMO').AsFloat) then
    begin
      Application.MessageBox(PChar('Vr. Desconto năo pode ser maior do que o desconto máximo permitido para o item: '
                             + #13 + QProduto.FieldByName('DESCRICAO').AsString + #13 + 'Valor Desc. Máximo(%):' + FloatToStrf((QProduto.FieldByName('DESC_MAXIMO').AsFloat ),Ffnumber,4,2)
                            // + #13 + 'Valor Desc. Máximo(R$):' + FloatToStrf(QProduto.FieldByName('DESC_MAXIMO').AsFloat,Ffnumber,4,2)
                             + #13 + 'Valor Desc. Solicitado(R$): ' + FloatToStrf(((Preco.Value * Desconto.Value) / 100),Ffnumber,4,2)), PChar(Msg_Title), mb_IconStop);

      Desconto.SetFocus;

      abort;
    end;

    if Total_Item.Value <= 0 then
    begin
      Application.MessageBox('Vr. Total inválido', PChar(Msg_Title), mb_IconStop);
      abort;
    end;

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT * FROM LOG_ORCAMENTO');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(CUPOM = :CUPOM)');
    QRel.Sql.Add('AND (TP_PROD_SERV = :TP_PROD_SERV)');
    QRel.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

    QRel.ParamByName('CUPOM').AsString        := Cod_Cupom; // SerialNum('C');
    QRel.ParamByName('TP_PROD_SERV').AsString := 'P';
    QRel.ParamByName('PRODUTO_ID').AsInteger  := QProduto.FieldByName('PRODUTO_ID').AsInteger;

    QRel.Prepare;
    QRel.Open;

    if QRel.IsEmpty then
    begin
      if Pagto = '' then
        // Cond_Pagto;

      QInsert.Sql.Clear;
      QInsert.Sql.Add('INSERT INTO LOG_ORCAMENTO(CUPOM,             TP_PROD_SERV,   PRODUTO_ID,      COD_BARRA, ' +
                                                 'DESCRICAO,        TRIBUTO_ID,     CST,             CFOP, ' +
                                                 'ALIQUOTA_ICMS,    IPI,            MVA,             QUANTIDADE, ' +
                                                 'VR_UNITARIO,      VR_DESCONTO,    VR_TOTAL, MT_2) VALUES( ' +
                                                 ':CUPOM,           :TP_PROD_SERV,  :PRODUTO_ID,     :COD_BARRA, ' +
                                                 ':DESCRICAO,       :TRIBUTO_ID,    :CST,            :CFOP, ' +
                                                 ':ALIQUOTA_ICMS,   :IPI,           :MVA,            :QUANTIDADE, ' +
                                                 ':VR_UNITARIO,     :VR_DESCONTO,   :VR_TOTAL, :MT_2)');

      QInsert.ParamByName('CUPOM').AsString        := Cod_Cupom; // SerialNum('C');
      QInsert.ParamByName('TP_PROD_SERV').AsString := 'P';
      QInsert.ParamByName('PRODUTO_ID').AsInteger  := QProduto.FieldByName('PRODUTO_ID').AsInteger;
      QInsert.ParamByName('COD_BARRA').AsString    := QProduto.FieldByName('COD_BARRA').AsString;
      QInsert.ParamByName('DESCRICAO').AsString    := Copy(QProduto.FieldByName('DESCRICAO').AsString,1,40);
      QInsert.ParamByName('TRIBUTO_ID').AsInteger  := QProduto.FieldByName('TRIBUTO_ID').AsInteger;
      QInsert.ParamByName('CST').AsString          := Copy(QProduto.FieldByName('ORIGEM').AsString, 1, 1) + Copy(QProduto.FieldByName('TRIBUTACAO').AsString, 1, 2);
      QInsert.ParamByName('CFOP').AsString         := QProduto.FieldByName('CFOP').AsString;
      QInsert.ParamByName('ALIQUOTA_ICMS').AsFloat := QProduto.FieldByName('ALIQUOTA_ICMS').AsFloat;
      QInsert.ParamByName('IPI').AsFloat           := QProduto.FieldByName('IPI').AsFloat;
      QInsert.ParamByName('MVA').AsFloat           := QProduto.FieldByName('MVA').AsFloat;
      QInsert.ParamByName('QUANTIDADE').AsFloat    := Quantidade.Value;
      QInsert.ParamByName('VR_UNITARIO').AsFloat   := Preco.Value;
      QInsert.ParamByName('VR_DESCONTO').AsFloat   := RoundTo(((Preco.Value * Desconto.Value) / 100), -2);
      QInsert.ParamByName('VR_TOTAL').AsFloat      := Total_Item.Value;
      QInsert.ParamByName('MT_2').AsFloat          := Fracao.value;

      QInsert.Prepare;
      QInsert.ExecSql;


    end
    else
    begin
      QInsert.Sql.Clear;
      QInsert.Sql.Add('UPDATE LOG_ORCAMENTO SET MT_2 = :MT_2, QUANTIDADE = :QUANTIDADE, VR_DESCONTO = :VR_DESCONTO, VR_TOTAL = :VR_TOTAL');
      QInsert.Sql.Add('WHERE');
      QInsert.Sql.Add('(CUPOM = :CUPOM)');
      QInsert.Sql.Add('AND (TP_PROD_SERV = :TP_PROD_SERV)');
      QInsert.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

      QInsert.ParamByName('QUANTIDADE').AsFloat    := (QRel.FieldByName('QUANTIDADE').AsFloat +  Quantidade.Value);
      QInsert.ParamByName('MT_2').AsFloat          := (QRel.FieldByName('MT_2').AsFloat +  FRACAO.Value);
      QInsert.ParamByName('VR_DESCONTO').AsFloat   := RoundTo(((QRel.FieldByName('VR_UNITARIO').AsFloat * Desconto.Value) / 100), -2);

      if (QProduto.FieldByName('FRACAO_VENDA').AsFloat > 0) AND (FrmPrincipal.Config.FieldByName('OBJETO_ORDEM').AsString = 'Madereira') then

      QInsert.ParamByName('VR_TOTAL').AsFloat      := ((QRel.FieldByName('MT_2').AsFloat +  Fracao.Value) * (QRel.FieldByName('VR_UNITARIO').AsFloat - RoundTo(((QRel.FieldByName('VR_UNITARIO').AsFloat * Desconto.Value) / 100), -2)))
      Else
      QInsert.ParamByName('VR_TOTAL').AsFloat      := ((QRel.FieldByName('QUANTIDADE').AsFloat +  QUANTIDADE.Value) * (QRel.FieldByName('VR_UNITARIO').AsFloat - RoundTo(((QRel.FieldByName('VR_UNITARIO').AsFloat * Desconto.Value) / 100), -2)));


      QInsert.ParamByName('CUPOM').AsString        := Cod_Cupom; // SerialNum('C');
      QInsert.ParamByName('TP_PROD_SERV').AsString := 'P';
      QInsert.ParamByName('PRODUTO_ID').AsInteger  := QProduto.FieldByName('PRODUTO_ID').AsInteger;

      QInsert.Prepare;
      QInsert.ExecSql;


    end;

    Soma;

    QLog_Orcamento.Sql.Clear;
    QLog_Orcamento.Sql.Add('SELECT * FROM LOG_ORCAMENTO');
    QLog_Orcamento.Sql.Add('WHERE');
    QLog_Orcamento.Sql.Add('(CUPOM = :CUPOM) ORDER BY SEQUENCIA');

    QLog_Orcamento.ParamByName('CUPOM').AsString := Cod_Cupom; // SerialNum('C');

    QLog_Orcamento.Prepare;
    QLog_Orcamento.Open;


    Cod_Produto.Text := '';
    Descricao.Text   := '';
    Quantidade.Value := 1;
    Preco.Value      := 0;
    Desconto.Value   := 0;
    Total_Item.Value := 0;
    Fracao.value     := 0;

    Cod_Produto.SetFocus;
  end
  else
    Cod_Produto.SetFocus;

end;

procedure TFrmOrcamento_Rapido.BtnOrcamentoClick(Sender: TObject);
begin

  try
