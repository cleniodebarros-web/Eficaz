procedure TFrmOrcamento_Rapido.Soma;
begin
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT SUM(VR_TOTAL) VR_TOTAL');
  QRel.Sql.Add('FROM LOG_ORCAMENTO');
  QRel.Sql.Add('WHERE');
  QRel.Sql.Add('(CUPOM = :CUPOM)');

  QRel.ParamByName('CUPOM').AsString := Cod_Cupom; // SerialNum('C');

  QRel.Prepare;
  QRel.Open;

  Total_Orcamento.Value := QRel.FieldByName('VR_TOTAL').AsFloat;
end;

