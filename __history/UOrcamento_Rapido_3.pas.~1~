procedure TFrmOrcamento_Rapido.QuantidadeExit(Sender: TObject);
begin

      precoatacado := False;

      if LeIni(ExtractFilePath(ParamStr(0)) + 'Eficaz.Ini', 'Sistema', 'Controle de Estoque no Orçamento') = 'True' then
      begin
        QRel.Sql.Clear;
        QRel.Sql.Add('SELECT SUM(QUANTIDADE) QUANTIDADE');
        QRel.Sql.Add('FROM LOG_ORCAMENTO');
        QRel.Sql.Add('WHERE');
        QRel.Sql.Add('(CUPOM = :CUPOM)');
        QRel.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

        QRel.ParamByName('CUPOM').AsString       := cod_cupom;
        QRel.ParamByName('PRODUTO_ID').AsInteger := QProduto.FieldByName('PRODUTO_ID').AsInteger;

        QRel.Prepare;
        QRel.Open;

        if (Quantidade.Value + QRel.FieldByName('QUANTIDADE').AsFloat) > QProduto.FieldByName('QUANTIDADE_C').AsFloat then
        begin
          Application.MessageBox('Produto com estoque insuficiente'  , 'Eficaz', MB_IconInformation + MB_OK);
          Cod_Produto.SetFocus;
        end;
      end;

  if (QProduto.FieldByName('QUANT_MAXIMA').AsFloat > 0) then
  begin
   Begin

      if Quantidade.Value >= QProduto.FieldByName('QUANT_MAXIMA').AsFloat  then
      if Application.MessageBox(PChar('Produto possui preço atacado configurado no sistema.'+ #13 + 'Produto: ' + QProduto.FieldByName('FANTASIA').AsString + #13 + 'Preco Atacado: R$' +
        FloatToStrF(QProduto.FieldByName('PRECO_ATACADO').AsFloat,FFnumber, 15, 2) + #13 + 'Deseja utilizar este preço?'),PChar(Msg_Title), mb_YesNo + mb_IconWarning + mb_DefButton1) = idYes
      then
      Begin
         Precoatacado := True;
         Preco.Value := QProduto.FieldByName('PRECO_ATACADO').AsFloat;
      End;
   End;

  end;

   if (QProduto.FieldByName('FRACAO_VENDA').AsFloat > 0) AND (FrmPrincipal.Config.FieldByName('OBJETO_ORDEM').AsString = 'Madereira') then
   Begin
    Fracao.Value     := RoundTo(Quantidade.value * QProduto.FieldByName('FRACAO_VENDA').AsFloat, -2);

    Total_Item.Value := (Fracao.Value * Preco.Value)

   End
   Else
    Total_Item.Value := (Quantidade.Value * Preco.Value);

end;

