          QUpdate.ExecSql;


        end;

        if (not QTabela.IsEmpty) and (LeIni(Arq_Ini, 'Sistema', 'Carga Autom嫢ica de Produtos') = 'True') and (FrmPrincipal.QEmpresa.FieldByName('CARGA').AsString = 'SIM') then
