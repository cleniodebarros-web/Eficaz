                     'ULT_QUANTIDADE = :ULT_QUANTIDADE, MARGEM_LUCRO = :MARGEM_LUCRO, QUANT_MINIMA = :ESTOQUE_MINIMO, FUNCIONARIO_ID = :FUNCIONARIO_ID ' +
                                         'WHERE ' +
                                         '(PRODUTO_ID = :PRODUTO_ID)');

