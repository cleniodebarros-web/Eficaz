procedure TFrmTributos_CBS_IBS.btnSaveClick(Sender: TObject);
begin
  DetailSearch('');

  if Validacao then
  begin
    if Operacao = 'Inserindo' then
    begin
      Insert;

      CmdSelectNull := 'WHERE (TRIBUTO_CBS_IBS_ID IS NOT NULL)';
      CmdOrderBy    := 'ORDER BY TRIBUTO_CBS_IBS_ID';

      QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

      QTabela.Open;
      QTabela.Last;
    end
    else
      Edit;

    Set_Campos(False);
    Habilitar(False);
    Botoes_Normal;
    Operacao := '';
    Consulta.TabVisible := True;
  end;
end;

