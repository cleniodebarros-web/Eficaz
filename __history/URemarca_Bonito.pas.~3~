procedure TFrmRemarca_Bonito.Margem_Atacado_NovoExit(Sender: TObject);
begin
  if Margem_Atacado_Novo.Value > 0 then
    Preco_Atacado_Novo.Value  := (Custo_Novo.value + ((Custo_Novo.value * Margem_Atacado_Novo.Value) / 100));
end;

procedure TFrmRemarca_Bonito.Margem_Prazo_NovoExit(Sender: TObject);
begin
  Preco_Prazo_Novo.Value      := (Custo_Novo.value + ((Custo_Novo.value * Margem_Prazo_Novo.Value) / 100));
end;

procedure TFrmRemarca_Bonito.Margem_Varejo_NovoChange(Sender: TObject);
begin
  if Margem_Varejo_Novo.Value = 0 then
    Margem_Varejo_Novo.Color := clRed
  else if Margem_Varejo_Novo.Value < FrmPrincipal.Config.FieldByName('ALERTA_REMARCAR').AsFloat then
    Margem_Varejo_Novo.Color := clYellow
  else
    Margem_Varejo_Novo.Color := clWindow;
end;

procedure TFrmRemarca_Bonito.Margem_Varejo_NovoExit(Sender: TObject);
begin
  Preco_Varejo_Novo.Value     := (Custo_Novo.value + ((Custo_Novo.value * Margem_Varejo_Novo.Value) / 100));
end;

procedure TFrmRemarca_Bonito.Preco_Atacado_NovoExit(Sender: TObject);
begin
  Margem_Atacado_Novo.Value := RoundTo((((Preco_Atacado_Novo.Value - Custo_Novo.Value) * 100) / Custo_Novo.Value), -2);
end;

procedure TFrmRemarca_Bonito.Preco_Prazo_NovoExit(Sender: TObject);
begin
  Margem_Prazo_Novo.Value   := RoundTo((((Preco_Prazo_Novo.Value - Custo_Novo.Value) * 100) / Custo_Novo.Value), -2);
end;

procedure TFrmRemarca_Bonito.Preco_Varejo_NovoExit(Sender: TObject);
begin
  Margem_Varejo_Novo.Value  := RoundTo((((Preco_Varejo_Novo.Value - Custo_Novo.Value) * 100) / Custo_Novo.Value), -2);
end;

procedure TFrmRemarca_Bonito.Custo_NovoExit(Sender: TObject);
begin
  Margem_Varejo_NovoExit(Sender);
  Margem_Prazo_NovoExit(Sender);
  Margem_Atacado_NovoExit(Sender);
end;

