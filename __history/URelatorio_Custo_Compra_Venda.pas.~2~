procedure TFrmRelatorio_Custo_Compra_Venda.btnExecutaClick(Sender: TObject);
begin
  try
    btnExecuta.Enabled := False;
    btnRetorna.Enabled := False;


    QRel.SQL.Clear;
    QRel.SQL.Add('SELECT PRODUTOS.PRODUTO_ID, PRODUTOS.ULT_QUANTIDADE, PRODUTOS.QUANTIDADE_C, PRODUTOS.DESCRICAO, PRODUTOS.DT_COMPRA, DT_MOVIMENTO AS DT_VENDA,');
    QRel.SQL.Add('PRODUTOS.CUSTO_COMPRA, PRODUTOS.CUSTOMEDIO, PRECO_VAREJO AS PRECO_VENDA FROM PRODUTOS');
    QRel.SQL.Add('WHERE');

    if Produto.Value > 0 then
       QRel.SQL.Add('PRODUTOS.PRODUTO_ID=:PRODUTO_ID AND');

    if Cbx_filtro.Text = 'DATA DA COMPRA' then
       QRel.SQL.Add('DT_COMPRA BETWEEN :DT_ENTRADA AND :DT_SAIDA');

    if Cbx_filtro.Text = 'DATA DA VENDA' then
       QRel.SQL.Add('DT_MOVIMENTO BETWEEN :DT_ENTRADA AND :DT_SAIDA');


    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
      begin
        QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');
        QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
      end;

      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Fornecedor')) > 0 then
      begin
        QRel.Sql.Add('AND (FORNECEDOR_ID = :FORNECEDOR_ID)');
        QRel.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Fornecedor'));
      end;

      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo')) > 0 then
      begin
        QRel.Sql.Add('AND (GRUPO_ID = :GRUPO_ID)');
        QRel.ParamByName('GRUPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo'));
      end;

      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo')) > 0 then
      begin
        QRel.Sql.Add('AND (SUBTIPO_ID = :SUBTIPO_ID)');
        QRel.ParamByName('SUBTIPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo'));
      end;


        if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo')) > 0 then
        begin
          QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');
          QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo'));
        end;


      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Inicial')) > 0 then
      begin
        QRel.Sql.Add('AND (PRODUTO_ID BETWEEN :PRODUTO_INICIAL AND :PRODUTO_FINAL)');
        QRel.ParamByName('PRODUTO_INICIAL').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Inicial'));
        QRel.ParamByName('PRODUTO_FINAL').AsInteger   := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Final'));
      end;

      QRel.SQL.Add('ORDER BY PRODUTOS.DESCRICAO');


    if Produto.Value > 0 then
       QRel.ParamByName('PRODUTO_ID').AsInteger  := StrToInt(Produto.Text);

       QRel.ParamByName('DT_ENTRADA').AsDateTime := Dtmen.Date;
       QRel.ParamByName('DT_SAIDA').AsDateTime   := Dtmai.Date;

       QRel.Prepare;
       QRel.Open;

    QRel.First;
    if QRel.IsEmpty then
        Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
    else
      begin
        if CheckBox1.Checked = True then
         Begin
          RDprint1.Impressora := HP;
          RDprint1.FonteTamanhoPadrao := S10cpp;
         End;

         RDprint1.TamanhoQteColunas := 150;
         RDprint1.OpcoesPreview.Preview     := True;
         RDprint1.MostrarProgresso          := True;
         RDprint1.Acentuacao                := SemAcento;
         RDprint1.TamanhoQteLinhas          := 1;
         RDprint1.Abrir;

           if linha > 66 then
           begin
             RDprint1.novapagina;
             Pagina := Pagina + 1;
           end;

           while not QRel.Eof do
           begin
              RDprint1.impD(linha, C1+5, QRel.FieldByName('PRODUTO_ID').AsString,[]);
              RDprint1.impF(linha, C2, Copy(QRel.FieldByName('DESCRICAO').AsString, 1, 40),[]);
              RDprint1.imp(linha, C3, DateToStr(QRel.FieldByName('DT_COMPRA').AsDateTime));
              RDprint1.imp(linha, C4, DateToStr(QRel.FieldByName('DT_VENDA').AsDateTime));
              RDprint1.ImpVal(linha,C5,'###,###,##0.00', QRel.FieldByName('CUSTO_COMPRA').AsFloat,[]);
              RDprint1.ImpVal(linha,C6,'###,###,##0.00', QRel.FieldByName('CUSTOMEDIO').AsFloat,[]);
              RDprint1.ImpVal(linha,C7-4,'###,###,##0.00', QRel.FieldByName('PRECO_VENDA').AsFloat,[]);
              RDprint1.ImpVal(linha,C8+4,'###,###,##0.00', QRel.FieldByName('ULT_QUANTIDADE').AsFloat,[]);
              RDprint1.ImpVal(linha,C9,'###,###,##0.00', QRel.FieldByName('QUANTIDADE_C').AsFloat,[]);



           if linha > 64 then
           begin
             RDprint1.novapagina;
             Pagina := Pagina + 1;
           end;

           Total_custo :=  QRel.FieldByName('CUSTO_COMPRA').AsFloat + Total_custo;
           Total_custo_M :=  QRel.FieldByName('CUSTOMEDIO').AsFloat + Total_custo_M;



            Inc(linha);
            QRel.Next;
           end;

           Inc(linha);
           RDprint1.LinhaH(linha,01,150,0,false);
           Inc(linha);
           RDprint1.impC(01,01 , 'Total:',[negrito]);
           RDprint1.ImpVal(linha,C5,'###,###,##0.00', TOTAL_CUSTO,[]);
           RDprint1.ImpVal(linha,C6,'###,###,##0.00', TOTAL_CUSTO_M,[]);
           RDprint1.ImpVal(linha,C7-4,'###,###,##0.00', TOTAL_VENDA,[]);








        Application.ProcessMessages;
        RDprint1.TamanhoQteLinhas:= 66;
        RDprint1.Fechar;
      end;

  finally
    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;   


end;


procedure TFrmRelatorio_Custo_Compra_Venda.RDprint1NewPage(Sender: TObject;
  Pagina: Integer);
begin

    C1 := 01;
    C2 := 08;
    C3 := 50;
    C4 := 65;
    C5 := 75;
    C6 := 90;
    C7 := 110;
    C8 := 120;
    C9 := 136;

    RDprint1.Imp(01, 01, FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString);
    RDprint1.ImpDir(01, (length(FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString)), 150, 'Sistema de Automaçăo de empresas Eficaz', []);
    RDprint1.Imp(02, 01, 'Data/Hora: ' + DateToStr(date) + ' - ' + TimeToStr(now));
    RDprint1.impDir(02, 80, 150, 'Página: ' + IntToStr(Pagina), []);
    RDprint1.impC(03, 70, '*** RELATÓRIO DE CUSTO COMPRA/VENDA ***',[negrito]);
    RDprint1.imp(04, 01, 'Período:'+ datetoStr(dtmen.date) + ' ŕ ' + datetoStr(dtmai.date));
    RDprint1.LinhaH(05,01,150,0,false);
    RDprint1.imp(06, C1+3, 'Id');
    RDprint1.imp(06, C2, 'Produto');
    RDprint1.imp(06, C3, 'Data Compra');
    RDprint1.imp(06, C4, 'Data Venda');
    RDprint1.imp(06, C5+2, 'Custo Compra');
    RDprint1.imp(06, C6+3, 'Custo Médio');
    RDprint1.imp(06, C7, 'Pç. Varejo');
    RDprint1.imp(06, C8+3, 'Qtd. Ult. Compra');
    RDprint1.imp(06, C9+6, 'Qtd Est');
    RDprint1.LinhaH(07,01,150,0,false);

    linha:= 08;

end;



