procedure TFrmTrans_Pagamento_Lote.CaixaKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
if (Key = Vk_F7) and (Sender = Fornecedor) then
    btnFornecedorClick(Self);

  if (Key = Vk_F7) and (Sender = Caixa) then
    btnCaixaClick(Self);

  if Key = Vk_Return then
    Perform(Wm_NextDlgctl, 0, 0);

end;

procedure TFrmTrans_Pagamento_Lote.DBGrid1KeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin
  if (Key = VK_F3) and (not QContas.IsEmpty) then
    Prorroga(QContas.FieldByName('TRANSACAO_ID').AsInteger, QContas.FieldByName('PARCELA_ID').AsString, QContas.FieldByName('TIPO_TRANSACAO').AsString,'P');

  if Key = VK_F9 then
    Perform(Wm_NextDlgCtl, 0, 0);
end;

