  DBGrid1.Columns[0].Width := 268;
  DBGrid1.Columns[1].Width := 90;
  DBGrid1.Columns[2].Width := 90;
  DBGrid1.Columns[3].Width := 40;
  DBGrid1.Columns[4].Width := 64;
  DBGrid1.Columns[5].Width := 90;
