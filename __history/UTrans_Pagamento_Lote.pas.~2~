procedure Pagamentos(id_fornecedor: Integer);
begin
  Cod_fornecedor := id_fornecedor;

  if not ThereIs('Trans. Mov. Financeira - Pagamento de Contas p/ Lote') then
    TFrmTrans_Pagamento_Lote.Create(Application);

  if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
    FrmPrincipal.Cascade;
end;

procedure TFrmTrans_Pagamento_Lote.Seleciona;
begin

  QContas.Sql.Clear;
  QContas.Sql.Add('SELECT FORNECEDORES.NOME, TRANSPARCELAS.*, TRANSACOES.HISTORICO, TRANSACOES.NUM_DOC, TRANSACOES.CONTA_ID, TRANSACOES.VENDEDOR_ID, TRANSACOES.EMPRESA_ID, TRANSACOES.TPCTB, TRANSACOES.C_CUSTO_ID, TRANSACOES.FORNECEDOR_ID');
  QContas.Sql.Add('FROM FORNECEDORES');
  QContas.Sql.Add('INNER JOIN TRANSACOES');
  QContas.Sql.Add('ON (FORNECEDORES.FORNECEDOR_ID = TRANSACOES.FORNECEDOR_ID)');
  QContas.Sql.Add('INNER JOIN TRANSPARCELAS');
  QContas.Sql.Add('ON (TRANSACOES.TRANSACAO_ID = TRANSPARCELAS.TRANSACAO_ID)');
  QContas.Sql.Add('WHERE');
  QContas.Sql.Add('(TRANSACOES.COND_PAGTO = :COND_PAGTO)');

  if Fornecedor.Value > 0 then
  begin
    QContas.Sql.Add('AND (TRANSACOES.FORNECEDOR_ID = :FORNECEDOR_ID)');
    QContas.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(Fornecedor.Text);
  end;

  QContas.Sql.Add('AND (TRANSPARCELAS.DT_VENCIMENTO BETWEEN :DT_INICIAL AND :DT_FINAL)');
  QContas.Sql.Add('AND (TRANSPARCELAS.VALOR > 0)');
  QContas.Sql.Add('AND (TRANSPARCELAS.BANCO_ID = 0)');
  QContas.Sql.Add('AND (TRANSPARCELAS.TIPO_TRANSACAO = :TIPO_TRANSACAO)');
  QContas.Sql.Add('AND ((TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL))');

  if chk_ordenar.Checked = True Then
   QContas.Sql.Add('ORDER BY TRANSPARCELAS.DT_VENCIMENTO , FORNECEDORES.NOME')
  Else
  QContas.Sql.Add('ORDER BY FORNECEDORES.NOME, TRANSPARCELAS.DT_VENCIMENTO');


  QContas.ParamByName('COND_PAGTO').AsString     := 'A PRAZO';
  QContas.ParamByName('DT_INICIAL').AsDateTime   := Dtmen.Date;
  QContas.ParamByName('DT_FINAL').AsDateTime     := Dtmai.Date;
  QContas.ParamByName('TIPO_TRANSACAO').AsString := 'T';

  QContas.Prepare;
  QContas.Open;

  Soma;

  DBGrid1.SetFocus;

end;

procedure TFrmTrans_Pagamento_Lote.Soma;
var
Vl: Double;
begin
  Vl := 0;

  QContas.First;
  while not QContas.Eof do
  begin
    Vl := Vl + QContas.FieldByName('VALOR').AsFloat;

    Application.ProcessMessages;
    QContas.Next;
  end;

  QContas.First;

  Label3.Caption := 'Soma : ' + FormatFloat('#,##0.00', Vl);
end;

