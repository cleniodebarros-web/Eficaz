  QContas.ParamByName('COND_PAGTO').AsString     := 'A PRAZO';
  QContas.ParamByName('DT_INICIAL').AsDateTime   := Dtmen.Date;
  QContas.ParamByName('DT_FINAL').AsDateTime     := Dtmai.Date;
  QContas.ParamByName('TIPO_TRANSACAO').AsString := 'T';

  QContas.Prepare;
