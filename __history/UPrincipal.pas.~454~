procedure TFrmPrincipal.Arquivo_Magnetico_2Click(Sender: TObject);
var
F1: TextFile;
Qt: Integer;
begin
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT PRODUTOS.*, TRIBUTOS.CODIGO_ECF');
  QRel.Sql.Add('FROM PRODUTOS');
  QRel.Sql.Add('INNER JOIN TRIBUTOS');
  QRel.Sql.Add('ON (PRODUTOS.TRIBUTO_ID = TRIBUTOS.TRIBUTO_ID)');
  QRel.Sql.Add('WHERE');
  QRel.Sql.Add('(PRODUTOS.EMPRESA_ID = :EMPRESA_ID)');
  QRel.Sql.Add('AND (PRODUTOS.STATUS = :STATUS)');

  if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
  begin
    QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

    QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
  end;

  QRel.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QRel.ParamByName('STATUS').AsString      := 'A';

  QRel.Prepare;
  QRel.Open;

  Qt := 0;

  AssignFile(F1, ExtractFilePath(ParamStr(0)) + 'Estoque_Fisco.Txt');
  Rewrite(F1);

  WriteLn(F1, 'P1' +
              StrZero(SemMascara(QEmpresa.FieldByName('CNPJ').AsString), 14, 0) +
              ForcaComprimento(SemMascara(QEmpresa.FieldByName('INSCR_ESTADUAL').AsString), 14, ' ') +
              ForcaComprimento(SemMascara(QEmpresa.FieldByName('INSCR_MUNICIPAL').AsString), 14, ' ') +
              ForcaComprimento(QEmpresa.FieldByName('RAZAO').AsString, 50, ' '));
  try
    QRel.First;
    while not QRel.Eof do
    begin
      WriteLn(F1, 'P2' +
                  StrZero(SemMascara(QEmpresa.FieldByName('CNPJ').AsString), 14, 0) +
                  ForcaComprimento(QRel.FieldByName('COD_BARRA').AsString, 14, ' ') +
                  ForcaComprimento(QRel.FieldByName('DESCRICAO').AsString, 50, ' ') +
                  ForcaComprimento(QRel.FieldByName('UNIDADE_VENDA').AsString, 6, ' ') +
                  Copy(QRel.FieldByName('CODIGO_ECF').AsString, 1, 1) +
                  StrZero(QRel.FieldByName('ALIQUOTA_ICMS').AsString, 4, 2) +
                  StrZero(QRel.FieldByName('PRECO_VAREJO').AsString, 12, 2));
      Inc(Qt);
      Application.ProcessMessages;
      QRel.Next;
    end;

    WriteLn(F1, 'P9' +
