    ACBrCTe1.Consultar;


    ShowMessage('Nş do Protocolo: ' + FrmPrincipal.ACBrCte1.WebServices.Consulta.Protocolo);
    ShowMessage('Data da Nota: ' + DateToStr(FrmPrincipal.ACBrCte1.WebServices.Consulta.DhRecbto));


    If not(InputQuery('Código da Transaçăo para Atualizar dados', 'Transacao_id', vAux)) then
         exit
    Else
    Begin

      QUpdate.Sql.Clear;
      QUpdate.Sql.Add('UPDATE COMPL_CTEFISCAL SET CHAVE_NFE = :CHAVE_NFE, PROTOCOLO =:PROTOCOLO, RECIBO= :RECIBO');
      QUpdate.Sql.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');

