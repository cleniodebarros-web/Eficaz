  If not FrmPrincipal.QSearchNuvem.IsEmpty  Then
  Begin

  FrmPrincipal.QUpdateNuvem.Sql.Clear;
  FrmPrincipal.QUpdateNuvem.Sql.Add(' UPDATE ESTOQUE_PRODUTOS SET PRODUTO_ID_MATRIZ = :PRODUTO_ID_MATRIZ, QUANTIDADE = :QUANTIDADE,DT_ATUALIZACAO = (SELECT CURRENT_DATE),HR_SYNC = (SELECT CURRENT_TIME)' +
                                    ' WHERE PRODUTO_ID = :PRODUTO_ID AND EMPRESA_ID = :EMPRESA_ID');

  FrmPrincipal.QUpdateNuvem.ParamByName('PRODUTO_ID_MATRIZ').AsInteger := produto_id_matriz;
  FrmPrincipal.QUpdateNuvem.ParamByName('QUANTIDADE').AsInteger := QUANTIDADE;
  FrmPrincipal.QUpdateNuvem.ParamByName('EMPRESA_ID').AsInteger := EMPRESA_ID;
  FrmPrincipal.QUpdateNuvem.ParamByName('PRODUTO_ID').AsInteger := produto_id;
  FrmPrincipal.QUpdateNuvem.Prepare;
  FrmPrincipal.QUpdateNuvem.ExecSQL;

  End
  Else
  Begin

  FrmPrincipal.QUpdateNuvem.Sql.Clear;

  FrmPrincipal.QUpdateNuvem.Sql.Add(' INSERT INTO estoque_produtos(produto_id, produto_id_matriz, empresa_id, descricao, quantidade, dt_atualizacao, hr_sync)' +
                                    ' VALUES(:PRODUTO_ID, :PRODUTO_ID_MATRIZ, :EMPRESA_ID, :DESCRICAO, :QUANTIDADE, (SELECT CURRENT_DATE), (SELECT CURRENT_TIME))');

  FrmPrincipal.QUpdateNuvem.ParamByName('PRODUTO_ID').AsInteger := produto_id;
  FrmPrincipal.QUpdateNuvem.ParamByName('PRODUTO_ID_MATRIZ').AsInteger := produto_id_matriz;
  FrmPrincipal.QUpdateNuvem.ParamByName('QUANTIDADE').AsInteger := QUANTIDADE;
  FrmPrincipal.QUpdateNuvem.ParamByName('EMPRESA_ID').AsInteger := EMPRESA_ID;
  FrmPrincipal.QUpdateNuvem.ParamByName('PRODUTO_ID').AsInteger := produto_id;

   FrmPrincipal.QSearch.Sql.Clear;
   FrmPrincipal.QSearch.Sql.Add('SELECT DESCRICAO FROM PRODUTOS WHERE PRODUTO_ID = :PRODUTO_ID');
   FrmPrincipal.QSearch.ParamByName('PRODUTO_ID').AsInteger := PRODUTO_ID;
   FrmPrincipal.QSearch.Prepare;
   FrmPrincipal.QSearch.Open;

  FrmPrincipal.QUpdateNuvem.ParamByName('DESCRICAO').AsString := FrmPrincipal.QSearch.FieldByname('DESCRICAO').AsString;


  FrmPrincipal.QUpdateNuvem.Prepare;
  FrmPrincipal.QUpdateNuvem.ExecSQL;

  End;


End;

