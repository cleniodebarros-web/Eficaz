procedure TFrmPrincipal.Timer3Timer(Sender: TObject);
begin
  QTimer3.Close;
  QTimer3.ParamByName('FUNCIONARIO_ID').AsInteger := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
  QTimer3.Prepare;
  QTimer3.Open();

  if QTimer3.IsEmpty then
    Exit;

  QOrc7.SQL.Clear;
  QOrc7.SQL.Add('SELECT * FROM ORCAMENTOS');
  QOrc7.SQL.Add('INNER JOIN AVISOS ON AVISOS.FUNCIONARIO_ID = ORCAMENTOS.VENDEDOR_ID AND AVISOS.EMPRESA_ID = ORCAMENTOS.EMPRESA_ID');
  QOrc7.SQL.Add('WHERE (ORCAMENTOS.ORCAMENTO_ID IS NOT NULL) AND (ORCAMENTOS.EMPRESA_ID = :EMPRESA_ID) AND ORCAMENTOS.DT_ORCAMENTO <= :DT_MOVIMENTO::DATE - 8');
  QOrc7.SQL.Add('AND (ORCAMENTOS.COMANDA IS NULL) AND (ORCAMENTOS.VENDEDOR_ID = :VENDEDOR_ID) AND ORCAMENTOS.STATUS = ''NORMAL''');
  QOrc7.ParamByName('VENDEDOR_ID').AsInteger    := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
  QOrc7.ParamByName('EMPRESA_ID').AsInteger     := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QOrc7.ParamByName('DT_MOVIMENTO').AsDateTime  := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  QOrc7.Prepare;
  QOrc7.Open();

  if QOrc7.IsEmpty then
    Exit;

  if (CompareTime(Now,StrToTime(QTimer3.FieldByName('AVISO1_HORA').AsString)) >= 0) and (CompareTime(Now,StrToTime(QTimer3.FieldByName('AVISO2_HORA').AsString)) < 0) and (not QTimer3.FieldByName('AVISO1_CONCLUIDO').AsBoolean) then
  begin
    QOrc7.SQL.Clear;
    QOrc7.SQL.Add('UPDATE AVISOS SET AVISO1_CONCLUIDO = TRUE');
    QOrc7.SQL.Add('WHERE FUNCIONARIO_ID = :FUNCIONARIO_ID AND EMPRESA_ID = :EMPRESA_ID');
    QOrc7.ParamByName('FUNCIONARIO_ID').AsInteger := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
    QOrc7.ParamByName('EMPRESA_ID').AsInteger     := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QOrc7.Prepare;
    QOrc7.ExecSQL;

    Application.MessageBox('Favor verificar Orçamentos que estăo próximos ao vencimento.', PChar(Msg_Title), MB_ICONWARNING);

    AvisoOrcamento7 := True;
    TFrmOrcamento_7.Create(Application);
  end
  else
  if (CompareTime(Now,StrToTime(QTimer3.FieldByName('AVISO2_HORA').AsString)) >= 0) and (CompareTime(Now,StrToTime(QTimer3.FieldByName('AVISO3_HORA').AsString)) < 0) and (not QTimer3.FieldByName('AVISO2_CONCLUIDO').AsBoolean) then
  begin
    QOrc7.SQL.Clear;
    QOrc7.SQL.Add('UPDATE AVISOS SET AVISO2_CONCLUIDO = TRUE');
    QOrc7.SQL.Add('WHERE FUNCIONARIO_ID = :FUNCIONARIO_ID AND EMPRESA_ID = :EMPRESA_ID');
    QOrc7.ParamByName('FUNCIONARIO_ID').AsInteger := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
    QOrc7.ParamByName('EMPRESA_ID').AsInteger     := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QOrc7.Prepare;
    QOrc7.ExecSQL;

    Application.MessageBox('Favor verificar Orçamentos que estăo próximos ao vencimento.', PChar(Msg_Title), MB_ICONWARNING);

    AvisoOrcamento7 := True;
    TFrmOrcamento_7.Create(Application);
  end
  else
  if (CompareTime(Now,StrToTime(QTimer3.FieldByName('AVISO3_HORA').AsString)) >= 0) and (not QTimer3.FieldByName('AVISO3_CONCLUIDO').AsBoolean) then
  begin
    QOrc7.SQL.Clear;
    QOrc7.SQL.Add('UPDATE AVISOS SET AVISO3_CONCLUIDO = TRUE');
    QOrc7.SQL.Add('WHERE FUNCIONARIO_ID = :FUNCIONARIO_ID AND EMPRESA_ID = :EMPRESA_ID');
    QOrc7.ParamByName('FUNCIONARIO_ID').AsInteger := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
    QOrc7.ParamByName('EMPRESA_ID').AsInteger     := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QOrc7.Prepare;
    QOrc7.ExecSQL;

    Application.MessageBox('Favor verificar Orçamentos que estăo próximos ao vencimento.', PChar(Msg_Title), MB_ICONWARNING);

    AvisoOrcamento7 := True;
    TFrmOrcamento_7.Create(Application);
  end;

  //'WHERE (ORCAMENTO_ID IS NOT NULL) AND (DT_MOVIMENTO = :DT_MOVIMENTO) AND (EMPRESA_ID = :EMPRESA_ID) AND (COMANDA IS NULL)';
  //'ORDER BY ORCAMENTO_ID';
  //FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger
