function StripChar(SourceStr: ShortString; CharToStrip: Char; Mode: Byte): ShortString;
var
I : Integer;
begin
  Result := '';

  if SourceStr <> '' then
  begin
    if Mode <> ReplaceLeft then
    begin
      while (Byte (SourceStr[0]) > 0) and (String(SourceStr[Byte (SourceStr[0])]) = CharToStrip) do
        Dec (SourceStr[0]);
    end;

    if Mode <> ReplaceRight then
    begin
      I := 1;
      while (I <= Byte(SourceStr[0])) and (String(SourceStr[I]) = CharToStrip) do
        Inc (I);

      if I > 1 then
        SourceStr := Copy (SourceStr, I, 255);

      if Mode = ReplaceAll then
      begin
        for I := 1 to Byte (SourceStr[0]) do
        begin
          if String(SourceStr[I]) <> CharToStrip then
          Result := Result + SourceStr[I];
          SourceStr := Result;
        end;
      end;

      Result := SourceStr;
    end;
  end;
end;

