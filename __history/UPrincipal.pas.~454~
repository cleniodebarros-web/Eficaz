procedure TFrmPrincipal.Atualizar_VersaoClick(Sender: TObject);
var
InputString: String;
begin
  Application.CreateForm(TFrmPasswordDlg, FrmPasswordDlg);
  try
    if FrmPasswordDlg.ShowModal = mrOk then
    begin
      if FrmPasswordDlg.Password.Text = Senha_Versao then
      begin
        InputString := InputBox(PChar(Msg_Title), 'Versăo' , 'LIGHT');

        if (LowerCase(InputString) = 'light') or  (LowerCase(InputString) = 'plus') or  (LowerCase(InputString) = 'standard') then
        begin

          IQuery.SQL.Clear;
          IQUERY.SQL.Add('UPDATE CONFIG SET VERSAO = :VERSAO');
          IQuery.ParamByName('VERSAO').AsString := EncryptMsg(lowerCase(InputString), 65);
          IQuery.Prepare;
          IQuery.ExecSQL;

          {Config.Edit;
          Config.Fields[22].AsString :=EncryptMsg(lowerCase(InputString), 65);
          Config.Post;}

          Application.MessageBox('O Sistema será reinicializado', PChar(Msg_Title), mb_IconInformation);

          Application.Terminate;
        end
        else
          Application.MessageBox('Valores aceitos: LIGHT, PLUS, STANDARD', PChar(Msg_Title), mb_IconStop);
      end
      else
        Application.MessageBox('Acesso negado', PChar(Msg_Title), mb_IconStop);
    end;
  finally
    FrmPasswordDlg.Release;
  end;
end;

