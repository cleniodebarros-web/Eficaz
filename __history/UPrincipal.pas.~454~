  FrmPrincipal.QSearchNuvem.Connection :=   FrmData.DBF_NuvemUP;

  FrmPrincipal.QSearchNuvem.Sql.Clear;
  FrmPrincipal.QSearchNuvem.Sql.Add('SELECT * FROM ESTOQUE_PRODUTOS WHERE PRODUTO_ID = :PRODUTO_ID AND EMPRESA_ID = :EMPRESA_ID');
