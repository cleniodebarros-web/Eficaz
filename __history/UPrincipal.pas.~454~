      Dezena := Dezenas[StrToInt(Trio[2])];

    if Trio[3] <> '0' then
      Unidade := Unidades[StrToInt(Trio[3])];
  end;

  if (Trio[1] = '1') and (Dezena = '') and (Unidade = '') then
