procedure TFrmPrincipal.Trocar_OperadorClick(Sender: TObject);
begin

   if Date <> FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime then
    begin
      Application.MessageBox(Pchar('O sistema está com data de movimento do dia ' + FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsString + ', porém uma nova abertura com data de ' + DateToStr(Date) + ' foi detectada. ' + #13 + #13 + 'Abra o sistema novamente para evitar divergęncias na data de movimentaçăo.'), PChar(Msg_Title), mb_IconStop);
