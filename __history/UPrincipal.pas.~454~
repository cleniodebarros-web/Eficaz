function Comparar(Ver, Sis: String): Boolean;
var
Arq: TSearchRec;
Ret, TamVer, TamSis: Integer;
DataVer, DataSis: TDateTime;
begin
  TamVer  := 0;
  TamSis  := 0;
  DataVer := 0;
  DataSis := 0;
  Result  := True;

  if FileExists(Ver) then
  begin
    Ret := FindFirst(Ver, faAnyFile, Arq);

    if Ret  = 0 then
    begin
      DataVer := FileDateToDateTime(Arq.Time);
      TamVer  := Arq.Size;
    end;

    FindClose(Arq);
  end
  else
    Result := False;

  if FileExists(Sis) then
  begin
    Ret := FindFirst(Sis, faAnyFile, Arq);

    if Ret = 0 then
    begin
      DataSis := FileDateToDateTime(Arq.Time);
      TamSis  := Arq.Size;
    end;

    FindClose(Arq);
  end
  else
    Result := False;

  if Result then
    Result := not (DataVer <> DataSis);
end;

function Substituir_Caracteres(S: String; C1: String; C2: String): String;
var
IndexadorS: Integer;
TrechosDaString: String[1];
StringAuxiliar: String;
begin
  IndexadorS     := 0;
  StringAuxiliar := '';

  if (length(C1) = 0) or (length(C1) = 1) then
  begin
    case length(C1) of
    0:
    begin
      if C1 = '' then
        S := C2;
    end;
    1:
    begin
      for IndexadorS := 1 to length(S) do
      begin
        TrechosDaString := Copy(S, IndexadorS, 1);

        if TrechosDaString = C1 then
          TrechosDaString := C2;

        StringAuxiliar := StringAuxiliar + TrechosDaString;
      end;
      S := StringAuxiliar;
    end;
    end;
  end;
  Result := S;
end;

