         IQuery.ParamByName('QUANTIDADE').AsFloat       := (QRel.FieldByName('QUANTIDADE_C').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat) * -1;
         IQuery.ParamByName('TRANSACAO_ID').AsInteger   := Id_Trans;

         IQuery.Prepare;
