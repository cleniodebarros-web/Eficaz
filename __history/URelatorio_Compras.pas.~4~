procedure TFrmRelatorio_Compras.btnExecutaClick(Sender: TObject);
var
I : Integer;
Parametro, Grupo : string;
Total_Qtd, Total_Valor : Real;
begin
// 125

// 325

  try
    btnExecuta.Enabled := False;
    btnRetorna.Enabled := False;

    QRel.Sql.Clear;

    if Tipo_Rel.Text = 'Sintético' then
       QRel.Sql.Add('SELECT GRUPO, SUM(QTD_COMPRA) QTD_COMPRA, SUM(VR_TOTAL) VR_TOTAL FROM(');

    if Tipo_Rel.Text = 'Analítico' then
     QRel.Sql.Add('SELECT TRANSACOES.NUM_DOC,TRANSITENS.PRODUTO_ID, PRODUTOS.DESCRICAO, TRANSACOES.DT_ENT_SAI, TABELAS.DESCRICAO GRUPO, SUM(TRANSITENS.QUANTIDADE) QTD_COMPRA, ' +
                 'SUM(TRANSITENS.VR_TOTAL + TRANSITENS.VALOR_ICMS_ST + TRANSITENS.VR_FRETE + TRANSITENS.VR_ACRESCIMO + TRANSITENS.VR_IPI + TRANSITENS.VR_FCPST + TRANSITENS.VR_FCP - TRANSITENS.DESC_RODAPE) VR_TOTAL, TRANSITENS.VR_UNITARIO, FORNECEDORES.NOME FORNECEDOR')
    else
    QRel.Sql.Add('SELECT TRANSITENS.PRODUTO_ID, PRODUTOS.DESCRICAO, PRODUTOS.COD_BARRA, TABELAS.DESCRICAO GRUPO, SUM(TRANSITENS.QUANTIDADE) QTD_COMPRA, ' +
                 'SUM(TRANSITENS.VR_TOTAL + TRANSITENS.VALOR_ICMS_ST + TRANSITENS.VR_FRETE + TRANSITENS.VR_ACRESCIMO + TRANSITENS.VR_IPI + TRANSITENS.VR_FCPST + TRANSITENS.VR_FCP - TRANSITENS.DESC_RODAPE) VR_TOTAL');

    QRel.Sql.Add('FROM TRANSITENS');
    QRel.Sql.Add('INNER JOIN TRANSACOES');
    QRel.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
    QRel.Sql.Add('LEFT JOIN PRODUTOS');
    QRel.Sql.Add('ON (TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID)');
    QRel.Sql.Add('INNER JOIN FORNECEDORES');
    QRel.Sql.Add('ON (FORNECEDORES.FORNECEDOR_ID = TRANSACOES.FORNECEDOR_ID)');
    QRel.Sql.Add('LEFT JOIN TABELAS');
    QRel.Sql.Add('ON (PRODUTOS.GRUPO_ID = TABELAS.TABELA_ID AND TABELAS.TIPO_TABELA = :TIPO_TABELA)');
    QRel.Sql.Add('LEFT JOIN NOTAS_CANCELADAS');
    QRel.Sql.Add('ON (TRANSACOES.TRANSACAO_ID = NOTAS_CANCELADAS.TRANSACAO_ID)');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(TRANSACOES.DT_ENT_SAI BETWEEN :DT_INICIAL AND :DT_FINAL)');
    QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
    QRel.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
    QRel.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
    QRel.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB) AND (TRANSITENS.TP_PROD_SERV = ''P'')');

    if TIPO_COMPRA.Text <> '' then
    begin
      QRel.Sql.Add('AND (TRANSACOES.TIPO_COMPRA = :TIPO_COMPRA)');
      QRel.ParamByName('TIPO_COMPRA').AsString := TIPO_COMPRA.Text;
    end;



    if (Tipo_Rel.Text = 'Resumido') then
    begin

          if (StrToInt(Prod_Inicial.Text) = 0)
            AND (StrToInt(Tributacao.Text) = 0 )
            AND (StrToInt(Localizacao.Text) = 0 )
            AND (StrToInt(SubTipo.Text) = 0 )
            AND (StrToInt(FAMILIA_ID.Text) = 0 )
            AND (StrToInt(GRUPO_ID.Text) = 0 )
            AND (StrToInt(Fornecedor.Text) = 0 )
          then
          begin
             QRGroup1.Enabled   := False;
             QRLabel2.Enabled   := False;
             QRExpr4.Enabled    := False;
             QRShape3.Enabled   := False;
             QRBand2.Enabled    := False;
          end
          else
          begin
              QRGroup1.Enabled := True;
              QRLabel2.Enabled := True;
              QRExpr4.Enabled := True;
              QRShape3.Enabled := True;
              QRBand2.Enabled := True;
          end;
    end
    else
    begin
             QRGroup1.Enabled := True;
             QRLabel2.Enabled := True;
             QRExpr4.Enabled := True;
             QRShape3.Enabled := True;
             QRBand2.Enabled := True;
    end;

    QRel.Sql.Add('AND (NOTAS_CANCELADAS.TRANSACAO_ID IS NULL)');

    if StrToInt(Fornecedor.Text) > 0 then
    begin
      QRel.Sql.Add('AND (TRANSACOES.FORNECEDOR_ID = :FORNECEDOR_ID)');
      QRel.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(Fornecedor.Text);
    end;

    if StrToInt(GRUPO_ID.Text) > 0 then
    begin
      QRel.Sql.Add('AND (PRODUTOS.GRUPO_ID = :GRUPO_ID)');
      QRel.ParamByName('GRUPO_ID').AsInteger := StrToInt(GRUPO_ID.Text);
    end;

    if StrToInt(FAMILIA_ID.Text) > 0 then
    begin
      QRel.Sql.Add('AND (PRODUTOS.SUBTIPO_ID = :SUBTIPO_ID)');
      QRel.ParamByName('SUBTIPO_ID').AsInteger := StrToInt(FAMILIA_ID.Text);
    end;

    if StrToInt(Localizacao.Text) > 0 then
    begin
      QRel.Sql.Add('AND (PRODUTOS.LOCALIZACAO_ID = :LOCALIZACAO_ID)');
      QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(Localizacao.Text);
    end;

    if StrToInt(Tributacao.Text) > 0 then
    begin
      QRel.Sql.Add('AND (PRODUTOS.TRIBUTO_ID = :TRIBUTO_ID)');
      QRel.ParamByName('TRIBUTO_ID').AsInteger := StrToInt(Tributacao.Text);
    end;

    if (StrToInt(Prod_Final.Text) > 0) then
    begin
      QRel.Sql.Add('AND (PRODUTOS.PRODUTO_ID BETWEEN :PRODUTO_INICIAL AND :PRODUTO_FINAL)');
      QRel.ParamByName('PRODUTO_INICIAL').AsInteger := StrToInt(Prod_Inicial.Text);
      QRel.ParamByName('PRODUTO_FINAL').AsInteger   := StrToInt(Prod_Final.Text);
    end;

    if (StrToInt(Produto_id.Text) > 0) then
    begin
      QRel.Sql.Add('AND (PRODUTOS.PRODUTO_ID = :PRODUTO_ID)');
      QRel.ParamByName('PRODUTO_ID').AsInteger := StrToInt(Produto_id.Text);
    end;


        if ( DstList.Items.Count > 0 ) then
        begin
          QRel.Sql.Add('AND((');

            for I := 0 to (DstList.Items.Count - 1) do
            begin
                if DstList.Items.Strings[I] <> '' then
                begin

                   {
                     if I = 0 then
                      begin
                       QRel.Sql.Add('TRANSITENS.CFOP = :CODIGO');
                       QRel.ParamByName('CODIGO').AsString := Copy( DstList.Items.Strings[I], 1, 4 );
                      end
                     else
                      Begin
                       QRel.Sql.Add('OR (TRANSITENS.CFOP = :CODIGO)');
                       QRel.ParamByName('CODIGO').AsString := Copy( DstList.Items.Strings[I], 1, 4 );
                     End;
                    }

                     Parametro := 'CODIGO_'+IntToStr(I);

                     if I = 0 then
                      begin
                       QRel.Sql.Add('(TRANSITENS.CFOP= :'+Parametro+') ');
                       QRel.ParamByName(Parametro).AsString := Copy( DstList.Items.Strings[I], 1, 4 );
                      end
                     else
                     begin
                       QRel.Sql.Add( 'OR (TRANSITENS.CFOP=:'+ Parametro + ')');
                       QRel.ParamByName(Parametro).AsString := Copy( DstList.Items.Strings[I], 1, 4 );
                     End;

                end;
            end;

            QRel.Sql.Add('))');
        end;



    if Tipo_Rel.Text = 'Analítico' then
    QRel.Sql.Add('GROUP BY TRANSACOES.NUM_DOC,TRANSACOES.DT_ENT_SAI,TRANSITENS.PRODUTO_ID, PRODUTOS.DESCRICAO, PRODUTOS.COD_BARRA, TABELAS.DESCRICAO,TRANSITENS.VR_UNITARIO, FORNECEDORES.NOME')
    Else
    QRel.Sql.Add('GROUP BY TRANSITENS.PRODUTO_ID, PRODUTOS.DESCRICAO, PRODUTOS.COD_BARRA, TABELAS.DESCRICAO');

   if Tipo_Rel.Text = 'Analítico' then
   Begin

    if Ordem.Text = 'CÓDIGO' then
      QRel.Sql.Add('ORDER BY 7, 3')
    else if Ordem.Text = 'DESCRIÇĂO' then
      QRel.Sql.Add('ORDER BY PRODUTOS.DESCRICAO, TRANSACOES.DT_ENT_SAI ')
    else if Ordem.Text = 'QUANTIDADE' then
      QRel.Sql.Add('ORDER BY 7, 8 DESC')
     else if Ordem.Text = 'DATA COMPRA' then
      QRel.Sql.Add('ORDER BY TRANSACOES.DT_ENT_SAI')
    else if Ordem.Text = 'VALOR COMPRA' then
      QRel.Sql.Add('ORDER BY 7, 9 DESC');

   End
   else

   begin

    if Ordem.Text = 'CÓDIGO' then
      QRel.Sql.Add('ORDER BY 4, 1')
    else if Ordem.Text = 'DESCRIÇĂO' then
      QRel.Sql.Add('ORDER BY 4, 2')
    else if Ordem.Text = 'QUANTIDADE' then
      QRel.Sql.Add('ORDER BY 4, 5 DESC')
    else if Ordem.Text = 'VALOR COMPRA' then
      QRel.Sql.Add('ORDER BY 4, 6 DESC');
   end;

    if Tipo_Rel.Text = 'Sintético' then
       QRel.Sql.Add(') AS TESTE GROUP BY GRUPO');


    QRel.ParamByName('TIPO_TABELA').AsString  := '7';
    QRel.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
    QRel.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
    QRel.ParamByName('CONDUTA').AsString      := '02';
    QRel.ParamByName('DEPTO').AsString        := '07';
    QRel.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QRel.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;

    QRel.Prepare;
    QRel.Open;

    QRLabel10.Caption := 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text;


    if QRel.IsEmpty then
      Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
    else
      begin

        if Tipo_Rel.Text = 'Sintético' then
          begin


          RDprint1.TamanhoQteColunas:=80;
          RDprint1.OpcoesPreview.Preview     := True;
          RDprint1.MostrarProgresso          := True;
          RDprint1.Acentuacao                := SemAcento;
          RDprint1.TamanhoQteLinhas          := 1;
          RDprint1.Abrir;

              if linha > 66 then
              begin
                RDprint1.novapagina;
                Pagina := Pagina + 1;
              end;

              Pagina:= 1;
              QRel.First;


                  RDprint1.ImpF(linha, 01, 'GRUPO', [negrito]);
                  RDprint1.ImpF(linha, 45, 'Qtd. Compra', [negrito]);
                  RDprint1.ImpF(linha, 61, 'Vr. Compra', [negrito]);
                  Inc(linha);
                  RDprint1.LinhaH(linha,01,80,0,false);

                  Inc(linha);

                  Total_Qtd   := 0;
                  Total_Valor := 0;

             while not QRel.Eof do
             Begin

                RDprint1.ImpF(linha, 01, QRel.FieldByName('GRUPO').AsString, []);
                RDprint1.ImpVal(linha, 45, ',###,##0.00', QRel.FieldByName('QTD_COMPRA').AsFloat,[]);
                RDprint1.ImpVal(linha, 60, ',###,##0.00', QRel.FieldByName('VR_TOTAL').AsFloat,[]);

                Total_Qtd := Total_Qtd + QRel.FieldByName('QTD_COMPRA').AsFloat;
                Total_Valor := Total_Valor + QRel.FieldByName('VR_TOTAL').AsFloat;

                Inc(linha);

                if linha > 63 then
                begin
                  RDprint1.novapagina;
                  Pagina := Pagina + 1;
                end;
                QRel.Next;
             End;

              Inc(linha);

              RDprint1.LinhaH(linha,45,55,0,false);
              RDprint1.LinhaH(linha,60,70,0,false);
              Inc(linha);
              RDprint1.ImpVal(linha, 45, ',###,##0.00', Total_Qtd,[]);
              RDprint1.ImpVal(linha, 60, ',###,##0.00', Total_Valor,[]);


              Application.ProcessMessages;
              RDprint1.TamanhoQteLinhas:= 66;
              RDprint1.Fechar;

          end
        else  if Tipo_Rel.Text = 'Analítico' then
        Begin
        if PRODUTO_ID.VALUE > 0 Then
         Begin

         Rel_Compras_Analitico_Prod.Prepare;
         Rel_Compras_Analitico_Prod.PreviewModal;

         End
         Else
         Begin
         Rel_Compras_Analitico.Prepare;
         Rel_Compras_Analitico.PreviewModal;

         End;
        End
        else
        Begin
        Fim.Prepare;
        Fim.PreviewModal;
        if chk_exportar.Checked Then
         Begin
         Fim.ExportToFilter(TQRXLSFilter.Create(ExtractFilePath(ParamStr(0)) + 'Exportados\Rel_Compras_' + Copy(Dtmen.Text,1,2) + Copy(Dtmen.Text,4,2) + Copy(Dtmen.Text,7,4) + '_' + Copy(Dtmai.Text,1,2) + Copy(Dtmai.Text,4,2) + Copy(Dtmai.Text,7,4)  + '.xls'));
         Application.MessageBox(PChar('Arquivo exportado para : ' + ExtractFilePath(ParamStr(0)) + 'Exportados\Rel_Compras_' + Copy(Dtmen.Text,1,2) + Copy(Dtmen.Text,4,2) + Copy(Dtmen.Text,7,4) + '_' +Copy(Dtmai.Text,1,2) + Copy(Dtmai.Text,4,2) + Copy(Dtmai.Text,7,4)  + '.xls') , PChar(Msg_Title), mb_IconInformation);
         End;
