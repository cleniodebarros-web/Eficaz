procedure TFrmRel_Produtos_por_Periodo.btnExecutaClick(Sender: TObject);
var
Data : string;
Subtotal_Qtd, Subtotal_Valor, Total: Real;
begin
try
          QRel.Sql.Clear;

          if Cmb_movimento.Text = 'Compra' Then
          Begin
             if Chk_Movimentacao.Checked then
             begin
             QRel.SQL.Add('SELECT PRODUTO_ID, DESCRICAO, COD_BARRA, DT_COMPRA, QUANTIDADE_C ESTOQUE FROM PRODUTOS WHERE PRODUTOS.DT_COMPRA BETWEEN :DT_INICIAL AND :DT_FINAL');
             QRel.Sql.Add('AND PRODUTOS.STATUS = :STATUS');
             end
             Else
             Begin
             QRel.SQL.Add('SELECT PRODUTO_ID, DESCRICAO, COD_BARRA, DT_COMPRA, QUANTIDADE_C ESTOQUE FROM PRODUTOS WHERE PRODUTOS.PRODUTO_ID NOT IN(');
             QRel.SQL.Add('SELECT PRODUTO_ID FROM PRODUTOS WHERE PRODUTOS.DT_COMPRA BETWEEN :DT_INICIAL AND :DT_FINAL)');
             QRel.Sql.Add('AND PRODUTOS.STATUS = :STATUS');
             End;
          End
          Else
          Begin
             if Chk_Movimentacao.Checked then
             begin
             QRel.SQL.Add('SELECT PRODUTO_ID, DESCRICAO, COD_BARRA, DT_MOVIMENTO, QUANTIDADE_C ESTOQUE FROM PRODUTOS WHERE PRODUTOS.DT_MOVIMENTO BETWEEN :DT_INICIAL AND :DT_FINAL');
             QRel.Sql.Add('AND PRODUTOS.STATUS = :STATUS');
             end
             Else
             Begin
             QRel.SQL.Add('SELECT PRODUTO_ID, DESCRICAO, COD_BARRA, DT_MOVIMENTO, QUANTIDADE_C ESTOQUE FROM PRODUTOS WHERE PRODUTOS.PRODUTO_ID NOT IN(');
             QRel.SQL.Add('SELECT PRODUTO_ID FROM PRODUTOS WHERE PRODUTOS.DT_MOVIMENTO BETWEEN :DT_INICIAL AND :DT_FINAL)');
             QRel.Sql.Add('AND PRODUTOS.STATUS = :STATUS');
             End;

          End;




           if Selecao.Text = 'Igual a 0' then
            QRel.Sql.Add('AND (PRODUTOS.QUANTIDADE_C = 0)')
          else if Selecao.Text = 'Maior do que 0' then
            QRel.Sql.Add('AND (PRODUTOS.QUANTIDADE_C > 0)')
          else if Selecao.Text = 'Menor do que 0' then
            QRel.Sql.Add('AND (PRODUTOS.QUANTIDADE_C < 0)')
          else if Selecao.Text = 'Todos' then
            QRel.Sql.Add('AND ((PRODUTOS.QUANTIDADE_C < 0) OR (PRODUTOS.QUANTIDADE_C = 0) OR (PRODUTOS.QUANTIDADE_C > 0))')
          else
            QRel.Sql.Add('AND (PRODUTOS.QUANTIDADE_C <> 0)');

           //FILTRO FORNECEDOR
          if StrToInt(Fornecedor.Text) > 0 then
          begin
            QRel.Sql.Add('AND (PRODUTOS.FORNECEDOR_ID = :FORNECEDOR_ID)');
            QRel.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(Fornecedor.Text);
          end;

          //FILTRO GRUPO
          if StrToInt(Grupo.Text) > 0 then
          begin
            QRel.Sql.Add('AND (PRODUTOS.GRUPO_ID = :GRUPO_ID)');
            QRel.ParamByName('GRUPO_ID').AsInteger := StrToInt(Grupo.Text);
          end;

          // FILTRO TRIBUTAÇĂO
          if StrToInt(Tributacao.Text) > 0 then
          begin
            QRel.Sql.Add('AND (PRODUTOS.TRIBUTO_ID = :TRIBUTO_ID)');
            QRel.ParamByName('TRIBUTO_ID').AsInteger := StrToInt(Tributacao.Text);
          end;

          //FILTRO SUBTIPO
          if StrToInt(SubTipo.Text) > 0 then
          begin
            QRel.Sql.Add('AND (PRODUTOS.SUBTIPO_ID = :SUBTIPO_ID)');
            QRel.ParamByName('SUBTIPO_ID').AsInteger := StrToInt(SubTipo.Text);
          end;

          //FILTRO LOCALIZAÇĂO
          if StrToInt(Localizacao.Text) > 0 then
          begin
            QRel.Sql.Add('AND (PRODUTOS.LOCALIZACAO_ID = :LOCALIZACAO_ID)');
            QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(Localizacao.Text);
          end;

           //FILTRO INTERVALO
          if  (StrToInt(Prod_Inicial.Text) >= 0) AND ( StrToInt(Prod_Final.Text) > 0 )  then
          begin
            QRel.Sql.Add('AND (PRODUTOS.PRODUTO_ID BETWEEN :PRODUTO_INICIAL AND :PRODUTO_FINAL)');
            QRel.ParamByName('PRODUTO_INICIAL').AsInteger := StrToInt(Prod_Inicial.Text);
            QRel.ParamByName('PRODUTO_FINAL').AsInteger   := StrToInt(Prod_Final.Text);
          end;

         QRel.Sql.Add('AND (PRODUTOS.EMPRESA_ID = :EMPRESA_ID)');
         QRel.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;


         QRel.Sql.Add('AND (PRODUTOS.TIPO_ITEM = :TIPO_ITEM)');
         QRel.ParamByName('TIPO_ITEM').AsString := TIPO_ITEM.Text;

         if Ordem.Text  = 'Descriçăo' then
            QRel.SQL.Add('ORDER BY PRODUTOS.DESCRICAO')
         else
            if Cmb_movimento.Text = 'Compra' Then
            QRel.SQL.Add('ORDER BY PRODUTOS.DT_COMPRA')
            Else
             QRel.SQL.Add('ORDER BY PRODUTOS.DT_MOVIMENTO');

          QRel.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
          QRel.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
          QRel.ParamByName('STATUS').AsString  := 'A';


          QRel.Prepare;
          QRel.Open;


      if QRel.IsEmpty then
        Application.MessageBox('Năo há dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
      else
      Begin
              if CheckBox1.Checked = True then
              Begin
               RDprint1.Impressora := HP;
               RDprint1.FonteTamanhoPadrao := S10cpp;
              End;

              RDprint1.TamanhoQteColunas         :=80;
              RDprint1.OpcoesPreview.Preview     := True;
              RDprint1.MostrarProgresso          := True;
              RDprint1.Acentuacao                := SemAcento;
              RDprint1.TamanhoQteLinhas          := 1;
              RDprint1.Abrir;
              RDprint1.Orientacao:= poPortrait;

              if linha > 66  then
              Begin
               RDprint1.Novapagina;
               Pagina := Pagina + 1;
              End;

              Data            := '';
              Total           := 0;
              Subtotal_Qtd    := 0;
              Subtotal_Valor  := 0;


            QRel.First;
            while not QRel.Eof do
            Begin

                 RDprint1.ImpF(linha, C1, Copy(QRel.FieldByName('PRODUTO_ID').AsString, 1 ,8), []);
                 RDprint1.ImpF(linha, C2, Copy(AllTrim(QRel.FieldByName('COD_BARRA').AsString), 1, 14), []);
                 RDprint1.ImpF(linha, C3, Copy(AllTrim(QRel.FieldByName('DESCRICAO').AsString), 1, 35), []);
                 if Cmb_movimento.Text = 'Compra' Then
                 RDprint1.ImpF(linha, C5, DateToStr(QRel.FieldByName('DT_COMPRA').AsDateTime), [])
                 ELSE
                 RDprint1.ImpF(linha, C5, DateToStr(QRel.FieldByName('DT_MOVIMENTO').AsDateTime), []);

                 RDprint1.ImpVal(linha,C4,'##0.00',QRel.FieldByName('ESTOQUE').AsFloat,[]);

             if linha > 63  then
             Begin
               RDprint1.Novapagina;
               Pagina := Pagina + 1;
             End;

             Inc(linha);
             QRel.Next;
            End;



        Application.ProcessMessages;
        RDprint1.TamanhoQteLinhas:= 66;
        RDprint1.Fechar;

      End;

  finally
    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;
end;


procedure TFrmRel_Produtos_por_Periodo.RDprint1NewPage(Sender: TObject;
  Pagina: Integer);
begin
           //posiçăo das colulas
           C1  := 01;
           C2  := 09;
           C3  := 25;
           C4  := 61;
           C5  := 70;

          RDprint1.Imp(01, 01, FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString);
          RDprint1.ImpDir(01, (length(FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString)), 80, 'Sistema de Automaçăo de empresas Eficaz', []);
          RDprint1.Imp(02, 01, 'Data/Hora: ' + DateToStr(date) + ' - ' + TimeToStr(now));
          RDprint1.impDir(02, 80, 80, 'Página: ' + IntToStr(Pagina), []);
          RDprint1.imp(03, 01, 'Período:'+ datetoStr(dtmen.date) + ' ŕ ' + datetoStr(dtmai.date));

           if Cmb_movimento.Text = 'Compra' Then
           Begin
           if Chk_Movimentacao.Checked then
           RDprint1.impC(04, 40, '*** PRODUTOS COM MOVIMENTAÇĂO DE COMPRAS  ***',[negrito])
           Else
           RDprint1.impC(04, 40, '*** PRODUTOS SEM MOVIMENTAÇĂO DE COMPRAS  ***',[negrito])
           End
           Else
           Begin
            if Chk_Movimentacao.Checked then
            RDprint1.impC(04, 40, '*** PRODUTOS COM MOVIMENTAÇĂO DE VENDAS ***',[negrito])
            Else
            RDprint1.impC(04, 40, '*** PRODUTOS SEM MOVIMENTAÇĂO DE VENDAS ***',[negrito])
           End;


          RDprint1.LinhaH(05,01,80,0,false);
          RDprint1.ImpF(06, C1, 'ID',[negrito]);
          RDprint1.ImpF(06, C2, 'COD. BARRAS', [negrito]);
          RDprint1.ImpF(06, C3, 'DESCRIÇĂO', [negrito]);
          RDprint1.ImpF(06, C4, 'ESTQ.', [negrito]);
          RDprint1.ImpF(06, C5 - 3, 'ULT. MOVIMENTO', [negrito]);
          RDprint1.LinhaH(07,01,80,0,false);
          linha := 08;

end;


