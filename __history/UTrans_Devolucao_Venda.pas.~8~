  QUpdate.ParamByName('SEQUENCIA').AsInteger    := S;
  QUpdate.ParamByName('PRODUTO_ID').AsInteger   := IQuery.FieldByName('PRODUTO_ID').AsInteger;
  QUpdate.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
  QUpdate.Prepare;
  QUpdate.ExecSQL;

  S := S + 1;

  IQuery.Next;

  end;
end;

