procedure TFrmTrans_Devolucao_Venda.Grid_ItensExit(Sender: TObject);
var
Perc_Quita :real;
begin
  if QSub_Detail.State in [dsInsert, dsEdit] then
  begin
    QSub_Detail.Cancel;

  end;

  if (FrmData.QAcesso.FieldByName('ALTERACAO').AsString = 'NĂO') and (FrmData.QAcesso.FieldByName('TPCTB').AsString = '2') then
  begin
    Application.MessageBox('Usuário sem permissăo para alteraçăo', PChar(Msg_Title), mb_IconStop);
    Botoes_Normal;
    Consulta.TabVisible := True;
    exit;
  end;

  if QTabela.FieldByName('DT_MOVIMENTO').AsDateTime < FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime then
  begin
    Application.MessageBox('Movimento já encerrado', PChar(Msg_Title), mb_IconStop);
    Botoes_Normal;
    Consulta.TabVisible := True;
    exit;
  end;

  btnEditClick(Self);

  VALOR_PRODUTOS.Value := 0;
  VR_IPI.Value         := 0;
  ITENS.Value          := 0;
  UNIDADES.Value       := 0;
  VR_PIS.Value         := 0;
  VR_COFINS.Value      := 0;
  VR_PIS_ST.Value      := 0;
  VR_COFINS_ST.Value   := 0;

  QSub_Detail.First;
  while not QSub_Detail.Eof do
  begin
    VALOR_PRODUTOS.Value := VALOR_PRODUTOS.Value + QSub_Detail.FieldByName('VR_TOTAL').AsFloat;
    VR_IPI.Value         := VR_IPI.Value + QSub_Detail.FieldByName('VR_IPI').AsFloat;
    ITENS.Value          := ITENS.Value + 1;
    UNIDADES.Value       := UNIDADES.Value + QSub_Detail.FieldByName('QUANTIDADE').AsFloat;

    if (QSub_Detail.FieldByName('CST_PIS').AsString = '05') or (QSub_Detail.FieldByName('CST_PIS').AsString = '75') then
      VR_PIS_ST.Value := VR_PIS_ST.Value + QSub_Detail.FieldByName('VR_PIS').AsFloat
    else
      VR_PIS.Value    := VR_PIS.Value + QSub_Detail.FieldByName('VR_PIS').AsFloat;

    if (QSub_Detail.FieldByName('CST_COFINS').AsString = '05') or (QSub_Detail.FieldByName('CST_COFINS').AsString = '75') then
      VR_COFINS_ST.Value := VR_COFINS_ST.Value + QSub_Detail.FieldByName('VR_COFINS').AsFloat
    else
      VR_COFINS.Value    := VR_COFINS.Value + QSub_Detail.FieldByName('VR_COFINS').AsFloat;

    Application.ProcessMessages;
    QSub_Detail.Next;
  end;


  if BASE_ICMS_NORMAL.CanFocus then
    BASE_ICMS_NORMAL.SetFocus
  else
    Botoes_Normal;
end;

procedure TFrmTrans_Devolucao_Venda.Grid_ItensKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin
  if (Key = Vk_F4) and (QSub_Detail.State = dsBrowse) and (not QSub_Detail.IsEmpty) then
    QSub_Detail.Delete;

  if (Key = Vk_F6) and (QSub_Detail.State = dsBrowse) and (not QSub_Detail.IsEmpty) then
    Atualiza_Impostos(QTabela.FieldByName('TRANSACAO_ID').AsInteger, QSub_Detail.FieldByName('PRODUTO_ID').AsInteger);

  if (Key = Vk_F7) and ((Grid_Itens.SelectedField.FieldName = 'produto_id') or (Grid_Itens.SelectedField.FieldName = 'tributo_id')  or (Grid_Itens.SelectedField.FieldName = 'CST')) and (QSub_Detail.State in [dsInsert, dsEdit]) then
  begin
    if Grid_Itens.SelectedField.FieldName = 'produto_id' then
      QSub_Detail.FieldByName('PRODUTO_ID').AsInteger := GetConsulta('ESTOQUE', StrToInt(EMPRESA_ID.Text), 0, QSub_Detail.FieldByName('PRODUTO_ID').AsInteger);

    if Grid_Itens.SelectedField.FieldName = 'conta_id' then
      QSub_Detail.FieldByName('CONTA_ID').AsInteger := GetConsulta('PLANO', 0, 0, QSub_Detail.FieldByName('CONTA_ID').AsInteger);

    if Grid_Itens.SelectedField.FieldName = 'tributo_id' then
      QSub_Detail.FieldByName('TRIBUTO_ID').AsInteger := GetConsulta('TRIBUTOS', 0, 0, QSub_Detail.FieldByName('TRIBUTO_ID').AsInteger);

    if Grid_Itens.SelectedField.FieldName = 'cst' then
      QSub_Detail.FieldByName('CST').AsString := GetConsulta_CST('CST_ICMS', QSub_Detail.FieldByName('CST').AsString);
  end;


    if (Key = VK_F9)  then
   Begin
   if FrmPrincipal.QEmpresa.FieldByName('CRT').AsString <> '1 - SIMPLES NACIONAL' then
   Begin
      Perform(Wm_NextDlgCtl, 0, 0);
      BtnSaveClick(Sender);
      BtnImpostosClick(sender);
   End
   Else
     Perform(Wm_NextDlgCtl, 0, 0);
   End;


  if ((Key = Vk_Up) or (Key = Vk_Down)) and (QSub_Detail.State in [dsInsert, dsEdit]) then
    Key := 0;

 end;

procedure TFrmTrans_Devolucao_Venda.Grid_ItensKeyPress(Sender: TObject;
  var Key: Char);
begin
  if Key = #46 then
    Key := #44;

  if Key = #13 then
    Keybd_Event(VK_TAB, 0, 0, 0);

  Key := AnsiUpperCase(Key)[1];
end;

procedure TFrmTrans_Devolucao_Venda.Grid_SaidasKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin

if (Key = Vk_F4) and (QSaidas_Notas.State = dsBrowse) and (not QSaidas_Notas.IsEmpty) then
 Begin
    if Application.MessageBox('Deseja apagar a saída selecionada e os itens na devoluçăo?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin

       QConsulta.Sql.Clear;
       QConsulta.Sql.Text := 'SELECT PRODUTO_ID FROM TRANSITENS WHERE TRANSACAO_ID = :TRANSACAO_ID';
       QConsulta.ParamByName('TRANSACAO_ID').AsInteger := QSaidas_Notas.FieldByName('SAIDA_ID').AsInteger;
       QConsulta.Prepare;
       QConsulta.Open;

       QConsulta.First;

       while not QConsulta.eof do
       Begin

        QUpdate.Sql.Clear;
        QUpdate.Sql.Text := 'DELETE FROM TRANSITENS WHERE PRODUTO_ID = :PRODUTO_ID AND TRANSACAO_ID = :TRANSACAO_ID';
        QUpdate.ParamByName('PRODUTO_ID').AsInteger   := QConsulta.FieldByName('PRODUTO_ID').AsInteger;
        QUpdate.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        QUpdate.Prepare;
        QUpdate.ExecSQL;

        QConsulta.Next;
       End;


       QSaidas_Notas.Delete;

       QSub_Detail.Refresh;

      end;
 End;
end;

