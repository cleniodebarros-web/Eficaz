  IQuery.ParamByName('CODIGO').AsString := QSub_Detail.FieldByName('CST').AsString;

  IQuery.Prepare;
  IQuery.Open;

  if IQuery.IsEmpty then
  begin

   if FrmPrincipal.QEmpresa.FieldByName('CRT').AsString = '1 - SIMPLES NACIONAL' then
   Application.MessageBox('Código CSOSN inválido', PChar(Msg_Title), mb_IconStop)
   Else
   Application.MessageBox('Código CST inválido', PChar(Msg_Title), mb_IconStop);

    Grid_Itens.SelectedIndex := 5;
    abort;
  end;

  if QSub_Detail.FieldByName('CST_PIS').AsString <> '' then
  begin
    IQuery.Sql.Clear;
    IQuery.Sql.Add('SELECT * FROM CST_PIS');
    IQuery.Sql.Add('WHERE');
    IQuery.Sql.Add('(CODIGO = :CODIGO)');

    IQuery.ParamByName('CODIGO').AsString := QSub_Detail.FieldByName('CST_PIS').AsString;

    IQuery.Prepare;
    IQuery.Open;

    if IQuery.IsEmpty then
    begin
      Application.MessageBox('Código CST PIS inválido', PChar(Msg_Title), mb_IconStop);
      abort;
    end;
  end;

  if QSub_Detail.FieldByName('CST_COFINS').AsString <> '' then
  begin
    IQuery.Sql.Clear;
    IQuery.Sql.Add('SELECT * FROM CST_COFINS');
    IQuery.Sql.Add('WHERE');
    IQuery.Sql.Add('(CODIGO = :CODIGO)');

    IQuery.ParamByName('CODIGO').AsString := QSub_Detail.FieldByName('CST_COFINS').AsString;

    IQuery.Prepare;
    IQuery.Open;

    if IQuery.IsEmpty then
    begin
      Application.MessageBox('Código CST COFINS inválido', PChar(Msg_Title), mb_IconStop);
      abort;
    end;
  end;

  if QSub_Detail.FieldByName('CST_PIS').AsString <> QSub_Detail.FieldByName('CST_COFINS').AsString then
  begin
    Application.MessageBox('Cód. CST PIS diferente de CST COFINS', PChar(Msg_Title), mb_IconStop);
    abort;
  end;
  
  if QSub_Detail.State = dsInsert then
  begin
    IQuery.Sql.Clear;
    IQuery.Sql.Add('SELECT * FROM TRANSITENS');
    IQuery.Sql.Add('WHERE');
    IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
    IQuery.Sql.Add('ORDER BY SEQUENCIA');

    IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;

    IQuery.Prepare;
    IQuery.Open;
    IQuery.Last;
    QSub_Detail.FieldByName('SEQUENCIA').AsInteger := (IQuery.FieldByName('SEQUENCIA').AsInteger + 1);
  end;


  if QProduto.FieldByName('REDUCAO_ICMS').AsFloat > 0 then
   QSub_Detail.FieldByName('VR_REDUCAO_BC').AsFloat := (QSub_Detail.FieldByName('VR_TOTAL').AsFloat - RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat * QProduto.FieldByName('REDUCAO_ICMS').AsFloat) / 100), -2));

  QSub_Detail.FieldByName('VR_UNITARIO').AsFloat := RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat + (QSub_Detail.FieldByName('VR_DESCONTO').AsFloat * QSub_Detail.FieldByName('QUANTIDADE').AsFloat)) / QSub_Detail.FieldByName('QUANTIDADE').AsFloat), -2);

  if QSub_Detail.FieldByName('BASE_CALC_PIS').AsFloat = 0 then
    QSub_Detail.FieldByName('BASE_CALC_PIS').AsFloat := QSub_Detail.FieldByName('VR_TOTAL').AsFloat;

  QSub_Detail.FieldByName('VR_PIS').AsFloat := ((QSub_Detail.FieldByName('BASE_CALC_PIS').AsFloat * QSub_Detail.FieldByName('ALIQUOTA_PIS').AsFloat) / 100);

  if QSub_Detail.FieldByName('BASE_CALC_COFINS').AsFloat = 0 then
    QSub_Detail.FieldByName('BASE_CALC_COFINS').AsFloat := QSub_Detail.FieldByName('VR_TOTAL').AsFloat;

  QSub_Detail.FieldByName('VR_COFINS').AsFloat := ((QSub_Detail.FieldByName('BASE_CALC_COFINS').AsFloat * QSub_Detail.FieldByName('ALIQUOTA_COFINS').AsFloat) / 100);

end;

