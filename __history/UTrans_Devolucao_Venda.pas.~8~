      QEstorno.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

      QEstorno.ParamByName('TRANSACAO_ID').AsInteger := StrToInt(SAIDA_ID.Text);

      QEstorno.Prepare;
      QEstorno.Open;

      QSub_Detail.First;
      while not QSub_Detail.Eof do
      begin

        VALOR_PRODUTOS.Value := VALOR_PRODUTOS.Value + QSub_Detail.FieldByName('VR_TOTAL').AsFloat;
        VR_IPI.Value         := VR_IPI.Value + QSub_Detail.FieldByName('VR_IPI').AsFloat;
        ITENS.Value          := ITENS.Value + 1;
        UNIDADES.Value       := UNIDADES.Value + QSub_Detail.FieldByName('QUANTIDADE').AsFloat;

        if (QSub_Detail.FieldByName('CST_PIS').AsString = '05') or (QSub_Detail.FieldByName('CST_PIS').AsString = '75') then
          VR_PIS_ST.Value := VR_PIS_ST.Value + QSub_Detail.FieldByName('VR_PIS').AsFloat
        else
          VR_PIS.Value    := VR_PIS.Value + QSub_Detail.FieldByName('VR_PIS').AsFloat;

        if (QSub_Detail.FieldByName('CST_COFINS').AsString = '05') or (QSub_Detail.FieldByName('CST_COFINS').AsString = '75') then
          VR_COFINS_ST.Value := VR_COFINS_ST.Value + QSub_Detail.FieldByName('VR_COFINS').AsFloat
        else
          VR_COFINS.Value    := VR_COFINS.Value + QSub_Detail.FieldByName('VR_COFINS').AsFloat;

        Application.ProcessMessages;
        QSub_Detail.Next;
      end;

      VALOR.Value := VALOR_PRODUTOS.Value + VR_ICMS_ST.Value + VR_IPI.Value + VR_ACRESCIMO.Value - VR_DESCONTO.Value;

      if (QEstorno.FieldByName('COND_PAGTO').AsString = 'A PRAZO') and (VALOR.Value > 0) then
      begin
        IQuery.Sql.Clear;
        IQuery.Sql.Add('DELETE FROM TRANSACOES');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(SAIDA_ID = :SAIDA_ID)');
        IQuery.Sql.Add('AND (CONDUTA = :CONDUTA) AND (DEVOLUCAO_ID = :DEVOLUCAO_ID)');

        IQuery.ParamByName('SAIDA_ID').AsInteger     := StrToInt(SAIDA_ID.Text);
        IQuery.ParamByName('CONDUTA').AsString       := '07';
        IQuery.ParamByName('DEVOLUCAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;

        IQuery.Prepare;
        IQuery.ExecSql;


        QQuitacao_Total.Sql.Clear;
        QQuitacao_Total.Sql.Add('SELECT  SUM(TRANSPARCELAS.VALOR) VALOR');
        QQuitacao_Total.Sql.Add('FROM CLIENTES');
        QQuitacao_Total.Sql.Add('INNER JOIN TRANSACOES');
        QQuitacao_Total.Sql.Add('ON (CLIENTES.CLIENTE_ID = TRANSACOES.CLIENTE_ID)');
        QQuitacao_Total.Sql.Add('INNER JOIN TRANSPARCELAS');
        QQuitacao_Total.Sql.Add('ON (TRANSACOES.TRANSACAO_ID = TRANSPARCELAS.TRANSACAO_ID)');
        QQuitacao_Total.Sql.Add('WHERE');
        QQuitacao_Total.Sql.Add('(TRANSACOES.TRANSACAO_ID = :TRANSACAO_ID)');
        QQuitacao_Total.Sql.Add('AND (TRANSPARCELAS.VALOR > 0)');
        QQuitacao_Total.Sql.Add('AND (TRANSPARCELAS.BANCO_ID = 0)');
        QQuitacao_Total.Sql.Add('AND (TRANSPARCELAS.TIPO_TRANSACAO = :TIPO_TRANSACAO)');
        QQuitacao_Total.Sql.Add('AND ((TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL))');


        QQuitacao_Total.ParamByName('TRANSACAO_ID').AsInteger  := StrToInt(SAIDA_ID.Text);
        QQuitacao_Total.ParamByName('TIPO_TRANSACAO').AsString := 'T';

        QQuitacao_Total.Prepare;
        QQuitacao_Total.Open;


        QQuitacao.Sql.Clear;
        QQuitacao.Sql.Add('SELECT CLIENTES.NOME, CLIENTES.ENDERECO, CLIENTES.NUMERO, TRANSPARCELAS.*, TRANSACOES.HISTORICO, TRANSACOES.NUM_DOC, TRANSACOES.CONTA_ID, TRANSACOES.VENDEDOR_ID, TRANSACOES.EMPRESA_ID, TRANSACOES.TPCTB, TRANSACOES.C_CUSTO_ID, TRANSACOES.CLIENTE_ID');
        QQuitacao.Sql.Add('FROM CLIENTES');
        QQuitacao.Sql.Add('INNER JOIN TRANSACOES');
        QQuitacao.Sql.Add('ON (CLIENTES.CLIENTE_ID = TRANSACOES.CLIENTE_ID)');
        QQuitacao.Sql.Add('INNER JOIN TRANSPARCELAS');
        QQuitacao.Sql.Add('ON (TRANSACOES.TRANSACAO_ID = TRANSPARCELAS.TRANSACAO_ID)');
        QQuitacao.Sql.Add('WHERE');
        QQuitacao.Sql.Add('(TRANSACOES.TRANSACAO_ID = :TRANSACAO_ID)');
        QQuitacao.Sql.Add('AND (TRANSPARCELAS.VALOR > 0)');
        QQuitacao.Sql.Add('AND (TRANSPARCELAS.BANCO_ID = 0)');
        QQuitacao.Sql.Add('AND (TRANSPARCELAS.TIPO_TRANSACAO = :TIPO_TRANSACAO)');
        QQuitacao.Sql.Add('AND ((TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL))');
        QQuitacao.Sql.Add('ORDER BY CLIENTES.NOME, TRANSPARCELAS.DT_VENCIMENTO, TRANSPARCELAS.PARCELA_ID');

        QQuitacao.ParamByName('TRANSACAO_ID').AsInteger  := StrToInt(SAIDA_ID.Text);
        QQuitacao.ParamByName('TIPO_TRANSACAO').AsString := 'T';

        QQuitacao.Prepare;
        QQuitacao.Open;

        QQuitacao.First;
        while not QQuitacao.Eof do
        begin


          IQuery.Sql.Clear;
          IQuery.Sql.Add('INSERT INTO TRANSACOES(' +
                         'DT_TRANS,       DT_MOVIMENTO,      CONDUTA, ' +
                         'EMPRESA_ID,     CLIENTE_ID,        BANCO_ID, ' +
                         'NUM_DOC,        SERIE,             FLUXO_CAIXA_ID, ' +
                         'SAIDA_ID,       PARCELA_ID,        VALOR_PARCELA, ' +
                         'VALOR,          BALANCO,           TPCTB, ' +
                         'AUTORIZ_ID,     HISTORICO,         CONTA_ID, DEVOLUCAO_ID) VALUES(' +
                         ':DT_TRANS,      :DT_MOVIMENTO,     :CONDUTA, ' +
                         ':EMPRESA_ID,    :CLIENTE_ID,       :BANCO_ID, ' +
                         ':NUM_DOC,       :SERIE,            :FLUXO_CAIXA_ID, ' +
                         ':SAIDA_ID,      :PARCELA_ID,       :VALOR_PARCELA, ' +
                         ':VALOR,         :BALANCO,          :TPCTB, ' +
                         ':AUTORIZ_ID,    :HISTORICO,        :CONTA_ID, :DEVOLUCAO_ID)');

          IQuery.ParamByName('DT_TRANS').AsDateTime      := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
          IQuery.ParamByName('DT_MOVIMENTO').AsDateTime  := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
          IQuery.ParamByName('CONDUTA').AsString         := '07';
          IQuery.ParamByName('EMPRESA_ID').AsInteger     := QEstorno.FieldByName('EMPRESA_ID').AsInteger;
          IQuery.ParamByName('CLIENTE_ID').AsInteger     := QEstorno.FieldByName('CLIENTE_ID').AsInteger;
          IQuery.ParamByName('BANCO_ID').AsInteger       := StrToInt(BANCO_ID.Text);
          IQuery.ParamByName('NUM_DOC').AsString         := QEstorno.FieldByName('NUM_DOC').AsString;
          IQuery.ParamByName('FLUXO_CAIXA_ID').AsInteger := 1;
          IQuery.ParamByName('SAIDA_ID').AsInteger       := StrToInt(SAIDA_ID.Text);
          IQuery.ParamByName('PARCELA_ID').AsString      := QQuitacao.FieldByName('PARCELA_ID').AsString;
          IQuery.ParamByName('VALOR_PARCELA').AsFloat    := QQuitacao.FieldByName('VALOR').AsFloat;
          IQuery.ParamByName('DEVOLUCAO_ID').AsInteger   := QTabela.FieldByName('TRANSACAO_ID').AsInteger;

          if VALOR.Value = QEstorno.FieldByName('VALOR').AsFloat then
          begin
            IQuery.ParamByName('SERIE').AsString     := 'N';
            IQuery.ParamByName('VALOR').AsFloat      := QQuitacao.FieldByName('VALOR').AsFloat;
            IQuery.ParamByName('CONTA_ID').AsInteger := 0;
          end
          else if VALOR.Value < QEstorno.FieldByName('VALOR').AsFloat then
          begin

            if QEntrada.FieldByName('ENTRADA').AsInteger > 0 then
            Perc_Quita := ((VALOR.Value * 100) / QQuitacao_Total.FieldByName('VALOR').AsFloat)
            Else
            Perc_Quita := ((VALOR.Value * 100) / QEstorno.FieldByName('VALOR').AsFloat);

            IQuery.ParamByName('SERIE').AsString     := 'P';
            IQuery.ParamByName('VALOR').AsFloat      := RoundTo(((QQuitacao.FieldByName('VALOR').AsFloat * Perc_Quita) / 100), -2);



            IQuery.ParamByName('CONTA_ID').AsInteger := 0;
          end
          else if VALOR.Value > QEstorno.FieldByName('VALOR').AsFloat then
          begin
            Perc_Quita := ((VALOR.Value * 100) / QEstorno.FieldByName('VALOR').AsFloat);

            IQuery.ParamByName('SERIE').AsString     := 'J';
            IQuery.ParamByName('VALOR').AsFloat      := RoundTo(((QQuitacao.FieldByName('VALOR').AsFloat * Perc_Quita) / 100), -2);
            IQuery.ParamByName('CONTA_ID').AsInteger := FrmPrincipal.Config.FieldByName('CONTA_JUROS').AsInteger;
          end;

          IQuery.ParamByName('BALANCO').AsString     := 'LIBERADO';
          IQuery.ParamByName('TPCTB').AsString       := QQuitacao.FieldByName('TPCTB').AsString;
          IQuery.ParamByName('AUTORIZ_ID').AsInteger := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
          IQuery.ParamByName('HISTORICO').AsString   := 'Ref. Devoluçăo Transaçăo ' + SAIDA_ID.Text;

          IQuery.Prepare;
          IQuery.ExecSql;

          Application.ProcessMessages;

          QQuitacao.Next;
        end;
      end;


     End ;

    Habilitar(False);
    Botoes_Normal;

    Operacao := '';
    Consulta.TabVisible := True;

  end;
end;

