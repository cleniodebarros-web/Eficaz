procedure TFrmTrans_Devolucao_Venda.Grid_ItensColEnter(Sender: TObject);
begin
  if QSub_Detail.State in [dsInsert, dsEdit] then
  begin
    ProdutoSearch;
    TributoSearch;
    ContaSearch;

    if (Grid_Itens.SelectedField.FieldName = 'conta_id') and (QProduto.IsEmpty) then
      Grid_Itens.SelectedIndex := 0;

    if (Grid_Itens.SelectedField.FieldName = 'tributo_id') and (QConta_Estoque.IsEmpty) then
      Grid_Itens.SelectedIndex := 2;

    if (Grid_Itens.SelectedField.FieldName = 'cfop') and (QTributo.IsEmpty) then
      Grid_Itens.SelectedIndex := 3;

    if (Grid_Itens.SelectedField.FieldName = 'cst') and (QCFOP_Estoque.IsEmpty) then
      Grid_Itens.SelectedIndex := 4;

    if (Grid_Itens.SelectedField.FieldName = 'vr_unitario') and (QSub_Detail.FieldByName('QUANTIDADE').AsFloat = 0) then
      Grid_Itens.SelectedIndex := 9;

    if (Grid_Itens.SelectedField.FieldName = 'vr_desconto') and (QSub_Detail.FieldByName('VR_UNITARIO').AsFloat = 0) then
      Grid_Itens.SelectedIndex := 10;
  end;
end;

procedure TFrmTrans_Devolucao_Venda.Grid_ItensColExit(Sender: TObject);
begin
  if QSub_Detail.State in [dsInsert, dsEdit] then
  begin
    if Grid_Itens.SelectedField.FieldName = 'produto_id' then
    begin
      ProdutoSearch;

      if QProduto.IsEmpty then
      begin
        QSub_Detail.FieldByName('DESCRICAO').AsString      := '';
        QSub_Detail.FieldByName('TRIBUTO_ID').AsInteger    := 0;
        QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat   := 0;
        QSub_Detail.FieldByName('VR_UNITARIO').AsFloat     := 0;
        QSub_Detail.FieldByName('CST_PIS').AsString        := '';
        QSub_Detail.FieldByName('ALIQUOTA_PIS').AsFloat    := 0;
        QSub_Detail.FieldByName('CST_COFINS').AsString     := '';
        QSub_Detail.FieldByName('ALIQUOTA_COFINS').AsFloat := 0;

        Application.MessageBox('Produto inexistente', PChar(Msg_Title), mb_IconStop);
        Grid_Itens.SelectedIndex := 0;
      end
      else
      begin
        QSub_Detail.FieldByName('DESCRICAO').AsString      := QProduto.FieldByName('DESCRICAO').AsString;
        QSub_Detail.FieldByName('TRIBUTO_ID').AsInteger    := QProduto.FieldByName('TRIBUTO_ID').AsInteger;
        QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat   := QProduto.FieldByName('ALIQUOTA_ICMS').AsFloat;
        QSub_Detail.FieldByName('VR_UNITARIO').AsFloat     := RoundTo(QProduto.FieldByName('PRECO_VAREJO').AsFloat, -2);
        QSub_Detail.FieldByName('CST_PIS').AsString        := QProduto.FieldByName('CST_PIS_ENTR').AsString;
        QSub_Detail.FieldByName('ALIQUOTA_PIS').AsFloat    := QProduto.FieldByName('PIS_ENTR').AsFloat;
        QSub_Detail.FieldByName('CST_COFINS').AsString     := QProduto.FieldByName('CST_COFINS_ENTR').AsString;
        QSub_Detail.FieldByName('ALIQUOTA_COFINS').AsFloat := QProduto.FieldByName('COFINS_ENTR').AsFloat;

        if QProduto.FieldByName('CTRL_SERIE').AsString = 'SIM' then
          Edita_Series(QTabela.FieldByName('TRANSACAO_ID').AsInteger, QSub_Detail.FieldByName('PRODUTO_ID').AsInteger, -1);

        IQuery.Sql.Clear;
        IQuery.Sql.Add('SELECT SUM(QUANTIDADE) QUANTIDADE');
        IQuery.Sql.Add('FROM TRANSITENS_SERIE');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
        IQuery.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

        IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        IQuery.ParamByName('PRODUTO_ID').AsInteger   := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;

        IQuery.Prepare;
        IQuery.Open;

        QSub_Detail.FieldByName('QUANTIDADE').AsFloat := IQuery.FieldByName('QUANTIDADE').AsFloat;
      end;
    end;

    if Grid_Itens.SelectedField.FieldName = 'conta_id' then
    begin
      ContaSearch;

      if QConta_Estoque.IsEmpty then
      begin
        QSub_Detail.FieldByName('CONTA_ID').AsInteger := 0;

        Application.MessageBox('Conta inexistente', PChar(Msg_Title), mb_IconStop);
        Grid_Itens.SelectedIndex := 2;
      end;
    end;

    if Grid_Itens.SelectedField.FieldName = 'cfop' then
    begin
      CFOPSearch;

      if QCFOP_Estoque.IsEmpty then
      begin
        QSub_Detail.FieldByName('CFOP').AsString := '';

        Application.MessageBox('CFOP inexistente', PChar(Msg_Title), mb_IconStop);
        Grid_Itens.SelectedIndex := 4;
      end;
    end;

    if Grid_Itens.SelectedField.FieldName = 'tributo_id' then
    begin
      TributoSearch;

      if QTributo.IsEmpty then
      begin
        QSub_Detail.FieldByName('CST').AsString := '';

        Application.MessageBox('Tributo inexistente', PChar(Msg_Title), mb_IconStop);
        Grid_Itens.SelectedIndex := 3;
      end
      else
      begin
        QSub_Detail.FieldByName('CFOP').AsString         := QTabela.FieldByName('CFOP').AsString;

        If FrmPrincipal.QEmpresa.FieldByName('CRT').AsString = '1 - SIMPLES NACIONAL' then
        QSub_Detail.FieldByName('CST').AsString          := QProduto.FieldByName('CSOSN').AsString
        Else
        QSub_Detail.FieldByName('CST').AsString          := Copy(QTributo.FieldByName('ORIGEM').AsString, 1, 1) + Copy(QTributo.FieldByName('TRIBUTACAO').AsString, 1, 2);

        QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat := QTributo.FieldByName('ALIQUOTA_ICMS').AsFloat;
      end;
    end;

    if Grid_Itens.SelectedField.FieldName = 'tributo_id' then
    begin
      TributoSearch;

      if QTributo.IsEmpty then
      begin
        QSub_Detail.FieldByName('CST').AsString := '';

        Application.MessageBox('Tributo inexistente', PChar(Msg_Title), mb_IconStop);
        Grid_Itens.SelectedIndex := 3;
      end
      else
        QSub_Detail.FieldByName('CST').AsString := Copy(QTributo.FieldByName('ORIGEM').AsString, 1, 1) + Copy(QTributo.FieldByName('TRIBUTACAO').AsString, 1, 2);
    end;

    if (Grid_Itens.SelectedField.FieldName = 'vr_unitario') or (Grid_Itens.SelectedField.FieldName = 'quantidade') or (Grid_Itens.SelectedField.FieldName = 'vr_desconto') then
    begin
      if Grid_Itens.SelectedField.FieldName = 'quantidade' then
      begin
        ProdutoSearch;

        if QProduto.FieldbyName('FRACAO_VENDA').AsFloat > 0 then
          QSub_Detail.FieldByName('QUANTIDADE').AsFloat := (QSub_Detail.FieldByName('QUANTIDADE').AsFloat * QProduto.FieldByName('FRACAO_VENDA').AsFloat);
      end;

      QSub_Detail.FieldByName('VR_TOTAL').AsFloat := RoundTo((QSub_Detail.FieldByName('QUANTIDADE').AsFloat * (QSub_Detail.FieldByName('VR_UNITARIO').AsFloat - QSub_Detail.FieldByName('VR_DESCONTO').AsFloat)), -2);
    end;
  end;
end;

