procedure TFrmSintegra.GerarRegistro61;
var
WRegistro61: TRegistro61;
begin
  WRegistro61 := TRegistro61.Create;

   IQuery.Sql.Text:= 'SELECT NUM_ECF FROM LICENCA_IF WHERE GERAR_SPED = 1';
   IQuery.Prepare;
   IQuery.Open;
   IQuery.First;

   while not IQuery.Eof do
   Begin

      QDespesa.Sql.Clear;
      QDespesa.Sql.Add('SELECT SERIE , DT_ENT_SAI,TRANSITENS.ALIQUOTA_ICMS, SUM(TRANSITENS.VR_TOTAL + TRANSITENS.VALOR_ICMS_ST + TRANSITENS.VR_FRETE + TRANSITENS.VR_ACRESCIMO ');
      QDespesa.Sql.Add('+ TRANSITENS.VR_IPI + TRANSITENS.VR_FCPST  + TRANSITENS.VR_FCP - TRANSITENS.DESC_RODAPE - TRANSITENS.VALOR_ICMS_DESON) VALOR, SUM(TRANSITENS.BASE_CALC_ICMS) BASE_ICMS_NORMAL,');
      QDespesa.Sql.Add('SUM(TRANSITENS.VALOR_ICMS) VR_ICMS_NORMAL,SUM(TRANSITENS.VALOR_ISENTO) VALOR_ISENTO, SUM(TRANSITENS.VALOR_OUTROS) VALOR_OUTROS,');
      QDespesa.Sql.Add('(SELECT  NUM_DOC NUM_DOC_INI FROM TRANSACOES   WHERE (TRANSACOES.DT_ENT_SAI =  :DT_REGISTRO)');
      QDespesa.Sql.Add('      AND (MODELO = :MODELO)');
      QDespesa.Sql.Add('      AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
      QDespesa.Sql.Add('      AND (TRANSACOES.TPCTB <= :TPCTB)');
      QDespesa.Sql.Add('      AND (TRANSACOES.CONDUTA = :CONDUTA)');
      QDespesa.Sql.Add('      AND (TRANSACOES.DEPTO = :DEPTO)');
      QDespesa.Sql.Add('      AND (TRANSACOES.SERIE = :SERIE)');
      QDespesa.Sql.Add('      ORDER BY NUM_DOC ASC LIMIT 1 ),');
      QDespesa.Sql.Add('(SELECT NUM_DOC NUM_DOC_FIM FROM TRANSACOES   WHERE (TRANSACOES.DT_ENT_SAI =  :DT_REGISTRO)');
      QDespesa.Sql.Add('      AND (MODELO = :MODELO)');
      QDespesa.Sql.Add('      AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
      QDespesa.Sql.Add('      AND (TRANSACOES.TPCTB <= :TPCTB)');
      QDespesa.Sql.Add('      AND (TRANSACOES.CONDUTA = :CONDUTA)');
      QDespesa.Sql.Add('      AND (TRANSACOES.SERIE = :SERIE)');
      QDespesa.Sql.Add('      AND (TRANSACOES.DEPTO = :DEPTO) ORDER BY NUM_DOC DESC LIMIT 1) NUM_DOC_FIM');
      QDespesa.Sql.Add('FROM TRANSITENS');
      QDespesa.Sql.Add('INNER JOIN TRANSACOES ON TRANSACOES.TRANSACAO_ID = TRANSITENS.TRANSACAO_ID');
      QDespesa.Sql.Add('INNER JOIN COMPL_NFCEFISCAL ON COMPL_NFCEFISCAL.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID');
      QDespesa.Sql.Add('      WHERE (TRANSACOES.DT_ENT_SAI = :DT_REGISTRO)');
      QDespesa.Sql.Add('      AND (MODELO = :MODELO)');
      QDespesa.Sql.Add('      AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
      QDespesa.Sql.Add('      AND (TRANSACOES.TPCTB <= :TPCTB)');
      QDespesa.Sql.Add('      AND (TRANSACOES.CONDUTA = :CONDUTA)');
      QDespesa.Sql.Add('      AND (TRANSACOES.DEPTO = :DEPTO)');
      QDespesa.Sql.Add('      AND (TRANSACOES.SERIE = :SERIE)');
      QDespesa.Sql.Add('	GROUP BY TRANSACOES.SERIE,TRANSACOES.DT_ENT_SAI, TRANSITENS.ALIQUOTA_ICMS');
      QDespesa.Sql.Add('	ORDER BY TRANSACOES.SERIE,TRANSACOES.DT_ENT_SAI,TRANSITENS.ALIQUOTA_ICMS');

