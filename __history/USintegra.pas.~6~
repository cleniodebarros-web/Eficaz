procedure TFrmSintegra.GerarRegistro75;
var
WRegistro75: TRegistro75;
begin
  QDespesa.Sql.Clear;
  QDespesa.Sql.Add('SELECT * FROM REGISTRO_75');
  QDespesa.Sql.Add('WHERE');
  QDespesa.Sql.Add('(DT_INICIAL = :DT_INICIAL)');
  QDespesa.Sql.Add('AND (DT_FINAL = :DT_FINAL)');

  QDespesa.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
  QDespesa.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;

  QDespesa.Prepare;
  QDespesa.Open;

  QDespesa.First;
  while not QDespesa.Eof do
  begin
    WRegistro75 := TRegistro75.Create;

    WRegistro75.DataInicial  := ACBrSintegra.Registro10.DataInicial;
    WRegistro75.DataFinal    := ACBrSintegra.Registro10.DataFinal;
    WRegistro75.Codigo       := QDespesa.FieldByName('COD_PRODUTO').AsString;
    WRegistro75.NCM          := QDespesa.FieldByName('NCM').AsString;
    WRegistro75.Descricao    := Copy(QDespesa.FieldByName('DESCRICAO').AsString,1,53);
    WRegistro75.Unidade      := QDespesa.FieldByName('UNIDADE').AsString;
    WRegistro75.AliquotaIpi  := QDespesa.FieldByName('ALIQUOTA_IPI').AsFloat;
    WRegistro75.AliquotaICMS := QDespesa.FieldByName('ALIQUOTA_ICMS').AsFloat;
    WRegistro75.Reducao      := QDespesa.FieldByName('REDUCAO_BASE_ICMS').AsFloat;
    WRegistro75.BaseST       := QDespesa.FieldByName('BASE_CALC_ST').AsFloat;

    ACBrSintegra.Registros75.Add(WRegistro75);

    Label2.Caption := 'Processando Registro 75: ' + QDespesa.FieldByName('COD_PRODUTO').AsString;

    Application.ProcessMessages;
    QDespesa.Next;
  end;
end;

procedure TFrmSintegra.InventarioChange(Sender: TObject);
begin
 if inventario.Text = 'N鬃' then
 Begin
 label6.Visible := False;
 label8.Visible := False;
 Preco.Visible  := False;
 Data.Visible   := False;
 end
 Else
 Begin
 label6.Visible := True;
 label8.Visible := True;
 Preco.Visible  := True;
 Data.Visible   := True;

  if Copy(DateToStr(date),4,2) = '03' then
  begin

   IQuery.SQL.Clear;
   IQuery.SQL.Add('SELECT DISTINCT DT_MOVIMENTO FROM POSICAO_PRODUTOS WHERE DT_MOVIMENTO <= :DT_FIM ORDER BY DT_MOVIMENTO DESC' );
   IQuery.ParamByName('DT_FIM').AsDate := StrToDate('31/12/' + IntToStr(StrToInt(Copy(DateToStr(Dtmen.Date), 7, 4))-1));
   IQuery.Prepare;
   IQuery.Open();


   Inventario.ItemIndex := 1;
   Preco.ItemIndex := 1;
   Data.Visible  := True;
   Preco.Visible := True;
   Label6.Visible := True;
   Label8.Visible := True;

   Data.Items.Clear;
   Data.Items.Add(IQuery.FieldByName('DT_MOVIMENTO').AsString);
   Data.ItemIndex := 0;
  end;
 End;
end;

procedure TFrmSintegra.Seleciona_Parceiro(Conduta, Depto: String; Fornecedor, Cliente: Integer);
begin
  if ((Conduta = '01') and (Depto = '03')) or ((Conduta = '01') and (Depto = '07')) or ((Conduta = '02') and (Depto = '10')) then
  begin
    QParceiro.Sql.Clear;
    QParceiro.Sql.Add('SELECT CLIENTES.* , TIPO_CLIENTE PESSOA FROM CLIENTES');
    QParceiro.Sql.Add('WHERE');
    QParceiro.Sql.Add('(CLIENTE_ID = :CLIENTE_ID)');

    QParceiro.ParamByName('CLIENTE_ID').AsInteger := Cliente;

    QParceiro.Prepare;
    QParceiro.Open;
  end;

  if ((Conduta = '02') and (Depto = '02')) or ((Conduta = '02') and (Depto = '07')) or ((Conduta = '01') and (Depto = '10')) then
  begin
    QParceiro.Sql.Clear;
    QParceiro.Sql.Add('SELECT FORNECEDORES.* , TIPO_FORNECEDOR PESSOA FROM FORNECEDORES');
    QParceiro.Sql.Add('WHERE');
    QParceiro.Sql.Add('(FORNECEDOR_ID = :FORNECEDOR_ID)');

    QParceiro.ParamByName('FORNECEDOR_ID').AsInteger := Fornecedor;

    QParceiro.Prepare;
    QParceiro.Open;
  end;
end;

procedure TFrmSintegra.Seleciona_Produtos;
begin
  QProduto.Sql.Clear;
  QProduto.Sql.Add('SELECT TRANSITENS.*, PRODUTOS.COD_BARRA, PRODUTOS.UNIDADE, PRODUTOS.NCM');
  QProduto.Sql.Add('FROM TRANSITENS');
  QProduto.Sql.Add('INNER JOIN PRODUTOS');
  QProduto.Sql.Add('ON (TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID)');
  QProduto.Sql.Add('WHERE');
  QProduto.Sql.Add('(TRANSITENS.TRANSACAO_ID = :TRANSACAO_ID)');

  QProduto.ParamByName('TRANSACAO_ID').AsInteger := QRel.FieldByName('TRANSACAO_ID').AsInteger;

  QProduto.Prepare;
  QProduto.Open;
end;

end.
