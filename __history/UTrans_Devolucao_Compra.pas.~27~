    IQuery.Open;

    if FrmPrincipal.QEmpresa.FieldByName('CRT').AsString <> '1 - SIMPLES NACIONAL' then
    Begin
    BASE_ICMS_NORMAL.Value := IQuery.FieldByName('BASE_CALC_ICMS').AsFloat;
