                                            'WHERE (TRANSACAO_ID = :TRANSACAO_ID)');

      QRel.ParamByName('BASE_ICMS_NORMAL').AsFloat := BASE_ICMS_NORMAL.Value;
      QRel.ParamByName('VR_ICMS_NORMAL').AsFloat   := VR_ICMS_NORMAL.Value;
      QRel.ParamByName('BASE_ICMS_ST').AsFloat     := BASE_ICMS_ST.Value;
      QRel.ParamByName('VR_ICMS_ST').AsFloat       := VR_ICMS_ST.Value;
      QRel.ParamByName('VALOR').AsFloat            := VALOR.Value;
      QRel.ParamByName('VR_ACRESCIMO').AsFloat     := VR_Acrescimo.Value;
      QRel.ParamByName('VR_DESCONTO').AsFloat      := Vr_Desconto.Value;
      QRel.ParamByName('VR_FCPST').AsFloat         := VR_FCPST.Value;
      QRel.ParamByName('VR_FCP').AsFloat           := VR_FCP.Value;


      QRel.ParamByName('TRANSACAO_ID').AsInteger := T_Id;

      QRel.Prepare;
      QRel.ExecSql;



      QTabela.Close;

      QTabela.Prepare;
      QTabela.Open;
     end
     Else
     Begin
      QRel.Sql.Clear;
      QRel.Sql.Add('UPDATE TRANSACOES SET VALOR = :VALOR, ' +
                                            'VR_ACRESCIMO = :VR_ACRESCIMO, ' +
                                            'VR_DESCONTO = :VR_DESCONTO ' +
                                            'WHERE (TRANSACAO_ID = :TRANSACAO_ID)');

      QRel.ParamByName('VALOR').AsFloat          := VALOR.Value;
      QRel.ParamByName('VR_ACRESCIMO').AsFloat   := Vr_Acrescimo.Value;
      QRel.ParamByName('VR_DESCONTO').AsFloat    := Vr_Desconto.Value;


