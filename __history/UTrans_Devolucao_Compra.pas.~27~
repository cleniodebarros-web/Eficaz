  Grid_Itens.Columns[7].Width  := 40;
  Grid_Itens.Columns[8].Width  := 35;
  Grid_Itens.Columns[9].Width  := 75;
  Grid_Itens.Columns[10].Width := 44;
  Grid_Itens.Columns[11].Width := 45;
  Grid_Itens.Columns[12].Width := 52;
  Grid_Itens.Columns[13].Width := 52;
  Grid_Itens.Columns[14].Width := 52;

  CmdSelect     := QTabela.Sql.Text;

  if Id_Trans = 0 then
    CmdSelectNull := 'WHERE (TRANSACAO_ID IS NOT NULL) AND (DT_MOVIMENTO = :DT_MOVIMENTO) AND (CONDUTA = :CONDUTA) AND (DEPTO = :DEPTO) AND (TPCTB = :TPCTB) AND (EMPRESA_ID = :EMPRESA_ID)'
  else
    CmdSelectNull := 'WHERE (TRANSACAO_ID = ' + IntToStr(Id_Trans) + ') AND (CONDUTA = :CONDUTA) AND (DEPTO = :DEPTO) AND (TPCTB = :TPCTB) AND (EMPRESA_ID = :EMPRESA_ID)';

  CmdOrderBy    := 'ORDER BY TRANSACAO_ID';
  Situacao      := False;

  QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

  if Id_Trans = 0 then
    QTabela.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

  QTabela.ParamByName('CONDUTA').AsString        := '01';
  QTabela.ParamByName('DEPTO').AsString          := '10';
  QTabela.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;
  QTabela.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QTabela.Prepare;
  QTabela.Open;

  if FrmPrincipal.QEmpresa.FieldByName('CRT').AsString = '1 - SIMPLES NACIONAL' then
  Grid_Itens.Columns[5].Title.Caption :='Csosn'
  Else
  Grid_Itens.Columns[5].Title.Caption :='CST';


  if FrmPrincipal.Config.FieldByName('REFORMA_TRIBUTARIA').AsInteger = 1 then
  TabSheet4.TabVisible := True
  Else
  TabSheet4.TabVisible := False;


  Consulta.Show;
end;


