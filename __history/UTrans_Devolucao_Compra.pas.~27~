    if Destacar_ICMS_ST.Checked then
     Begin
      VALOR.Value        := VALOR_PRODUTOS.Value + VR_ICMS_ST.Value + VR_IPI.Value + VR_ACRESCIMO.Value + VR_FRETE.Value + VR_FCPST.Value - VR_DESCONTO.Value;
      BASE_ICMS_ST.Value := IQuery.FieldByName('BASE_CALC_ST').AsFloat;
      VR_ICMS_ST.Value   := IQuery.FieldByName('VALOR_ICMS_ST').AsFloat;
     End
    else
      VALOR.Value := VALOR_PRODUTOS.Value + VR_IPI.Value + VR_ACRESCIMO.Value + VR_FRETE.Value - VR_DESCONTO.Value;


    if FrmPrincipal.QEmpresa.FieldByName('CRT').AsString <> '1 - SIMPLES NACIONAL' then
    Begin
    if  (VR_FCPST.Value <> V_FCPST) or (VR_FCP.Value <> V_FCP) or (BASE_ICMS_NORMAL.Value <> B_ICMS) or (VR_ICMS_NORMAL.Value <> V_ICMS) or (BASE_ICMS_ST.Value <> B_ICMS_ST) or (VR_ICMS_ST.Value <> V_ICMS_ST) or (VALOR.Value <> Vr_Old) then
     begin
