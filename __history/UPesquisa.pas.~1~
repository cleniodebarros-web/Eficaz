    ChavePesquisa := 'WHERE (' + QTabela.FieldByName('CAMPO').AsString + ' > ' + #39 + Txt_Sql.Text + #39 + ')'
  else if (Condicao.Text = 'é maior ou igual a') and (Txt_Sql.Text <> '') then
    ChavePesquisa := 'WHERE (' + QTabela.FieldByName('CAMPO').AsString + ' >= ' + #39 + Txt_Sql.Text + #39 + ')'
