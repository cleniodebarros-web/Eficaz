  if (Key = Vk_F7) and (QTabela.FieldByName('CONSULTA').AsString <> '') then
    Txt_Sql2.Text := IntToStr(GetConsulta(QTabela.FieldByName('CONSULTA').AsString, 0, 0, 0));

  if (Key = Vk_Return) or (Key = Vk_Down) then
