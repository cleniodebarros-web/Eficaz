procedure TFrmRel_Compras.SearchFornecedor;
begin
  try
    QFornecedor.Sql.Clear;
    QFornecedor.Sql.Add('SELECT * FROM FORNECEDORES');
    QFornecedor.Sql.Add('WHERE');
    QFornecedor.Sql.Add('(FORNECEDOR_ID = :FORNECEDOR_ID)');
    QFornecedor.Sql.Add('AND (STATUS = :STATUS)');

    QFornecedor.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(Fornecedor.Text);
    QFornecedor.ParamByName('STATUS').AsString         := 'A';

    QFornecedor.Prepare;
    QFornecedor.Open;
  except

  end;
end;

procedure TFrmRel_Compras.btnExecutaClick(Sender: TObject);
begin
// 203, 325
  if Tipo_Rel.Text = 'Analítico - apenas itens' then
  begin
    if QRel.IsEmpty then
      Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
    else
    Begin
      try

        QLayoutFastReport.SQL.Clear;
        QLayoutFastReport.SQL.Add('SELECT NOME_ARQUIVO, ARQUIVO_RELATORIO FROM CONFIG_RELATORIOS');
        QLayoutFastReport.SQL.Add('WHERE NOME_RELATORIO = :NOME_RELATORIO');
        QLayoutFastReport.SQL.Add('OR NOME_RELATORIO = :BASE;');
        QLayoutFastReport.ParamByName('NOME_RELATORIO').AsString := 'URel_Compras_Analitico_Itens';
        QLayoutFastReport.ParamByName('BASE').AsString := 'base';
        QLayoutFastReport.Open();

      Except
        on e:Exception do
        begin
          Application.MessageBox(PChar('Erro:' + #13 +
            'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
        end;
      end;

      Relatorio_Principal.Clear;

      DadosRelatorio.Open;
      DadosRelatorio.EmptyDataSet;

      while not QRel.eof Do
      Begin
        DadosRelatorio.append;

        DadosRelatorio.FieldByName('NUM_DOC').AsString        := QRel.FieldByName('NUM_DOC').AsString;
        DadosRelatorio.FieldByName('DT_TRANS').AsDateTime     := QRel.FieldByName('DT_TRANS').AsDateTime;
        DadosRelatorio.FieldByName('FORNECEDOR_ID').AsInteger := QRel.FieldByName('FORNECEDOR_ID').AsInteger;
        DadosRelatorio.FieldByName('NOME').AsString           := QRel.FieldByName('NOME').AsString;
        DadosRelatorio.FieldByName('CFOP').AsString           := QRel.FieldByName('CFOP').AsString;
        DadosRelatorio.FieldByName('PRODUTO_ID').AsInteger    := QRel.FieldByName('PRODUTO_ID').AsInteger;
        DadosRelatorio.FieldByName('DESCRICAO').AsString      := QRel.FieldByName('DESCRICAO').AsString;
        DadosRelatorio.FieldByName('QUANTIDADE').AsFloat      := QRel.FieldByName('QUANTIDADE').AsFloat;
        DadosRelatorio.FieldByName('VR_UNITARIO').AsFloat     := QRel.FieldByName('VR_UNITARIO').AsFloat;
        DadosRelatorio.FieldByName('VR_TOTAL').AsFloat        := QRel.FieldByName('VR_TOTAL').AsFloat;

        DadosRelatorio.Post;

        QRel.Next;
      End;

      Relatorio_Principal.Clear;
      Relatorio_Principal.InheritFromTemplate('URel_Compras_Analitico_Itens.fr3');
      Relatorio_Principal := FrmPrincipal.Configura_Relatorio_FastReport(Relatorio_Principal, 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text, 'Relatório de Compras - Itens');
      Relatorio_Principal.ShowReport(true);
    End;
  end
  else
  begin
    try
      btnExecuta.Enabled := False;
      btnRetorna.Enabled := False;

      QRel.Sql.Clear;
      QRel.Sql.Add('SELECT TRANSACOES.*, FORNECEDORES.NOME FORNECEDOR,');
      QRel.Sql.Add('(SELECT SUM((PRODUTOS.PRECO_VAREJO * TRANSITENS.QUANTIDADE))');
      QRel.Sql.Add('FROM TRANSITENS');
      QRel.Sql.Add('LEFT JOIN PRODUTOS');
      QRel.Sql.Add('ON (TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID)');
      QRel.Sql.Add('WHERE');
      QRel.Sql.Add('(TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)) VALOR_VENDA');
      QRel.Sql.Add('FROM TRANSACOES');
      QRel.Sql.Add('LEFT JOIN FORNECEDORES');
      QRel.Sql.Add('ON (TRANSACOES.FORNECEDOR_ID = FORNECEDORES.FORNECEDOR_ID)');
      QRel.Sql.Add('LEFT JOIN NOTAS_CANCELADAS');
      QRel.Sql.Add('ON (TRANSACOES.TRANSACAO_ID = NOTAS_CANCELADAS.TRANSACAO_ID)');
      QRel.Sql.Add('WHERE');

      if Tipo_Data.Text = 'Data da Nota' then
       Begin
        QRlabel10.Caption := 'Data Nota';
        QRel.Sql.Add('(TRANSACOES.DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL)');
       End
      else if Tipo_Data.Text = 'Data de Entrada' then
      Begin
        QRlabel10.Caption := 'Data Entrada';
        QRel.Sql.Add('(TRANSACOES.DT_ENT_SAI BETWEEN :DT_INICIAL AND :DT_FINAL)');
      End
      else if Tipo_Data.Text = 'Data do Movimento' then
      Begin
        QRlabel10.Caption := 'Data Movimento';
        QRel.Sql.Add('(TRANSACOES.DT_MOVIMENTO BETWEEN :DT_INICIAL AND :DT_FINAL)');
      End
      else if Tipo_Data.Text = 'Data do Sped' then
      Begin
        QRlabel10.Caption := 'Data Movimento';
        QRel.Sql.Add('(TRANSACOES.DT_SPED BETWEEN :DT_INICIAL AND :DT_FINAL)');
      End
      else
        QRel.Sql.Add('(TRANSACOES.DT_ENT_SAI BETWEEN :DT_INICIAL AND :DT_FINAL)');



      if (Tipo_Entrada.Text = 'COMPRA') OR (Tipo_Entrada.Text = 'BONIFICAÇĂO') OR (Tipo_Entrada.Text = 'REMESSA') OR (Tipo_Entrada.Text = 'TRANSFERĘNCIA')  then
      begin
        QRel.Sql.Add('AND (TRANSACOES.TIPO_COMPRA = :TIPO_COMPRA)');
        QRel.ParamByName('TIPO_COMPRA').AsString    := Tipo_Entrada.Text;
      end
      else if Tipo_Entrada.Text = 'DESPESA' then
      begin
        QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
        QRel.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
        QRel.ParamByName('CONDUTA').AsString      := '02';
        QRel.ParamByName('DEPTO').AsString        := '02';
      end
      else
      begin
        QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
        QRel.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
        QRel.ParamByName('CONDUTA').AsString      := '02';
        QRel.ParamByName('DEPTO').AsString        := '07';
        //QRel.ParamByName('CONDUTA2').AsString     := '02';
        //QRel.ParamByName('DEPTO2').AsString       := '02';
      end;

      QRel.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
      QRel.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB)');
      //QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
      //QRel.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
      QRel.Sql.Add('AND (NOTAS_CANCELADAS.TRANSACAO_ID IS NULL)');

      if Cond_Pagto.Text <> '' then
        QRel.Sql.Add('AND (TRANSACOES.COND_PAGTO = :COND_PAGTO)');

      if Fornecedor.Value > 0 then
        QRel.Sql.Add('AND (TRANSACOES.FORNECEDOR_ID = :FORNECEDOR_ID)');


       if Tipo_Data.Text = 'Data da Nota' then
       QRel.Sql.Add('ORDER BY  TRANSACOES.DT_TRANS, TRANSACOES.TRANSACAO_ID')
       else if Tipo_Data.Text = 'Data de Entrada' then
       QRel.Sql.Add('ORDER BY  TRANSACOES.DT_ENT_SAI, TRANSACOES.TRANSACAO_ID')
       else if Tipo_Data.Text = 'Data do Movimento' then
       QRel.Sql.Add('ORDER BY  TRANSACOES.DT_MOVIMENTO, TRANSACOES.TRANSACAO_ID')
       else if Tipo_Data.Text = 'Data do Sped' then
       QRel.Sql.Add('ORDER BY  TRANSACOES.DT_SPED, TRANSACOES.TRANSACAO_ID')
       Else
       QRel.Sql.Add('ORDER BY  TRANSACOES.DT_ENT_SAI, TRANSACOES.TRANSACAO_ID');


      QRel.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
      QRel.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
      QRel.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
      QRel.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;

      //QRel.ParamByName('CONDUTA').AsString      := '02';
      //QRel.ParamByName('DEPTO').AsString        := '07';


      if Cond_Pagto.Text <> '' then
        QRel.ParamByName('COND_PAGTO').AsString := Cond_Pagto.Text;

      if Fornecedor.Value > 0 then
        QRel.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(Fornecedor.Text);

      QRel.Prepare;
      QRel.Open;

      QRLabel1.Caption  := 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text;
      QRLabel46.Caption := 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text;

      if QRel.IsEmpty then
        Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
      else
      begin
        if Tipo_Rel.Text = 'Analítico' then
        Begin
          Compras_Analitico2.Prepare;
          Compras_Analitico2.PreviewModal;
        End
        else
        Begin
          Compras_Sintetico.Prepare;
          Compras_Sintetico.PreviewModal;
        End;
      end;

    finally
      btnExecuta.Enabled := True;
      btnRetorna.Enabled := True;
    end;
  end;
end;

