procedure TFrmFechamento_Mensal.btnExecutaClick(Sender: TObject);
var
texto_fastrep,Celula1,celula2,Celula3,celula4,Celula5,celula6: TfrxTableCell; // MemoView;

total_loja,Total_Loja_Custo, Total_MENSALIADE_RELOGIO, TOTAL_PECAS,TOTAL_SERVICOS,TOTAL_EQUIPAMENTO,TOTAL_COMISSAO,TOTAL_CONTRATO,TOTAL_MENSALIDADE_RELOGIO,TOTAL_VENDA_SISTEMA,TOTAL_MENSALIDADE,TOTAL_EMPRESTIMOS,TOTAL_GERAL : REAL;
Total_MENSALIADE_RELOGIO_G, TOTAL_PECAS_G,TOTAL_SERVICOS_G,TOTAL_EQUIPAMENTO_G,TOTAL_COMISSAO_G,TOTAL_CONTRATO_G,TOTAL_MENSALIDADE_RELOGIO_G,TOTAL_VENDA_SISTEMA_G,TOTAL_MENSALIDADE_G,TOTAL_EMPRESTIMOS_G,TOTAL_G:real;
total_icms, total_icms_g,total_fornecedores,total_fornecedores_g,total_transferencia,total_transferencia_g,total_iss,total_iss_g,total_comissao_int,total_comissao_int_g :real;
total_acordo_fornecedores,total_tarifas_bancarias,total_juros_boleto, total_energia ,total_agua,total_aluguel,total_combustivel,total_contador,	total_despesas_viagem, total_internet, total_lanches, total_material_escritorio:real;
total_material_laboratorio, total_material_limpeza, total_manutencao_veiculos, total_outros_servicos, total_marketing , total_consultoria, total_despesas_operacionais, total_reformas, total_manutencao_sites, total_correios, total_fretes ,total_telefone:real;
total_parcelamento_municipal, total_ipva, total_iptu , total_inss, total_fgts, total_taxas_incendio, total_alvara_funcionamento, total_parcelamento_estadual, total_parcelamento_inss, total_salarios_colaboradores,total_colaboradores_operacionais,total_DECIMO_TERCEIRO:real;
total_ferias,	total_recisoes, 	total_pro_labore, 	total_despesas_pessoal, 	total_sindicato, total_Serasa, total_despesa:real;
begin
  // 255, 325
  //SQL RECEITAS ARILMAQ

  QSearch.sql.Clear;
  QSearch.Sql.Add('SELECT * FROM FECHAMENTO_MENSAL WHERE DT_INICIAL = :DT_INICIAL AND DT_FINAL = :DT_FINAL ');
  Qsearch.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
  Qsearch.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;

  QSearch.Prepare;
  QSearch.Open;

  IF QSearch.IsEmpty Then
  Begin

    QReceitas.Sql.Clear;
    QReceitas.Sql.Add('SELECT EMPRESA, SUM(PECAS) PECAS , SUM(SERVICOS) SERVICOS, SUM(EQUIPAMENTO) EQUIPAMENTO ,SUM(COMISSAO) COMISSAO,');
    QReceitas.Sql.Add('SUM(CONTRATO) CONTRATO ,SUM(MENSALIDADE_RELOGIO) MENSALIDADE_RELOGIO,SUM(VENDA_SISTEMA) VENDA_SISTEMA,');
    QReceitas.Sql.Add('SUM(MENSALIDADE_EFICAZ) MENSALIDADE_EFICAZ,SUM(EMPRESTIMOS) EMPRESTIMOS,SUM(POSICAO_ESTOQUE) POSICAO_ESTOQUE');
    QReceitas.Sql.Add('FROM(');
    // PECAS/SERVICOS
    QReceitas.Sql.Add('SELECT EMPRESA_ID EMPRESA, SUM(VALOR_PECAS) PECAS ,SUM(VALOR_SERVICOS) SERVICOS ,0 EQUIPAMENTO, 0 COMISSAO, 0 CONTRATO,');
    QReceitas.Sql.Add('0 MENSALIDADE_RELOGIO, 0 VENDA_SISTEMA, 0 MENSALIDADE_EFICAZ,0 EMPRESTIMOS,0 POSICAO_ESTOQUE');
    QReceitas.Sql.Add('FROM ordem_servico');
    QReceitas.Sql.Add('WHERE DT_FECHAMENTO BETWEEN :DT_INICIAL AND :DT_FINAL ');
    QReceitas.Sql.Add('AND STATUS = ''FATURADO'' ');
    QReceitas.Sql.Add('GROUP BY EMPRESA_ID');
    QReceitas.Sql.Add('UNION ALL');
    //EQUIPAMENTOS  A AVISTA
    QReceitas.Sql.Add('SELECT TABELAS.EMPRESA, 0 PECAS , 0 SERVICOS , SUM(VALOR) EQUIPAMENTO, 0 COMISSAO, 0 CONTRATO,');
    QReceitas.Sql.Add('0 MENSALIDADE_RELOGIO, 0 VENDA_SISTEMA, 0 MENSALIDADE_EFICAZ,0 EMPRESTIMOS,0 POSICAO_ESTOQUE');
    QReceitas.Sql.Add('FROM TRANSACOES');
    QReceitas.Sql.Add('INNER JOIN TABELAS');
    QReceitas.Sql.Add('ON ((TRANSACOES.CONTA_ID = TABELAS.TABELA_ID) AND (TABELAS.TIPO_TABELA = ''4''))');
    QReceitas.Sql.Add('WHERE dt_ent_sai BETWEEN :DT_INICIAL AND :DT_FINAL ');
    QReceitas.Sql.Add('AND conta_id  in (850,851,852,853,854)');
    QReceitas.Sql.Add('AND TRANSACOES.TRANSACAO_ID NOT IN (SELECT TRANSACAO_ID FROM NOTAS_CANCELADAS)');
    QReceitas.Sql.Add('AND COND_PAGTO = ''A VISTA'' ');
    QReceitas.Sql.Add('GROUP BY TABELAS.empresa');
    QReceitas.Sql.Add('UNION ALL');
    //EQUIPAMENTOS A PRAZO
    QReceitas.Sql.Add('SELECT TABELAS.EMPRESA, 0 PECAS , 0 SERVICOS ,SUM(VALOR) EQUIPAMENTO, 0 COMISSAO, 0 CONTRATO,');
    QReceitas.Sql.Add('0 MENSALIDADE_RELOGIO, 0 VENDA_SISTEMA, 0 MENSALIDADE_EFICAZ,0 EMPRESTIMOS,0 POSICAO_ESTOQUE');
    QReceitas.Sql.Add('FROM TRANSACOES');
    QReceitas.Sql.Add('INNER JOIN TABELAS');
    QReceitas.Sql.Add('ON ((TRANSACOES.CONTA_ID = TABELAS.TABELA_ID) AND (TABELAS.TIPO_TABELA = ''4''))');
    QReceitas.Sql.Add('WHERE dt_ent_sai BETWEEN :DT_INICIAL AND :DT_FINAL ');
    QReceitas.Sql.Add('AND conta_id  in (855,856,857,858,859)');
    QReceitas.Sql.Add('AND TRANSACOES.TRANSACAO_ID NOT IN (SELECT TRANSACAO_ID FROM NOTAS_CANCELADAS)');
    QReceitas.Sql.Add('GROUP BY TABELAS.empresa');
    QReceitas.Sql.Add('UNION ALL');
    //CONTRATO DE SERVIÇOS
    QReceitas.Sql.Add('SELECT TABELAS.EMPRESA, 0 PECAS , 0 SERVICOS ,0 EQUIPAMENTO, 0 COMISSAO,  SUM(VALOR) CONTRATO,');
    QReceitas.Sql.Add('0 MENSALIDADE_RELOGIO, 0 VENDA_SISTEMA, 0 MENSALIDADE_EFICAZ,0 EMPRESTIMOS,0 POSICAO_ESTOQUE ');
    QReceitas.Sql.Add('FROM TRANSACOES');
    QReceitas.Sql.Add('INNER JOIN TABELAS');
    QReceitas.Sql.Add('ON ((TRANSACOES.CONTA_ID = TABELAS.TABELA_ID) AND (TABELAS.TIPO_TABELA = ''4''))');
    QReceitas.Sql.Add('WHERE dt_ent_sai BETWEEN :DT_INICIAL AND :DT_FINAL ');
    QReceitas.Sql.Add('AND conta_id  = 1144');
    QReceitas.Sql.Add('AND TRANSACOES.TRANSACAO_ID NOT IN (SELECT TRANSACAO_ID FROM NOTAS_CANCELADAS)');
    QReceitas.Sql.Add('GROUP BY TABELAS.empresa');
    QReceitas.Sql.Add('UNION ALL');
