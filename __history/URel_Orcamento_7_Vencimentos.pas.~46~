procedure TFrmRel_Orcamento_7_Vencimentos.StatusChange(Sender: TObject);
begin
  if Status.Text = 'Cancelados' then
  begin
    Label1.Visible := True;
    Dtmai.Visible  := True;
    Dtmen.Visible  := True;
    Dtmen.Date := StrToDate('01/' + Copy(DateToStr(IncMonth(date,-1)), 4, 7));
    Dtmai.Date := date;
  end
  else
  begin
    Label1.Visible := False;
    Dtmai.Visible  := False;
    Dtmen.Visible  := False;
  end;
end;

procedure TFrmRel_Orcamento_7_Vencimentos.TecnicoKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin
  if (Key = Vk_F7) and (Sender = Tecnico) then
    btnTecnicoClick(Self);

  if (Key = Vk_F7) and (Sender = Centro_Custo) then
    btnCentro_CustoClick(Self);

   if (Key = Vk_F7) and (Sender = Atendente) then
    btnAtendenteClick(Self);

   if (Key = Vk_F7) and (Sender = edt_cliente) then
    btnClienteClick(Self);

  if Key = Vk_Return then
    Perform(Wm_NextDlgctl, 0, 0);
end;

end.
