      ULTIMO_vendedor := QRel.FieldByName('VENDEDOR_ID').AsInteger;

      NOME_VENDEDOR   := QAtendente.FieldByName('NOME').AsString;



      if linha > 63 then
      begin
        RDprint1.novapagina;
        Pagina := Pagina + 1;
      end;


      QRel.Next;

       IF  (registro = totalregistro)Then
       Begin
        RDprint1.LinhaH(linha, 01, 180, 0,false);
        Inc(linha);
        RDprint1.Imp(linha, p3 + 3,'Vendedor: ' + NOME_VENDEDOR);
