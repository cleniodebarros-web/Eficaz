      //total_serv  := total_serv  + QRel.FieldByName('VALOR_SERVICOS').AsFloat;
     //total_pecas := total_pecas + QRel.FieldByName('VALOR_PECAS').AsFloat;
      total_geral    := total_geral + QRel.FieldByName('VALOR').AsFloat;
      total_vendedor := total_vendedor + QRel.FieldByName('VALOR').AsFloat;
      total_desconto :=   total_desconto + QRel.FieldByName('VR_DESCONTO').AsFloat ;
      total_acrescimo :=   total_acrescimo + QRel.FieldByName('VR_ACRESCIMO').AsFloat ;
      desconto_Vendedor := Desconto_Vendedor + QRel.FieldByName('VR_DESCONTO').AsFloat ;
      acrescimo_Vendedor := acrescimo_Vendedor + QRel.FieldByName('VR_acrescimo').AsFloat ;


      Inc(linha);


      if QRel.FieldByName('STATUS').AsString = 'FATURADO' Then
      Begin
      Total_Faturado := (Total_Faturado + 1);
      t_Faturado := T_Faturado + 1
      End;

      Total_Normal   := (Total_Normal + 1);
      t_normal := T_normal + 1;


      if  (atendente.value > 0) Then
      Begin
       if QRel.FieldByName('STATUS').AsString = 'FATURADO' Then
       T_Faturado :=  Total_Faturado +  T_Faturado;

       T_Normal   :=  Total_Normal   +  T_Normal;
