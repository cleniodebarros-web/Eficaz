procedure TFrmRel_Orcamento_7_Vencimentos.btnExecutaClick(Sender: TObject);
begin
  // 255, 325
  QRel.Sql.Clear;
  QRel.Sql.Add('SELECT ORCAMENTOS.*, FUNCIONARIOS.NOME, EMPRESAS.RAZAO');
  QRel.Sql.Add('FROM ORCAMENTOS');

  QRel.Sql.Add('INNER JOIN FUNCIONARIOS');
  QRel.Sql.Add('ON (ORCAMENTOS.VENDEDOR_ID = FUNCIONARIOS.FUNCIONARIO_ID)');
  QRel.Sql.Add('INNER JOIN EMPRESAS');
  QRel.Sql.Add('ON (ORCAMENTOS.EMPRESA_ID = EMPRESAS.EMPRESA_ID)');
  
  QRel.Sql.Add('WHERE');

  if Status.Text = 'Cancelados' then
  begin
    QRel.Sql.Add('ORCAMENTOS.STATUS = ''CANCELADO''');
    QRel.Sql.Add('AND ORCAMENTOS.DT_ORCAMENTO BETWEEN :DT_INI AND :DT_FIM');
    QRel.ParamByName('DT_INI').AsDateTime := Dtmen.Date;
    QRel.ParamByName('DT_FIM').AsDateTime := Dtmai.Date;
  end
  else
  begin
    QRel.Sql.Add('ORCAMENTOS.STATUS = ''NORMAL''');
    QRel.Sql.Add('AND ORCAMENTOS.DT_ORCAMENTO <= ''TODAY''::DATE');
    if Status.Text = 'Menos de 7 dias' then
    begin
      QRel.Sql.Add('-8');
    end
    else
    if Status.Text = 'Menos de 4 dias' then
    begin
      QRel.Sql.Add('-11');
    end
    else
    if Status.Text = 'Menos de 1 dia' then
    begin
      QRel.Sql.Add('-14');
    end
    else
      QRel.Sql.Add('-15');
  end;

  if Atendente.Value > 0 then
  begin
    QRel.Sql.Add('AND (ORCAMENTOS.VENDEDOR_ID = :ATENDENTE)');
    QRel.ParamByName('ATENDENTE').AsInteger := StrToInt(Atendente.Text);
  end
  Else
    QRel.Sql.Add('AND (ORCAMENTOS.VENDEDOR_ID > 1 )');

  QRel.Sql.Add('AND ((ORCAMENTOS.TRANSACAO_ID = 0) or (ORCAMENTOS.TRANSACAO_ID IS NULL))');
  if Empresa.Value > 0 then
  begin
    QRel.Sql.Add('AND (ORCAMENTOS.EMPRESA_ID =:EMPRESA_ID)');
    QRel.ParamByName('EMPRESA_ID').AsInteger := StrToInt(Empresa.Text);
  end;

  if edt_cliente.Value > 0 then
  begin
    QRel.Sql.Add('AND (ORCAMENTOS.CLIENTE_ID =:CLIENTE_ID)');
    QRel.ParamByName('CLIENTE_ID').AsInteger := StrToInt(edt_cliente.Text);
  end;


    QRel.Sql.Add('ORDER BY FUNCIONARIOS.NOME, ORCAMENTOS.DT_ORCAMENTO, ORCAMENTOS.ORCAMENTO_ID, ORCAMENTOS.TRANSACAO_ID');

  QRel.Prepare;
  QRel.Open;

  if QRel.IsEmpty then
    Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
  else
  begin

    RDprint1.TamanhoQteColunas:=180;
    RDprint1.OpcoesPreview.Preview     := True;
    RDprint1.MostrarProgresso          := True;
    RDprint1.Acentuacao                := SemAcento;
    RDprint1.TamanhoQteLinhas          := 1;
    RDprint1.Abrir;

    if linha > 66 then
    begin
      RDprint1.novapagina;
      Pagina := Pagina + 1;
    end;

    Pagina:= 1;
    total_geral := 0;
    ULTIMO_VENDEDOR := 0;
    T_Faturado :=  0;
    T_Normal   :=  0;
    total_faturado := 0;
    Total_normal := 0;
    TotalRegistro := 0 ;
    registro := 0;
    Desconto_Vendedor  := 0;
    Acrescimo_Vendedor := 0;

    QRel.First;
    while not QRel.Eof do
    Begin
       TotalRegistro := totalRegistro + 1;
       QRel.Next;
    End;

    QRel.First;
    while not QRel.Eof do
    Begin

      inc(registro);

      QAtendente.SQL.Clear;
      QAtendente.SQL.Add('SELECT FUNCIONARIO_ID, NOME FROM FUNCIONARIOS WHERE FUNCIONARIO_ID = :FUNCIONARIO_ID');
      QAtendente.ParamByName('FUNCIONARIO_ID').AsInteger :=  QRel.FieldByName('VENDEDOR_ID').AsInteger;
