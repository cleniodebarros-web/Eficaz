            Writeln(F, '161104000600010' + Copy(QEstoque.FieldByName('DESCRICAO').AsString, 1, 20) + #13);
            Writeln(F, '161104000020210' + 'R$  ' + FormatFloat('#,##0.00', QEstoque.FieldByName('PRECO_VAREJO').AsFloat) + #13);
            Writeln(F, 'Q' + StrZero(IntToStr(Quantidade.Value), 4, 0));
