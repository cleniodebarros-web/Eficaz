        end;
      end;

      Codigo_Inicial.SetFocus;
    end;

    if Op_Sel = '4' then
    begin
      QEstoque.Sql.Clear;
      QEstoque.Sql.Add('SELECT * FROM PRODUTOS');
      QEstoque.Sql.Add('WHERE');
      QEstoque.Sql.Add('(DT_PRECO >= :DT_PRECO)');

      QEstoque.ParamByName('DT_PRECO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

      QEstoque.Prepare;
      QEstoque.Open;

      QEstoque.First;
      while not QEstoque.Eof do
      begin
        if Impr.Text = 'Datamax' then
        begin
          if LeIni(Arq_Ini, 'Sistema', 'Datamax') = 'COM1' then
