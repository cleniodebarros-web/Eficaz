          AssignFile(F, 'COM2');

        Rewrite(F);
        try
          Writeln(F, #2 + 'L' + #13);
          Writeln(F, 'D11' + #13);
          Writeln(F, '121101200600008' + Copy(FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString, 1, 17) + #13);
          Writeln(F, '121101200600143' + Copy(FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString, 1, 17) + #13);
          Writeln(F, '121101200600272' + Copy(FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString, 1, 17) + #13);
          Writeln(F, '111101200520008' + Copy(QEstoque.FieldByName('DESCRICAO').AsString, 1, 20) + #13);
          Writeln(F, '111101200520143' + Copy(QEstoque.FieldByName('DESCRICAO').AsString, 1, 20) + #13);
          Writeln(F, '111101200520272' + Copy(QEstoque.FieldByName('DESCRICAO').AsString, 1, 20) + #13);
          Writeln(F, '1F6204000020008' + QEstoque.FieldByName('COD_BARRA').AsString + #13);
          Writeln(F, '1F6204000020143' + QEstoque.FieldByName('COD_BARRA').AsString + #13);
          Writeln(F, '1F6204000020272' + QEstoque.FieldByName('COD_BARRA').AsString + #13);
          Writeln(F, 'Q' + StrZero(IntToStr(Quantidade.Value), 4, 0) + #13);
          Writeln(F, 'E' + #13);
        finally
          CloseFile(F);
        end;
      end;

      if Impr.Text = 'Zebra TLP2844' then
      begin
        if LeIni(Arq_Ini, 'Sistema', 'Path Impressora') <> '' then
          AssignFile(F, LeIni(Arq_Ini, 'Sistema', 'Path Impressora'))
