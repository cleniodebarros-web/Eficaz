procedure TFrmEtiquetas_Validade.Seleciona_Produtos;
begin
  QEstoque.Sql.Clear;
  QEstoque.Sql.Add('SELECT * FROM PRODUTOS');
  QEstoque.Sql.Add('WHERE');

  if (Codigo_Inicial.Value > 0) and (Codigo_Final.Value > 0) then
  begin
    QEstoque.Sql.Add('(PRODUTO_ID BETWEEN :CODIGO_INICIAL AND :CODIGO_FINAL)');

    QEstoque.ParamByName('CODIGO_INICIAL').AsInteger := StrToInt(Codigo_Inicial.Text);
    QEstoque.ParamByName('CODIGO_FINAL').AsInteger   := StrToInt(Codigo_Final.Text);
  end
  else
  begin
    QEstoque.Sql.Add('((DT_PRECO BETWEEN :DT_INICIAL AND :DT_FINAL) OR (DT_ATUALIZACAO BETWEEN :DT_INICIAL AND :DT_FINAL))');

    QEstoque.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
    QEstoque.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
  end;

  QEstoque.Sql.Add('AND (STATUS = :STATUS)');

  QEstoque.ParamByName('STATUS').AsString := 'A';

  QEstoque.Prepare;
  QEstoque.Open;
end;

procedure TFrmEtiquetas_Validade.btnExecutaClick(Sender: TObject);
var
F: TextFile;
C, Q, W, X: Integer;
D1, D2, D3: String;
begin
  try
    if Op_Sel = '1' then
    begin
      C := 0;

      Seleciona_Produtos;

      QEstoque.First;
      while not QEstoque.Eof do
      begin
        if Quantidade.Value > 0 then
          Q := Quantidade.Value
        else
          Q := QEstoque.FieldByName('ULT_QUANTIDADE').AsInteger;

        for W := 1 to Q do
        begin
          D1 := D1 + Repl(QEstoque.FieldByName('COD_BARRA').AsString, Tam_Etiq.Value);
          D2 := D2 + Repl(Copy(QEstoque.FieldByName('DESCRICAO').AsString, 1, 17), Tam_Etiq.Value);
          D3 := D3 + Repl(FormatFloat('#,##0.00', QEstoque.FieldByName('PRECO_VAREJO').AsFloat), Tam_Etiq.Value);

          Inc(C);

          if C >= Colunas.Value then
          begin
            try
              AssignFile(F, 'LPT1');
              Rewrite(F);

              if Tipo_Font.Checked then
                WriteLn(F, #27#15 + D1)
              else
                WriteLn(F, #27#18 + D1);

              WriteLn(F, D2);
              WriteLn(F, D3);
              WriteLn(F, #27#18);

              if Linhas.Value > 0 then
              begin
                for X := 1 to Linhas.Value do
                  WriteLn(F, '');
              end;

              CloseFile(F);
              Sleep(StrToInt(Tempo.Text));
            except
              CloseFile(F);
            end;

            C  := 0;
            D1 := '';
            D2 := '';
            D3 := '';
          end;
        end;

        Application.ProcessMessages;
        QEstoque.Next;
      end;

      if (C < Colunas.Value) and (C > 0) then
      begin
        try
          AssignFile(F, 'LPT1');
          Rewrite(F);

          if Tipo_Font.Checked then
            WriteLn(F, #27#15 + D1)
          else
            WriteLn(F, #27#18 + D1);

          WriteLn(F, D2);
          WriteLn(F, D3);
          WriteLn(F, #27#18);

          if Linhas.Value > 0 then
          begin
            for X := 1 to Linhas.Value do
              WriteLn(F, '');
          end;

          CloseFile(F);

          Sleep(StrToInt(Tempo.Text));
        except
          CloseFile(F);
        end;
      end;
    end;

    if Op_Sel = '2' then
