    QRel.First;

    while not QRel.Eof do
    begin
    Sugestao := 0;

    Table_Temp.Append;
    Table_Temp.FieldByName('PRODUTO_ID').AsInteger    := QRel.FieldByName('PRODUTO_ID').AsInteger;
    Table_Temp.FieldByName('COD_BARRA').AsString      := QRel.FieldByName('COD_BARRA').AsString;;
    Table_Temp.FieldByName('DESCRICAO').AsString      := QRel.FieldByName('DESCRICAO').AsString;
    Table_Temp.FieldByName('QUANTIDADE').AsFloat      := QRel.FieldByName('QUANTIDADE').AsFloat;
    Table_Temp.FieldByName('QUANT_MINIMA').AsFloat    := QRel.FieldByName('QUANT_MINIMA').AsFloat;
    Table_Temp.FieldByName('QUANT_EMBALAGEM').AsFloat := QRel.FieldByName('QTD_EMBALAGEM').AsFloat;
    Table_Temp.FieldByName('CUSTO_COMPRA').AsFloat    := QRel.FieldByName('CUSTO_COMPRA').AsFloat;
    Table_Temp.FieldByName('DT_COMPRA').AsDateTime    := QRel.FieldByName('DT_COMPRA').AsFloat;
    Table_Temp.FieldByName('DT_MOVIMENTO').AsDateTime := QRel.FieldByName('DT_MOVIMENTO').AsFloat;


    IBQuery.Sql.Clear;
    IBQuery.Sql.Add('SELECT TRANSITENS.QUANTIDADE, TRANSACOES.DT_TRANS, TRANSACOES.CONDUTA');
    IBQuery.Sql.Add('FROM TRANSITENS');
    IBQuery.Sql.Add('INNER JOIN TRANSACOES');
    IBQuery.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
    IBQuery.Sql.Add('WHERE');
    IBQuery.Sql.Add('(TRANSITENS.PRODUTO_ID = :PRODUTO_ID)');
    IBQuery.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
    IBQuery.Sql.Add('AND ((TRANSACOES.CONDUTA = :CD_VENDA) OR (TRANSACOES.CONDUTA = :CD_COMPRA) OR (TRANSACOES.CONDUTA = :CD_CONSUMO))');
    IBQuery.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
    IBQuery.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB)');
    IBQuery.Sql.Add('AND (TRANSACOES.DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL)');

    IBQuery.ParamByName('PRODUTO_ID').AsInteger  := QRel.FieldByName('PRODUTO_ID').AsInteger;
    IBQuery.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    IBQuery.ParamByName('CD_VENDA').AsString     := '01';
    IBQuery.ParamByName('CD_COMPRA').AsString    := '02';
    IBQuery.ParamByName('CD_CONSUMO').AsString   := '17';
    IBQuery.ParamByName('DEPTO').AsString        := '07';
    IBQuery.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;
    IBQuery.ParamByName('DT_INICIAL').AsDateTime := (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime - 180);
    IBQuery.ParamByName('DT_FINAL').AsDateTime   := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

    IBQuery.Sql.Add('ORDER BY TRANSACOES.DT_TRANS');

    IBQuery.Prepare;
    IBQuery.Open;
    IBQuery.First;

      while not IBQuery.Eof do
      Begin

        AA := StrToInt(Copy(FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsString, 4, 2));
        BB := StrToInt(Copy(FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsString, 7, 4));

        for X := 6 downto 1 do
        begin
          MES[X]              := StrZero(IntToStr(AA), 2, 0) + '/' + StrZero(IntToStr(BB), 4, 0);
          S1[X]               := 0;
          S2[X]               := 0;
          S3[X]               := 0;
          S4[X]               := 0;
          CP[X]               := 0;
          AA                  := AA - 1;

          if AA = 0 then
          begin
            AA := 12;
            BB := BB - 1;
          end;
        end;

        DIA := StrToInt(Copy(IBQuery.FieldByName('DT_TRANS').AsString, 1, 2));

        if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[1] then
        begin
          if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
          begin
            if DIA <= 7 then
              S1[1] := S1[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 7) and (DIA <= 14) then
              S2[1] := S2[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 14) and (DIA <= 21) then
              S3[1] := S3[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if DIA > 21 then
              S4[1] := S4[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if IBQuery.FieldByName('CONDUTA').AsString = '02' then
            CP[1] := CP[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
        end;

        if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[2] then
        begin
          if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
          begin
            if DIA <= 7 then
              S1[2] := S1[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 7) and (DIA <= 14) then
              S2[2] := S2[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 14) and (DIA <= 21) then
               S3[2] := S3[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if DIA > 21 then
              S4[2] := S4[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;
          if IBQuery.FieldByName('CONDUTA').AsString = '02' then
            CP[2] := CP[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
        end;

        if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[3] then
        begin
          if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
          begin
            if DIA <= 7 then
              S1[3] := S1[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 7) and (DIA <= 14) then
              S2[3] := S2[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 14) and (DIA <= 21) then
              S3[3] := S3[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if DIA > 21 then
              S4[3] := S4[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if IBQuery.FieldByName('CONDUTA').AsString = '02' then
            CP[3] := CP[3] + QRel.FieldByName('QUANTIDADE').AsFloat;
        end;

        if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[4] then
        begin
          if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
          begin
            if DIA <= 7 then
              S1[4] := S1[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 7) and (DIA <= 14) then
              S2[4] := S2[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 14) and (DIA <= 21) then
              S3[4] := S3[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if DIA > 21 then
              S4[4] := S4[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if IBQuery.FieldByName('CONDUTA').AsString = '02' then
            CP[4] := CP[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
        end;

        if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[5] then
        begin
          if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
          begin
            if DIA <= 7 then
              S1[5] := S1[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 7) and (DIA <= 14) then
              S2[5] := S2[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 14) and (DIA <= 21) then
              S3[5] := S3[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if DIA > 21 then
              S4[5] := S4[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if IBQuery.FieldByName('CONDUTA').AsString = '02' then
            CP[5] := CP[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
        end;

        if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[6] then
        begin
          if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
          begin
            if DIA <= 7 then
              S1[6] := S1[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 7) and (DIA <= 14) then
              S2[6] := S2[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if (DIA > 14) and (DIA <= 21) then
              S3[6] := S3[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat
            else if DIA > 21 then
              S4[6] := S4[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if IBQuery.FieldByName('CONDUTA').AsString = '02' then
            CP[6] := CP[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
        end;

         Sugestao := Sugestao + ((S1[4] + S2[4] + S3[4] + S4[4] + S1[5] + S2[5] + S3[5] + S4[5] +
                S1[6] + S2[6] + S3[6] + S4[6]) / 90) * 30;

       Application.ProcessMessages;
       IBQuery.Next
      End;

      if Sugestao > QRel.FieldByName('QUANTIDADE').AsFloat  then
             Table_Temp.FieldByName('SUGESTAO_COMPRA').AsFloat   :=  Round(Sugestao - QRel.FieldByName('QUANTIDADE').AsFloat);


        Table_Temp.Post;

        Application.ProcessMessages;
        QRel.Next;

    end;

    if cbOdenarPor.Text = 'Descriçăo' then
    Begin
     Table_Temp.IndexFieldNames := 'DESCRICAO';

     // Table_Temp.Filter := 'ORDER BY DESCRICAO';
     // Table_Temp.Filtered:= True;
    End;

    if cbOdenarPor.Text = 'Data' then
    Begin
      Table_Temp.IndexFieldNames := 'DT_COMPRA';
      //Table_Temp.Filter := 'ORDER BY DATA';
      //Table_Temp.Filtered:= True;
    End;



    if  Table_Temp.IsEmpty then
      Application.MessageBox('Năo há dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
    else
      Begin
          if CheckBox1.Checked = True then
          Begin
           RDprint1.Impressora         := HP;
           RDprint1.FonteTamanhoPadrao := S10cpp;

           //RDprint1.Orientacao         := poLandscape;
          End;

          RDprint1.TamanhoQteColunas         := 130;
          RDprint1.OpcoesPreview.Preview     := True;
          RDprint1.MostrarProgresso          := True;
          RDprint1.Acentuacao                := SemAcento;
          RDprint1.TamanhoQteLinhas          := 1;
          RDprint1.Abrir;

        if linha > 66  then
          Begin
           RDprint1.Novapagina;
           Pagina := Pagina + 1;
          End;

        Table_Temp.First;

        while not Table_Temp.Eof do
        Begin
          RDprint1.ImpD(linha, C1+6, Table_Temp.FieldByName('PRODUTO_ID').AsString,[]);
          RDprint1.Imp(linha, C2, Table_Temp.FieldByName('COD_BARRA').AsString);
          RDprint1.Imp(linha, C3, Copy(Table_Temp.FieldByName('DESCRICAO').AsString, 1,50));
          RDprint1.ImpVal(linha,C4,'###,##0.00', Table_Temp.FieldByName('QUANTIDADE').AsFloat,[]);
          RDprint1.ImpVal(linha,C5,'###,##0.00', Table_Temp.FieldByName('QUANT_MINIMA').AsFloat,[]);
          RDprint1.ImpVal(linha,C6,'###,##0.00', Table_Temp.FieldByName('CUSTO_COMPRA').AsFloat,[]);
          RDprint1.ImpVal(linha,C7,'###,##0.00', Table_Temp.FieldByName('SUGESTAO_COMPRA').AsFloat,[]);
          RDprint1.ImpVal(linha,C9,'###,##0.00', Table_Temp.FieldByName('QUANT_EMBALAGEM').AsFloat,[]);


          if Chk_UltimaVenda.Checked then
          RDprint1.Imp(linha, C8, Table_Temp.FieldByName('DT_MOVIMENTO').AsString)
          Else
          RDprint1.Imp(linha, C8, Table_Temp.FieldByName('DT_COMPRA').AsString);

         if linha > 63  then
          Begin
           RDprint1.Novapagina;
           Pagina := Pagina + 1;
          End;
          Inc(linha);
          Table_Temp.Next;
        End;

        Application.ProcessMessages;
        RDprint1.TamanhoQteLinhas:= 66;
        RDprint1.Fechar;
      End;

  finally
      Table_Temp.Close;

    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;

  }

end;

