{$R *.dfm}

procedure TFrmItensAbaixoDoMinimoRDP.relatorio_quickrep();
var
  X, AA, BB, I, J, DIA: Integer;
  MES: array[1..6] of String;
  S1, S2, S3, S4, CP: array[1..6] of Real;
  Sugestao: Real;

begin

  btnExecuta.Enabled := False;
  btnRetorna.Enabled := False;

  QRel.SQL.Clear;

  if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
  begin
    QRel.Sql.Add('SELECT PRODUTO_ID, COD_BARRA, DESCRICAO, QUANTIDADE_C AS QUANTIDADE, QUANT_MINIMA, CUSTO_COMPRA, DT_COMPRA,DT_MOVIMENTO,QTD_EMBALAGEM,FORNECEDOR_ID');
    QRel.Sql.Add('FROM PRODUTOS');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(EMPRESA_ID = :EMPRESA_ID)');

    if cb_tipo.ItemIndex = 0 then
       QRel.Sql.Add('AND (QUANTIDADE_C < QUANT_MINIMA)');

    if cb_tipo.ItemIndex = 1 then
       QRel.Sql.Add('AND (QUANTIDADE_C = QUANT_MINIMA)');

    if cb_tipo.ItemIndex = 2 then
       QRel.Sql.Add('AND (QUANTIDADE_C > QUANT_MINIMA)');



    if chk_mostrar_todos.Checked = False then
    begin
      QRel.Sql.Add('AND DT_COMPRA BETWEEN :DT_INICIO AND :DT_FINAL');
      QRel.ParamByName('DT_INICIO').AsDate := StrToDate(Dtmen.Text);
      QRel.ParamByName('DT_FINAL').AsDate  := StrToDate(Dtmai.Text);
    end;


  end
  else
  begin
    QRel.Sql.Add('SELECT PRODUTO_ID, COD_BARRA, DESCRICAO, QUANTIDADE_G AS QUANTIDADE, QUANT_MINIMA, CUSTO_COMPRA, DT_COMPRA,DT_MOVIMENTO,QTD_EMBALAGEM,FORNECEDOR_ID');
    QRel.Sql.Add('FROM PRODUTOS');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(EMPRESA_ID = :EMPRESA_ID)');
    QRel.Sql.Add('AND (QUANTIDADE_G < QUANT_MINIMA)');

    if chk_mostrar_todos.Checked = False then
    begin
      QRel.Sql.Add('AND DT_COMPRA BETWEEN :DT_INICIO AND :DT_FINAL');
      QRel.ParamByName('DT_INICIO').AsDate := StrToDate(Dtmen.Text);
      QRel.ParamByName('DT_FINAL').AsDate  := StrToDate(Dtmai.Text);
    end;
  end;

    QRel.Sql.Add('AND (STATUS = :STATUS)');

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
    begin
      QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');
      QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
    end;


    if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Fornecedor')) > 0 then
    begin
      QRel.Sql.Add('AND (FORNECEDOR_ID = :FORNECEDOR_ID)');
      QRel.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Fornecedor'));
    end;

    if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo')) > 0 then
    begin
      QRel.Sql.Add('AND (GRUPO_ID = :GRUPO_ID)');
      QRel.ParamByName('GRUPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo'));
    end;

    if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo')) > 0 then
    begin
      QRel.Sql.Add('AND (SUBTIPO_ID = :SUBTIPO_ID)');
      QRel.ParamByName('SUBTIPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo'));
    end;

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) = 0 then
    begin
      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo')) > 0 then
      begin
        QRel.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');
        QRel.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo'));
      end;
    end;

    if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Inicial')) > 0 then
    begin
      QRel.Sql.Add('AND (PRODUTO_ID BETWEEN :PRODUTO_INICIAL AND :PRODUTO_FINAL)');
      QRel.ParamByName('PRODUTO_INICIAL').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Inicial'));
      QRel.ParamByName('PRODUTO_FINAL').AsInteger   := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Final'));
    end;


  if cbOdenarPor.Text = 'Descriçăo' then
     QRel.Sql.Add('ORDER BY DESCRICAO');

  if cbOdenarPor.Text = 'Data' then
     QRel.Sql.Add('ORDER BY DT_COMPRA');


  QRel.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QRel.ParamByName('STATUS').AsString      := 'A';

  QRel.Prepare;
  QRel.Open;
  QRel.First;

  QRLabel21.Caption := 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text;

  if QRel.IsEmpty then
    Application.MessageBox('Năo há dados para serem impressos', PChar(Msg_Title), mb_IconInformation)
  else
    begin
      //Limpo a tabela mostrada ao cliente
      if CliDataSet_rel_itens_abaixo_min.Active then
        CliDataSet_rel_itens_abaixo_min.EmptyDataSet;

      while not QRel.Eof do
      begin

        CliDataSet_rel_itens_abaixo_min.Append;
        CliDataSet_rel_itens_abaixo_min.FieldByName('PRODUTO_ID').AsString    := QRel.FieldByName('PRODUTO_ID').AsString;
        CliDataSet_rel_itens_abaixo_min.FieldByName('COD_BARRA').AsString     := QRel.FieldByName('COD_BARRA').AsString;
        CliDataSet_rel_itens_abaixo_min.FieldByName('DESCRICAO').AsString     := QRel.FieldByName('DESCRICAO').AsString;
        CliDataSet_rel_itens_abaixo_min.FieldByName('QUANTIDADE').AsString    := formatfloat('#0.00', QRel.FieldByName('QUANTIDADE').AsFloat);
        CliDataSet_rel_itens_abaixo_min.FieldByName('QTD_EMBALAGEM').AsString := formatfloat('#0.00', QRel.FieldByName('QTD_EMBALAGEM').AsFloat);
        CliDataSet_rel_itens_abaixo_min.FieldByName('QUANT_MINIMA').AsString  := formatfloat('#0.00', QRel.FieldByName('QUANT_MINIMA').AsFloat);
        CliDataSet_rel_itens_abaixo_min.FieldByName('CUSTO_COMPRA').AsString  := formatfloat('#0.00', QRel.FieldByName('CUSTO_COMPRA').AsFloat);
        CliDataSet_rel_itens_abaixo_min.FieldByName('FORNECEDOR').AsInteger   := QRel.FieldByName('FORNECEDOR_ID').AsInteger;
        if Chk_UltimaVenda.Checked then
          begin
            CliDataSet_rel_itens_abaixo_min.FieldByName('DT_COMPRA').AsString := QRel.FieldByName('DT_MOVIMENTO').AsString;
            QRLabel5.Caption := 'Últ.Vda.';
          end
        else
          begin
            CliDataSet_rel_itens_abaixo_min.FieldByName('DT_COMPRA').AsString := QRel.FieldByName('DT_COMPRA').AsString;
            QRLabel5.Caption := 'Últ.Cpr.';
          end;

       if chk_sugestao.Checked Then
       Begin
        //Calculo da quantidade sugestăo de compra.
        Sugestao := 0;
        IBQuery.Sql.Clear;
        IBQuery.Sql.Add('SELECT TRANSITENS.QUANTIDADE, TRANSACOES.DT_TRANS, TRANSACOES.CONDUTA');
        IBQuery.Sql.Add('FROM TRANSITENS');
        IBQuery.Sql.Add('INNER JOIN TRANSACOES');
        IBQuery.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
        IBQuery.Sql.Add('WHERE');
        IBQuery.Sql.Add('(TRANSITENS.PRODUTO_ID = :PRODUTO_ID)');
        IBQuery.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
        IBQuery.Sql.Add('AND ((TRANSACOES.CONDUTA = :CD_VENDA) OR (TRANSACOES.CONDUTA = :CD_COMPRA) OR (TRANSACOES.CONDUTA = :CD_CONSUMO))');
        IBQuery.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
        IBQuery.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB)');
        IBQuery.Sql.Add('AND (TRANSACOES.DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL)');

        IBQuery.ParamByName('PRODUTO_ID').AsInteger  := QRel.FieldByName('PRODUTO_ID').AsInteger;
        IBQuery.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
        IBQuery.ParamByName('CD_VENDA').AsString     := '01';
        IBQuery.ParamByName('CD_COMPRA').AsString    := '02';
        IBQuery.ParamByName('CD_CONSUMO').AsString   := '17';
        IBQuery.ParamByName('DEPTO').AsString        := '07';
        IBQuery.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;
        IBQuery.ParamByName('DT_INICIAL').AsDateTime := (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime - 90);
        IBQuery.ParamByName('DT_FINAL').AsDateTime   := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;

        IBQuery.Sql.Add('ORDER BY TRANSACOES.DT_TRANS');

        IBQuery.Prepare;
        IBQuery.Open;
        IBQuery.First;

        while not IBQuery.Eof do
        Begin

          AA := StrToInt(Copy(FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsString, 4, 2));
          BB := StrToInt(Copy(FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsString, 7, 4));

          for X := 6 downto 1 do
          begin
            MES[X]              := StrZero(IntToStr(AA), 2, 0) + '/' + StrZero(IntToStr(BB), 4, 0);
            S1[X]               := 0;
            S2[X]               := 0;
            S3[X]               := 0;
            S4[X]               := 0;
            CP[X]               := 0;
            AA                  := AA - 1;

            if AA = 0 then
            begin
              AA := 12;
              BB := BB - 1;
            end;
          end;

          DIA := StrToInt(Copy(IBQuery.FieldByName('DT_TRANS').AsString, 1, 2));

          if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[1] then
          begin
            if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
            begin
              if DIA <= 7 then
                S1[1] := S1[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 7) and (DIA <= 14) then
                S2[1] := S2[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 14) and (DIA <= 21) then
                S3[1] := S3[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if DIA > 21 then
                S4[1] := S4[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
            end;

            if IBQuery.FieldByName('CONDUTA').AsString = '02' then
              CP[1] := CP[1] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[2] then
          begin
            if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
            begin
              if DIA <= 7 then
                S1[2] := S1[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 7) and (DIA <= 14) then
                S2[2] := S2[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 14) and (DIA <= 21) then
                 S3[2] := S3[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if DIA > 21 then
                S4[2] := S4[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
            end;
            if IBQuery.FieldByName('CONDUTA').AsString = '02' then
              CP[2] := CP[2] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[3] then
          begin
            if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
            begin
              if DIA <= 7 then
                S1[3] := S1[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 7) and (DIA <= 14) then
                S2[3] := S2[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 14) and (DIA <= 21) then
                S3[3] := S3[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if DIA > 21 then
                S4[3] := S4[3] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
            end;

            if IBQuery.FieldByName('CONDUTA').AsString = '02' then
              CP[3] := CP[3] + QRel.FieldByName('QUANTIDADE').AsFloat;
          end;

          if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[4] then
          begin
            if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
            begin
              if DIA <= 7 then
                S1[4] := S1[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 7) and (DIA <= 14) then
                S2[4] := S2[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 14) and (DIA <= 21) then
                S3[4] := S3[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if DIA > 21 then
                S4[4] := S4[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
            end;

            if IBQuery.FieldByName('CONDUTA').AsString = '02' then
              CP[4] := CP[4] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[5] then
          begin
            if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
            begin
              if DIA <= 7 then
                S1[5] := S1[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 7) and (DIA <= 14) then
                S2[5] := S2[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 14) and (DIA <= 21) then
                S3[5] := S3[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if DIA > 21 then
                S4[5] := S4[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
            end;

            if IBQuery.FieldByName('CONDUTA').AsString = '02' then
              CP[5] := CP[5] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

          if Copy(IBQuery.FieldByName('DT_TRANS').AsString, 4, 7) = MES[6] then
          begin
            if (IBQuery.FieldByName('CONDUTA').AsString = '01') or (IBQuery.FieldByName('CONDUTA').AsString = '17') then
            begin
              if DIA <= 7 then
                S1[6] := S1[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 7) and (DIA <= 14) then
                S2[6] := S2[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if (DIA > 14) and (DIA <= 21) then
                S3[6] := S3[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat
              else if DIA > 21 then
                S4[6] := S4[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
            end;

            if IBQuery.FieldByName('CONDUTA').AsString = '02' then
              CP[6] := CP[6] + IBQuery.FieldByName('QUANTIDADE').AsFloat;
          end;

           Sugestao := Sugestao + ((S1[4] + S2[4] + S3[4] + S4[4] + S1[5] + S2[5] + S3[5] + S4[5] +
                  S1[6] + S2[6] + S3[6] + S4[6]) / 90) * 30;

         Application.ProcessMessages;
         IBQuery.Next
        End;

        if Sugestao > QRel.FieldByName('QUANTIDADE').AsFloat  then
          CliDataSet_rel_itens_abaixo_min.FieldByName('SUG_COMPRA').AsString := formatfloat('#0.00', Round(Sugestao - QRel.FieldByName('QUANTIDADE').AsFloat))
        else
          CliDataSet_rel_itens_abaixo_min.FieldByName('SUG_COMPRA').AsString := '0,00';
        END;

        CliDataSet_rel_itens_abaixo_min.Post;

        QRel.Next;
      end;

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo') = '0' then
        QRLabel20.Caption := 'Grupo: TODOS'
      else
        QRLabel20.Caption := 'Grupo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo')), '7');

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo') = '0' then
        QRLabel6.Caption := 'Sub-Tipo: TODOS'
      else
        QRLabel6.Caption := 'Sub-Tipo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo')), '5');

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo') = '0' then
        QRLabel28.Caption := 'Sub-Tipo: TODOS'
      else
        QRLabel28.Caption := 'Sub-Tipo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo')), '5');

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo') = '0' then
        QRLabel29.Caption := 'Sub-Tipo: TODOS'
      else
        QRLabel29.Caption := 'Sub-Tipo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo')), '5');


      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo') = '0' then
        QRLabel22.Caption := 'Localizaçăo: TODAS'
      else
        QRLabel22.Caption := 'Localizaçăo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo')), '8');

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo') = '0' then
