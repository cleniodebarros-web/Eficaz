procedure TFrmNFe.FormShow(Sender: TObject);
var
IniFile: String;
Ini: TIniFile;
StreamMemo: TMemoryStream;
Temp: TComponent;
i:Integer;
DESC_FUNRURAL,DESC_COOPERATIVA, Bruto, Liquido :Real;
Complemento_pr:Boolean;
begin
 Nota_referenciada := False;

  QTransacao.Sql.Clear;
  QTransacao.Sql.Add('SELECT * FROM TRANSACOES');
  QTransacao.Sql.Add('WHERE');
  QTransacao.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

  QTransacao.ParamByName('TRANSACAO_ID').AsInteger := ID;

  QTransacao.Prepare;
  QTransacao.Open;

  if QTransacao.FieldByName('SAIDA_ID').AsInteger <> 0 then
  Begin
  QOrigem.Sql.Clear;
  QOrigem.Sql.Add('SELECT * FROM TRANSACOES');
  QOrigem.Sql.Add('WHERE');
  QOrigem.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

  QOrigem.ParamByName('TRANSACAO_ID').AsInteger := QTransacao.FieldByName('SAIDA_ID').AsInteger;

  QOrigem.Prepare;
  QOrigem.Open;
  End;

  if QTransacao.FieldByName('ENTRADA_ID').AsInteger <> 0 then
  Begin
  QOrigem.Sql.Clear;
  QOrigem.Sql.Add('SELECT * FROM TRANSACOES');
  QOrigem.Sql.Add('WHERE');
  QOrigem.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

  QOrigem.ParamByName('TRANSACAO_ID').AsInteger := QTransacao.FieldByName('ENTRADA_ID').AsInteger;

  QOrigem.Prepare;
  QOrigem.Open;
  End;

  { if QTransacao.FieldByName('SUB_SERIE').AsString ='C'  then
   Begin
     Finalidade_emissao.Items.Clear;
     Finalidade_Emissao.Items.Add('2-NFE COMPLEMENTAR');
     Finalidade_Emissao.Items.Add('3-NFE DE AJUSTE');
   End;
  }

  QParceiro.Sql.Clear;
  QParceiro.Sql.Add('SELECT * FROM CLIENTES');
  QParceiro.Sql.Add('WHERE');
  QParceiro.Sql.Add('(CLIENTE_ID = :CLIENTE_ID)');

  QParceiro.ParamByName('CLIENTE_ID').AsInteger := QTransacao.FieldByName('CLIENTE_ID').AsInteger;

  QParceiro.Prepare;
  QParceiro.Open;


  if (not QOrigem.IsEmpty) then
  Begin
  Finalidade_Emissao.Clear;
  Finalidade_Emissao.Items.Add('1-NFE NORMAL');
  Finalidade_Emissao.Items.Add('4-DEVOLUÇĂO/RETORNO');
  Finalidade_Emissao.ItemIndex := 0;
  End;



  if QTransacao.FieldByName('COND_PAGTO').AsString = 'A VISTA' then
    COND_PAGTO.ItemIndex := 0
  else  if QTransacao.FieldByName('COND_PAGTO').AsString = 'A PRAZO' then
    COND_PAGTO.ItemIndex := 1
  else if QTransacao.FieldByName('COND_PAGTO').AsString = 'CARTAO' then
    COND_PAGTO.ItemIndex := 2
  else if QTransacao.FieldByName('COND_PAGTO').AsString = 'CHEQUE' then
    COND_PAGTO.ItemIndex := 3;


  QTabela.Sql.Clear;
  QTabela.Sql.Add('SELECT * FROM COMPL_NFISCAL');
  QTabela.Sql.Add('WHERE');
  QTabela.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

  QTabela.ParamByName('TRANSACAO_ID').AsInteger := ID;

  QTabela.Prepare;
  QTabela.Open;

  if QTabela.IsEmpty then
  begin
    Set_Campos(True);
    UF_VEICULO.Text          := '  ';
    UF_TRANSPORTADOR.Text    := '  ';
    DT_SAIDA.Date            := date;
    HR_SAIDA.Text            := Copy(TimeToStr(time), 1, 8);
    TRANSACAO_ID.Value       := ID;
    NO_DOC_FISCAL.Value      := 0;
    QUANTIDADE_VOLUMES.Value := QTransacao.FieldByName('UNIDADES').AsFloat;
    ESPECIE_VOLUMES.Text     := 'CAIXA';
    Empresa_id.Value         := FrmPrincipal.QEmpresa.FieldByName('EMPRESA_ID').AsInteger;

    QItens.Sql.Clear;
    QItens.Sql.Add('SELECT * FROM TRANSITENS');
    QItens.Sql.Add('WHERE');
    QItens.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
    QItens.Sql.Add('ORDER BY SEQUENCIA ASC');

    QItens.ParamByName('TRANSACAO_ID').AsInteger := ID;

    QItens.Prepare;
    QItens.Open;

    //PESO_BRUTO.Value   := 0;
    //PESO_LIQUIDO.Value := 0;

    QItens.First;
    while not QItens.Eof do
    begin
      ProdutoSearch(QItens.FieldByName('PRODUTO_ID').AsInteger);

      PESO_BRUTO.Value   := PESO_BRUTO.Value + (QProdutos.FieldByName('PESO').AsFloat * QItens.FieldByName('QUANTIDADE').AsFloat);
      PESO_LIQUIDO.Value := PESO_LIQUIDO.Value + (QProdutos.FieldByName('PESO_UNITARIO').AsFloat * QItens.FieldByName('QUANTIDADE').AsFloat);

      Application.ProcessMessages;
      QItens.Next;
    end;
  end
  else
  Begin

    Set_Campos(False);

    QItens.Sql.Clear;
    QItens.Sql.Add('SELECT * FROM TRANSITENS');
    QItens.Sql.Add('WHERE');
    QItens.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
    QItens.Sql.Add('ORDER BY SEQUENCIA ASC');

    QItens.ParamByName('TRANSACAO_ID').AsInteger := ID;

    QItens.Prepare;
    QItens.Open;

    Bruto   := 0;
    Liquido := 0;

    QItens.First;
    while not QItens.Eof do
    begin
      ProdutoSearch(QItens.FieldByName('PRODUTO_ID').AsInteger);

      Bruto   := Bruto + (QProdutos.FieldByName('PESO').AsFloat * QItens.FieldByName('QUANTIDADE').AsFloat);
      Liquido := Liquido + (QProdutos.FieldByName('PESO_UNITARIO').AsFloat * QItens.FieldByName('QUANTIDADE').AsFloat);

      Application.ProcessMessages;
      QItens.Next;
    end;

    if (Bruto > 0) and (Liquido > 0) then
    begin
      PESO_BRUTO.Value := Bruto;
      PESO_LIQUIDO.Value := Liquido;
    end;

  End;


  if INSTRUCOES.Lines.Text = '' then
  begin
    IniFile := ChangeFileExt(ExtractFilePath(ParamStr(0)) + 'NFe', '.Ini');

    Ini := TIniFile.Create(IniFile);
    try
      StreamMemo := TMemoryStream.Create;

      Ini.ReadBinaryStream('Informaçőes Adicionais', 'Texto', StreamMemo);
      INSTRUCOES.Lines.LoadFromStream(StreamMemo);
      StreamMemo.Free;
    finally
      Ini.Free;
    end;


    if (FrmPrincipal.QEmpresa.FieldByName('CRT').AsString =  '1 - SIMPLES NACIONAL') and (INSTRUCOES.Lines.Text = '') then
    Begin
      INSTRUCOES.Lines.Add('PERMITE O APROVEITAMENTO DO CRÉDITO DE ICMS NO VALOR DE R$ ' + FormatFloat('#,##0.00', (QTransacao.FieldByName('VALOR').AsFloat * FrmPrincipal.Config.FieldByName('ALIQ_SIMPLES').AsFloat) / 100) +
                           ' CORRESPONDENTE Ŕ ALÍQUOTA DE ' + FormatFloat('#,##0.00', FrmPrincipal.Config.FieldByName('ALIQ_SIMPLES').AsFloat) + '%, NOS TERMOS DO ART. 23 DA LC 123/2006');

       if QTransacao.FieldByName('OBSERVACAO').AsString <> '' then
      INSTRUCOES.Lines.Add(QTransacao.FieldByName('OBSERVACAO').AsString);
    End;

    if (FrmPrincipal.config.FieldByName('OBJETO_ORDEM').AsString = 'Cooperativa') and (QTransacao.FieldByName('SUB_SERIE').AsString = 'P') then
    begin
      desc_cooperativa := RoundTo ((QTransacao.FieldByName('VALOR_PRODUTOS').AsFloat * FrmPrincipal.config.FieldByName('DESC_COOPERATIVA').AsFloat / 100) , -2);
      desc_funrural    := RoundTo ((QTransacao.FieldByName('VALOR_PRODUTOS').AsFloat * FrmPrincipal.config.FieldByName('DESC_FUNRURAL').AsFloat / 100) , -2);

      INSTRUCOES.Lines.Add('R$' + FormatFloat('#,##0.00', desc_funrural) + ' VALOR REF INSS FUNRURAL DO PRODUTOR RETIDO EM 1,5% CFE LEI 8.212/91. ');
      INSTRUCOES.Lines.Add('R$' + FormatFloat('#,##0.00', desc_cooperativa) + ' VALOR ref.' +  FormatFloat('#,##0.00',FrmPrincipal.config.FieldByName('DESC_COOPERATIVA').AsFloat) +  '% DA CONTRIBUIÇĂO COOPERATIVISTA. ');

    end;

  end;

  if INSTRUCOES_2.Lines.Text = '' then
  begin
    IniFile := ChangeFileExt(ExtractFilePath(ParamStr(0)) + 'NFe', '.Ini');

    Ini := TIniFile.Create(IniFile);
    try
      StreamMemo := TMemoryStream.Create;

      Ini.ReadBinaryStream('Informaçőes Adicionais2', 'Texto', StreamMemo);
      INSTRUCOES_2.Lines.LoadFromStream(StreamMemo);
      StreamMemo.Free;
    finally
      Ini.Free;
    end;

    if QParceiro.FieldByName('PRODUTOR_R').AsInteger = 1 Then
    Begin
     Complemento_Pr := False;

     QItens.First;
     While not QItens.Eof do
     Begin

      IQuery.SQL.Clear;
      IQuery.SQL.Add('SELECT CST_PR FROM TRIBUTOS WHERE TRIBUTO_ID = :TRIBUTO_ID');
      IQuery.ParamByName('TRIBUTO_ID').AsInteger := QItens.FieldByName('TRIBUTO_ID').AsInteger;
      IQuery.Prepare;
      IQuery.Open();

      if IQuery.FieldByName('CST_PR').AsString <> '' Then
      Complemento_Pr := True;

      QItens.Next;

     End;

     if Complemento_pr Then
     Begin

        IniFile := ChangeFileExt(ExtractFilePath(ParamStr(0)) + 'NFe', '.Ini');

        Ini := TIniFile.Create(IniFile);
        try
          StreamMemo := TMemoryStream.Create;

          Ini.ReadBinaryStream('Informaçőes Adicionais Pr', 'Texto', StreamMemo);
          INSTRUCOES_2.Lines.LoadFromStream(StreamMemo);
          StreamMemo.Free;
        finally
          Ini.Free;
        end;


     End;
     Complemento_Pr := False;
    End;

  end;

  if Copy(QTransacao.FieldByName('COMPLEMENTO').AsString,1,7) = 'Rf.Doc:' then
  Begin
  Nota_Referenciada :=  True;
  Instrucoes.Lines.Clear;
  Instrucoes.lines.Add(QTransacao.FieldByName('COMPLEMENTO').AsString);

  if FrmPrincipal.QEmpresa.FieldByName('CRT').AsString <> '1 - SIMPLES NACIONAL' then
  Instrucoes.Enabled := False;
  End;

  if QTransacao.FieldByName('CHAVE_NFE_REF').AsString <> '' then
  begin
  INSTRUCOES_2.Lines.Clear;
  INSTRUCOES_2.Lines.Add('Nfe Ref.: ' + QTransacao.FieldByName('CHAVE_NFE_REF').AsString);
  end;

  QNotas.Close;
  QNotas.ParamByName('TRANSACAO_ID').AsInteger := ID;
  QNotas.Prepare;
  QNotas.Open;

   if (not QNotas.IsEmpty)  then
   Begin

       QNotas.First;
       if not QNotas.IsEmpty then
       Begin
         Instrucoes.Lines.Clear;
         While not QNotas.Eof do
         Begin
         Instrucoes.Lines.Add('Nfe Ref.: ' + QNotas.FieldByName('CHAVE_NFE').AsString);
         QNotas.Next;
         End;
       End;

   End;


  if QTransacao.FieldByName('PEDIDO_ID').AsInteger > 0 then
  Begin

      IQuery.SQL.Clear;
      IQuery.SQL.Add('SELECT OBSERVACAO_NFE FROM PEDIDOS WHERE PEDIDO_ID = :PEDIDO_ID');
      IQuery.ParamByName('PEDIDO_ID').AsInteger:= QTransacao.FieldByName('PEDIDO_ID').AsInteger;
      IQuery.Prepare;
      IQuery.Open();

      INSTRUCOES_2.lines.Add(IQuery.FieldByName('OBSERVACAO_NFE').AsString);

  End;


  CFOP_COMPL.Text      := Cod_CFOP;
  Resp_Frete.ItemIndex := 3;
  IDX := 0;


  if Transmitido = 1 then
  Begin
   for I := 0 to (ComponentCount - 1) do
   begin
    Temp := Components[I];

     if Temp is TEdit then
       TEdit(Temp).Enabled := False;

    if Temp is TComboBox then
       TComboBox(Temp).Enabled := False;

    if Temp is TCurrencyEdit then
       TCurrencyEdit(Temp).Enabled := False;

    if Temp is TRxCalcEdit then
      TRxCalcEdit(Temp).Enabled := False;

    if Temp is TDateEdit then
      TDateEdit(Temp).Enabled := False;

    if Temp is TMaskEdit  then
      TMaskEdit(Temp).Enabled := False;

    if Temp is TMemo  then
      TMemo(Temp).Enabled := False;

   End;

    BtnGera.enabled := False;
  end;
end;

procedure TFrmNFe.GerarXMLClick(Sender: TObject);
begin
  Application.CreateForm(TFrmPasswordDlg, FrmPasswordDlg);
  try
    if FrmPasswordDlg.ShowModal = mrOk then
    begin
      if FrmPasswordDlg.Password.Text = Senha_Suporte then
      begin
         GeraXML := True;
         btnGeraClick(Sender);
         GeraXML := False;

        if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
          Cascade;
      end
      else
        Application.MessageBox('Acesso negado', PChar(Msg_Title), mb_IconStop);
    end;
  finally
    FrmPasswordDlg.Release;
  end;

end;

end.
