procedure TFrmSPED_Pis_Cofins.RecalcularPISCOFINS;
var
Vr_Pis, Vr_Cofins, Vr_Pis_St, Vr_Cofins_St : Real;
Dia: TDateTime;
begin
  {
  Label3.Caption := 'Aguardando liberaçăo do banco de dados.';
  Application.ProcessMessages;
  while FrmPrincipal.QEmpresa.FieldByName('DESABILITA_TRIGGER').AsInteger = 1 do
  begin
    Sleep(3000);
    FrmPrincipal.QEmpresa.Refresh;
  end;

  IQuery.Sql.Clear;
  IQuery.Sql.Add('UPDATE EMPRESAS SET DESABILITA_TRIGGER = 1');
  IQuery.Prepare;
  IQuery.ExecSql;
  }
  Label3.Caption := 'Preparando transaçőes';
  Application.ProcessMessages;
  IQuery.Sql.Clear;
  IQuery.Sql.Add('ALTER TABLE TRANSACOES DISABLE TRIGGER TRANSACOES_UP');
  IQuery.Prepare;
  IQuery.ExecSql;

  Label3.Caption := 'Preparando produtos';
  Application.ProcessMessages;
  IQuery.Sql.Clear;
  IQuery.Sql.Add('ALTER TABLE PRODUTOS DISABLE TRIGGER PRODUTOS_UP');
  IQuery.Prepare;
  IQuery.ExecSql;

  try
   Label3.Caption := 'Preparando produtos mobile';
   Application.ProcessMessages;
   IQuery.Sql.Clear;
   IQuery.Sql.Add('ALTER TABLE PRODUTOS DISABLE TRIGGER MOBILE_SYNC_PRODUTOS');
   IQuery.Prepare;
   IQuery.ExecSql;
  except

  end;
  {
  Dia := Dtmen.Date;
  while Dia <= Dtmai.Date do
  begin
    Label3.Caption := DateToStr(Dia) + ' - Corrigindo CST PIS/COFINS e alíq Prod';
    Application.ProcessMessages;
    QTabela.Sql.Clear;
    QTabela.Sql.Add('update TRANSITENS');
    QTabela.Sql.Add('set CST_PIS = PRODUTOS.CST_PIS, CST_COFINS = PRODUTOS.CST_COFINS,');
    QTabela.Sql.Add('ALIQUOTA_PIS = PRODUTOS.PIS, ALIQUOTA_COFINS = PRODUTOS.COFINS');
    QTabela.Sql.Add('from PRODUTOS');
    QTabela.Sql.Add('where TRANSITENS.TP_PROD_SERV = ''P''');
    QTabela.Sql.Add('and TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID');
    QTabela.Sql.Add('and TRANSACAO_ID in (select transacao_id from transacoes where dt_sped = :DIA and CONDUTA = ''01'')');
    //QTabela.Sql.Add('and (TRANSITENS.CST_PIS is NULL or transitens.cst_cofins is null)');
    QTabela.ParamByName('DIA').AsDateTime := Dia;
    QTabela.Prepare;
    QTabela.ExecSQL;

    Label3.Caption := DateToStr(Dia) + ' - Corrigindo CST PIS/COFINS e alíquotas Serv';
    Application.ProcessMessages;
    QTabela.Sql.Clear;
    QTabela.Sql.Add('update TRANSITENS');
    QTabela.Sql.Add('set CST_PIS = SERVICOS.CST_PIS, CST_COFINS = SERVICOS.CST_COFINS,');
    QTabela.Sql.Add('ALIQUOTA_PIS = SERVICOS.PIS, ALIQUOTA_COFINS = SERVICOS.COFINS');
    QTabela.Sql.Add('from SERVICOS');
    QTabela.Sql.Add('where TRANSITENS.TP_PROD_SERV = ''S''');
    QTabela.Sql.Add('and TRANSITENS.PRODUTO_ID = SERVICOS.SERVICO_ID');
    QTabela.Sql.Add('and TRANSACAO_ID in (select transacao_id from transacoes where dt_sped = :DIA and CONDUTA = ''01'')');
    QTabela.ParamByName('DIA').AsDateTime := Dia;
    QTabela.Prepare;
    QTabela.ExecSQL;

    Label3.Caption := DateToStr(Dia) + ' - Corrigindo aliq. de agrup. de orçamentos';
    Application.ProcessMessages;
    QTabela.Sql.Clear;
    QTabela.Sql.Add('update transitens');
    QTabela.Sql.Add('set aliquota_pis = produtos.pis, aliquota_cofins = produtos.cofins');
    QTabela.Sql.Add('from produtos');
    QTabela.Sql.Add('where transacao_id in (');
    QTabela.Sql.Add('select transacao_id from TRANSACOES');
    QTabela.Sql.Add('where BALANCO = ''AGRUPADO'' and dt_sped = :DIA and CONDUTA = ''01'' and cfop not in (''5929'', ''6929'') order by transacao_id)');
    QTabela.Sql.Add('and transitens.produto_id = produtos.produto_id;');
    QTabela.ParamByName('DIA').AsDateTime := Dia;
    QTabela.Prepare;
    QTabela.ExecSQL;

    Label3.Caption := DateToStr(Dia) + ' - Zerando aliquotas de agrup. de nfce';
    Application.ProcessMessages;
    QTabela.Sql.Clear;
    QTabela.Sql.Add('update transitens');
    QTabela.Sql.Add('set aliquota_pis = 0, aliquota_cofins = 0,');
    QTabela.Sql.Add('base_calc_pis = 0, base_calc_cofins = 0,');
    QTabela.Sql.Add('vr_pis = 0, vr_cofins = 0,');
    QTabela.Sql.Add('cst_pis = ''49'', cst_cofins = ''49''');
    QTabela.Sql.Add('from produtos');
    QTabela.Sql.Add('where transacao_id in (');
    QTabela.Sql.Add('select transacao_id from TRANSACOES');
    QTabela.Sql.Add('where BALANCO = ''AGRUPADO'' and dt_sped = :DIA and CONDUTA = ''01'' and cfop in (''5929'', ''6929'') order by transacao_id)');
    QTabela.Sql.Add('and transitens.produto_id = produtos.produto_id;');
    QTabela.ParamByName('DIA').AsDateTime := Dia;
    QTabela.Prepare;
    QTabela.ExecSQL;

    Label3.Caption := DateToStr(Dia) + ' - Corrigindo valores PIS/COFINS itens';
    Application.ProcessMessages;
    QTabela.Sql.Clear;
    QTabela.Sql.Add('update TRANSITENS set');
    QTabela.Sql.Add('BASE_CALC_PIS = vr_total - desc_rodape - VALOR_ICMS,');
    QTabela.Sql.Add('BASE_CALC_COFINS = vr_total - desc_rodape - VALOR_ICMS,');
    QTabela.Sql.Add('VR_PIS = (vr_total - desc_rodape-VALOR_ICMS)*aliquota_pis/100,');
    QTabela.Sql.Add('VR_COFINS = (vr_total - desc_rodape-VALOR_ICMS)*aliquota_COFINS/100');
    QTabela.Sql.Add('where transacao_id in (select transacao_id from transacoes where dt_sped = :DIA and CONDUTA = ''01'')');
    QTabela.Sql.Add('and ALIQUOTA_PIS > 0 and cfop not in (''5929'', ''6929'')');
    QTabela.ParamByName('DIA').AsDateTime := Dia;
    QTabela.Prepare;
    QTabela.ExecSQL;

    Label3.Caption := DateToStr(Dia) + ' - Corrigindo valores PIS/COFINS transaçőes';
    Application.ProcessMessages;
    QTabela.Sql.Clear;
    QTabela.Sql.Add('update transacoes');
    QTabela.Sql.Add('set base_calc_pis = base_calc_pis_itens,');
    QTabela.Sql.Add('vr_pis = vr_pis_itens,');
    QTabela.Sql.Add('base_calc_cofins = base_calc_cofins_itens,');
    QTabela.Sql.Add('vr_cofins = vr_cofins_itens');
    QTabela.Sql.Add('from');
    QTabela.Sql.Add('(select transacao_id,');
    QTabela.Sql.Add('sum(base_calc_pis) base_calc_pis_itens, sum(vr_pis) vr_pis_itens,');
    QTabela.Sql.Add('sum(base_calc_cofins) base_calc_cofins_itens, sum(vr_cofins) vr_cofins_itens');
    QTabela.Sql.Add('from transitens');
    QTabela.Sql.Add('where transacao_id in');
    QTabela.Sql.Add('(select transacao_id from transacoes where dt_sped = :DIA and CONDUTA = ''01'')');
    QTabela.Sql.Add('group by transacao_id)');
    QTabela.Sql.Add('as itens');
    QTabela.Sql.Add('where transacoes.transacao_id = itens.transacao_id');
    QTabela.ParamByName('DIA').AsDateTime := Dia;
    QTabela.Prepare;
    QTabela.ExecSQL;

    Dia := Dia + 1;
  end;

  Label3.Caption := 'Finalizada a correçăo dia a dia';
  Application.ProcessMessages;

  //antigo

  QTabela.Sql.Clear;
  QTabela.Sql.Add('SELECT * FROM TRANSACOES WHERE DT_SPED BETWEEN :DT_INICIAL AND :DT_FINAL');
  QTabela.Sql.Add('AND ((TRANSACOES.CONDUTA = :CD_VDA) AND ((TRANSACOES.DEPTO = :DPT_DEV) OR (TRANSACOES.DEPTO = :DPT_ENT_SAI)))');
  QTabela.Sql.Add('AND (MODELO IN (''65'',''55'')');
  QTabela.ParamByName('CD_VDA').AsString       := '01';
  QTabela.ParamByName('DPT_ENT_SAI').AsString  := '07';
  QTabela.ParamByName('DPT_DEV').AsString      := '10';
 // QTabela.ParamByName('MODELO').AsString       := '2D';
  // QTabela.ParamByName('CD_CPR').AsString       := '02';
  QTabela.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
  QTabela.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;

  QTabela.Prepare;
  QTabela.Open;


  QTabela.First;
  while not QTabela.Eof do

  begin
    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT CONDUTA, DEPTO, TRANSITENS.*, PRODUTOS.PIS PIS_SAI, PRODUTOS.COFINS COFINS_SAI, PRODUTOS.CST_PIS CST_PIS_SAI, ' +
                 'PRODUTOS.PIS_ENTR, PRODUTOS.COFINS_ENTR, PRODUTOS.CST_PIS_ENTR, PRODUTOS.CST_COFINS_ENTR,' +
                 'PRODUTOS.CST_COFINS CST_COFINS_SAI, CFOP.CST_SAIDA CFOP_SAIDA, CFOP.NAT_REC CFOP_NAT_REC, SERVICOS.PIS SRV_PIS_SAI, SERVICOS.COFINS ' +
                 'SRV_COFINS_SAI, SERVICOS.CST_PIS SRV_CST_PIS_SAI, SERVICOS.CST_COFINS SRV_CST_COFINS_SAI ');
    QRel.Sql.Add('FROM TRANSITENS');
    QRel.Sql.Add('INNER JOIN TRANSACOES');
    QRel.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
    QRel.Sql.Add('LEFT JOIN PRODUTOS');
    QRel.Sql.Add('ON (TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID)');
    QRel.Sql.Add('LEFT JOIN SERVICOS');
    QRel.Sql.Add('ON (TRANSITENS.PRODUTO_ID = SERVICOS.SERVICO_ID)');
    QRel.Sql.Add('LEFT JOIN CFOP');
    QRel.Sql.Add('ON (TRANSITENS.CFOP = CFOP.COD_CFOP)');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(TRANSITENS.TRANSACAO_ID = :TRANSACAO_ID)');

    QRel.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;

    QRel.Prepare;
    QRel.Open;

    QRel.First;
    while not QRel.Eof do
    begin
      IQuery.Sql.Clear;
      IQuery.SQL.Add('select case when count(transacao_id) > 0 then ''SIM'' else ''NAO'' end agrupado from transacoes where cod_cont = :TRANSACAO_ID and modelo != ''02''');
      IQuery.ParamByName('TRANSACAO_ID').AsString := QTabela.FieldByName('TRANSACAO_ID').AsString;
      IQuery.Prepare;
      IQuery.Open;
      //QTabela.FieldByName('BALANCO').AsString = 'AGRUPADO'
      if (IQuery.FieldByName('AGRUPADO').AsString = 'SIM')  OR ((QRel.FieldByName('SRV_CST_PIS_SAI').AsString = '49') AND (QRel.FieldByName('TP_PROD_SERV').AsString = 'S')) OR (QRel.FieldByName('CFOP_SAIDA').AsString <> '' ) then
      Begin

        //Alterado dia 24/03/14 Regivaldo
        //or (QTabela.FieldByName('CFOP').AsString = '5927') or (QTabela.FieldByName('CFOP').AsString = '6927') or (QTabela.FieldByName('CFOP').AsString = '5929') then

        // retirado 24/02/23 solicitaçăo regivaldo
        //OR (QTabela.FieldByName('TIPO_VENDA').AsString = 'REMESSA')
        IQuery.Sql.Clear;
        IQuery.Sql.Add('UPDATE TRANSITENS SET CST_PIS = :CST_PIS, CST_COFINS = :CST_COFINS, BASE_CALC_PIS = 0, ' +
                       'ALIQUOTA_PIS = :ALIQUOTA_PIS, VR_PIS = 0, BASE_CALC_COFINS = 0, ALIQUOTA_COFINS = :ALIQUOTA_COFINS, VR_COFINS = 0');

        if QRel.FieldByName('CFOP_SAIDA').AsString <> '' then
        IQuery.Sql.Add(',NAT_REC = :NAT_REC');

      End
      else
      begin
        IQuery.Sql.Clear;
        IQuery.Sql.Add('UPDATE TRANSITENS SET CST_PIS = :CST_PIS, CST_COFINS = :CST_COFINS, BASE_CALC_PIS = (VR_TOTAL  - DESC_RODAPE  - VALOR_ICMS), ' +
                       'ALIQUOTA_PIS = :ALIQUOTA_PIS, VR_PIS = ROUND((((VR_TOTAL  - DESC_RODAPE  - VALOR_ICMS) * CAST(:ALIQUOTA_PIS AS NUMERIC(15,2))) / 100),2), ' +
                       'BASE_CALC_COFINS = (VR_TOTAL  - DESC_RODAPE  - VALOR_ICMS), ' +
                       'ALIQUOTA_COFINS = :ALIQUOTA_COFINS, VR_COFINS = ROUND((((VR_TOTAL - DESC_RODAPE - VALOR_ICMS) * CAST(:ALIQUOTA_COFINS AS NUMERIC(15,2))) / 100),2)');

        if QRel.FieldByName('CFOP_SAIDA').AsString <> '' then
        IQuery.Sql.Add(',NAT_REC = :NAT_REC');


      end;

      //+ QSub_Detail.FieldByName('VR_IPI').AsFloat + QSub_Detail.FieldByName('VALOR_ICMS_ST').AsFloat;
      // Lei 9718 de 1998 art 3ş  14/07/14
      //Foi retirado:
      // + VALOR_ICMS_ST
      //Incluido  campos 14/08/14 Regivaldo
      //+ VR_IPI + VR_FRETE

     //Retirado da base de calculo
     //VR_ACRESCIMO + VR_IPI + VR_FRETE - DESC_RODAPE
     //Regivaldo 16/05/15

      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
      IQuery.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');


          if QRel.FieldByName('TP_PROD_SERV').AsString = 'S' then
          Begin
          IQuery.ParamByName('CST_PIS').AsString        := QRel.FieldByName('SRV_CST_PIS_SAI').AsString;
          IQuery.ParamByName('CST_COFINS').AsString     := QRel.FieldByName('SRV_CST_COFINS_SAI').AsString;
          IQuery.ParamByName('ALIQUOTA_PIS').AsFloat    := QRel.FieldByName('SRV_PIS_SAI').AsFloat;
          IQuery.ParamByName('ALIQUOTA_COFINS').AsFloat := QRel.FieldByName('SRV_COFINS_SAI').AsFloat;
          End
          Else
          Begin
          if (QRel.FieldByName('CONDUTA').AsString = '02') AND (QRel.FieldByName('DEPTO').AsString = '10') then

          Begin
          IQuery.ParamByName('CST_PIS').AsString        := QRel.FieldByName('CST_PIS_ENTR').AsString;
          IQuery.ParamByName('CST_COFINS').AsString     := QRel.FieldByName('CST_COFINS_ENTR').AsString;
          IQuery.ParamByName('ALIQUOTA_PIS').AsFloat    := QRel.FieldByName('PIS_ENTR').AsFloat;
          IQuery.ParamByName('ALIQUOTA_COFINS').AsFloat := QRel.FieldByName('COFINS_ENTR').AsFloat;
          End
          Else
          IQuery.ParamByName('CST_PIS').AsString        := QRel.FieldByName('CST_PIS_SAI').AsString;
          IQuery.ParamByName('CST_COFINS').AsString     := QRel.FieldByName('CST_COFINS_SAI').AsString;
          IQuery.ParamByName('ALIQUOTA_PIS').AsFloat    := QRel.FieldByName('PIS_SAI').AsFloat;
          IQuery.ParamByName('ALIQUOTA_COFINS').AsFloat := QRel.FieldByName('COFINS_SAI').AsFloat;
          End;


      if (QTabela.FieldByName('BALANCO').AsString = 'AGRUPADO') and ((QTabela.FieldByName('CFOP').AsString = '5929') or  (QTabela.FieldByName('CFOP').AsString = '6929')) then
      begin
        IQuery.ParamByName('CST_PIS').AsString        := '49';
        IQuery.ParamByName('CST_COFINS').AsString     := '49';
        IQuery.ParamByName('ALIQUOTA_PIS').AsFloat    := 0;
        IQuery.ParamByName('ALIQUOTA_COFINS').AsFloat := 0;
      end;

      if QRel.FieldByName('CFOP_SAIDA').AsString <> '' then
      begin
        IQuery.ParamByName('CST_PIS').AsString        := QRel.FieldByName('CFOP_SAIDA').AsString;
        IQuery.ParamByName('CST_COFINS').AsString     := QRel.FieldByName('CFOP_SAIDA').AsString;
        IQuery.ParamByName('ALIQUOTA_PIS').AsFloat    := 0;
        IQuery.ParamByName('ALIQUOTA_COFINS').AsFloat := 0;
        IQuery.ParamByName('NAT_REC').AsString        := QRel.FieldByName('CFOP_NAT_REC').AsString;
      end;

      if QRel.FieldByName('CST_PIS').AsString = '05' Then
      begin
      IQuery.ParamByName('ALIQUOTA_PIS').AsFloat    := 0.65;
      IQuery.ParamByName('ALIQUOTA_COFINS').AsFloat := 3;
      end;


      IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
      IQuery.ParamByName('PRODUTO_ID').AsInteger   := QRel.FieldByName('PRODUTO_ID').AsInteger;

      IQuery.Prepare;
      IQuery.ExecSql;




      if ((QRel.FieldByName('PIS_SAI').AsFloat = 0) AND (QRel.FieldByName('TP_PROD_SERV').AsString = 'P')) and (QRel.FieldByName('CST_PIS').AsString <> '05') then
      begin
        IQuery.Sql.Clear;
        IQuery.Sql.Add('UPDATE TRANSITENS SET BASE_CALC_PIS = 0, BASE_CALC_COFINS = 0, VR_COFINS = 0, VR_PIS = 0');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
        IQuery.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

        IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        IQuery.ParamByName('PRODUTO_ID').AsInteger   := QRel.FieldByName('PRODUTO_ID').AsInteger;

        IQuery.Prepare;
        IQuery.ExecSql;

      end;

      if (QRel.FieldByName('CST_PIS').AsString = '05')  then
      begin
        IQuery.Sql.Clear;
        IQuery.Sql.Add('UPDATE TRANSITENS SET BASE_CALC_PIS = 0, BASE_CALC_COFINS = 0, VR_COFINS = 0, VR_PIS = 0');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
        IQuery.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

        IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        IQuery.ParamByName('PRODUTO_ID').AsInteger   := QRel.FieldByName('PRODUTO_ID').AsInteger;

        IQuery.Prepare;
        IQuery.ExecSql;

      end;

      if (QRel.FieldByName('CST_PIS').AsString = '06')  then
