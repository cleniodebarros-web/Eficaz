       ALIQ_CONT         := StrToFloat(FormatFloat('#.##0.000', QRel.FieldByName('ALIQUOTA_PIS').AsFloat));
       VL_CONT_APU       := ((Total_Saidas - Total_devolucoes) *   QRel.FieldByName('ALIQUOTA_PIS').AsFloat) / 100;

       QCFOP.Close;
       QCFOP.ParamByName('COD_CFOP').AsString :=  '5102';
       QCFOP.prepare;
       QCFOP.open;

      COD_CTA       := QCFOP.FieldByName('CONTA_ID').AsString;
      // COD_CTA       := '';
      // INF_COMPL         :=  '';
     end;

     with RegistroP200New do
     begin
       PER_REF         := Copy(DateToStr(Dtmen.date),4,2) + Copy(DateToStr(Dtmen.date),7,4);
       VL_TOT_CONT_APU := ((Total_Saidas - Total_devolucoes) *   QRel.FieldByName('ALIQUOTA_PIS').AsFloat) / 100;
       VL_TOT_AJ_REDUC := 0;
       VL_TOT_AJ_ACRES := 0;
       VL_TOT_CONT_DEV := ((Total_Saidas - Total_devolucoes) *   QRel.FieldByName('ALIQUOTA_PIS').AsFloat) / 100;
       COD_REC         := '299101';
     end;

   end;

 end;
 ACBrSPEDPisCofins1.WriteBloco_P;
End;


