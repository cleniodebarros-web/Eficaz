    FrmFecha_Orcamento.VENDEDOR_ID.Text     := IntToStr(FrmFecha_Orcamento.QSearch.FieldByName('VENDEDOR_ID').AsInteger);
    FrmFecha_Orcamento.COND_PAGTO.Text      := FrmFecha_Orcamento.QSearch.FieldByName('COND_PAGTO').AsString;
