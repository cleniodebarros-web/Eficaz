     begin
         Hora_Inicial.Enabled := True;
         Hora_Final.Enabled   := True;
         Hora_Inicial.SetFocus;
     end
     else
     begin
         Hora_Inicial.Enabled := False;
         Hora_Final.Enabled   := False;
         Hora_Inicial.Text := '';
         Hora_Final.Text   := '';
     end;


end;

