procedure TFrmRel_Comandas_Garcom.btnExecutaClick(Sender: TObject);
var
  vr_total,qt_total: Real;
  dt_combinada_inicial, dt_combinada_final: string;
begin
// 125, 327
     btnExecuta.Enabled := False;

    try
        Hora_Inicial.EditMask := '!90:00;0;_';
        Hora_Final.EditMask := '!90:00;0;_';

        QRel.Close;
        QRel.SQL.Clear;
        QRel.SQL.Add('SELECT');
        QRel.SQL.Add('	BAR.COD_PRODUTO,');
        QRel.SQL.Add('	BAR.DESCRICAO,');
        QRel.SQL.Add('	BAR.VR_UNITARIO,');

        if not AgruparItens.Checked then
        begin
          QRel.SQL.Add('	BAR.DATA,');
          QRel.SQL.Add('	BAR.HORA,');
          QRel.SQL.Add('	CASE WHEN BAR.MESA = 99000 THEN ''BALCĂO'' WHEN BAR.MESA >= 600 THEN ''DELIVERY'' ELSE TO_CHAR(BAR.MESA, ''fm000'') END AS MESA,');
          QRel.SQL.Add('	BAR.GARCOM,');
          QRel.SQL.Add('	( SELECT NOME FROM FUNCIONARIOS WHERE FUNCIONARIO_ID = BAR.GARCOM ) AS NOME,');
          QRel.Sql.Add('  TO_TIMESTAMP(''''||BAR.DATA||''-''||BAR.HORA||'''', ''YYYY/MM/DD-HH24:MI:SS'')::TIMESTAMP DATA_COMBINADA,');
          QRel.SQL.Add('	BAR.QUANTIDADE,');
          QRel.SQL.Add('	BAR.VR_TOTAL');
        end
        else
        begin
          QRel.SQL.Add('	NULL AS DATA,');
          QRel.SQL.Add('	NULL AS HORA,');
          QRel.SQL.Add('	NULL AS MESA,');
          QRel.SQL.Add('	NULL AS GARCOM,');
          QRel.SQL.Add('	NULL AS NOME,');
          QRel.Sql.Add('  NULL AS DATA_COMBINADA,');
          QRel.SQL.Add('	SUM(BAR.QUANTIDADE) QUANTIDADE,');
          QRel.SQL.Add('	SUM(BAR.QUANTIDADE)*BAR.VR_UNITARIO VR_TOTAL');
        end;

        QRel.SQL.Add('FROM');
        QRel.SQL.Add('	BAR');

        if QGrupo.FieldByName('TABELA_ID').AsInteger <> 0 then
        begin
          QRel.SQL.Add('	INNER JOIN PRODUTOS ON ( BAR.COD_PRODUTO = PRODUTOS.PRODUTO_ID )');
          QRel.SQL.Add('	INNER JOIN TABELAS ON ( PRODUTOS.GRUPO_ID = TABELAS.TABELA_ID )');
        end;

        QRel.SQL.Add('WHERE');
        if ComboboxTurnos.Enabled then
        begin
          dt_combinada_inicial := Concat(QTurnoComboBox.FieldByName('DT_INICIAL').AsString, '-', QTurnoComboBox.FieldByName('HORA_INICIAL').AsString);

          if (QTurnoComboBox.FieldByName('DT_FINAL').AsDateTime < QTurnoComboBox.FieldByName('DT_INICIAL').AsDateTime) then
          begin
            dt_combinada_final := 'Turno aberto';
            QRel.Sql.Add('TO_TIMESTAMP(''''||BAR.DATA||''-''||BAR.HORA||'''', ''YYYY/MM/DD-HH24:MI:SS'')::TIMESTAMP >= TO_TIMESTAMP(:DATA_COMBINADA_INICIAL, ''DD/MM/YYYY-HH24:MI:SS'')');
            QRel.ParamByName('DATA_COMBINADA_INICIAL').AsString := dt_combinada_inicial;
          end
          else
          begin
            dt_combinada_final := Concat(QTurnoComboBox.FieldByName('DT_FINAL').AsString, '-', QTurnoComboBox.FieldByName('HORA_FINAL').AsString);
            QRel.Sql.Add('TO_TIMESTAMP(''''||BAR.DATA||''-''||BAR.HORA||'''', ''YYYY/MM/DD-HH24:MI:SS'')::TIMESTAMP BETWEEN TO_TIMESTAMP(:DATA_COMBINADA_INICIAL, ''DD/MM/YYYY-HH24:MI:SS'')');
            QRel.Sql.Add('AND TO_TIMESTAMP(:DATA_COMBINADA_FINAL, ''DD/MM/YYYY-HH24:MI:SS'')');
            QRel.ParamByName('DATA_COMBINADA_INICIAL').AsString := dt_combinada_inicial;
            QRel.ParamByName('DATA_COMBINADA_FINAL').AsString := dt_combinada_final;
          end;
        end
        else
        begin
          dt_combinada_inicial := Dtmen.Text;
          dt_combinada_final   := Dtmai.Text;
          QRel.Sql.Add('(BAR.DATA >= :DT_INICIAL) AND');
          QRel.Sql.Add('(BAR.DATA <= :DT_FINAL)');
          QRel.ParamByName('DT_INICIAL').AsDate := Dtmen.Date;
          QRel.ParamByName('DT_FINAL').AsDate := Dtmai.Date;
        end;

        if (AllTrim(Hora_Inicial.Text) <> '') and (AllTrim(Hora_Final.Text) <> '') then
        begin

            Hora_Inicial.EditMask := '!90:00;1;_';
            Hora_Final.EditMask := '!90:00;1;_';

            if (Length(Hora_Inicial.Text) = 5) and (Length(Hora_Final.Text) = 5) then
            begin
                try
                    QRel.SQL.Add('AND CAST(BAR.HORA AS TIME) BETWEEN :HORA_INICIAL AND :HORA_FINAL ');
                    QRel.ParamByName('HORA_INICIAL').AsTime := StrToTime(Hora_Inicial.Text + ':00');
                    QRel.ParamByName('HORA_FINAL').AsTime := StrToTime(Hora_Final.Text + ':59');
                except
                     //
                end;
            end;
        end;

        if QGrupo.FieldByName('TABELA_ID').AsInteger <> 0 then
        begin
          QRel.SQL.Add('AND TABELAS.TABELA_ID = :TABELA_ID');
          QRel.SQL.Add('AND TABELAS.TIPO_TABELA = :TIPO_TABELA');
          QRel.ParamByName('TABELA_ID').AsInteger := QGrupo.FieldByName('TABELA_ID').AsInteger;
          QRel.ParamByName('TIPO_TABELA').AsString := '7';
        end;

        QRel.SQL.Add('	AND ( BAR.STATUS = :STATUS ) ');
        if not DeliveryBalcao.Checked then
          QRel.Sql.Add('AND (BAR.MESA < 600 )');

        if Mesa.Value > 0 then
        begin
            QRel.SQL.Add('	AND ( BAR.MESA = :MESA ) ');
            QRel.ParamByName('MESA').AsInteger := StrToInt(Mesa.Text);
        end;

        if Garcom.Value > 0 then
        begin
            QRel.SQL.Add('	AND ( BAR.GARCOM = :GARCOM ) ');
            QRel.ParamByName('GARCOM').AsInteger := StrToInt(Garcom.Text);
        end;

        QRel.SQL.Add('	AND ( BAR.CANCELADO = :CANCELADO ) ');

        if Produto.Value > 0 then
        begin
            QRel.SQL.Add('AND BAR.COD_PRODUTO = :COD_PRODUTO');
            QRel.ParamByName('COD_PRODUTO').AsInteger := StrToInt(Produto.Text);
        end;

        if not AgruparItens.Checked then
        begin
          if Ordem.Text = 'Data, Hora' then
          begin
              QRel.SQL.Add('ORDER BY BAR.DATA, BAR.HORA, BAR.MESA');
          end;

          if Ordem.Text = 'Mesa' then
          begin
              QRel.SQL.Add('ORDER BY BAR.MESA, BAR.DATA, BAR.HORA');
          end;

          if Ordem.Text = 'Garçom' then
          begin
              QRel.SQL.Add('ORDER BY NOME, BAR.DATA, BAR.HORA');
          end;

          if Ordem.Text = 'Produto' then
          begin
              QRel.SQL.Add('ORDER BY BAR.DESCRICAO, BAR.DATA, BAR.HORA');
          end;
        end
        else
        begin
          QRel.SQL.Add('group by cod_produto, descricao, vr_unitario');
          QRel.SQL.Add('order by descricao');
        end;

        if Tipo.Text = 'Fechada' then
            QRel.ParamByName('STATUS').AsString := 'F'
        else
            QRel.ParamByName('STATUS').AsString := 'A';

        QRel.ParamByName('CANCELADO').AsString := '0';

        QRel.Prepare;
        QRel.Open();

        if QRel.IsEmpty then
            Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
        else
        begin

            QRel.First;

            try

             QLayoutFastReport.SQL.Clear;
             QLayoutFastReport.SQL.Add('SELECT NOME_ARQUIVO, ARQUIVO_RELATORIO FROM CONFIG_RELATORIOS');
             QLayoutFastReport.SQL.Add('WHERE NOME_RELATORIO = :NOME_RELATORIO');
             QLayoutFastReport.SQL.Add('OR NOME_RELATORIO = :BASE;');
             if not AgruparItens.Checked then
               QLayoutFastReport.ParamByName('NOME_RELATORIO').AsString := 'URel_Comandas_Garcom'
             else
               QLayoutFastReport.ParamByName('NOME_RELATORIO').AsString := 'URel_Comandas_Garcom_Agrupado';
             QLayoutFastReport.ParamByName('BASE').AsString := 'base';
             QLayoutFastReport.Open();


            Except
            on e:Exception do
            begin
              Application.MessageBox(PChar('Erro:' + #13 +
                'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
            end;
            end;

            Relatorio_Principal.Clear;
            DadosRelatorio.Open;
            DadosRelatorio.EmptyDataSet;
            vr_total := 0;
            while not Qrel.Eof do
            begin
                DadosRelatorio.Append;

                DadosRelatorio.FieldByName('DATA').AsString       := Qrel.FieldByName('DATA').AsString;
                DadosRelatorio.FieldByName('HORA').AsString       := Qrel.FieldByName('HORA').AsString;
                DadosRelatorio.FieldByName('NOME').AsString       := Qrel.FieldByName('NOME').AsString;
                DadosRelatorio.FieldByName('MESA').AsString       := StrZero(Qrel.FieldByName('MESA').AsString, 3, 0);
                DadosRelatorio.FieldByName('DESCRICAO').AsString  := Qrel.FieldByName('DESCRICAO').AsString;
                DadosRelatorio.FieldByName('QUANTIDADE').AsFloat  := Qrel.FieldByName('QUANTIDADE').AsFloat;
                DadosRelatorio.FieldByName('VR_UNITARIO').AsFloat := Qrel.FieldByName('VR_UNITARIO').AsFloat;
                DadosRelatorio.FieldByName('VR_TOTAL').AsFloat    := Qrel.FieldByName('VR_TOTAL').AsFloat;

                DadosRelatorio.Post;

                //RDprint1.ImpF(linha, 01, Qrel.FieldByName('DATA').AsString, []);
                //RDprint1.ImpF(linha, 13, Copy(Qrel.FieldByName('HORA').AsString, 1, 5), []);
                //RDprint1.ImpF(linha, 20, Copy(Qrel.FieldByName('NOME').AsString, 1, 15), []);
                //RDprint1.ImpF(linha, 41, StrZero(Qrel.FieldByName('MESA').AsString, 3, 0), []);
                //RDprint1.ImpF(linha, 50, Copy(Qrel.FieldByName('DESCRICAO').AsString, 1, 30), []);
                //RDprint1.ImpVal(linha, 82, ',#,##0.00', Qrel.FieldByName('QUANTIDADE').AsFloat, []);
                //RDprint1.ImpVal(linha, 95, ',#,##0.00', Qrel.FieldByName('VR_UNITARIO').AsFloat, []);
                //RDprint1.ImpVal(linha, 110, ',#,##0.00', Qrel.FieldByName('VR_TOTAL').AsFloat, []);

                //vr_total := vr_total + Qrel.FieldByName('VR_TOTAL').AsFloat;
                //qt_total := qt_total + Qrel.FieldByName('QUANTIDADE').AsFloat;

                //if linha > 63 then
                //begin
                //    RDprint1.novapagina;
                //    Pagina := Pagina + 1;
                //end;

                //Inc(Linha);
                QRel.Next;
            end;

            //Inc(linha);
            //RDprint1.LinhaH(linha, 105, 120, 0, false);
            //RDprint1.LinhaH(linha, 77, 92, 0, false);
            //Inc(linha);
            //RDprint1.ImpVal(linha, 110, ',#,##0.00', vr_total, [negrito]);
            //RDprint1.ImpVal(linha, 82, ',#,##0.00', qt_total, [negrito]);

            //RDprint1.TamanhoQteLinhas := 66;
            //RDprint1.Fechar;
            Relatorio_Principal.Clear;
            if not AgruparItens.Checked then
              Relatorio_Principal.InheritFromTemplate('URel_Comandas_Garcom.fr3')
            else
              Relatorio_Principal.InheritFromTemplate('URel_Comandas_Garcom_Agrupado.fr3');
            Relatorio_Principal := FrmPrincipal.Configura_Relatorio_FastReport(Relatorio_Principal, 'Período: ' + dt_combinada_inicial + ' a ' + dt_combinada_final, 'Relatório de Comandas por Garçom');
            Relatorio_Principal.ShowReport(true);
        end;
    finally
       begin
           btnExecuta.Enabled := True;
       end;
    end;


end;

procedure TFrmRel_Comandas_Garcom.Relatorio_PrincipalLoadTemplate(
  Report: TfrxReport; const TemplateName: string);
var
  BlobStream: TStream;

begin
  QLayoutFastReport.First;
  while not QLayoutFastReport.Eof do
  begin
    //ShowMessage(TemplateName + ' ' + QLayoutFastReport.FieldByName('NOME_RELATORIO').AsString);
    if AnsiCompareText(QLayoutFastReport.FieldByName('NOME_ARQUIVO').AsString, TemplateName) = 0 then
    begin
      //ShowMessage(TemplateName + ' ' + QLayoutFastReport.FieldByName('NOME_ARQUIVO').AsString);
      //ShowMessage('Cheguei aqui');
      BlobStream := TMemoryStream.Create;
      TBlobField(QLayoutFastReport.FieldByName('ARQUIVO_RELATORIO')).SaveToStream(BlobStream);
      BlobStream.Position := 0;
      Report.LoadFromStream(BlobStream);
      BlobStream.Free;
      break;
    end;
    QLayoutFastReport.Next;
  end;
end;

