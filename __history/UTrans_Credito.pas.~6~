procedure TFrmTrans_Credito.COND_PAGTOChange(Sender: TObject);
begin
  if (Operacao = 'Alterando') or (Operacao = 'Inserindo') then
  begin
    if (COND_PAGTO.Text = 'A VISTA') OR (COND_PAGTO.Text = 'CHEQUE') OR (COND_PAGTO.Text = 'PIX')   then
    begin

      BANCO_ID.Enabled         := True;
      FLUXO_CAIXA_ID.Enabled   := True;
      btnBanco.Enabled         := True;
      btnFluxoCaixa.Enabled    := True;


      QFinalizadora.Close;
      QFinalizadora.SQL.Clear;
      QFinalizadora.Sql.Add('SELECT * FROM FINALIZADORAS WHERE TIPO_TRANSACAO = 1');
      QFinalizadora.Prepare;
      QFinalizadora.Open;

      Finalizadora_id.KeyValue := 1;
      Finalizadora_id.Enabled  := True;

    end;

    if COND_PAGTO.Text = 'A PRAZO' then
    begin

      QFinalizadora.Close;
      QFinalizadora.SQL.Clear;
      QFinalizadora.Sql.Add('SELECT * FROM FINALIZADORAS WHERE TIPO_TRANSACAO = 2');
      QFinalizadora.Prepare;
      QFinalizadora.Open;

      Finalizadora_id.KeyValue := QFinalizadora.FieldByName('FINALIZADORA_ID').AsInteger;
      Finalizadora_id.Enabled  := True;

      BANCO_ID.Value           := 0;
      FLUXO_CAIXA_ID.Value     := 0;
      BANCO_ID.Enabled         := False;
      FLUXO_CAIXA_ID.Enabled   := False;
      btnBanco.Enabled         := False;
      btnFluxoCaixa.Enabled    := False;





      //DetailSearch('');
    end;

    if Cond_pagto.Text = 'CARTAO' then
    Begin
      QFinalizadora.SQL.Clear;
      QFinalizadora.Sql.Add('SELECT * FROM FINALIZADORAS WHERE CLIENTE_ID > 0');
      QFinalizadora.Prepare;
      QFinalizadora.Open;


       BANCO_ID.Enabled        := True;
       FLUXO_CAIXA_ID.Enabled  := True;
       btnBanco.Enabled        := True;
       btnFluxoCaixa.Enabled   := True;

       Finalizadora_id.KeyValue := QFinalizadora.FieldByName('FINALIZADORA_ID').AsInteger;

       Finalizadora_id.Enabled := True;


    End;


  end;
End;



