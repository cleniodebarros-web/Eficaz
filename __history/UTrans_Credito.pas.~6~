procedure TFrmTrans_Credito.Set_Campos(Vazio: Boolean);
var
I: Integer;
Temp: TComponent;
begin
  for I := 0 to (ComponentCount - 1) do
  begin
    Temp := Components[I];

    if Vazio then
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := '';

      if Temp is TDateEdit then
        TDateEdit(Temp).Text := '';

      if Temp is TComboBox then
        TComboBox(Temp).Text := '';

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := 0;

      if Temp is TRxCalcEdit then
        TRxCalcEdit(Temp).Value := 0;

      if Temp is TDBLookupComboBox then
        TDBLookupComboBox(Temp).KeyValue := 0;
    end
    else
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := QTabela.FieldByName(TEdit(Temp).Name).AsString;

      if Temp is TDateEdit then
        TDateEdit(Temp).Text := QTabela.FieldByName(TDateEdit(Temp).Name).AsString;

      if Temp is TComboBox then
        TComboBox(Temp).Text := QTabela.FieldByName(TComboBox(Temp).Name).AsString;

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := QTabela.FieldByName(TCurrencyEdit(Temp).Name).AsFloat;

      if Temp is TRxCalcEdit then
        TRxCalcEdit(Temp).Value := QTabela.FieldByName(TRxCalcEdit(Temp).Name).AsFloat;

      if Temp is  TDBLookupComboBox then
         TDBLookupComboBox(Temp).KeyValue := QTabela.FieldByName(TMemo(Temp).Name).AsInteger;

      if QTabela.FieldByName('COMPLEMENTO').AsString = 'MENSALIDADE' then
      Chk_Mensalidade.Checked := True
      else
      Chk_Mensalidade.Checked := False;

    end;
  end;

  if (QTabela.FieldByName('OPERADOR').AsString <> '')  then
  begin
   IQuery.SQL.Clear;
   IQuery.SQL.Add('SELECT FUNCIONARIOS.NOME FROM OPERADORES');
   IQuery.SQL.Add('INNER JOIN FUNCIONARIOS ON FUNCIONARIOS.FUNCIONARIO_ID = OPERADORES.FUNCIONARIO_ID');
   IQuery.SQL.Add('WHERE CAST(OPERADOR_ID AS INTEGER) = CAST(:OPERADOR AS INTEGER)');
   IQuery.ParamByName('OPERADOR').AsString := QTabela.FieldByName('OPERADOR').AsString;
   IQuery.Prepare;
   IQuery.Open;

    Lbl_Funcionario.Visible := True;
    Lbl_Funcionario.Caption := 'Operador Caixa: ' + Copy(IQuery.FieldByName('NOME').AsString,1,15);
  end
  Else
  Begin
    Lbl_Funcionario.Visible := False;
    Lbl_Funcionario.Caption := '';
  End;



  DetailSearch('');

  CONDUTA.Text := '01';
  DEPTO.Text   := '03';
  TPCTB.Text   := FrmData.QAcesso.FieldByName('TPCTB').AsString;
end;

