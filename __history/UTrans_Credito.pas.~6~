     if Temp is TDBLookupComboBox then
    begin
      if Sql = 'UPDATE TRANSACOES SET ' then
        Sql := Sql + TDBLookupComboBox(Temp).Name + ' = :' + TDBLookupComboBox(Temp).Name
      else
        Sql := Sql + ', ' + TDBLookupComboBox(Temp).Name + ' = :' + TDBLookupComboBox(Temp).Name;
    end;
  end;

  Sql := Sql + ' WHERE (TRANSACAO_ID = :ID)';

  
