  begin
    QCusto.Close;

    QCusto.ParamByName('TABELA_ID').AsInteger := StrToInt(C_CUSTO_ID.Text);

    QCusto.Prepare;
    QCusto.Open;
  end;
 {
  if ((Tabela = '') or (Tabela = 'Patrimônio')) and (PATRIMONIO_ID.Text <> '') then
