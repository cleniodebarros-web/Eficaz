       Begin
         TRY


         QUpdate.Sql.Clear;
         QUpdate.Sql.ADD('UPDATE CLIENTES SET LIMITE_CR = ( LIMITE_CR +  :VALOR ) WHERE CLIENTE_ID =:CLIENTE_ID');
         QUpdate.ParamByName('CLIENTE_ID').AsInteger := StrToint(CLIENTE_ID.TEXT);
         QUpdate.ParamByName('VALOR').AsFloat        := Valor.Value;
         QUpdate.Prepare;
         QUpdate.ExecSql;

