  object QRel: TFDQuery
    Connection = FrmData.DbF_Eficaz
    FetchOptions.AssignedValues = [evAutoFetchAll]
    FetchOptions.AutoFetchAll = afTruncate
    SQL.Strings = (
      
        'SELECT "Eficaz_Logs".log.*,Funcionarios.Nome  from "Eficaz_Logs"' +
        '.log'
      
        'INNER JOIN FUNCIONARIOS ON "Eficaz_Logs".log.funcionario_id = fu' +
        'ncionarios.funcionario_id '
      'where tabela = :tabela and '
      'dt_log between :dt_inicial and :dt_final')
    Left = 8
    Top = 82
    ParamData = <
      item
        Name = 'TABELA'
        DataType = ftString
        ParamType = ptInput
        Value = ''
      end
      item
        Name = 'DT_INICIAL'
        DataType = ftDate
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'DT_FINAL'
        DataType = ftDate
        ParamType = ptInput
        Value = Null
      end>
  end
