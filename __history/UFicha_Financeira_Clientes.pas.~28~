procedure TFrmExtrato_Ficha_Financeira.btnClienteClick(Sender: TObject);
begin
   try
    Cliente.Value := GetConsulta('CLIENTES', 0, 0, StrToInt(Cliente.Text));
  except
    Cliente.Value := GetConsulta('CLIENTES', 0, 0, 0);
  end;
end;


procedure TFrmExtrato_Ficha_Financeira.SearchCliente;
begin
  QCliente.Close;
  QCliente.ParamByName('CLIENTE_ID').AsInteger := StrToInt(Cliente.Text);
  QCliente.Prepare;
  QCliente.Open;
end;


procedure TFrmExtrato_Ficha_Financeira.btnExecutaClick(Sender: TObject);
var
Gerencial: Boolean;
NomeCliente: String;
total_Multa: Real;
texto_fastrep: TfrxMemoView;
begin
// 125, 325
  try

    //if Cliente.Value = 0 then
    //abort;

    btnExecuta.Enabled := False;
    btnRetorna.Enabled := False;

    if Order_Data.Text = 'Histórico de saldo' then
    begin
      QRel.SQL.Clear;
      QRel.SQL.Add('WITH SALDO_ANT AS (');
      QRel.SQL.Add('SELECT SUM(VALOR_LANCADO) SALDO_ANTERIOR, CLIENTE_ID');
      QRel.SQL.Add('FROM CLIENTES_SALDO');
      QRel.SQL.Add('WHERE CLIENTE_ID = :CLIENTE_ID');
      QRel.SQL.Add('AND DT_SALDO < :DT_INI');
      QRel.SQL.Add('GROUP BY CLIENTE_ID');
      QRel.SQL.Add(')');
      QRel.SQL.Add('SELECT CS.VALOR_LANCADO, CS.DT_SALDO, CS.HORA_SALDO, CS.HISTORICO,');
      QRel.SQL.Add('C.NOME CLIENTE_NOME, C.SALDO_CONTA, F.NOME FUNCIONARIO_NOME, COALESCE(S.SALDO_ANTERIOR,0) SALDO_ANTERIOR');
      QRel.SQL.Add('FROM CLIENTES_SALDO CS');
      QRel.SQL.Add('INNER JOIN CLIENTES C');
      QRel.SQL.Add('ON CS.CLIENTE_ID = C.CLIENTE_ID');
      QRel.SQL.Add('LEFT JOIN SALDO_ANT S');
      QRel.SQL.Add('ON CS.CLIENTE_ID  = S.CLIENTE_ID');
      QRel.SQL.Add('INNER JOIN FUNCIONARIOS F');
      QRel.SQL.Add('ON CS.FUNCIONARIO_ID = F.FUNCIONARIO_ID');
      QRel.SQL.Add('WHERE CS.CLIENTE_ID = :CLIENTE_ID');
      QRel.SQL.Add('AND CS.DT_SALDO BETWEEN :DT_INI AND :DT_FIM');
      QRel.SQL.Add('ORDER BY CS.SALDO_ID');
      QRel.ParamByName('CLIENTE_ID').AsInteger := StrToInt(Cliente.Text);
      QRel.ParamByName('DT_INI').AsDate := Dtmen.Date;
      QRel.ParamByName('DT_FIM').AsDate := Dtmai.Date;
      QRel.Prepare;
      QRel.Open;

      if QRel.IsEmpty then
        Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
      else
      Begin
        try

         QLayoutFastReport.SQL.Clear;
         QLayoutFastReport.SQL.Add('SELECT NOME_ARQUIVO, ARQUIVO_RELATORIO FROM CONFIG_RELATORIOS');
         QLayoutFastReport.SQL.Add('WHERE NOME_RELATORIO = :NOME_RELATORIO');
         QLayoutFastReport.SQL.Add('OR NOME_RELATORIO = :BASE;');
         QLayoutFastReport.ParamByName('NOME_RELATORIO').AsString := 'USaldo_Cliente';
         QLayoutFastReport.ParamByName('BASE').AsString := 'base';
         QLayoutFastReport.Open();


        Except
        on e:Exception do
        begin
          Application.MessageBox(PChar('Erro:' + #13 +
            'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
        end;


        end;


        Relatorio_Principal.Clear;


        DadosRelatorio.Open;
        DadosRelatorio.EmptyDataSet;


        while not QRel.eof Do
        Begin
        DadosRelatorio.append;

        DadosRelatorio.FieldByName('CLIENTE_NOME').AsString     := QRel.FieldByName('CLIENTE_NOME').AsString;
        DadosRelatorio.FieldByName('HISTORICO').AsString        := QRel.FieldByName('HISTORICO').AsString;
        DadosRelatorio.FieldByName('FUNCIONARIO_NOME').AsString := QRel.FieldByName('FUNCIONARIO_NOME').AsString;
        DadosRelatorio.FieldByName('DT_SALDO').AsDateTime       := QRel.FieldByName('DT_SALDO').AsDateTime;
        DadosRelatorio.FieldByName('HORA_SALDO').AsDateTime     := QRel.FieldByName('HORA_SALDO').AsDateTime;
        DadosRelatorio.FieldByName('VALOR_LANCADO').AsFloat     := QRel.FieldByName('VALOR_LANCADO').AsFloat;
        DadosRelatorio.FieldByName('SALDO_CONTA').AsFloat       := QRel.FieldByName('SALDO_CONTA').AsFloat;


        DadosRelatorio.Post;

        QRel.Next;

        End;


        Relatorio_Principal.Clear;

        Relatorio_Principal.InheritFromTemplate('USaldo_Cliente.fr3');

        Relatorio_Principal := FrmPrincipal.Configura_Relatorio_FastReport(Relatorio_Principal, 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text, 'Histórico de Saldo');

        texto_fastrep:= TfrxMemoView(Relatorio_Principal.FindComponent('cabecalho_cliente'));
        if texto_fastrep <> nil then
        begin
            texto_fastrep.Text := QRel.FieldByName('CLIENTE_NOME').AsString;
        end;

        Relatorio_Principal.ShowReport(true);
      End;

      Exit;
    end;

    //Fim do histórico de saldo

    Saldo     := 0;
    Gerencial := True;

    try
      QRel.Sql.Clear;
      QRel.Sql.Add('SELECT TPCTB');
      QRel.Sql.Add('FROM TRANSITENS');

      QRel.Prepare;
      QRel.Open;
    except
      Gerencial := False;
    end;

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT TRANSACAO_ID, DT_EMISSAO, DT_PAGAMENTO, SAIDA_ID, CONDUTA, CLIENTE_ID, DT_ENT_SAI, NOME, CNPJ, TELEFONE_1, FAX,');
    QRel.Sql.Add('ENDERECO, NUMERO, MUNICIPIO, BAIRRO, ESTADO, DT_VENCIMENTO, DUPLICATA, ESPECIE, PAGTO, VALOR, VR_DESCONTO, VALOR_T, BANCO_ID, VALOR_ORI');
    QRel.Sql.Add('FROM (SELECT TRANSACOES.TRANSACAO_ID, NULL DT_EMISSAO, TRANSACOES.DT_TRANS DT_PAGAMENTO, TRANSACOES.NUM_DOC SAIDA_ID,');
    QRel.Sql.Add('TRANSACOES.CONDUTA, TRANSACOES.CLIENTE_ID, TRANSACOES.DT_ENT_SAI, CLIENTES.NOME, CLIENTES.CNPJ,');
    QRel.SQL.Add('CLIENTES.TELEFONE_1, CLIENTES.FAX, CLIENTES.ENDERECO, CLIENTES.NUMERO, CLIENTES.MUNICIPIO, CLIENTES.BAIRRO, CLIENTES.ESTADO,');
    QRel.SQL.Add('NULL DT_VENCIMENTO, NULL DUPLICATA, NULL ESPECIE, NULL PAGTO, TRANSACOES.VALOR, 0 VR_DESCONTO,  0 VALOR_T, 0 BANCO_ID, TRANSACOES1.VALOR VALOR_ORI');
    QRel.SQL.Add('FROM TRANSACOES AS TRANSACOES1');
    QRel.SQL.Add('INNER JOIN TRANSACOES on (TRANSACOES1.TRANSACAO_ID = TRANSACOES.SAIDA_ID)');
    QRel.SQL.Add('INNER JOIN CLIENTES on (TRANSACOES.CLIENTE_ID = CLIENTES.CLIENTE_ID)');

    if StrToInt(Cliente.Text) = 0 then
     QRel.SQL.Add('WHERE TRANSACOES.CLIENTE_ID <> 0');

    if StrToInt(Cliente.Text) > 0 then
    QRel.SQL.Add('WHERE TRANSACOES.CLIENTE_ID = :CLIENTE');



    QRel.SQL.Add('AND TRANSACOES.DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL');
    QRel.SQL.Add('AND TRANSACOES.CONDUTA = :CONDUTA ');
    QRel.SQL.Add('AND TRANSACOES.TPCTB = :TPCTB ');
    QRel.SQL.Add('AND TRANSACOES.BALANCO <> :BALANCO ');
    QRel.SQL.Add('UNION ALL');
    QRel.SQL.Add('SELECT TRANSACOES.TRANSACAO_ID, TRANSACOES.DT_TRANS DT_EMISSAO, NULL DT_PAGAMENTO, CAST(TRANSACOES.SAIDA_ID AS VARCHAR(10)),');
    QRel.SQL.Add('TRANSACOES.CONDUTA, TRANSACOES.CLIENTE_ID, TRANSACOES.DT_ENT_SAI, CLIENTES.NOME, CLIENTES.CNPJ,');
    QRel.SQL.Add('CLIENTES.TELEFONE_1, CLIENTES.FAX, CLIENTES.ENDERECO, CLIENTES.NUMERO, CLIENTES.MUNICIPIO, CLIENTES.BAIRRO, CLIENTES.ESTADO,');
    QRel.SQL.Add('DT_VENCIMENTO, DUPLICATA, TRANSPARCELAS.ESPECIE, PAGTO, 0 VALOR, TRANSACOES.VR_DESCONTO, TRANSPARCELAS.VALOR VALOR_T, TRANSPARCELAS.BANCO_ID, 0 VALOR_ORI');
    QRel.SQL.Add('FROM TRANSACOES');
    QRel.SQL.Add('INNER JOIN TRANSPARCELAS ON (TRANSPARCELAS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
    QRel.SQL.Add('INNER JOIN CLIENTES ON (TRANSACOES.CLIENTE_ID = CLIENTES.CLIENTE_ID)');

    if StrToInt(Cliente.Text) = 0 then
     QRel.SQL.Add('WHERE TRANSACOES.CLIENTE_ID <> 0');

    if StrToInt(Cliente.Text) > 0 then
    QRel.SQL.Add('WHERE TRANSACOES.CLIENTE_ID = :CLIENTE');


    QRel.SQL.Add('AND TRANSACOES.DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL');
    QRel.SQL.Add('AND TRANSACOES.CONDUTA = :CONDUTA_VENDA');
    QRel.SQL.Add('AND TRANSACOES.TPCTB = :TPCTB ');
    QRel.SQL.Add('AND (TRANSPARCELAS.AGRUPAMENTO = 0) OR (TRANSPARCELAS.AGRUPAMENTO IS NULL)');
    QRel.SQL.Add('AND (TRANSACOES.DEPTO = :DEPARTAMENTO OR TRANSACOES.DEPTO = :DEPARTAMENTO2)) AS TESTE');

    QRel.SQL.Add('WHERE DT_ENT_SAI BETWEEN :DT_INICIAL AND :DT_FINAL');

    if Order_Data.Text = 'Pagos' then
    Begin
      QRel.SQL.Add('AND CONDUTA = :CONDUTA');
    End;

    if Order_Data.Text = 'Em aberto' then
    Begin
      QRel.SQL.Add('AND BANCO_ID  = :BANCO_ID AND VALOR_T > 0 ');
    End;



    if (StrToInt(Cliente.Text) = 0) and (chk_dt_emissao.Checked = False) AND (chk_dt_vencimento.Checked = False) AND (chk_dt_pagamento.Checked = False) then
      QRel.SQL.Add('ORDER BY NOME, DT_ENT_SAI');

    if (StrToInt(Cliente.Text) = 0) and (chk_dt_emissao.Checked = True) then
      QRel.SQL.Add('ORDER BY NOME, DT_ENT_SAI');

    if (StrToInt(Cliente.Text) = 0) and (chk_dt_vencimento.Checked = True) then
      QRel.SQL.Add('ORDER BY NOME, DT_VENCIMENTO');

    if (StrToInt(Cliente.Text) = 0) and (chk_dt_pagamento.Checked = True) then
      QRel.SQL.Add('ORDER BY NOME, DT_PAGAMENTO');



    if  (StrToInt(Cliente.Text) <> 0) then
    Begin
     If chk_dt_emissao.Checked = True then
      QRel.SQL.Add('ORDER BY DT_ENT_SAI');

     If chk_dt_vencimento.Checked = True then
      QRel.SQL.Add('ORDER BY DT_VENCIMENTO');

     If chk_dt_pagamento.Checked = True then
      QRel.SQL.Add('ORDER BY DT_PAGAMENTO');
    End;


    QRel.ParamByName('DT_INICIAL').AsDateTime   := Dtmen.Date;
    QRel.ParamByName('DT_FINAL').AsDateTime     := Dtmai.Date;

    if StrToInt(Cliente.Text) > 0 then
    QRel.ParamByName('CLIENTE').AsInteger       := StrToInt(Cliente.Text);

    QRel.ParamByName('CONDUTA').AsString        := '07';
    QRel.ParamByName('DEPARTAMENTO').AsString   := '07';
    QRel.ParamByName('DEPARTAMENTO2').AsString  := '03';
    QRel.ParamByName('CONDUTA_VENDA').AsString  := '01';
    QRel.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;
    QRel.ParamByName('BALANCO').AsString        := 'AGRUPADO';

    if Order_Data.Text = 'Em aberto' then
    QRel.ParamByName('BANCO_ID').AsInteger := 0;

    QRel.Prepare;
    QRel.Open;


    if QRel.IsEmpty then
      Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
    else
     // Extrato.PreviewModal;
    Begin

     if CheckBox1.Checked = True then
         Begin
          RDprint1.Impressora := HP;
          RDprint1.FonteTamanhoPadrao := S10cpp;
         End;

          RDprint1.Orientacao:= poLandscape;
          RDprint1.TamanhoQteColunas:=180;
          RDprint1.OpcoesPreview.Preview     := True;
          RDprint1.MostrarProgresso          := True;
          RDprint1.Acentuacao                := SemAcento;
          RDprint1.TamanhoQteLinhas          := 1;
          RDprint1.Abrir;


            if linha > 66 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;

                  Pagina := 1;
                   Juros := 0;
            total_multa  := 0;
            NomeCliente  := '';


            QRel.first;
            while not QRel.Eof do
            Begin


             if (NomeCliente <> QRel.FieldByName('NOME').AsString) AND (StrToInt(Cliente.Text) = 0) then
            Begin
               Inc(linha);
               Inc(linha);


                if linha > 64 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;


               if NomeCliente <> '' then
               Begin

                   if linha > 64 then
                   begin
                    RDprint1.novapagina;
                    Pagina := Pagina + 1;
                   end;



                  RDprint1.Imp(linha, 61, 'Total Recebido: ');
                  RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Pago,[negrito]);
                  Inc(linha);

                  RDprint1.Imp(linha, 60, 'Total a Receber: ');
                  RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Receber,[negrito]);
                  Inc(linha);


                  RDprint1.Imp(linha, 70, 'Juros:');
                  RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Juros,[negrito]);
                  Inc(linha);

                  if linha > 64 then
                  begin
                    RDprint1.novapagina;
                    Pagina := Pagina + 1;
                  end;


                  RDprint1.Imp(linha, 70, 'Multa:');
                  RDprint1.impVal(linha, 80, '###,###,##0.00', total_multa,[negrito]);
                  Inc(linha);


                  RDprint1.Imp(linha, 64, 'Total Geral:');
                  RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Geral,[negrito]);
                  Inc(linha);
                  RDprint1.LinhaH(linha,01,180,0,false);
                  Inc(linha);
                  Inc(linha);

                  if linha > 64 then
                  begin
                     RDprint1.novapagina;
                     Pagina := Pagina + 1;
                  end;

                   Total_Pago     := 0;
                   Total_Receber  := 0;
                   Total_Juros    := 0;
                   Total_Geral    := 0;
                   total_multa    := 0;
               End;



               if linha > 64 then
               begin
                RDprint1.novapagina;
                Pagina := Pagina + 1;
               end;



               RDprint1.impF(linha, 01, QRel.FieldByName('NOME').AsString +' - CNPJ/CPF: '+ QRel.FieldByName('CNPJ').AsString, [negrito]);
               Inc(linha);
               RDprint1.Imp(linha, 01, 'Telefone:'+ QRel.FieldByName('TELEFONE_1').AsString);
               Inc(linha);
               RDprint1.Imp(linha, 01, 'Endereço: ' + QRel.FieldByName('ENDERECO').AsString  + ', ' + QRel.FieldByName('NUMERO').AsString);
               Inc(linha);
               RDprint1.Imp(linha, 01, 'Bairro: '+ QRel.FieldByName('BAIRRO').AsString + ' - Município: ' + QRel.FieldByName('MUNICIPIO').AsString + ' ' + QRel.FieldByName('ESTADO').AsString );
               Inc(linha);

               if linha > 64 then
                begin
                  RDprint1.novapagina;
                  Pagina := Pagina + 1;
                end;


               RDprint1.LinhaH(linha,01,180,0,false);
               Inc(linha);
                RDprint1.Imp(linha, 01, 'Dt. Emissăo');
                RDprint1.Imp(linha, 14, 'Nş Doc');
                RDprint1.Imp(linha, 27, 'Vr em Aberto');
                RDprint1.Imp(linha, 44, 'Juros');
                RDprint1.Imp(linha, 59, 'Multa');
                RDprint1.Imp(linha, 78, 'Desconto');
                RDprint1.Imp(linha, 98, 'Vencimento');
                RDprint1.Imp(linha, 116, 'Pagamento');
                RDprint1.Imp(linha, 130, 'Valor Pago');
                RDprint1.Imp(linha, 146, 'Valor Original');
                RDprint1.Imp(linha, 165, 'Total');
                RDprint1.Imp(linha, 173, 'Espécie');


           if linha > 66 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;


               Inc(linha);
               NomeCliente := QRel.FieldByName('NOME').AsString;
            End; 

            Juros  := 0;
            Dif    := 0;
            Correc := 0;
            Total  := 0;
            Multa  := 0;


            if QRel.FieldByName('DT_VENCIMENTO').AsString <> ''  then
             Begin
              if (QRel.FieldByName('DT_VENCIMENTO').AsDateTime < FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime) AND (QRel.FieldByName('ESPECIE').AsString <> 'RESTANTE') then
              Begin
              Multa  := (((QRel.FieldByName('VALOR_T').AsFloat + QRel.FieldByName('VALOR_ORI').AsFloat) * FrmPrincipal.Config.FieldByName('MULTA').AsFloat) / 100);
              Multa  := RoundTo(Multa, -2);
              End;

              if QRel.FieldByName('DT_VENCIMENTO').AsDateTime < FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime then
              Begin
              Dif:= FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime - QRel.FieldByName('DT_VENCIMENTO').AsDateTime;
              Correc := (((((QRel.FieldByName('VALOR_T').AsFloat + QRel.FieldByName('VALOR_ORI').AsFloat)  * FrmPrincipal.Config.FieldByName('JUROS_MENSAL').AsFloat) / 100) / 30) * Dif);
              Correc := RoundTo(Correc, -2);
              End;
             End;
             Juros := Correc ;

             if QRel.FieldByName('CONDUTA').AsString <> '07' then
             Total := ((QRel.FieldByName('VALOR_T').AsFloat  + Juros + Multa) - QRel.FieldByName('VR_DESCONTO').AsFloat);

            RDprint1.imp(linha, 01, QRel.FieldByName('DT_ENT_SAI').AsString);

            if QRel.FieldByName('CONDUTA').AsString = '07' then
             RDprint1.imp(linha, 13, QRel.FieldByName('SAIDA_ID').AsString)
            else
             RDprint1.imp(linha, 13, QRel.FieldByName('DUPLICATA').AsString);

            RDprint1.impVal(linha, 31, '#,##0.00',QRel.FieldByName('VALOR_T').AsFloat,[]);
            RDprint1.impVal(linha, 41, '#,##0.00', Juros,[]);
            RDprint1.impVal(linha, 56, '#,##0.00', Multa,[]);
            RDprint1.impVal(linha, 77, '#,##0.00', QRel.FieldByName('VR_DESCONTO').AsFloat,[]);

            if not QRel.FieldByName('DT_VENCIMENTO').IsNull then
               RDprint1.impF(linha, 98,QRel.FieldByName('DT_VENCIMENTO').AsString,[]);

            if QRel.FieldByName('DT_PAGAMENTO').AsString <>'' then
             RDprint1.impF(linha, 115, DateToStr(QRel.FieldByName('DT_PAGAMENTO').AsDateTime),[]);

            if QRel.FieldByName('CONDUTA').AsString = '07' then
             RDprint1.impVal(linha, 132, '#,##0.00', QRel.FieldByName('VALOR').AsFloat,[])
             else
             RDprint1.impVal(linha, 132, '#,##0.00', strToFloat('0,00'),[]);


            RDprint1.impVal(linha, 152, '#,##0.00', QRel.FieldByName('VALOR_ORI').AsFloat,[]);

            RDprint1.impVal(linha, 162, '#,##0.00', Total,[]);
            RDprint1.impD(linha, 180, QRel.FieldByName('ESPECIE').AsString,[]);

            if linha > 64 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;



           Total_Pago    := Total_Pago + QRel.FieldByName('VALOR').AsFloat;
           Total_Receber := Total_Receber + QRel.FieldByName('VALOR_T').AsFloat;

           if QRel.FieldByName('CONDUTA').AsString <> '07' then
           Total_Juros   := Total_Juros + Juros;


           total_multa:= total_multa + Multa;

           Total_Geral   := Total_Receber + Total_Juros + total_multa;

           Inc(linha);
           QRel.next;

           End;

          if linha > 64 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;

        RDprint1.LinhaH(linha,01,180,0,false);
        Inc(linha);
        if linha > 64 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;

        Inc(linha);
        RDprint1.Imp(linha, 61, 'Total Recebido: ');
        RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Pago,[negrito]);
        Inc(linha);

        RDprint1.Imp(linha, 60, 'Total a Receber: ');
        RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Receber,[negrito]);
        Inc(linha);

         if linha > 64 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;

        RDprint1.Imp(linha, 70, 'Juros:');
        RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Juros,[negrito]);
        Inc(linha);


        if linha > 64 then
            begin
              RDprint1.novapagina;
              Pagina := Pagina + 1;
            end;

        RDprint1.Imp(linha, 70, 'Multa:');
        RDprint1.impVal(linha, 80, '###,###,##0.00', total_multa,[negrito]);
        Inc(linha);


        RDprint1.Imp(linha, 64, 'Total Geral:');
        RDprint1.impVal(linha, 80, '###,###,##0.00', Total_Geral,[negrito]);
        Inc(linha);

        RDprint1.LinhaH(linha,01,180,0,false);
        Inc(linha);

        Total_Pago    := 0;
        Total_Receber := 0;
        Total_Juros   := 0;
        Total_Geral   := 0;
        total_multa :=0;

        Application.ProcessMessages;
        RDprint1.TamanhoQteLinhas:= 66;
        RDprint1.Fechar;
        Qrel.Close;
    End;

  finally
    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;
end;


