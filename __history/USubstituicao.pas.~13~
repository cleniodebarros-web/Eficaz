procedure TFrmSubstituicao.btnExecutaClick(Sender: TObject);
var
T_Id, P_Id: Integer;
begin
  if PageControl2.ActivePage <> TabSheet5 then
    Exit;

  if Valida_Veiculo then
  begin
    T_Id   := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
    P_Id   := QTabela.FieldByName('PRODUTO_ID').AsInteger;

    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT TRANSACAO_ID, PRODUTO_ID FROM TRANSITENS_VEICULO WHERE TRANSACAO_ID = :TRANSACAO_ID AND PRODUTO_ID = :PRODUTO_ID');
    IQuery.ParamByName('TRANSACAO_ID').AsInteger := T_Id;
    IQuery.ParamByName('PRODUTO_ID').AsInteger   := P_Id;
    IQuery.Prepare;
    IQuery.Open;

    if IQuery.Eof then
    begin
      IQuery.SQL.Clear;
      IQuery.SQL.Add('INSERT INTO TRANSITENS_VEICULO (');
      IQuery.SQL.Add('TRANSACAO_ID, PRODUTO_ID, TPOP, CHASSI, CCOR, XCOR, POT, CILIN, PESOL, PESOB, NSERIE, TPCOMB, NMOTOR, CMT, DIST,');
      IQuery.SQL.Add('ANOMOD, ANOFAB, TPPINT, TPVEIC, ESPVEIC, VIN, CONDVEIC, CMOD, CCORDENATRAN, LOTA, TPREST');
      IQuery.SQL.Add(') VALUES (');
      IQuery.SQL.Add(':TRANSACAO_ID, :PRODUTO_ID, :TPOP, :CHASSI, :CCOR, :XCOR, :POT, :CILIN, :PESOL, :PESOB, :NSERIE, :TPCOMB, :NMOTOR, :CMT, :DIST,');
      IQuery.SQL.Add(':ANOMOD, :ANOFAB, :TPPINT, :TPVEIC, :ESPVEIC, :VIN, :CONDVEIC, :CMOD, :CCORDENATRAN, :LOTA, :TPREST');
      IQuery.SQL.Add(')');
    end
    else
    begin
      IQuery.SQL.Clear;
      IQuery.SQL.Add('UPDATE TRANSITENS_VEICULO SET');
      IQuery.SQL.Add('TPOP = :TPOP, CHASSI = :CHASSI, CCOR = :CCOR, XCOR = :XCOR, POT = :POT, CILIN = :CILIN, PESOL = :PESOL,');
      IQuery.SQL.Add('PESOB = :PESOB, NSERIE = :NSERIE, TPCOMB = :TPCOMB, NMOTOR = :NMOTOR, CMT = :CMT, DIST = :DIST,');
      IQuery.SQL.Add('ANOMOD = :ANOMOD, ANOFAB = :ANOFAB, TPPINT = :TPPINT, TPVEIC = :TPVEIC, ESPVEIC = :ESPVEIC, VIN = :VIN,');
      IQuery.SQL.Add('CONDVEIC = :CONDVEIC, CMOD = :CMOD, CCORDENATRAN = :CCORDENATRAN, LOTA = :LOTA, TPREST = :TPREST');
      IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID AND PRODUTO_ID = :PRODUTO_ID');
    end;

    IQuery.ParamByName('TRANSACAO_ID').AsInteger := T_Id;
    IQuery.ParamByName('PRODUTO_ID').AsInteger   := P_Id;
    IQuery.ParamByName('TPOP').AsInteger         := StrToInt(Copy(TipoOperacao.Text,1,1));
    IQuery.ParamByName('CHASSI').AsString        := Chassi.Text;
    IQuery.ParamByName('CCOR').AsString          := CodCorMontadora.Text;
    IQuery.ParamByName('XCOR').AsString          := DescricaoCor.Text;
