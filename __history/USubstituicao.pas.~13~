procedure TFrmSubstituicao.FormShow(Sender: TObject);
begin
  TabSheet3.Show;

  Display_Campos;

  Inconsistencias;


  if  (QTabela.FieldByName('TIPO_IMP').Value <> 2) then
    desc_rodape.ReadOnly := False;

  if not ((Existe_Recebimento(QTabela.FieldByName('TRANSACAO_ID').AsInteger)) or (Existe_Pagamento(QTabela.FieldByName('TRANSACAO_ID').AsInteger)))  then
    CST_IPI.SetFocus;

  if FrmPrincipal.Config.FieldByName('VENDA_VEICULOS_NOVOS').AsString = 'True' then
  begin
    TabSheet5.TabVisible := True;
    PageControl2.ActivePage := TabSheet5;
    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT * FROM TRANSITENS_VEICULO WHERE TRANSACAO_ID = :TRANSACAO_ID AND PRODUTO_ID = :PRODUTO_ID');
    IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
    IQuery.ParamByName('PRODUTO_ID').AsInteger   := QTabela.FieldByName('PRODUTO_ID').AsInteger;
    IQuery.Prepare;
    IQuery.Open;

    if not IQuery.Eof then
    begin
      TipoOperacao.ItemIndex       := BuscaIndex(TipoOperacao.Items, IQuery.FieldByName('TPOP').AsString);
      Chassi.Text                  := IQuery.FieldByName('CHASSI').AsString;
      CodCorMontadora.Text         := IQuery.FieldByName('CCOR').AsString;
      DescricaoCor.Text            := IQuery.FieldByName('XCOR').AsString;
      Potencia.Text                := IQuery.FieldByName('POT').AsString;
      Cilindradas.Text             := IQuery.FieldByName('CILIN').AsString;
      PesoLiquido.Value            := IQuery.FieldByName('PESOL').AsFloat;
      PesoBruto.Value              := IQuery.FieldByName('PESOB').AsFloat;
      NumeroSerie.Text             := IQuery.FieldByName('NSERIE').AsString;
      TipoCombustivel.ItemIndex    := BuscaIndex(TipoCombustivel.Items, IQuery.FieldByName('TPCOMB').AsString);
      NumeroMotor.Text             := IQuery.FieldByName('NMOTOR').AsString;
      CapacidadeMaximaTracao.Value := IQuery.FieldByName('CMT').AsFloat;
      DistanciaEixos.Text          := IQuery.FieldByName('DIST').AsString;
      AnoModelo.Value              := IQuery.FieldByName('ANOMOD').AsInteger;
      AnoFabricacao.Value          := IQuery.FieldByName('ANOFAB').AsInteger;
      TipoPintura.ItemIndex        := BuscaIndex(TipoPintura.Items, IQuery.FieldByName('TPPINT').AsString);
      TipoVeiculo.ItemIndex        := BuscaIndex(TipoVeiculo.Items, StrZero(IQuery.FieldByName('TPVEIC').AsString,2,0));
      EspecieVeiculo.ItemIndex     := BuscaIndex(EspecieVeiculo.Items, IQuery.FieldByName('ESPVEIC').AsString);
      VIN.ItemIndex                := BuscaIndex(VIN.Items, IQuery.FieldByName('VIN').AsString);
      CondicaoVeiculo.ItemIndex    := BuscaIndex(CondicaoVeiculo.Items, IQuery.FieldByName('CONDVEIC').AsString);
      CodigoMarcaModelo.Text       := IQuery.FieldByName('CMOD').AsString;
      CodCorDenatran.ItemIndex     := BuscaIndex(CodCorDenatran.Items, IQuery.FieldByName('CCORDENATRAN').AsString);
      LotacaoMaxima.Value          := IQuery.FieldByName('LOTA').AsInteger;
      Restricao.ItemIndex          := BuscaIndex(Restricao.Items, IQuery.FieldByName('TPREST').AsString);
    end;
  end
  else
    TabSheet5.TabVisible := False;

end;

function BuscaIndex(Lista:TStrings; Item:String):Integer;
var aux: string;
begin
  Result := -1;
  for aux in Lista do
  begin
    if Item = Copy(aux,1,Item.Length) then
    begin
      Result := Lista.IndexOf(aux);
      Break;
    end;
  end;
end;

end.
