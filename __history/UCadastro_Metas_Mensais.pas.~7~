  if (Key = Vk_F7) and (Sender = VENDEDOR_ID2V) then
    btnVendedor3Click(Self);

  //if (Key = Vk_F7) and (Sender = VENDEDOR_ID_2) then
  //  btnVendedor_2Click(Self);

