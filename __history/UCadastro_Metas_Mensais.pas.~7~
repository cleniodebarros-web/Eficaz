total_material_laboratorio, total_material_limpeza, total_manutencao_veiculos, total_outros_servicos, total_marketing , total_consultoria, total_despesas_operacionais, total_reformas, total_manutencao_sites, total_correios, total_fretes ,total_telefone:real;
total_parcelamento_municipal, total_ipva, total_iptu , total_inss, total_fgts, total_taxas_incendio, total_alvara_funcionamento, total_parcelamento_estadual, total_parcelamento_inss, total_salarios_colaboradores,total_colaboradores_operacionais,total_DECIMO_TERCEIRO:real;
total_ferias,	total_recisoes, 	total_pro_labore, 	total_despesas_pessoal, 	total_sindicato, total_Serasa, total_despesa:real;
begin
  // 255, 325
  //SQL RECEITAS ARILMAQ

  QSearch.sql.Clear;
  QSearch.Sql.Add('SELECT * FROM FECHAMENTO_MENSAL_METAS WHERE DT_INICIAL = :DT_INICIAL AND DT_FINAL = :DT_FINAL ');
  Qsearch.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
  Qsearch.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;

  QSearch.Prepare;
  QSearch.Open;

  IF QSearch.IsEmpty Then
  Begin
      QInsert.SQL.Clear;
      QInsert.SQL.Add('SELECT NEXTVAL(:GEN_FECHAMENTO_MENSAL) ID');
      QInsert.ParamByName('GEN_FECHAMENTO_MENSAL').AsString :=  'GEN_FECHAMENTO_MENSAL';

      QInsert.Prepare;
      QInsert.Open;

      Id_Fechamento := QInsert.FieldByName('ID').AsInteger;


      QSearch.sql.Clear;
      QSearch.Sql.Add('SELECT EMPRESA_ID FROM EMPRESAS WHERE STATUS = ''A'' ');

      QSearch.Prepare;
      QSearch.Open;
      QSearch.First;

    IF QSearch.IsEmpty Then
    Begin

     while not QSearch.eof do
     Begin

       if QSearch.FieldByName('EMPRESA_ID_MATRIZ').AsInteger = 1 Then
       Begin
         try

          QInsert.Sql.Clear;
          QInsert.Sql.Add('INSERT INTO FECHAMENTO_MENSAL_METAS (FECHAMENTO_MENSAL_METAS_ID,EMPRESA_ID , DT_INICIAL,DT_FINAL,VENDEDOR_ID,VENDEDOR_ID2,META_S,SUPER_META_S,DESAFIO_S,');
          QInsert.Sql.Add('VR_APURADO_S, META_P ,SUPER_META_P,DESAFIO_P,VR_APURADO_P, META_V, SUPER_META_V,DESAFIO_V,VR_APURADO_V,COMISSAO)');
          QInsert.Sql.Add('VALUES(:FECHAMENTO_MENSAL_METAS_ID,:EMPRESA_ID , :DT_INICIAL,:DT_FINAL,:VENDEDOR_ID,:VENDEDOR_ID2,:META_S,:SUPER_META_S,:DESAFIO_S,');
          QInsert.Sql.Add(':VR_APURADO_S, :META_P ,:SUPER_META_P,:DESAFIO_P,:VR_APURADO_P, :META_V, :SUPER_META_V,:DESAFIO_V,:VR_APURADO_V,:COMISSAO)');


          QInsert.ParamByName('FECHAMENTO_MENSAL_ID').AsInteger   := Id_Fechamento;
          QInsert.ParamByName('EMPRESA_ID').AsInteger             := QSearch.FieldByName('EMPRESA').AsInteger;
          QInsert.ParamByName('DT_INICIAL').AsDateTime            := Dtmen.Date;
          QInsert.ParamByName('DT_FINAL').AsDateTime              := Dtmai.Date;
          QInsert.ParamByName('VENDEDOR_ID').AsInteger            := StrToInt(Vendedor_id1_ps.Text);
          QInsert.ParamByName('VENDEDOR_ID2').AsInteger           := StrToInt(Vendedor_id1_v.Text);
          QInsert.ParamByName('META_S').AsFloat                   := StrToFloat(Meta_s1.Text);
          QInsert.ParamByName('SUPER_META_S').AsFloat             := StrToFloat(Super_Meta_s1.Text);
          QInsert.ParamByName('DESAFIO_S').AsFloat                := StrToFloat(Desafio_s1.Text);
          QInsert.ParamByName('VR_APURADO_S').AsFloat             := StrToFloat(Vr_Apurado_s1.Text);
          QInsert.ParamByName('META_P').AsFloat                   := StrToFloat(Meta_p1.Text);
          QInsert.ParamByName('SUPER_META_P').AsFloat             := StrToFloat(Super_Meta_p1.Text);
          QInsert.ParamByName('DESAFIO_P').AsFloat                := StrToFloat(Desafio_p1.Text);
          QInsert.ParamByName('VR_APURADO_P').AsFloat             := StrToFloat(Vr_Apurado_p1.Text);
          QInsert.ParamByName('META_V').AsFloat                   := StrToFloat(Meta_v1.Text);
          QInsert.ParamByName('SUPER_META_V').AsFloat             := StrToFloat(Super_Meta_v1.Text);
          QInsert.ParamByName('DESAFIO_V').AsFloat                := StrToFloat(Desafio_v1.Text);
          QInsert.ParamByName('VR_APURADO_V').AsFloat             := StrToFloat(Vr_Apurado_v1.Text);
          QInsert.ParamByName('META_V2').AsFloat                  := StrToFloat(Meta_v1_2.Text);
          QInsert.ParamByName('SUPER_META_V2').AsFloat            := StrToFloat(Super_Meta_v1_2.Text);
          QInsert.ParamByName('DESAFIO_V2').AsFloat               := StrToFloat(Desafio_v1_2.Text);
          QInsert.ParamByName('VR_APURADO_V2').AsFloat            := StrToFloat(Vr_Apurado_v1_2.Text);

          QInsert.Prepare;
          QInsert.ExecSQL;
         except

            on e:Exception do
            begin
              Application.MessageBox(PChar('Erro gravar METAS 01:' + #13 +
                'Erro: ' + e.Message), 'Erro', MB_ICONSTOP + MB_TASKMODAL);
            end;


         end;
       End
       Else if QSearch.FieldByName('EMPRESA_ID_MATRIZ').AsInteger = 2 Then
       Begin
         try

          QInsert.Sql.Clear;
          QInsert.Sql.Add('INSERT INTO FECHAMENTO_MENSAL_METAS (FECHAMENTO_MENSAL_METAS_ID,EMPRESA_ID , DT_INICIAL,DT_FINAL,VENDEDOR_ID,VENDEDOR_ID2,META_S,SUPER_META_S,DESAFIO_S,');
          QInsert.Sql.Add('VR_APURADO_S, META_P ,SUPER_META_P,DESAFIO_P,VR_APURADO_P, META_V, SUPER_META_V,DESAFIO_V,VR_APURADO_V)');
          QInsert.Sql.Add('VALUES(:FECHAMENTO_MENSAL_METAS_ID,:EMPRESA_ID , :DT_INICIAL,:DT_FINAL,:VENDEDOR_ID,:VENDEDOR_ID2,:META_S,:SUPER_META_S,:DESAFIO_S,');
          QInsert.Sql.Add(':VR_APURADO_S, :META_P ,:SUPER_META_P,:DESAFIO_P,:VR_APURADO_P, :META_V, :SUPER_META_V,:DESAFIO_V,:VR_APURADO_V,:COMISSAO)');


          QInsert.ParamByName('FECHAMENTO_MENSAL_ID').AsInteger   := Id_Fechamento;
