procedure TFrmCadastro_metas.DetailSearch(Tabela: String);
begin

  if ((Tabela = '') or (Tabela = 'Vendedor1')) and (VENDEDOR_ID1_PS.Text <> '') then
  begin
    QVendedor.Close;
    QVendedor.ParamByName('FUNCIONARIO_ID').AsInteger := StrToInt(VENDEDOR_ID1_PS.Text);
    QVendedor.Prepare;
    QVendedor.Open;

  end;
  if ((Tabela = '') or (Tabela = 'Vendedor2')) and (VENDEDOR_ID1_V.Text <> '') then
  begin

    QVendedor_2.Close;
    QVendedor_2.ParamByName('FUNCIONARIO_ID').AsInteger := StrToInt(VENDEDOR_ID1_V.Text);
    QVendedor_2.Prepare;
    QVendedor_2.Open;
  end;

  if ((Tabela = '') or (Tabela = 'Vendedor3')) and (VENDEDOR_ID2V.Text <> '') then
  begin
    QVendedor_3.Close;
    QVendedor_3.ParamByName('FUNCIONARIO_ID').AsInteger := StrToInt(VENDEDOR_ID2V.Text);
    QVendedor_3.Prepare;
    QVendedor_3.Open;
  end;
end;

