procedure TFrmRel_Orcamentos.btnExecutaClick(Sender: TObject);
begin
// 125, 325
  try
    btnExecuta.Enabled := False;
    btnRetorna.Enabled := False;

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT ORCAMENTOS.*, FUNCIONARIOS.NOME VENDEDOR');
    QRel.Sql.Add('FROM ORCAMENTOS');
    QRel.Sql.Add('LEFT JOIN FUNCIONARIOS');
    QRel.Sql.Add('ON (ORCAMENTOS.VENDEDOR_ID = FUNCIONARIOS.FUNCIONARIO_ID)');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(ORCAMENTOS.DT_ORCAMENTO BETWEEN :DT_INICIAL AND :DT_FINAL)');
    QRel.Sql.Add('AND (ORCAMENTOS.EMPRESA_ID = :EMPRESA_ID)');
    QRel.Sql.Add('AND (ORCAMENTOS.COMANDA IS NULL)');

    if Cond_pagto.Text <> '' then
    QRel.Sql.Add('AND (COND_PAGTO = :COND_PAGTO)');

    if Tipo_Orcamento.Text = 'Orc. Agrupados' then
      QRel.Sql.Add('AND (ORCAMENTOS.TRANSACAO_ID > 0)');

    if Tipo_Orcamento.Text = 'Orc. n/ Agrupados' then
      QRel.Sql.Add('AND ((ORCAMENTOS.TRANSACAO_ID = 0) OR (ORCAMENTOS.TRANSACAO_ID IS NULL))');
    
    QRel.Sql.Add('ORDER BY ORCAMENTOS.COND_PAGTO, ORCAMENTOS.ORCAMENTO_ID, ORCAMENTOS.DT_ORCAMENTO');

    QRel.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
    QRel.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
    QRel.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

    if Cond_pagto.Text <> '' then
    QRel.ParamByName('COND_PAGTO').AsString :=  Cond_pagto.Text;

    QRel.Prepare;
    QRel.Open;

    QRLabel1.Caption := 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text;

    if QRel.IsEmpty then
      Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
    else
      Orcamentos.PreviewModal;
  finally
    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;
end;

