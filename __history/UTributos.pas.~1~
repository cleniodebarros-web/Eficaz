  Result := False;

  DESCRICAO.Color  := clWindow;
  ORIGEM.Color     := clWindow;
  TRIBUTACAO.Color := clWindow;
  CFOP.Color       := clWindow;

  if (ORIGEM.Text <> '0-NACIONAL') and (ORIGEM.Text <> '1-ESTRANGEIRA-IMPORTAﾇﾃO DIRETA') and (ORIGEM.Text <> '2-ESTRANGEIRA-ADQUIRIDA NO MERCADO INTERNO') and
     (ORIGEM.Text <> '3-NACIONAL- MERCADORIA OU BEM  COM CONT. IMPORTACAO') and (ORIGEM.Text <> '4-NACIONAL-DECRETO 288/67 E LEIS 8248/91,8387/91,10176/01,11484/07') and
     (ORIGEM.Text <> '5-NACIONAL-CONTEUDO IMPORTﾇﾃO INFERIOR OU IGUAL 40%') and (ORIGEM.Text <> '6-ESTRANGEIRA-IMP. DIRETA SEM SIMILAR NACIONAL RESOLUﾇﾃO CAMEX') and
     (ORIGEM.Text <> '7-ESTRANGEIRA-ADQ. MERCAD. INTERNO SEM SIMILAR NACIONAL RES. CAMEX') then
  begin
    Application.MessageBox('Origem Mercadoria', PChar(Msg_Title), mb_IconStop);
    ORIGEM.Color := clYellow;
    ORIGEM.SetFocus;
    exit;
  end;

  if (TRIBUTACAO.Text <> '00-TRIBUTADA INTEGRALMENTE') and (TRIBUTACAO.Text <> '10-TRIBUTADO E C/ COBR. DO ICMS P/ ST') and (TRIBUTACAO.Text <> '20-COM REDUﾇﾃO DE BASE DE CﾁLCULO') and
     (TRIBUTACAO.Text <> '30-ISENTA OU N/ TRIB. E C/ COBR. DO ICMS P/ ST') and (TRIBUTACAO.Text <> '40-ISENTA') and (TRIBUTACAO.Text <> '41-NﾃO TRIBUTADA') and (TRIBUTACAO.Text <> '50-SUSPENSﾃO') and
     (TRIBUTACAO.Text <> '51-DIFERIMENTO') and (TRIBUTACAO.Text <> '60-ICMS COBRADO ANT. P/ ST') and (TRIBUTACAO.Text <> '70-C/ RED. DE B. DE CﾁLC. E COBR. DO ICMS P/ ST') and (TRIBUTACAO.Text <> '90-OUTRAS') then
  begin
    Application.MessageBox('Trib. Pelo ICMS inv疝ido', PChar(Msg_Title), mb_IconStop);
    TRIBUTACAO.Color := clYellow;
    TRIBUTACAO.SetFocus;
    exit;
  end;

  if DESCRICAO.Text = '' then
  begin
    Application.MessageBox('Informe a Descri鈬o', PChar(Msg_Title), mb_IconStop);
    DESCRICAO.Color := clYellow;
    DESCRICAO.SetFocus;
    exit;
  end;

  if QCFOP.IsEmpty then
  begin
    Application.MessageBox('CFOP inexistente', PChar(Msg_Title), mb_IconStop);
    CFOP.Color := clYellow;
    CFOP.SetFocus;
    exit;
  end;

  Result := True;
end;

procedure TFrmTributos.ManutencaoShow(Sender: TObject);
begin
  Set_Campos(False);
  Botoes_Normal;
end;

procedure TFrmTributos.Set_Campos(Vazio: Boolean);
var
I: Integer;
Temp: TComponent;
begin
  for I := 0 to (ComponentCount - 1) do
  begin
    Temp := Components[I];

    if Vazio then
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := '';

      if Temp is TComboBox then
        TComboBox(Temp).Text := '';

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := 0;
    end
    else
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := QTabela.FieldByName(TEdit(Temp).Name).AsString;

      if Temp is TComboBox then
        TComboBox(Temp).Text := QTabela.FieldByName(TComboBox(Temp).Name).AsString;

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := QTabela.FieldByName(TCurrencyEdit(Temp).Name).AsFloat;
    end;
  end;
end;

procedure TFrmTributos.btnDeleteClick(Sender: TObject);
begin
  if FrmData.QAcesso.FieldByName('EXCLUSAO').AsString = 'NﾃO' then
  begin
    Application.MessageBox('Usu疵io sem permiss縊 para exclus縊', PChar(Msg_Title), mb_IconStop);
    exit;
  end;

  if Application.MessageBox('Deseja realmente excluir?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
  begin


    IQuery.Sql.Clear;
    IQuery.Sql.Add('DELETE FROM TRIBUTOS');
    IQuery.Sql.Add('WHERE');
    IQuery.Sql.Add('(TRIBUTO_ID = :ID)');

    IQuery.ParamByName('ID').AsInteger := QTabela.FieldByName('TRIBUTO_ID').AsInteger;

    IQuery.Prepare;
    IQuery.ExecSql;

    QTabela.Close;
    QTabela.Open;
    Set_Campos(False);
    Botoes_Normal;
  end;
end;

