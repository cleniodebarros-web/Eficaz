procedure TFrmTributos.DetailSearch(Tabela: String);
begin
  if ((Tabela = '') or (Tabela = 'CFOP')) and (CFOP.Text <> '') then
  begin
    QCFOP.Close;
    QCFOP.ParamByName('COD_CFOP').AsString := CFOP.Text;
    QCFOP.Prepare;
    QCFOP.Open;
  end;
end;

