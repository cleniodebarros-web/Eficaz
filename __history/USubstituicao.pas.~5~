procedure TFrmSubstituicao.DBEdit1KeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if (Key = Vk_F7) and (Sender = CST_PIS) then
    btnCst_PisClick(Self);

  if (Key = Vk_F7) and (Sender = CST_COFINS) then
    btnCst_CofinsClick(Self);

  if (Key = Vk_F7) and (Sender = CST_IPI) then
    btnCst_IpiClick(Self);

  if (Key = Vk_Return) or (Key = Vk_Down) then
    Perform(Wm_NextDlgctl, 0, 0);

  if Key = Vk_Up then
    Perform(Wm_NextDlgctl, 1, 0);
end;

