procedure TFrmSubstituicao.btnEditClick(Sender: TObject);
var
T_Id, P_Id: Integer;
T_Prod: String;
begin
  T_Id   := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
  P_Id   := QTabela.FieldByName('PRODUTO_ID').AsInteger;
  T_Prod := QTabela.FieldByName('TP_PROD_SERV').AsString;

  IQuery.Sql.Clear;
  IQuery.Sql.Add('UPDATE TRANSITENS SET BASE_CALC_ICMS = :BASE_CALC_ICMS, ' +
                                        'VALOR_ICMS = :VALOR_ICMS, ' +
                                        'BASE_CALC_ST = :BASE_CALC_ST, ' +
                                        'VALOR_ISENTO = :VALOR_ISENTO, ' +
                                        'VALOR_OUTROS = :VALOR_OUTROS, ' +
                                        'VR_REDUCAO_BC = :VR_REDUCAO_BC, ' +
                                        'CST_IPI = :CST_IPI, ' +
                                        'ALIQUOTA_ST = :ALIQUOTA_ST, ' +
                                        'CST_PIS = :CST_PIS, ' +
                                        'BASE_CALC_PIS = :BASE_CALC_PIS, ' +
                                        'ALIQUOTA_PIS = :ALIQUOTA_PIS, ' +
                                        'VR_PIS = :VR_PIS, ' +
                                        'CST_COFINS = :CST_COFINS, ' +
                                        'BASE_CALC_COFINS = :BASE_CALC_COFINS, ' +
                                        'ALIQUOTA_COFINS = :ALIQUOTA_COFINS, ' +
                                        'VR_COFINS = :VR_COFINS, ' +
                                        'VALOR_ICMS_ST = :VALOR_ICMS_ST, ' +
                                        'VR_PIS_RET = :VR_PIS_RET, ' +
                                        'VR_COFINS_RET = :VR_COFINS_RET, '+
                                        'VALOR_ICMS_DESON = :VALOR_ICMS_DESON, ' +
                                        'VR_BASE_FCPST = :VR_BASE_FCPST,' +
                                        'P_FCPST = :P_FCPST,' +
                                        'VR_FCPST = :VR_FCPST, ' +
                                        'VR_BASE_FCP = :VR_BASE_FCP,' +
                                        'P_FCP = :P_FCP,' +
                                        'VR_FCP = :VR_FCP, ' +
                                        'VR_FRETE = :VR_FRETE, ' +
                                        'DESC_RODAPE = :DESC_RODAPE ' +
                                        'WHERE (TRANSACAO_ID = :TRANSACAO_ID) ' +
                                        'AND (PRODUTO_ID = :PRODUTO_ID) ' +
                                        'AND (TP_PROD_SERV = :TP_PROD_SERV)');


  IQuery.ParamByName('BASE_CALC_ICMS').AsFloat   := Base_Calc_ICMS.Value;
  IQuery.ParamByName('VALOR_ICMS').AsFloat       := Valor_ICMS.Value;
  IQuery.ParamByName('BASE_CALC_ST').AsFloat     := Base_Calc_ST.Value;
  IQuery.ParamByName('VALOR_ISENTO').AsFloat     := Valor_Isento.Value;
  IQuery.ParamByName('VALOR_OUTROS').AsFloat     := Valor_Outros.Value;
  IQuery.ParamByName('VR_REDUCAO_BC').AsFloat    := Reducao_Bc.Value;
  IQuery.ParamByName('CST_IPI').AsString         := CST_IPI.Text;
  IQuery.ParamByName('ALIQUOTA_ST').AsFloat      := Aliquota_St.Value;
  IQuery.ParamByName('CST_PIS').AsString         := CST_PIS.Text;
  IQuery.ParamByName('BASE_CALC_PIS').AsFloat    := Base_Calc_Pis.Value;
  IQuery.ParamByName('ALIQUOTA_PIS').AsFloat     := Aliquota_Pis.Value;
  IQuery.ParamByName('VR_PIS').AsFloat           := Vr_Pis.Value;
  IQuery.ParamByName('CST_COFINS').AsString      := CST_COFINS.Text;
  IQuery.ParamByName('BASE_CALC_COFINS').AsFloat := Base_Calc_Cofins.Value;
  IQuery.ParamByName('ALIQUOTA_COFINS').AsFloat  := Aliquota_Cofins.Value;
  IQuery.ParamByName('VR_COFINS').AsFloat        := Vr_Cofins.Value;
  IQuery.ParamByName('VR_PIS_RET').AsFloat       := Vr_Pis_Ret.Value;
  IQuery.ParamByName('VR_COFINS_RET').AsFloat    := Vr_Cofins_Ret.Value;
  IQuery.ParamByName('VALOR_ICMS_DESON').AsFloat := Valor_Icms_Deson.Value;
  IQuery.ParamByName('VR_BASE_FCPST').AsFloat    := VR_BASE_FCPST.Value;
  IQuery.ParamByName('P_FCPST').AsFloat          := P_FCPST.Value;
  IQuery.ParamByName('VR_FCPST').AsFloat         := VR_FCPST.Value;
  IQuery.ParamByName('VR_BASE_FCP').AsFloat      := VR_BASE_FCP.Value;
  IQuery.ParamByName('P_FCP').AsFloat            := P_FCP.Value;
  IQuery.ParamByName('VR_FCP').AsFloat           := VR_FCP.Value;
  IQuery.ParamByName('VR_FRETE').AsFloat         := VR_FRETE.Value;
  IQuery.ParamByName('DESC_RODAPE').AsFloat      := desc_rodape.Value;

  if Perc_ST.Value > 0 then
    IQuery.ParamByName('VALOR_ICMS_ST').AsFloat := RoundTo(((Perc_ST.Value * QTabela.FieldByName('VR_TOTAL').AsFloat) / 100), -2)
  else
    IQuery.ParamByName('VALOR_ICMS_ST').AsFloat := Valor_ICMS_ST.Value;

  IQuery.ParamByName('TRANSACAO_ID').AsInteger := T_Id;
  IQuery.ParamByName('PRODUTO_ID').AsInteger   := P_Id;
  IQuery.ParamByName('TP_PROD_SERV').AsString  := T_Prod;

  IQuery.Prepare;
  IQuery.ExecSql;



  QTabela.Close;

  QTabela.Prepare;
  QTabela.Open;

  QTabela.Locate('TRANSACAO_ID;PRODUTO_ID;TP_PROD_SERV', VarArrayOf([T_Id, P_Id, T_Prod]), [loCaseInsensitive]);

  Display_Campos;
end;

procedure TFrmSubstituicao.btnNextClick(Sender: TObject);
begin
  QTabela.Next;
  Display_Campos;

  if QTabela.Eof then
  begin
    btnNext.Enabled  := False;
    btnPrior.Enabled := True;
  end;
end;

procedure TFrmSubstituicao.btnPriorClick(Sender: TObject);
begin
  QTabela.Prior;
  Display_Campos;

  if QTabela.Bof then
  begin
    btnPrior.Enabled := False;
    btnNext.Enabled  := True;
  end;
end;

