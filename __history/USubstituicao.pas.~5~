procedure Atualiza_Impostos(Transacao, Produto: Integer);
begin
  Application.CreateForm(TFrmSubstituicao, FrmSubstituicao);
  try
    FrmSubstituicao.QTabela.Close;

    FrmSubstituicao.QTabela.ParamByName('TRANSACAO_ID').AsInteger := Transacao;

    FrmSubstituicao.QTabela.Prepare;
    FrmSubstituicao.QTabela.Open;

    if Produto > 0 then
      FrmSubstituicao.QTabela.Locate('PRODUTO_ID', Produto, [loCaseInsensitive]);

    if FrmSubstituicao.QTabela.FieldByName('DT_MOVIMENTO').AsDateTime = FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime then
      FrmSubstituicao.btnEdit.Enabled := True
    else
      FrmSubstituicao.btnEdit.Enabled := False;

    FrmSubstituicao.ShowModal;
  finally
    FrmSubstituicao.Release;
  end;
end;
procedure TFrmSubstituicao.inconsistencias;
begin

  Table_Inconsistencias.Open;
  Table_Inconsistencias.EmptyDataSet;

  QTabela.First;

 While not QTabela.eof do
 Begin
  QSearch.Sql.Clear;
  QSearch.Sql.Text := 'SELECT ALIQUOTA_ICMS FROM PRODUTOS WHERE PRODUTO_ID = :PRODUTO_ID';
  QSearch.ParamByName('PRODUTO_ID').AsInteger :=  QTabela.FieldByName('PRODUTO_ID').AsInteger;
  QSearch.Prepare;
  QSearch.Open;

  if  (QTabela.FieldByName('CST').AsString = '060') Then  //(QSearch.FieldByName('ALIQUOTA_ICMS').aSFloat > 0) and
  Begin

   Table_inconsistencias.append;

   Table_Inconsistencias.FieldByName('PRODUTO_ID').AsInteger := QTabela.FieldByName('PRODUTO_ID').AsInteger;
   Table_Inconsistencias.FieldByName('DESCRICAO').AsString   := Copy(QTabela.FieldByName('DESCRICAO').AsString,1,50);
   Table_Inconsistencias.FieldByName('ERRO').AsString        := 'Produto tributado que possui em seu cadastro ST';

   Table_inconsistencias.Post;

  End;

  QTabela.Next;
 End;



end;

