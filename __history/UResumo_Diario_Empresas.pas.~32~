procedure TFrmResumo_Diario_Empresas.FormCreate(Sender: TObject);
begin
  Dtmen.Date := StrToDate('01/' + Copy(DateToStr(date), 4, 7));
  Dtmai.Date := Ult_Dia_Mes(date);

  Fdac_Temp.Free;
  Fdac_Temp := TFDMemTable.Create(nil);

  TRY
    with Fdac_Temp.FieldDefs do
    begin
      Clear;
      Add('TRANSACAO_ID', ftInteger, 0, False);
      Add('PRODUTO_ID', ftInteger, 0, False);
      Add('DESCRICAO', ftString, 70, False);
      Add('QUANTIDADE', ftFloat, 0, False);
      Add('DESC_RODAPE', ftFloat, 0, False);
      Add('VR_TOTAL', ftFloat, 0, False);
    end;

    with Fdac_Temp.IndexDefs do
    begin
      Clear;
      Add('TEMP', 'TRANSACAO_ID;PRODUTO_ID', [ixCaseInsensitive]);
    end;
    Fdac_Temp.IndexName := 'TEMP';
    Fdac_Temp.CreateDataSet;
    Fdac_Temp.Open;

    except on E: Exception do
     ShowMessage( E.Message );
  end;

  //Quando o campo for string, depois do ftString é obrigatório o tamanho que o campo vai ocupar na tabela.
  CDCredito.FieldDefs.Add('GRUPO_DRE', ftString, 50, False);
  CDCredito.FieldDefs.Add('DESCRICAO', ftString, 50, False);
  CDCredito.FieldDefs.Add('VALOR_CREDITO', ftFloat, 0, False);
  CDCredito.CreateDataSet;

  CDDebito.FieldDefs.Add('GRUPO_DRE', ftString, 50, False);
  CDDebito.FieldDefs.Add('DESCRICAO', ftString, 50, False);
  CDDebito.FieldDefs.Add('VALOR_DEBITO', ftFloat, 0, False);
  CDDebito.CreateDataSet;


end;

