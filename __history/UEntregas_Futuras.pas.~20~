function TFrmEntregas_Futuras.Validacao: Boolean;
var
Cpf_Valido, Cnpj_Valido: Boolean;
begin
  Result := False;

  TRANSACAO_ID.Color     := clWindow;
  CLIENTE_ID.Color       := clWindow;
  EMPRESA_ID.Color       := clWindow;
  CPF_CNPJ.Color         := clWindow;
  BtnImpItens.Font.Color := clWindow;

  IQuery.Sql.Clear;
  IQuery.Sql.Add('SELECT * FROM TRANSACOES');
  IQuery.Sql.Add('WHERE');
  IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
  IQuery.Sql.Add('AND (CONDUTA = :CONDUTA)');
  IQuery.Sql.Add('AND (DEPTO = :DEPTO)');

  IQuery.ParamByName('TRANSACAO_ID').AsInteger := StrToInt(TRANSACAO_ID.Text);
  IQuery.ParamByName('CONDUTA').AsString       := '01';
  IQuery.ParamByName('DEPTO').AsString         := '07';

  IQuery.Prepare;
  IQuery.Open;

  if IQuery.IsEmpty then
  begin
    Application.MessageBox('TransaÁ„o inexistente', PChar(Msg_Title), mb_IconStop);
    TRANSACAO_ID.Color := clYellow;
    TRANSACAO_ID.SetFocus;
    exit;
  end
