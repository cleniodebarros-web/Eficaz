                      'VR_TOTAL,CST_PIS,CST_COFINS,DESC_RODAPE,SEQUENCIA,COD_CLASSTRIB,CST_CBSIBS,ALIQ_CBS,ALIQ_IBSUF,ALIQ_IBSMUNIC) VALUES(' +
