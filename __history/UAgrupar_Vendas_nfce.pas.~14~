      QUpdate.ParamByName('PRODUTO_ID').AsInteger    := QRel.FieldByName('PRODUTO_ID').AsInteger;
      QUpdate.ParamByName('TP_PROD_SERV').AsString   := 'P';

      If Cfop_Origem Then
