procedure TFrmMovimento_Clientes.btnExecutaClick(Sender: TObject);
begin

  try

    btnExecuta.Enabled := False;
    btnRetorna.Enabled := False;

   IF Movimento.Text = 'COM MOVIMENTO' THEN
   Begin

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT CLIENTES.DT_FICHA , CLIENTES.NOME CLIENTE ,  COUNT(NUM_DOC) QTD_CUPOM , SUM(VALOR) VALOR ' +
                 'FROM TRANSACOES ' +
                 'INNER JOIN CLIENTES ON CLIENTES.CLIENTE_ID =  TRANSACOES.CLIENTE_ID ' +
                 'WHERE DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL ' +
                 'AND COND_PAGTO  = ''A PRAZO''  AND TIPO_VENDA = ''VENDA'' AND STATUS = ''A'' ' +
                 'GROUP BY CLIENTES.NOME, CLIENTES.DT_FICHA');



   End
   Else
   Begin

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT DT_FICHA, NOME CLIENTE, 0 QTD_COUNT, 0 VALOR FROM CLIENTES ' +
                 'WHERE CLIENTE_ID NOT IN (SELECT CLIENTES.CLIENTE_ID ' +
                 'FROM TRANSACOES ' +
                 'INNER JOIN CLIENTES ON CLIENTES.CLIENTE_ID =  TRANSACOES.CLIENTE_ID ' +
                 'WHERE DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL  ' +
                 'AND COND_PAGTO  = ''A PRAZO'' AND TIPO_VENDA = ''VENDA'' ' +
                 'GROUP BY CLIENTES.CLIENTE_ID) ' +
                 'AND STATUS = ''A'' ');

   End;

    IF Ordem.text = 'NOME' Then
    QRel.Sql.Add('ORDER BY CLIENTE')
    Else If Ordem.text = 'QTD. VENDAS' Then
    QRel.Sql.Add('ORDER BY QTD_CUPOM')
    Else If Ordem.text = 'VALOR' Then
    QRel.Sql.Add('ORDER BY VALOR');

   QRel.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
   QRel.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;


   QRel.Prepare;
   QRel.Open;


    {


    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT TRANSACOES.DT_TRANS, TRANSACOES.NUM_DOC, CLIENTES.NOME AS CLIENTE, CLIENTES.ESTADO, ' +
                 'CLIENTES.MUNICIPIO, FUNCIONARIOS.NOME AS VENDEDOR, TABELAS.DESCRICAO, PRODUTOS.PESO_UNITARIO, ' +
                 'TRANSITENS.QUANTIDADE, PRODUTOS.FRACAO_VENDA, (TRANSITENS.VR_UNITARIO - TRANSITENS.VR_DESCONTO) AS VR_UNITARIO, ' +
                 'TRANSITENS.VR_TOTAL, TRANSACOES.VALOR, TRANSACOES.VR_FRETE, ((TRANSACOES.VR_DESCONTO + (TRANSACOES.DESCONTO_FINANCEIRO * TRANSACOES.VALOR_PRODUTOS) / 100)) AS VR_DESCONTO, ' +
                 'TRANSITENS.VALOR_ICMS_ST, TRANSACOES.VALOR_PRODUTOS, TRANSACOES.TIPO_VENDA');
    QRel.Sql.Add('FROM TRANSITENS');
    QRel.Sql.Add('INNER JOIN TRANSACOES');
    QRel.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
    QRel.Sql.Add('LEFT JOIN CLIENTES');
    QRel.Sql.Add('ON (CLIENTES.CLIENTE_ID = TRANSACOES.CLIENTE_ID)');
    QRel.Sql.Add('LEFT JOIN FUNCIONARIOS');
    QRel.Sql.Add('ON (FUNCIONARIOS.FUNCIONARIO_ID = TRANSACOES.VENDEDOR_ID)');
    QRel.Sql.Add('INNER JOIN PRODUTOS');
    QRel.Sql.Add('ON (PRODUTOS.PRODUTO_ID = TRANSITENS.PRODUTO_ID)');
    QRel.Sql.Add('INNER JOIN TABELAS');
    QRel.Sql.Add('ON (PRODUTOS.GRUPO_ID = TABELAS.TABELA_ID AND TABELAS.TIPO_TABELA = :TIPO_TABELA)');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(TRANSACOES.DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL)');
    QRel.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
    QRel.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB)');
    QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
    QRel.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');

    if Cliente.Value > 0 then
    begin
      QRel.Sql.Add('AND (TRANSACOES.CLIENTE_ID = :CLIENTE)');
      QRel.ParamByName('CLIENTE').AsInteger := StrToInt(Cliente.Text);
    end;

    if NFiscal.Text <> '' then
    begin
      QRel.Sql.Add('AND (TRANSACOES.NUM_DOC = :NUM_DOC)');
      QRel.ParamByName('NUM_DOC').AsString := NFiscal.Text;
    end;

    if Estado.Text <> '' then
    begin
      QRel.Sql.Add('AND (CLIENTES.ESTADO = :ESTADO)');
      QRel.ParamByName('ESTADO').AsString := Estado.Text;
    end;

    QRel.Sql.Add('ORDER BY TRANSACOES.DT_TRANS, TRANSACOES.TRANSACAO_ID');
    QRel.ParamByName('TIPO_TABELA').AsString := '7';
    QRel.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
    QRel.ParamByName('DT_FINAL').AsDateTime := Dtmai.Date;
    QRel.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QRel.ParamByName('TPCTB').AsString := FrmData.QAcesso.FieldByName('TPCTB').AsString;
    QRel.ParamByName('CONDUTA').AsString := '01';
    QRel.ParamByName('DEPTO').AsString := '07';
    QRel.Prepare;
    QRel.Open;
    }

    QRLabel1.Caption := 'Período: ' + Dtmen.Text + ' a ' + Dtmai.Text;

    if QRel.IsEmpty then
      Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
    else
      Vendas.PreviewModal;
  finally
    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;
end;

