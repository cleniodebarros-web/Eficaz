       if chk_exportar.Checked Then
       Begin
       Fim.ExportToFilter(TQRXLSFilter.Create(ExtractFilePath(ParamStr(0)) + 'Exportados\Fim_Vendas_' + Copy(Dtmen.Text,1,2) + Copy(Dtmen.Text,4,2) + Copy(Dtmen.Text,7,4) + '_' + Copy(Dtmai.Text,1,2) + Copy(Dtmai.Text,4,2) + Copy(Dtmai.Text,7,4)  + '.xls'));
