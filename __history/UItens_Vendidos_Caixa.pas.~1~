procedure TFrmItens_Vendidos_Caixa.SearchBanco;
begin
  QBanco.Close;

  QBanco.ParamByName('BANCO_ID').AsInteger   := StrToInt(Caixa_Banco.Text);
  QBanco.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

  QBanco.Prepare;
  QBanco.Open;

  if QBanco.IsEmpty then
    btnExecuta.Enabled := False
  else
    btnExecuta.Enabled := True;
end;

procedure TFrmItens_Vendidos_Caixa.btnCaixa_BancoClick(Sender: TObject);
begin
  try
    Caixa_Banco.Value := GetConsulta('BANCOS', 0, 0, StrToInt(Caixa_Banco.Text));
  except
    Caixa_Banco.Value := GetConsulta('BANCOS', 0, 0, 0);
  end;
end;

procedure TFrmItens_Vendidos_Caixa.btnExecutaClick(Sender: TObject);
begin
// 125, 325
  try
    btnExecuta.Enabled := False;
    btnRetorna.Enabled := False;

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT PRODUTOS.CUSTO_COMPRA,LICENCA_IF.SERIAL,TRANSACOES.MODELO, TABELAS.DESCRICAO GRUPO,TRANSACOES.DT_TRANS, TRANSACOES.CONDUTA, TRANSACOES.DEPTO, TRANSACOES.NUM_DOC, TRANSACOES.VR_ACRESCIMO,');
    QRel.Sql.Add('TRANSACOES.VR_DESCONTO DESCONTO_VENDA, TRANSACOES.VALOR, TRANSITENS.* FROM TRANSITENS');
    QRel.Sql.Add('INNER JOIN TRANSACOES');
    QRel.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
    QRel.Sql.Add('INNER JOIN PRODUTOS');
    QRel.Sql.Add('ON (TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID)');
    QRel.Sql.Add('INNER JOIN LICENCA_IF');
    QRel.Sql.Add('ON (TRANSACOES.BANCO_ID = CAST(LICENCA_IF.NUM_ECF AS INTEGER))');
    QRel.Sql.Add('INNER JOIN TABELAS');
    QRel.Sql.Add('ON (PRODUTOS.GRUPO_ID = TABELAS.TABELA_ID)');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(TRANSACOES.DT_TRANS BETWEEN :DT_INICIAL AND :DT_FINAL)');
    QRel.Sql.Add('AND (TRANSACOES.EMPRESA_ID = :EMPRESA_ID)');
    QRel.Sql.Add('AND (TRANSACOES.TPCTB <= :TPCTB)');
    QRel.Sql.Add('AND (TRANSACOES.BANCO_ID = :BANCO_ID)');
    QRel.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
    QRel.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
    QRel.Sql.Add('AND (TRANSACOES.TRANSACAO_ID NOT IN (SELECT TRANSACAO_ID FROM NOTAS_CANCELADAS))');
    QRel.Sql.Add('AND (TRANSACOES.TRANSACAO_ID NOT IN (SELECT TRANSACAO_ID FROM NOTAS_CANCELADAS_NFCE))');
    QRel.Sql.Add('AND (TABELAS.TIPO_TABELA = :TIPO_TABELA)');

    if StrToInt(LeIni(Arq_Ini, 'Par‚metros Estoque', 'Grupo')) > 0 then
      begin
        QRel.Sql.Add('AND (PRODUTOS.GRUPO_ID = :GRUPO_ID)');
        QRel.ParamByName('GRUPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Par‚metros Estoque', 'Grupo'));
      end;

    QRel.Sql.Add('ORDER BY TRANSITENS.TRANSACAO_ID, TRANSACOES.NUM_DOC');

    QRel.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
    QRel.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
    QRel.ParamByName('EMPRESA_ID').AsInteger  := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QRel.ParamByName('TPCTB').AsString        := FrmData.QAcesso.FieldByName('TPCTB').AsString;
    QRel.ParamByName('BANCO_ID').AsInteger    := QBanco.FieldByName('BANCO_ID').AsInteger;
    QRel.ParamByName('CONDUTA').AsString      := '01';
    QRel.ParamByName('DEPTO').AsString        := '07';
    QRel.ParamByName('TIPO_TABELA').AsString  := '7';

    QRel.Prepare;
    QRel.Open;

    QRLabel1.Caption := 'PerÌodo: ' + Dtmen.Text + ' a ' + Dtmai.Text;

    if QRel.IsEmpty then
      Application.MessageBox('N„o h· dados para os par‚metros informados', PChar(Msg_Title), mb_IconInformation)
    else
      Itens_Vendidos_Caixa.PreviewModal;
  finally
    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;
end;

procedure TFrmItens_Vendidos_Caixa.btnRetornaClick(Sender: TObject);
begin
  Close;
end;

procedure TFrmItens_Vendidos_Caixa.Caixa_BancoChange(Sender: TObject);
begin
  if Caixa_Banco.Value > 0 then
    SearchBanco;

  if QBanco.IsEmpty then
    btnExecuta.Enabled := False
  else
    btnExecuta.Enabled := True;
end;

procedure TFrmItens_Vendidos_Caixa.Caixa_BancoKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if (Key = Vk_F7) and (Sender = Caixa_Banco) then
    btnCaixa_BancoClick(Self);

  if Key = Vk_Return then
    Perform(Wm_NextDlgctl, 0, 0);
end;

procedure TFrmItens_Vendidos_Caixa.DtmenEnter(Sender: TObject);
begin
  Keybd_Event(VK_LEFT, 0, 0, 0);
end;

procedure TFrmItens_Vendidos_Caixa.DtmenKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if (Key = Vk_Return) or (Key = Vk_Down) then
  //  Perform(Wm_NextDlgctl, 0, 0);

  if Key = Vk_Up then
    Perform(Wm_NextDlgctl, 1, 0);
end;

procedure TFrmItens_Vendidos_Caixa.FormClose(Sender: TObject; var Action: TCloseAction);
