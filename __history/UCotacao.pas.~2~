    QProdutos.Prepare;
    QProdutos.Open;
  end;
end;

procedure TFrmCotacao.btnCriaClick(Sender: TObject);
var
CONTADOR, CP, Z, X, W , NM_SEQ : Integer;
NM,NM_ANTERIOR: String;
Alterado : Boolean;
begin

  CP := 0;
  Z := 0;
  NM_ANTERIOR := '';
  NM_SEQ := 0;

  if FrmPrincipal.OpenDialog1.Execute then
  begin

    if FileExists(FrmPrincipal.OpenDialog1.FileName) then
    begin
      Application.MessageBox('O arquivo selecionado já existe', PChar(Msg_Title), mb_IconStop);
       exit;
    end;

   //  Cotacao.FetchOptions.Unidirectional := False;

    Cotacao.Free;
    Cotacao := TFDMemTable.Create(nil);

    with Cotacao do
    begin

      with FieldDefs do
      begin
        Clear;
        Add('CDEST', ftInteger, 0, False);
        Add('BARRA', ftString, 20, False);
        Add('NMEST', ftString, 40, False);
        Add('MEDIA', ftFloat, 0, False);
        Add('QUANT', ftFloat, 0, False);
        Add('UNID', ftString, 5, False);

        for CONTADOR := 0 to (DstList.Items.Count - 1) do
        begin
          NM := '';

          for X := 1 to 10 do
          begin
            if Copy(DstList.Items[CONTADOR], X, 1) <> ' ' then
              NM := NM + Copy(DstList.Items[CONTADOR],X, 1)
            else
              NM := NM + '_' ;

          end;


          if (NM <> '') and (Z <= 10) then
          Begin
            Alterado := False;

            if NM_ANTERIOR = NM then
            Begin
             inc(NM_SEQ);
             NM := IntTostr(NM_SEQ) +  NM;
             Alterado := True;
            End;

            Add(NM, ftFloat, 0, False);

            if NOT Alterado then
            NM_Anterior := NM;

          End;

          Inc(CP);
          Inc(Z);
        end;

        if CP <= 10 then
        begin
          for W := 1 to 10 - Z do
            Add('Nulo_' + IntToStr(W), ftFloat, 0, False);
        end;

        Add('Forne', ftInteger, 0, False);
        Add('Preco', ftFloat, 0, False);
      end;

      with IndexDefs do
      begin
        Clear;
        Add('', 'CDEST', [ixPrimary, ixUnique]);
        Add('COTACAO', 'NMEST', [ixCaseInsensitive]);
        Add('COTFOR', 'FORNE', [ixCaseInsensitive]);
      end;

      IndexName := 'COTACAO';

      Open;



      if Application.MessageBox('Deseja exportar os itens abaixo do ponto mínimo?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      begin
        QMinimo.Sql.Clear;
        QMinimo.Sql.Add('SELECT * FROM PRODUTOS');
        QMinimo.Sql.Add('WHERE');
        QMinimo.Sql.Add('(STATUS = :STATUS)');
        QMinimo.Sql.Add('AND (EMPRESA_ID = :EMPRESA_ID)');

        if FrmData.QAcesso.FieldByName('TPCTB').AsString = '3' then
          QMinimo.Sql.Add('AND (QUANTIDADE_G < QUANT_MINIMA)')
        else
          QMinimo.Sql.Add('AND (QUANTIDADE_C < QUANT_MINIMA)');

        if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
        begin
          QMinimo.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

          QMinimo.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
        end;

        QMinimo.ParamByName('STATUS').AsString      := 'A';
        QMinimo.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

        QMinimo.Prepare;
        QMinimo.Open;


        QMinimo.First;
        while not QMinimo.Eof do
        begin
           if not Cotacao.FindKey([QMinimo.FieldByName('PRODUTO_ID').AsInteger]) then
            Begin
            Cotacao.Append;
            Cotacao.FieldByName('CDEST').AsInteger :=        QMinimo.FieldbyName('PRODUTO_ID').AsInteger;
            Cotacao.FieldByName('BARRA').AsString  :=        QMinimo.FieldbyName('COD_BARRA').AsString;
            Cotacao.FieldByName('NMEST').AsString  :=        Copy(QMinimo.FieldbyName('DESCRICAO').AsString,1,40);
            Cotacao.FieldByName('MEDIA').AsFloat   :=        QMinimo.FieldbyName('MEDIA_CONSUMO').AsFloat;
            Cotacao.FieldByName('QUANT').AsFloat   :=        QMinimo.FieldbyName('QUANT_MINIMA').AsFloat;
            Cotacao.FieldByName('UNID').AsString   :=        QMinimo.FieldbyName('UNIDADE_VENDA').AsString;
            Cotacao.Post;
            End;

          Application.ProcessMessages;
          QMinimo.Next;
        end;

        QMinimo.Close;
      end;

      FieldByName('CDEST').ReadOnly := True;
      FieldByName('BARRA').ReadOnly := True;
      FieldByName('NMEST').ReadOnly := True;
      FieldByname('MEDIA').ReadOnly := True;
      FieldByName('FORNE').ReadOnly := True;
      FieldByName('PRECO').ReadOnly := True;

      for W := 1 to FieldCount - 1 do
      begin
        if Copy(Fields[W].FieldName, 1, 4) = 'Nulo' then
          Fields[W].ReadOnly := True;
      end;
    end;

    DataCotacao.DataSet := Cotacao;
    dbGrid3.DataSource := DataCotacao;

    btnCria.Enabled  := False;
    btnAbre.Enabled  := False;
    btnFecha.Enabled := True;
    btnRel.Enabled   := True;
    btnPed.Enabled   := True;

    Cotacao.Open;


    //FDDataMove1.Destination     := FrmPrincipal.OpenDialog1.FileName;
   { FDDataMove1.Source          := Cotacao;
    FDDataMove1.SourceKind      := skDataSet;
    FDDataMove1.DestinationKind := skText;
    FDDataMove1.TextFileName    := FrmPrincipal.OpenDialog1.FileName;
    FDDataMove1.TextAnalyze     := [taFields,taDelimSep,taHeader];
    FDDataMove1.Execute; }

   // ExportDataSetToCVS(Cotacao,FrmPrincipal.OpenDialog1.FileName);


    FrmCotacao.Caption := 'Cotaçăo de Preços - ' + FrmPrincipal.OpenDialog1.FileName;
    QProdutos.Prepare;
    QProdutos.Open;
  end;
end;

