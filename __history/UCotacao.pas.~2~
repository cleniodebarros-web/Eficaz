    QProdutos.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

    QProdutos.Prepare;
    QProdutos.Open;
  end;

  if (Key = VK_F7) AND (btnCria.Enabled  = False) then
  begin
     Try
      TX := InputBox('Localizar', 'Descr. do Item/Código de Barras: ', '');
      if StrToInt(Copy(Tx,1,1)) >= 0 then
