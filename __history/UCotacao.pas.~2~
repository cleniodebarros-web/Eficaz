F1: TextFile;
I : Integer;
Arquivo :String;
DecimalSeparator :Char;
begin
  DecimalSeparator := '.';
  Arquivo := 'cotacao_eficaz_' + Copy(TimeToStr(Time),1,2)+ Copy(TimeToStr(Time),4,2) + Copy(TimeToStr(Time),7,2) + '_' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2);

  AssignFile(F1, ExtractFilePath(ParamStr(0)) + '\Cotacoes\' + Arquivo + '.Txt');
  Rewrite(F1);

  WriteLn(F1, Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + ';' + DateToStr(date) + ';COTACAO ' + Copy(Arquivo,16,6)+ ';' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 7, 4) + ';' +  IntToStr((DstList.Items.Count)));
  WriteLn(F1, 'FORNECEDOR_ID;NOME;CNPJ;CONTATO;ENDERECO;NUMERO;BAIRRO;COMPLEMENTO;MUNICIPIO;ESTADO;CEP;DDD;TELEFONE_1;TELEFONE_2;EMAIL;REPRESENTANTE;EMAIL,DDD,CELULAR');



  for I := 0 to (DstList.Items.Count - 1) do
  Begin
  IQuery.SQL.Clear;
  IQuery.Sql.Add('SELECT * FROM FORNECEDORES WHERE FORNECEDOR_ID = :FORNECEDOR_ID');
  IQuery.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(Copy(DstList.Items.Strings[I],56,4));
  IQuery.Prepare;
  IQuery.Open;

  Writeln(F1, IQuery.FieldByName('FORNECEDOR_ID').AsString + ';' +
                  IQuery.FieldByName('NOME').AsString + ';' +
                  IQuery.FieldByName('CNPJ').AsString + ';' +
                  IQuery.FieldByName('CONTATO').AsString + ';' +
                  IQuery.FieldByName('ENDERECO').AsString + ';' +
                  IQuery.FieldByName('NUMERO').AsString + ';' +
                  IQuery.FieldByName('BAIRRO').AsString + ';' +
                  IQuery.FieldByName('COMPLEMENTO').AsString + ';' +
                  IQuery.FieldByName('MUNICIPIO').AsString + ';' +
                  IQuery.FieldByName('ESTADO').AsString + ';' +
                  IQuery.FieldByName('CEP').AsString + ';' +
                  IQuery.FieldByName('DDD').AsString + ';' +
                  IQuery.FieldByName('TELEFONE_1').AsString + ';' +
                  IQuery.FieldByName('TELEFONE_2').AsString + ';' +
                  IQuery.FieldByName('EMAIL').AsString + ';' +
                  IQuery.FieldByName('REPRESENTANTE').AsString + ';' +
                  IQuery.FieldByName('EMAIL_REPRESENTANTE').AsString + ';' +
                  IQuery.FieldByName('DDD_R').AsString + ';' +
                  IQuery.FieldByName('TELEFONE_R').AsString);

  End;
  WriteLn(F1, '--');
  WriteLn(F1, 'CODIGO;PRODUTO;CODBARRAS;UNIDADE;QUANTIDADE;ULTIMO_PRECO;ESTOQUE;ESTQUE_MINIMO');

  Cotacao.First;
  while not Cotacao.Eof do
  begin
    QMinimo.Sql.Clear;
    QMinimo.Sql.Add('SELECT * FROM PRODUTOS');
    QMinimo.Sql.Add('WHERE');
    QMinimo.Sql.Add('(STATUS = :STATUS)');
    QMinimo.Sql.Add('AND (EMPRESA_ID = :EMPRESA_ID)');
    QMinimo.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
    begin
      QMinimo.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QMinimo.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
    end;

    QMinimo.Sql.Add('ORDER BY COD_BARRA');

    QMinimo.ParamByName('STATUS').AsString      := 'A';
    QMinimo.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
    QMinimo.ParamByName('PRODUTO_ID').AsInteger := Cotacao.FieldByName('CDEST').AsInteger;

    QMinimo.Prepare;
    QMinimo.Open;

    Writeln(F1, Cotacao.FieldByName('CDEST').AsString + ';' +
                Cotacao.FieldByName('NMEST').AsString + ';' +
                Cotacao.FieldByName('BARRA').AsString + ';' +
                Cotacao.FieldByName('UNID').AsString + ';' +
                Cotacao.FieldByName('QUANT').AsString + ';' +
                QMinimo.FieldByName('CUSTO_COMPRA').AsString + ';' +
                QMinimo.FieldByName('QUANTIDADE_C').AsString + ';' +
                QMinimo.FieldByName('QUANT_MINIMA').AsString);

    Application.ProcessMessages;
    Cotacao.Next;
  end;

  CloseFile(F1);

  DecimalSeparator := ',';
  Application.MessageBox(PChar('Arquivo ' + ExtractFilePath(ParamStr(0)) + Arquivo + '.Txt gerado com sucesso'), PChar(Msg_Title), mb_IconInformation);
end;

