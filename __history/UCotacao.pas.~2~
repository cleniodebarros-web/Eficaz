procedure TFrmCotacao.DBGrid2KeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
var
TX, Condicao: String;
Quant: Double;
InputInteger : Integer;
begin
  if (Key = VK_F3) AND (btnCria.Enabled  = False) then
  begin
    Condicao := GetPesquisa('PRODUTOS');

    QProdutos.Sql.Clear;
    QProdutos.Sql.Add('SELECT * FROM PRODUTOS');

    if Condicao <> '' then
    begin
      if FrmData.QAcesso.FieldByName('DESATIVADOS').AsString = 'True' then
        QProdutos.Sql.Add(Condicao)
      else
        QProdutos.Sql.Add(Condicao + ' AND (STATUS = ' + #39 + 'A' + #39 + ')');
    end
    Else
       QProdutos.Sql.Add('WHERE (STATUS = ' + #39 + 'A' + #39 + ')');

    QProdutos.Sql.Add('AND (EMPRESA_ID = :EMPRESA_ID)');

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
    begin
      QProdutos.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QProdutos.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
    end;

     if Application.MessageBox('Deseja exibir os itens abaixo do ponto mínimo?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
     Begin
       if FrmData.QAcesso.FieldByName('TPCTB').AsString = '3' then
          QProdutos.Sql.Add('AND (QUANTIDADE_G < QUANT_MINIMA)')
        else
          QProdutos.Sql.Add('AND (QUANTIDADE_C < QUANT_MINIMA)');
     End;

    QProdutos.Sql.Add('ORDER BY DESCRICAO');

    QProdutos.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

    QProdutos.Prepare;
    QProdutos.Open;


    if Application.MessageBox('Deseja exportar os itens selecionados?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
    begin
      Cotacao.FieldByname('CDEST').ReadOnly := False;
      Cotacao.FieldByname('BARRA').ReadOnly := False;
      Cotacao.FieldByname('NMEST').ReadOnly := False;
      Cotacao.FieldByname('MEDIA').ReadOnly := False;
      Cotacao.FieldByName('FORNE').ReadOnly := False;
      Cotacao.FieldByName('PRECO').ReadOnly := False;

      Cotacao.IndexName := 'COTACAO';

      QProdutos.First;
      while not QProdutos.Eof do
      begin
        if not Cotacao.FindKey([QProdutos.FieldByName('PRODUTO_ID').AsInteger]) then
          Cotacao.AppendRecord([QProdutos.FieldbyName('PRODUTO_ID').AsInteger,
                                QProdutos.FieldByName('COD_BARRA').AsString,
                                QProdutos.FieldByName('DESCRICAO').AsString,
                                QProdutos.FieldByName('MEDIA_CONSUMO').AsFloat,
                                QProdutos.FieldByName('QUANT_MINIMA').AsFloat,
                                QProdutos.FieldByName('UNIDADE_VENDA').AsString]);

        Application.ProcessMessages;
        QProdutos.Next;
      end;

      QProdutos.First;

      Cotacao.FieldByName('CDEST').ReadOnly := True;
      Cotacao.FieldByName('BARRA').ReadOnly := True;
      Cotacao.FieldByName('NMEST').ReadOnly := True;
      Cotacao.FieldByname('MEDIA').ReadOnly := True;
      Cotacao.FieldByName('FORNE').ReadOnly := True;
      Cotacao.FieldByName('PRECO').ReadOnly := True;
    end;
  end;

  if (Key = VK_F5) AND (btnCria.Enabled  = False) then
  begin
    Ordem := 'Código';

    QProdutos.Sql.Clear;
    QProdutos.Sql.Add('SELECT * FROM PRODUTOS');
    QProdutos.Sql.Add('WHERE');
    QProdutos.Sql.Add('(STATUS = :STATUS)');
    QProdutos.Sql.Add('AND (EMPRESA_ID = :EMPRESA_ID)');

    if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
    begin
      QProdutos.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

      QProdutos.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
    end;

    QProdutos.Sql.Add('ORDER BY COD_BARRA');

    QProdutos.ParamByName('STATUS').AsString      := 'A';
    QProdutos.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

    QProdutos.Prepare;
    QProdutos.Open;
  end;

  if (Key = VK_F6) AND (btnCria.Enabled  = False) then
  begin
    Ordem := 'Descricao';

    QProdutos.Sql.Clear;
    QProdutos.Sql.Add('SELECT * FROM PRODUTOS');
    QProdutos.Sql.Add('WHERE');
    QProdutos.Sql.Add('(STATUS = :STATUS)');
