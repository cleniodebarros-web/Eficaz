procedure TFrmFuncionarios.btnSaveClick(Sender: TObject);
Var
tp_status,Celular:string;
begin
  DetailSearch('');

  if Validacao then
  begin
    if Operacao = 'Inserindo' then
    begin
      Insert;

      CmdSelectNull := 'WHERE (CPF = :CPF)';
      CmdOrderBy    := 'ORDER BY FUNCIONARIO_ID';

      QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

      QTabela.ParamByName('CPF').AsString := CPF.Text;

      QTabela.Open;
      QTabela.Last;
    end
    else
      Edit;

    if (senha.text <> '') or (senhaWeb_Ori <> '') Then
    Begin

     if QTabela.FieldByName('STATUS').AsString = 'A' Then
     tp_status := '1'
     Else
     tp_status := '0';

     if senha.text = '' Then
     tp_status := '0';


     atualizar_EficazWeb(FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString,QTabela.FieldByName('NOME').AsString,QTabela.FieldByName('TELEFONE').AsString,QTabela.FieldByName('FUNCIONARIO_ID').AsString,
                         QTabela.FieldByName('SENHA').AsString,QTabela.FieldByName('EMAIL').AsString,tp_status);

    End;

    if (Trim(senha_eficaz_mobile.Text) <> '') then
    begin
      Atualiza_Eficaz_Mobile();
    end;

    Set_Campos(False);

    if QTabela.IsEmpty then
    begin
      QEmpresa.Close;
      QCusto.Close;
      QCargo.Close;
    end;

    Habilitar(False);
    Botoes_Normal;
    Operacao := '';
    Consulta.TabVisible := True;
  end;
end;

