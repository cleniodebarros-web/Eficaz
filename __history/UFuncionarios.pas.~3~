procedure TFrmFuncionarios.Atualiza_Eficaz_Mobile();
var
  Json: string;
  sResponse: string;
  JsonEnviarApi: TStringStream;
  Http: TIdHTTP;
  chave_api, cnpj, nome, email, senha,
  status_funcionario, liberado, json_resposta_api: string;
  obj: TJSONObject; //Precisa da uses DBXJSON no DelphiXe5
  visualizar_cadastro_produto, visualizar_cadastro_cliente,
  visualizar_cadastro_fornecedor, visualizar_orcamento,
  visualizar_recebimento_de_contas: Boolean;
  funcionario_id_eficaz: Integer;
begin
  QAcesso.SQL.Clear;
  QAcesso.SQL.Add('SELECT * FROM ACESSO WHERE FUNCIONARIO_ID = :FUNCIONARIO_ID');
  QAcesso.ParamByName('FUNCIONARIO_ID').AsInteger := QTabela.FieldByName('FUNCIONARIO_ID').AsInteger;
  QAcesso.Open();

  chave_api := 'tAMWa4+9qWSFq-$w';
  cnpj := FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString;
  nome := QTabela.FieldByName('NOME').AsString;
  email := QTabela.FieldByName('email_eficaz_mobile').AsString;
  senha := QTabela.FieldByName('senha_eficaz_mobile').AsString;
  status_funcionario := QTabela.FieldByName('STATUS').AsString;
  liberado := acesso_eficaz_mobile.Text;
  visualizar_cadastro_produto := Caso(Copy(QAcesso.FieldByName('OPCOES').AsString, 20, 1));
  visualizar_cadastro_cliente := Caso(Copy(QAcesso.FieldByName('OPCOES').AsString, 23, 1));
  visualizar_cadastro_fornecedor := Caso(Copy(QAcesso.FieldByName('OPCOES').AsString, 24, 1));
  visualizar_orcamento := Caso(Copy(QAcesso.FieldByName('OPCOES').AsString, 42, 1));
  visualizar_recebimento_de_contas := Caso(Copy(QAcesso.FieldByName('OPCOES').AsString, 33, 1));
  funcionario_id_eficaz := QTabela.FieldByName('FUNCIONARIO_ID').AsInteger;

  Json := '{"chave_api": "'+chave_api+'",' +
    '"cnpj": "'+cnpj+'",' +
    '"nome": "'+nome+'",' +
    '"email": "'+email+'",' +
    '"senha": "'+senha+'",' +
    '"status_funcionario": "'+status_funcionario+'",' +
    '"liberado": "'+liberado+'",' +
    '"visualizar_cadastro_produto": "'+BoolToStr(visualizar_cadastro_produto)+'",' +
    '"visualizar_cadastro_cliente": "'+BoolToStr(visualizar_cadastro_cliente)+'",' +
    '"visualizar_cadastro_fornecedor": "'+BoolToStr(visualizar_cadastro_fornecedor)+'",' +
    '"visualizar_orcamento": "'+BoolToStr(visualizar_orcamento)+'",' +
    '"visualizar_recebimento_de_contas": "'+BoolToStr(visualizar_recebimento_de_contas)+'",' +
    '"funcionario_id_eficaz": "'+IntToStr(funcionario_id_eficaz)+'"' +
    '}';

  JsonEnviarApi := TStringStream.Create(Json, TEncoding.UTF8);


  try
    Http := TIdHTTP.Create(nil);
    Http.Request.ContentType  := 'application/json';
    Http.Request.CharSet      := 'utf-8';
    Http.ConnectTimeout       := 3000;

    Http.Response.ContentType := 'application/json';
    Http.Response.CharSet     := 'UTF-8';
                         189.126.105.48
    try
      Http.Post('http://189.126.105.48:5000/atu_cadastra_usuario_nuvem', JsonEnviarApi);
      //Http.Post('http://10.0.0.94:5000/atu_cadastra_usuario_nuvem', JsonEnviarApi);
    except
      on E:EIdHTTPProtocolException do
        begin
          obj := TJSONObject.ParseJSONValue(E.ErrorMessage) as TJSONObject;

          if obj = nil then
            //raise Exception.Create('Error parsing JSON')
          else
            Application.MessageBox(PChar('Eficaz Mobile: '#13#10 + obj.GetValue('msg').Value), PChar(Msg_Title), mb_IconStop);

          obj.Free
        end;
      on E: Exception do
        begin
          Application.MessageBox(PChar('Eficaz Mobile: '#13#10 + E.Message), PChar(Msg_Title), mb_IconStop);
        end;
    end;

  finally
    JsonEnviarApi.Free;
    Http.Free;
  end;

end;

procedure TFrmFuncionarios.AlfabetoClick(Sender: TObject);
begin
  if Alfabeto.TabIndex <> 26 then
  begin
    if FrmPrincipal.Config.FieldByName('VER_DESATIVADOS').AsString = 'True' then
      CmdSelectNull := 'WHERE (NOME LIKE ' + #39 + Chr(Alfabeto.TabIndex + 65) + '%' + #39 + ')'
    else
      CmdSelectNull := 'WHERE (NOME LIKE ' + #39 + Chr(Alfabeto.TabIndex + 65) + '%' + #39 + ') AND (STATUS = ' + #39 + 'A' + #39 + ')';
  end
  else
  begin
    if FrmPrincipal.Config.FieldByName('VER_DESATIVADOS').AsString = 'True' then
      CmdSelectNull := 'WHERE (FUNCIONARIO_ID IS NOT NULL)'
    else
      CmdSelectNull := 'WHERE (FUNCIONARIO_ID IS NOT NULL) AND (STATUS = ' + #39 + 'A' + #39 + ')';
  end;

  CmdOrderBy := 'ORDER BY NOME';

  QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;
  
  QTabela.Open;
end;

