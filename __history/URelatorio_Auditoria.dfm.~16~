  object QRel: TFDQuery
    Connection = FrmData.DbF_Eficaz
    FetchOptions.AssignedValues = [evAutoFetchAll]
    FetchOptions.AutoFetchAll = afTruncate
    SQL.Strings = (
      
        'SELECT AUDITORIA.*, FUNCIONARIOS.NOME,PRODUTOS.DESCRICAO ,CLIENT' +
        'ES.NOME CLIENTE,FORNECEDORES.NOME FORNECEDOR '
      'FROM AUDITORIA'
      
        'LEFT JOIN FUNCIONARIOS ON FUNCIONARIOS.FUNCIONARIO_ID = AUDITORI' +
        'A.FUNCIONARIO_ID'
      'LEFT JOIN PRODUTOS ON PRODUTOS.PRODUTO_ID = AUDITORIA.TABELA_ID'
      'LEFT JOIN CLIENTES ON CLIENTES.CLIENTE_ID = AUDITORIA.TABELA_ID'
      
        'LEFT JOIN FORNECEDORES ON FORNECEDORES.FORNECEDOR_ID = AUDITORIA' +
        '.TABELA_ID'
      'WHERE CAST(DT_LOG AS DATE) BETWEEN :DT_INICIAL AND :DT_FINAL'
      'AND CAST(HR_LOG AS TIME) BETWEEN :HR_INICIAL AND :HR_FINAL'
      'AND TABELA = :TABELA ORDER BY FUNCIONARIO_ID')
    Left = 8
    Top = 82
    ParamData = <
      item
        Name = 'DT_INICIAL'
        DataType = ftDateTime
        ParamType = ptInput
        Value = 45200d
      end
      item
        Name = 'DT_FINAL'
        DataType = ftDateTime
        ParamType = ptInput
        Value = 45229d
      end
      item
        Name = 'HR_INICIAL'
        DataType = ftTime
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'HR_FINAL'
        DataType = ftTime
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'TABELA'
        DataType = ftString
        ParamType = ptInput
        Value = 'FORNECEDORES'
      end>
  end
