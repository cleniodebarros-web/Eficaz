procedure TFrmPlano_Contas.GravaPlano(Codigo, Descricao, Altsaldo, Chave: String);
begin
  IQuery.Sql.Clear;
  IQuery.Sql.Add('INSERT INTO PLANO( ' +
                 'CODIGO,    DESCRICAO,    ALTSALDO,    CHAVE) VALUES(' +
                 ':CODIGO,   :DESCRICAO,   :ALTSALDO,   :CHAVE)');

  IQuery.ParamByName('CODIGO').AsString    := Codigo;
  IQuery.ParamByName('DESCRICAO').AsString := Descricao;
  IQuery.ParamByName('ALTSALDO').AsString  := Altsaldo;
  IQuery.ParamByName('CHAVE').AsString     := Chave;

  IQuery.Prepare;
  IQuery.ExecSql;

end;

function TFrmPlano_Contas.Existe_Lancamento;
begin
  IQuery.Sql.Clear;
  IQuery.Sql.Add('SELECT * FROM RAZAO');
  IQuery.Sql.Add('WHERE');
  IQuery.Sql.Add('(CONTA_DB LIKE :CONTA)');
  IQuery.Sql.Add('OR (CONTA_CR LIKE :CONTA)');

  IQuery.ParamByName('CONTA').AsString := QTabela.FieldByName('COD_CONTABIL').AsString + '%';

  IQuery.Prepare;
  IQuery.Open;

  if IQuery.IsEmpty then
    Result := False
  else
    Result := True;
end;

procedure TFrmPlano_Contas.AlfabetoClick(Sender: TObject);
begin
  if Alfabeto.TabIndex <> 26 then
  begin
    if FrmPrincipal.Config.FieldByName('VER_DESATIVADOS').AsString = 'True' then
      CmdSelectNull := 'WHERE (DESCRICAO LIKE ' + #39 + Chr(Alfabeto.TabIndex + 65) + '%' + #39 + ') AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')'
    else
      CmdSelectNull := 'WHERE (DESCRICAO LIKE ' + #39 + Chr(Alfabeto.TabIndex + 65) + '%' + #39 + ') AND (STATUS = ' + #39 + 'A' + #39 + ') AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')';
  end
  else
  begin
    if FrmPrincipal.Config.FieldByName('VER_DESATIVADOS').AsString = 'True' then
      CmdSelectNull := 'WHERE (TABELA_ID IS NOT NULL) AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')'
    else
      CmdSelectNull := 'WHERE (TABELA_ID IS NOT NULL) AND (STATUS = ' + #39 + 'A' + #39 + ') AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')';
  end;

  if  FrmPrincipal.Config.FieldByName('FILTRO_PLANO').AsString = 'True' Then
    CmdSelectNull := 'WHERE (TABELA_ID IS NOT NULL) AND (STATUS = ' + #39 + 'A' + #39 + ') AND (TIPO_TABELA = ' + #39 + '4' + #39 + ') AND (ESPECIAL = ' + #39 + 'SIM' + #39 + ')';


  CmdOrderBy := 'ORDER BY TABELA_ID';

  QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

  QTabela.Prepare;
  QTabela.Open;
end;

