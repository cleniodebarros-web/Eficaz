procedure TFrmPlano_Contas.QRBand2BeforePrint(Sender: TQRCustomBand;
  var PrintBand: Boolean);
begin
  if (QPlano.FieldByName('CODIGO').AsString = '2') or (QPlano.FieldByName('CODIGO').AsString = '3') or (QPlano.FieldByName('CODIGO').AsString = '4') or (QPlano.FieldByName('CODIGO').AsString = '6') then
    Plano.NewPage;

  if length(QPlano.FieldByName('CODIGO').AsString) <= 4 then
  begin
    QRDBText2.Font.Style := [(fsBold)];
    QRDBText5.Font.Style := [(fsBold)];
    QRDBText6.Font.Style := [(fsBold)];

    QRBand2.Height := 34;
    QRDBText2.Top  := 9;
    QRDBText5.Top  := 9;
    QRDBText6.Top  := 9;
  end
  else
  begin
    if QPlano.FieldByName('ALTSALDO').AsString = 'NĂO' then
    begin
      QRDBText2.Font.Style := [(fsBold)];
      QRDBText5.Font.Style := [(fsBold)];
      QRDBText6.Font.Style := [(fsBold)];

      QRband2.Height := 34;
      QRDBText2.Top  := 9;
      QRDBText5.Top  := 9;
      QRDBText6.Top  := 9;
    end
    else
    begin
      QRDBText2.Font.Style := [];
      QRDBText5.Font.Style := [];
      QRDBText6.Font.Style := [];

      QRBand2.Height := 17;
      QRDBText2.Top  := 1;
      QRDBText5.Top  := 1;
      QRDBText6.Top  := 1;
    end;
  end;
end;

procedure TFrmPlano_Contas.Set_Campos(Vazio: Boolean);
var
I: Integer;
Temp: TComponent;
begin
  for I := 0 to (ComponentCount - 1) do
  begin
    Temp := Components[I];

    if Vazio then
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := '';

      if Temp is TComboBox then
        TComboBox(Temp).Text := '';

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := 0;

      if Temp is TDateEdit then
        TDateEdit(Temp).Text := '  /  /    ';
    end
    else
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := QTabela.FieldByName(TEdit(Temp).Name).AsString;

      if Temp is TComboBox then
        TComboBox(Temp).Text := QTabela.FieldByName(TComboBox(Temp).Name).AsString;

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := QTabela.FieldByName(TCurrencyEdit(Temp).Name).AsFloat;

      if Temp is TDateEdit then
        TDateEdit(Temp).Date := QTabela.FieldByName(TDateEdit(Temp).Name).AsDateTime;
    end;
  end;

  TIPO_TABELA.Text := '4';
  DetailSearch('');
end;

procedure TFrmPlano_Contas.SUB_CATEGORIAExit(Sender: TObject);
begin
  DetailSearch('Conta');

  TIPO_CONTA.Text := QContas.FieldByName('TIPO_CONTA').AsString;

  if not QContas.IsEmpty then
  begin
    QPlano.Sql.Clear;
    QPlano.Sql.Add('SELECT COUNT(*) TOTAL');
    QPlano.Sql.Add('FROM TABELAS');
    QPlano.Sql.Add('WHERE');
    QPlano.Sql.Add('(SUB_CATEGORIA = :SUB_CATEGORIA)');
    QPlano.Sql.Add('AND (TIPO_TABELA = :TIPO_TABELA)');
    QPlano.Sql.Add('AND (NIVEL = :NIVEL)');
    QPlano.Sql.Add('AND (STATUS = :STATUS)');

    QPlano.ParamByName('SUB_CATEGORIA').AsInteger := QContas.FieldByName('TABELA_ID').AsInteger;
