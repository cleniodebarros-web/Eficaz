function TFrmPlano_Contas.Validacao: Boolean;
begin
  Result := False;

  DESCRICAO.Color     := clWindow;
  NIVEL.Color         := clWindow;
  TIPO_CONTA.Color    := clWindow;
  SUB_CATEGORIA.Color := clWindow;

  if Descricao.Text = '' then
  begin
    Application.MessageBox('Informe a Descriçăo', PChar(Msg_Title), mb_IconStop);

    DESCRICAO.Color := clYellow;
    DESCRICAO.SetFocus;

    exit;
  end;

  if (NIVEL.Text <> 'ANALÍTICA') and (NIVEL.Text <> 'SINTÉTICA') and (NIVEL.Text <> 'CARACTERÍSTICA') and (NIVEL.Text <> 'CONTA DE PATRIMÔNIO') and (NIVEL.Text <> 'CONTA DE RESULTADO') and (NIVEL.Text <> 'ESTRUTURA PATRIMONIAL') and (NIVEL.Text <> 'NATUREZA E FINALIDADE') and (NIVEL.Text <> 'RESULTADO ECONÔMICO') and (NIVEL.Text <> 'SISTEMA PRÓPRIO') then
  begin
    Application.MessageBox('Nível inválido', PChar(Msg_Title), mb_IconStop);

    NIVEL.Color := clYellow;
    NIVEL.SetFocus;

    exit;
  end;

  if (NIVEL.Text = 'ANALÍTICA') and (QContas.IsEmpty) then
  begin
    Application.MessageBox('Campo Sub-Categoria de está incompleto', PChar(Msg_Title), mb_IconWarning);

    SUB_CATEGORIA.Color := clYellow;
    SUB_CATEGORIA.SetFocus;

    exit;
  end;

  if (NIVEL.Text <> 'ANALÍTICA') and (SUB_CATEGORIA.Value > 0) then
  begin
    Application.MessageBox('Năo é preciso informar a Conta Sub-Categoria', PChar(Msg_Title), mb_IconWarning);

    NIVEL.Color := clYellow;
    NIVEL.SetFocus;

    exit;
  end;

  if FrmPrincipal.Config.FieldByName('PLANO_PROPRIO').AsString = 'True' then
  begin
    if (NIVEL.Text = 'ANALÍTICA') and (not QContas.IsEmpty) then
    begin
      if (length(QContas.FieldByName('COD_CONTABIL').AsString) <> 10) and (length(QContas.FieldByName('COD_CONTABIL').AsString) <> 15) then
      begin
        Application.MessageBox('Conta Sintética inválida', PChar(Msg_Title), mb_IconStop);

        SUB_CATEGORIA.Color := clYellow;
        SUB_CATEGORIA.SetFocus;

        exit;
      end;
    end;

    if (TIPO_CONTA.Text <> 'ATIVO CIRCULANTE') and (TIPO_CONTA.Text <> 'REALIZ. A L. PRAZO') and (TIPO_CONTA.Text <> 'ATIVO PERMANENTE') and (TIPO_CONTA.Text <> 'COMP. DO ATIVO') and (TIPO_CONTA.Text <> 'PASSIVO CIRCULANTE') and (TIPO_CONTA.Text <> 'EXIGÍVEL A L. PRAZO') and (TIPO_CONTA.Text <> 'RES. EXERC. FUTUROS') and (TIPO_CONTA.Text <> 'PATRIMÔNIO LÍQUIDO') and (TIPO_CONTA.Text <> 'COMP. DO PASSIVO') and (TIPO_CONTA.Text <> 'RECEITA') and (TIPO_CONTA.Text <> 'DESPESA') and (TIPO_CONTA.Text <> 'APUR.  RESULTADO') then
    begin
      Application.MessageBox('Tipo da Conta inválido', PChar(Msg_Title), mb_IconStop);

      TIPO_CONTA.Color := clYellow;
      TIPO_CONTA.SetFocus;

      exit;
    end;
  end
  else
  begin
    if (TIPO_CONTA.Text <> 'ATIVO') and (TIPO_CONTA.Text <> 'ATIVO CIRCULANTE') and (TIPO_CONTA.Text <> 'REALIZÁVEL') and (TIPO_CONTA.Text <> 'REALIZ. LONGO PRAZO') and (TIPO_CONTA.Text <> 'ATIVO PERMANENTE') and (TIPO_CONTA.Text <> 'COMPENSAÇŐES ATIVAS') and (TIPO_CONTA.Text <> 'PASSIVO') and (TIPO_CONTA.Text <> 'PASSIVO CIRCULANTE') and (TIPO_CONTA.Text <> 'EXIGÍVEL') and (TIPO_CONTA.Text <> 'EXIG. A LONGO PRAZO') and (TIPO_CONTA.Text <> 'RES. EXERC. FUTUROS') and (TIPO_CONTA.Text <> 'PATRIMÔNIO LÍQUIDO') and (TIPO_CONTA.Text <> 'COMP. PASSIVAS') and (TIPO_CONTA.Text <> 'RESULTADO') then
    begin
      Application.MessageBox('Tipo da Conta inválido', PChar(Msg_Title), mb_IconStop);

      TIPO_CONTA.Color := clYellow;
      TIPO_CONTA.SetFocus;

      exit;
    end;
  end;

  Result := True;
end;

