procedure TFrmPlano_Contas.btnImportaClick(Sender: TObject);
var
F1: TextFile;
S, Cod_Plano: String;
Colunas: TStringList;
ID: Integer;
begin
  FrmPrincipal.OpenDialog1.Title      := 'Selecione o Arquivo';
  FrmPrincipal.OpenDialog1.DefaultExt := '*.Txt';
  FrmPrincipal.OpenDialog1.Filter     := 'Arquivos Txt (*.Txt)|*.Txt|Arquivos Csv (*.Csv)|*.Txt|Todos os Arquivos (*.*)|*.*';
  FrmPrincipal.OpenDialog1.InitialDir := ExtractFilePath(ParamStr(0));

  if Application.MessageBox('Plano de Contas Padrăo ANS?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
  begin
    if FrmPrincipal.OpenDialog1.Execute then
    begin
      try
        Panel3.Visible := True;
{
        IQuery.Sql.Clear;
        IQuery.Sql.Add('DELETE FROM TABELAS');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TIPO_TABELA = :TIPO_TABELA)');

        IQuery.ParamByName('TIPO_TABELA').AsString := '4';

        IQuery.Prepare;
        IQuery.ExecSql;


}
        AssignFile(F1, FrmPrincipal.OpenDialog1.FileName);
        Reset(F1);

        QTabela.Last;
        
        ID := (QTabela.FieldByName('TABELA_ID').AsInteger + 1);

        while not Eof(F1) do
        begin
          ReadLn(F1, S);

          try
            Colunas := TStringList.Create;

            Colunas.Text := StringReplace(S, ';', #13, [rfReplaceAll]);

            Panel3.Caption := Colunas.Strings[1];

            Application.ProcessMessages;

            try
              if length(Colunas.Strings[0]) <= 5 then
                Cod_Plano := Colunas.Strings[0]
              else if length(Colunas.Strings[0]) = 6 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 1)
              else if length(Colunas.Strings[0]) = 7 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 2)
              else if length(Colunas.Strings[0]) = 8 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 3)
              else if length(Colunas.Strings[0]) = 9 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 4)
              else if length(Colunas.Strings[0]) = 10 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 4) + '.' + Copy(Colunas.Strings[0], 10, 1)
              else if length(Colunas.Strings[0]) = 11 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 4) + '.' + Copy(Colunas.Strings[0], 10, 2)
              else if length(Colunas.Strings[0]) = 12 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 4) + '.' + Copy(Colunas.Strings[0], 10, 3)
              else if length(Colunas.Strings[0]) = 13 then
                Cod_Plano := Copy(Colunas.Strings[0], 1, 5) + '.' + Copy(Colunas.Strings[0], 6, 4) + '.' + Copy(Colunas.Strings[0], 10, 4);

              IQuery.Sql.Clear;
              IQuery.Sql.Add('SELECT * FROM TABELAS');
              IQuery.Sql.Add('WHERE');
              IQuery.Sql.Add('(COD_CONTABIL = :COD_CONTABIL)');

              IQuery.ParamByName('COD_CONTABIL').AsString := Cod_Plano;

              IQuery.Prepare;
              IQuery.Open;

              if IQuery.IsEmpty then
              begin
                IQuery.Sql.Clear;
                IQuery.Sql.Add('INSERT INTO TABELAS( ' +
                               'TABELA_ID,    DESCRICAO,     NIVEL,        SUB_CATEGORIA, ' +
                               'TIPO_CONTA,   COD_CONTABIL,  TIPO_TABELA,  STATUS) VALUES(' +
                               ':TABELA_ID,   :DESCRICAO,    :NIVEL,       :SUB_CATEGORIA, ' +
                               ':TIPO_CONTA,  :COD_CONTABIL, :TIPO_TABELA, :STATUS)');

                IQuery.ParamByName('TABELA_ID').AsInteger     := ID;
                IQuery.ParamByName('DESCRICAO').AsString      := Copy(Colunas.Strings[1], 1, 70);
                IQuery.ParamByName('NIVEL').AsString          := 'SINTÉTICA';
                IQuery.ParamByName('SUB_CATEGORIA').AsInteger := 0;
                IQuery.ParamByName('TIPO_CONTA').AsString     := '';
                IQuery.ParamByName('COD_CONTABIL').AsString   := Cod_Plano;
                IQuery.ParamByName('TIPO_TABELA').AsString    := '4';
                IQuery.ParamByName('STATUS').AsString         := 'A';

                IQuery.Prepare;
                IQuery.ExecSql;



                Inc(ID);
              end
              else
              begin
                IQuery.Sql.Clear;
                IQuery.Sql.Add('UPDATE TABELAS SET DESCRICAO = :DESCRICAO');
                IQuery.Sql.Add('WHERE');
                IQuery.Sql.Add('(COD_CONTABIL = :COD_CONTABIL)');

                IQuery.ParamByName('DESCRICAO').AsString    := Copy(Colunas.Strings[1], 1, 70);
                IQuery.ParamByName('COD_CONTABIL').AsString := Cod_Plano;

                IQuery.Prepare;
                IQuery.ExecSql;


              end;
            except

            end;
          finally
            Colunas.Free;
          end;

          Application.ProcessMessages;
        end;

        IQuery.Sql.Clear;
        IQuery.Sql.Add('SET GENERATOR GEN_CONTAS TO ' + IntToStr(ID));

        IQuery.Prepare;
        IQuery.ExecSql;


      finally
        CloseFile(F1);
        Panel3.Visible := False;
        Panel3.Caption := 'Aguarde...';
      end;
    end;
  end
  else
  begin
    if FrmPrincipal.OpenDialog1.Execute then
    begin
      try
        Panel3.Visible := True;

        AssignFile(F1, FrmPrincipal.OpenDialog1.FileName);
        Reset(F1);

        while not Eof(F1) do
        begin
          ReadLn(F1, S);

          IQuery.Sql.Clear;
          IQuery.Sql.Add('INSERT INTO TABELAS( ' +
                         'TABELA_ID,    DESCRICAO,     NIVEL,    SUB_CATEGORIA, ' +
                         'TIPO_CONTA,   COD_CONTABIL,  TIPO_TABELA) VALUES(' +
                         ':TABELA_ID,   :DESCRICAO,    :NIVEL,   :SUB_CATEGORIA, ' +
                         ':TIPO_CONTA,  :COD_CONTABIL, :TIPO_TABELA)');

          IQuery.ParamByName('TABELA_ID').AsInteger     := StrToInt(Alltrim(SemMascara(Copy(S, 1, 6))));
          IQuery.ParamByName('DESCRICAO').AsString      := Alltrim(Copy(S, 22, 70));
          IQuery.ParamByName('NIVEL').AsString          := Alltrim(Copy(S, 94, 15));
          IQuery.ParamByName('SUB_CATEGORIA').AsInteger := StrToInt(Alltrim(SemMascara(Copy(S, 112, 6))));
          IQuery.ParamByName('TIPO_CONTA').AsString     := Alltrim(Copy(S, 120, 16));
          IQuery.ParamByName('COD_CONTABIL').AsString   := Alltrim(Copy(S, 225, 20));
          IQuery.ParamByName('TIPO_TABELA').AsString    := '4';

          IQuery.Prepare;
          IQuery.ExecSql;



          Panel3.Caption := Alltrim(Copy(S, 22, 70));

          Application.ProcessMessages;
        end;
      finally
        CloseFile(F1);
        Panel3.Visible := False;
        Panel3.Caption := 'Aguarde...';
      end;
    end;
  end;

  if FrmPrincipal.Config.FieldByName('MOSTRAR_CADASTROS').AsString = 'True' then
  begin
    if FrmPrincipal.Config.FieldByName('VER_DESATIVADOS').AsString = 'True' then
      CmdSelectNull := 'WHERE (TABELA_ID IS NOT NULL) AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')'
    else
      CmdSelectNull := 'WHERE (TABELA_ID IS NOT NULL) AND (STATUS = ' + #39 + 'A' + #39 + ') AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')';
  end
  else
  begin
    if FrmPrincipal.Config.FieldByName('VER_DESATIVADOS').AsString = 'True' then
      CmdSelectNull := 'WHERE (TABELA_ID IS NULL) AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')'
    else
      CmdSelectNull := 'WHERE (TABELA_ID IS NULL) AND (STATUS = ' + #39 + 'A' + #39 + ') AND (TIPO_TABELA = ' + #39 + '4' + #39 + ')';
  end;

  if  FrmPrincipal.Config.FieldByName('FILTRO_PLANO').AsString = 'True' Then
    CmdSelectNull := 'WHERE (TABELA_ID IS NOT NULL) AND (STATUS = ' + #39 + 'A' + #39 + ') AND (TIPO_TABELA = ' + #39 + '4' + #39 + ') AND (ESPECIAL = ' + #39 + 'SIM' + #39 + ')';

