procedure TFrmPlano_Contas.btnSaveClick(Sender: TObject);
begin
  DetailSearch('');

  Dt_Alteracao.Date := Date;

  if Validacao then
  begin
    if Operacao = 'Inserindo' then
    begin
      Insert;

      CmdSelectNull := 'WHERE (DESCRICAO = :DESCRICAO) AND (STATUS = :STATUS) AND (TIPO_TABELA = :TIPO_TABELA)';
      CmdOrderBy   := 'ORDER BY TABELA_ID';

      QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

      QTabela.ParamByName('DESCRICAO').AsString   := DESCRICAO.Text;
      QTabela.ParamByName('STATUS').AsString      := 'A';
      QTabela.ParamByName('TIPO_TABELA').AsString := '4';

      QTabela.Prepare;
      QTabela.Open;
      
      QTabela.Last;
    end
    else
      Edit;

    if FrmPrincipal.Config.FieldByName('PLANO_PROPRIO').AsString = 'False' then
      COD_CONTABIL.ReadOnly := True
    else
      COD_CONTABIL.ReadOnly := False;

    Set_Campos(False);

    if QTabela.IsEmpty then
      QContas.Close;

    Habilitar(False);
    Botoes_Normal;
    Operacao := '';
    Consulta.TabVisible := True;
  end;
end;

procedure TFrmPlano_Contas.Button1Click(Sender: TObject);
var
Sub_Conta, Codigo: String;
begin
  if not InputQuery('Importaçăo de Contas', 'Sub-Conta:', Sub_Conta) then
    exit;

  if not InputQuery('Importaçăo de Contas', 'Codigo:', Codigo) then
    exit;

  Q2011.Sql.Clear;
  Q2011.Sql.Add('SELECT * FROM TABELAS');
  Q2011.Sql.Add('WHERE');
  Q2011.Sql.Add('(TIPO_TABELA = :TIPO_TABELA)');
  Q2011.Sql.Add('AND (NIVEL = :NIVEL)');
  Q2011.Sql.Add('AND (COD_CONTABIL LIKE :COD_CONTABIL)');
  Q2011.Sql.Add('ORDER BY COD_CONTABIL');

  Q2011.ParamByName('TIPO_TABELA').AsString  := '4';
  Q2011.ParamByName('NIVEL').AsString        := 'ANALÍTICA';
  Q2011.ParamByName('COD_CONTABIL').AsString := Codigo + '%';

  Q2011.Prepare;
  Q2011.Open;

  Q2011.First;
  while not Q2011.Eof do
  begin
    btnInsertClick(Sender);

    DESCRICAO.Text     := Q2011.FieldByName('DESCRICAO').AsString;
    NIVEL.Text         := 'ANALÍTICA';
    SUB_CATEGORIA.Text := Sub_Conta;

    SUB_CATEGORIAExit(Sender);

    TIPO_CONTA.Text    := 'ATIVO CIRCULANTE';
    TIPO_TABELA.Text   := '4';

    btnSaveClick(Sender);

    Application.ProcessMessages;
    Q2011.Next;
  end;
end;

