        QArq.ParamByName('TRIBUTO_ID').AsInteger := QRel.FieldByName('TRIBUTO_ID').AsInteger
      else
        QArq.ParamByName('TRIBUTO_ID').AsInteger := 1;

      if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
        QArq.ParamByName('QUANTIDADE').AsFloat   := (QRel.FieldByName('QUANTIDADE_C').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat)
      else
        QArq.ParamByName('QUANTIDADE').AsFloat   := (QRel.FieldByName('QUANTIDADE_G').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat);


        QArq.ParamByName('CFOP').AsString          := '1556';
        QArq.ParamByName('VR_UNITARIO').AsFloat    := QRel.FieldByName('CUSTOMEDIO').AsFloat;

      if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
        QArq.ParamByName('VR_TOTAL').AsFloat     := ((QRel.FieldByName('QUANTIDADE_C').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat) * QRel.FieldByName('CUSTOMEDIO').AsFloat)
      else
        QArq.ParamByName('VR_TOTAL').AsFloat     := ((QRel.FieldByName('QUANTIDADE_G').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat) * QRel.FieldByName('CUSTOMEDIO').AsFloat);

      QArq.ParamByName('MOVIMENTO').AsInteger := 0;

      QArq.Prepare;
      QArq.ExecSql;

       if (FrmPrincipal.Config.FieldByName('CONTROLE_ESTQ_LOC').AsString = 'True') Then
      Begin

         IQuery.Sql.Clear;
         IQuery.Sql.Add('INSERT INTO LOCALIZACAO_ESTOQUE_PRODUTOS(PRODUTO_ID,LOCALIZACAO_ID,DESCRICAO,DT_SAIDA,QUANTIDADE,TRANSACAO_ID) ' +
                        'VALUES(:PRODUTO_ID,:LOCALIZACAO_ID,:DESCRICAO,:DT_SAIDA,:QUANTIDADE,:TRANSACAO_ID)');

         IQuery.ParamByName('PRODUTO_ID').AsInteger     := QRel.FieldByName('PRODUTO_ID').AsInteger;
         IQuery.ParamByName('LOCALIZACAO_ID').AsInteger := FrmPrincipal.Config.FieldByName('LOCALIZACAO_ID').AsInteger;
         IQuery.ParamByName('DESCRICAO').AsString       := FrmPrincipal.Config.FieldByName('LOCALIZACAO_DESCRICAO').AsString;
         IQuery.ParamByName('DT_SAIDA').AsDateTime      := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
         IQuery.ParamByName('QUANTIDADE').AsFloat       := (QRel.FieldByName('QUANTIDADE_C').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat) * -1;
         IQuery.ParamByName('TRANSACAO_ID').AsInteger   := Id_Trans;

         IQuery.Prepare;
         IQuery.ExecSQL;

      End;



      if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
        Vl_Trans := Vl_Trans + ((QRel.FieldByName('QUANTIDADE_C').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat) * QRel.FieldByName('CUSTOMEDIO').AsFloat)
      else
        Vl_Trans := Vl_Trans + ((QRel.FieldByName('QUANTIDADE_G').AsFloat - QRel.FieldByName('QUANTIDADE_A').AsFloat) * QRel.FieldByName('CUSTOMEDIO').AsFloat);

      Application.ProcessMessages;
      QRel.Next;
    end;

    QArq.Sql.Clear;
    QArq.Sql.Add('UPDATE TRANSACOES SET VALOR = :VALOR');
    QArq.Sql.Add('WHERE');
    QArq.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

    QArq.ParamByName('VALOR').AsFloat          := Vl_Trans;
    QArq.ParamByName('TRANSACAO_ID').AsInteger := Id_Trans;

    QArq.Prepare;
    QArq.ExecSql;


  end;

  IF (QTabela.FieldByName('UNIDADE_VENDA').AsString = 'KG') AND  (StrToFloat(Inputstring) >= 1 ) then
  begin
    if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
    Begin

    QArq.Sql.Clear;
    QArq.Sql.Add('UPDATE PRODUTOS SET QUANTIDADE_C = :QUANTIDADE');
    QArq.Sql.Add('WHERE');
    QArq.Sql.Add('(PRODUTO_ID = :PRODUTO_ID)');

    QArq.Params[0].AsFloat     := StrToFloat(Inputstring);
    QArq.Params[1].AsInteger   := QTabela.FieldByName('PRODUTO_ID').AsInteger;

    QArq.Prepare;
    QArq.ExecSql;
    End
    else
    begin

    QArq.Sql.Clear;
    QArq.Sql.Add('UPDATE PRODUTOS SET QUANTIDADE_G = :QUANTIDADE');
    QArq.Sql.Add('WHERE');
    QArq.Sql.Add('(PRODUTO_ID = :PRODUTO_ID)');

    QArq.Params[0].AsFloat     := StrToFloat(Inputstring);
    QArq.Params[1].AsInteger   := QTabela.FieldByName('PRODUTO_ID').AsInteger;

    QArq.Prepare;
    QArq.ExecSql;

    end;

  end;



  QArq.Sql.Clear;
  QArq.Sql.Add('UPDATE INVENTARIO_PRODUTOS SET ST_INVENTARIO = :ST');
  QArq.Sql.Add('WHERE');
  QArq.Sql.Add('(ST_INVENTARIO = :TP)');

  QArq.Params[0].AsString   := 'F';
  QArq.Params[1].AsString   := 'A';

  QArq.Prepare;
  QArq.ExecSql;



  Application.MessageBox('Inventario por produto finalizado com sucesso', PChar(Msg_Title), mb_IconInformation);


 //end;

 end;

