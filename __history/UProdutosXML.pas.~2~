procedure TFrmProdutosXML.BtnCalcularCustoCompraClick(Sender: TObject);
begin

   QSearch.Sql.Clear;
   QSearch.Sql.Add('SELECT  DT_ENT_SAI, (TRANSITENS.VR_UNITARIO - TRANSITENS.VR_DESCONTO) CUSTO_COMPRA, PRODUTO_ID,DESCRICAO');
   QSearch.Sql.Add('FROM TRANSITENS');
   QSearch.Sql.Add('INNER JOIN TRANSACOES ON TRANSACOES.TRANSACAO_ID = TRANSITENS.TRANSACAO_ID');
   QSearch.Sql.Add('WHERE CONDUTA = ''02'' AND DEPTO = ''07'' AND DT_ENT_SAI >= :DT_ENT_SAI');
   QSearch.Sql.Add('AND PRODUTO_ID =  :PRODUTO_ID  AND FORNECEDOR_ID = :FORNECEDOR_ID');
   QSearch.Sql.Add('ORDER BY DT_ENT_SAI DESC LIMIT 1');

   QSearch.ParamByName('DT_ENT_SAI').AsDate       := StrtoDate('01/01/01');
   QSearch.ParamByName('PRODUTO_ID').AsInteger    := QTabela.FieldByName('PRODUTO_ID').AsInteger;
   QSearch.ParamByName('FORNECEDOR_ID').AsInteger :=  QFornecedor.FieldByName('FORNECEDOR_ID').AsInteger;
   QSearch.Prepare;
   QSearch.Open;


  if Application.MessageBox(Pchar('Produto: ' + QSearch.FieldByName('DESCRICAO').AsString + #13 + 'Data da última entrada: ' +
                                  DateToStr(QSearch.FieldByName('DT_ENT_SAI').AsDateTime) +#13 + 'Valor Custo Compra: '+
                                  FloatToStrF(QSearch.FieldByName('CUSTO_COMPRA').AsFloat,ffNumber,15,2) +#13 + 'Deseja efetuar a alteraçao no Custo de Compra?'), PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then

  Begin
    {
    QCalcularCusto.Sql.Clear;
    QCalcularCusto.Sql.Add('UPDATE PRODUTOS SET CUSTO_COMPRA = :CUSTO_COMPRA WHERE PRODUTO_ID = :PRODUTO_ID');

    QCalcularCusto.ParamByName('CUSTO_COMPRA').AsFloat := QSearch.FieldByName('CUSTO_COMPRA').AsFloat;
    QCalcularCusto.ParamByName('PRODUTO_ID').AsInteger := QTabela.FieldByName('PRODUTO_ID').AsInteger;


    QCalcularCusto.Prepare;
    QCalcularCusto.ExecSQL;
     }

    Custo_compra.value :=  QSearch.FieldByName('CUSTO_COMPRA').AsFloat + Vr_IcmsSt.Value + Vr_Frete.value +Vr_Ipi.Value + Vr_Despesas.Value + Dif_Icms.Value ;
    Custo_Compra.Refresh;


     Application.MessageBox('Produto atualizado com sucesso.', PChar(Msg_Title), MB_ICONINFORMATION);



  End;



end;

