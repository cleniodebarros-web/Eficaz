procedure TFrmProdutosXML.AtualizaCustos;
var
  dt_trans, dt_ent_sai: TDate;
  vr_compra, csto_compra: Real;
  fornecedor_id: Integer;
  nome, num_doc: string;

begin
  {
  IQuery.SQL.Clear;
  IQuery.SQL.Add('UPDATE PRODUTOS SET DT_COMPRA = T.DT_TRANS, DT_ENTRADA = T.DT_ENT_SAI,');
  IQuery.SQL.Add('VALOR_COMPRA = T.VALOR_COMPRA, CUSTO_COMPRA = T.CUSTO_COMPRA, FORNECEDOR_ID = T.FORNECEDOR_ID');
  IQuery.SQL.Add('FROM');
  IQuery.SQL.Add('(SELECT distinct on (PRODUTO_ID) PRODUTO_ID, TRANSITENS.TRANSACAO_ID, DT_TRANS, DT_ENT_SAI, TRANSITENS.VR_UNITARIO VALOR_COMPRA,');
  IQuery.SQL.Add('(TRANSITENS.VR_UNITARIO - TRANSITENS.VR_DESCONTO) CUSTO_COMPRA, TRANSACOES.FORNECEDOR_ID');
  IQuery.SQL.Add('FROM TRANSITENS');
  IQuery.SQL.Add('INNER JOIN TRANSACOES ON TRANSACOES.TRANSACAO_ID = TRANSITENS.TRANSACAO_ID');
  IQuery.SQL.Add('INNER JOIN FORNECEDORES ON TRANSACOES.FORNECEDOR_ID = FORNECEDORES.FORNECEDOR_ID');
  IQuery.SQL.Add('WHERE CONDUTA = ''02'' AND DEPTO = ''07'' AND DT_ENT_SAI >= :DT_ENT_SAI');
  IQuery.SQL.Add('ORDER BY PRODUTO_ID, DT_ENT_SAI desc) as T');
  IQuery.SQL.Add('WHERE PRODUTOS.PRODUTO_ID = T.PRODUTO_ID');

  IQuery.ParamByName('DT_ENT_SAI').AsDate := StrtoDate('01/01/01');
  IQuery.Prepare;
  IQuery.ExecSQL;
  }
  if FrmPrincipal.Config.FieldByName('ALTERAR_PRECO_CUSTO').AsString = 'True' then
    Exit;

  QSearch.Sql.Clear;
  QSearch.Sql.Add('SELECT DT_TRANS, DT_ENT_SAI, TRANSACOES.FORNECEDOR_ID, TRANSITENS.VR_UNITARIO VALOR_COMPRA ');
  //QSearch.Sql.Add(',(TRANSITENS.VR_UNITARIO + (TRANSITENS.VALOR_ICMS_ST + TRANSITENS.VR_FRETE + TRANSITENS.VR_IPI + TRANSITENS.VR_ACRESCIMO - TRANSITENS.VR_DESCONTO)/TRANSITENS.QUANTIDADE) CUSTO_COMPRA');
  QSearch.Sql.Add('FROM TRANSITENS');
  QSearch.Sql.Add('INNER JOIN TRANSACOES ON TRANSACOES.TRANSACAO_ID = TRANSITENS.TRANSACAO_ID');
  QSearch.Sql.Add('LEFT JOIN FORNECEDORES ON TRANSACOES.FORNECEDOR_ID = FORNECEDORES.FORNECEDOR_ID');
  QSearch.Sql.Add('WHERE CONDUTA IN (''02'', ''19'') AND DEPTO = ''07'' AND DT_ENT_SAI >= :DT_ENT_SAI');
  QSearch.Sql.Add('AND TRANSITENS.PRODUTO_ID = :PRODUTO_ID');
  QSearch.Sql.Add('AND TRANSACOES.TIPO_COMPRA = ''COMPRA'' ');

  QSearch.Sql.Add('ORDER BY DT_ENT_SAI DESC LIMIT 1');

  QSearch.ParamByName('DT_ENT_SAI').AsDate       := StrtoDate('01/01/23');
  QSearch.ParamByName('PRODUTO_ID').AsInteger    := QTabela.FieldByName('PRODUTO_ID').AsInteger;
  QSearch.Prepare;
  QSearch.Open;

  //ShowMessage(BoolToStr(not QSearch.IsEmpty) + ' ababa ' + FloatToStr(QSearch.FieldByName('VALOR_COMPRA').AsFloat));
  if (not QSearch.IsEmpty) and (QSearch.FieldByName('VALOR_COMPRA').AsFloat > 0.01) then
  begin

    dt_trans      := QSearch.FieldByName('DT_TRANS').AsDateTime;
    dt_ent_sai    := QSearch.FieldByName('DT_ENT_SAI').AsDateTime;
    vr_compra     := QSearch.FieldByName('VALOR_COMPRA').AsFloat;
    csto_compra   := QSearch.FieldByName('VALOR_COMPRA').AsFloat + Vr_IcmsSt.Value + Vr_Frete.value +Vr_Ipi.Value + Vr_Despesas.Value + Dif_Icms.Value ;
    fornecedor_id := QSearch.FieldByName('FORNECEDOR_ID').AsInteger;

   if QTabela.FieldByName('VR_COMPRA_MANUAL').AsInteger = 0 Then
   Begin
    QSearch.Sql.Clear;
    QSearch.Sql.Add('UPDATE PRODUTOS SET DT_COMPRA = :DT_TRANS, DT_ENTRADA = :DT_ENT_SAI,');
    QSearch.Sql.Add('VALOR_COMPRA = :VALOR_COMPRA, CUSTO_COMPRA = :CUSTO_COMPRA, FORNECEDOR_ID = :FORNECEDOR_ID');
    QSearch.Sql.Add('WHERE PRODUTO_ID = :PRODUTO_ID');

    QSearch.ParamByName('DT_TRANS').AsDate         := dt_trans;
    QSearch.ParamByName('DT_ENT_SAI').AsDate       := dt_ent_sai;
    QSearch.ParamByName('VALOR_COMPRA').AsFloat    := vr_compra;
    QSearch.ParamByName('CUSTO_COMPRA').AsFloat    := csto_compra;
    QSearch.ParamByName('FORNECEDOR_ID').AsInteger := fornecedor_id;
    QSearch.ParamByName('PRODUTO_ID').AsInteger    := QTabela.FieldByName('PRODUTO_ID').AsInteger;

    QSearch.Prepare;
    QSearch.ExecSQL;
   End;

    if not QTabela.IsEmpty then
    begin
      QTabela.Edit;
      QTabela.FieldByName('DT_COMPRA').AsDateTime    := dt_trans;
      QTabela.FieldByName('DT_ENTRADA').AsDateTime   := dt_ent_sai;

      if QTabela.FieldByName('VR_COMPRA_MANUAL').AsInteger = 1 Then
      Begin
      QTabela.FieldByName('VALOR_COMPRA').AsFloat    := valor_compra.Value;
      QTabela.FieldByName('CUSTO_COMPRA').AsFloat    := valor_compra.Value + Vr_IcmsSt.Value + Vr_Frete.value +Vr_Ipi.Value + Vr_Despesas.Value + Dif_Icms.Value ;

        if  (Valor_Compra_origem <> StrToFloat(valor_compra.Text)) Then
        QTabela.FieldByName('DT_VR_COMPRA_MANUAL').AsDateTime    := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime
        Else
        QTabela.FieldByName('DT_VR_COMPRA_MANUAL').AsDateTime    := dt_ent_sai;

      End
      Else
      Begin
      QTabela.FieldByName('VALOR_COMPRA').AsFloat    := vr_compra;
      QTabela.FieldByName('CUSTO_COMPRA').AsFloat    := csto_compra;
      End;

      QTabela.FieldByName('FORNECEDOR_ID').AsInteger := fornecedor_id;
      QTabela.Post;
    end;

    if QTabela.FieldByName('VR_COMPRA_MANUAL').AsInteger = 1 Then
    Begin
    lbl_VrCompraNota.Visible    := True;
    lbl_dtVrCompraNota.Visible  := True;
