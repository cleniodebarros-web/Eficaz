       GravarLog('PRODUTO','DELETAR',DateToStr(date),TimeToStr(time),TCurrencyEdit(Temp).Name,FloatToStr(TCurrencyEdit(Temp).Value),FloatToStr(QTabela.FieldbyName(TCurrencyEdit(Temp).Name).AsFloat),FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger,QTabela.FieldByName('PRODUTO_ID').AsInteger);
