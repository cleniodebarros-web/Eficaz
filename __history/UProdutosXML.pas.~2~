      if QDesagregacao.FieldByName('INSUMO_ID').AsInteger = QTabela.FieldByName('PRODUTO_ID').AsInteger then
      Application.MessageBox('Código do Insumo é o mesmo do produto principal favor verificar.', PChar(Msg_Title), mb_IconStop)
      Else
      QDesagregacao.FieldByName('DESCRICAO').AsString := IQuery.FieldByName('DESCRICAO').AsString;

      End;
    end;

    if Grid_Desagregacao.SelectedField.FieldName = 'quantidade' then
    Begin
      Iquery.Sql.Clear;
      IQuery.Sql.Add('SELECT SUM(QUANTIDADE) QUANTIDADE FROM DESAGREGACAO_ITENS');
      IQuery.Sql.Add('WHERE PRODUTO_ID = :PRODUTO_ID');

      IQuery.ParamByName('PRODUTO_ID').AsInteger := QTabela.FieldByName('PRODUTO_ID').AsInteger;

      IQuery.Prepare;
      IQuery.Open;


      IF (IQuery.FieldByName('QUANTIDADE').AsFloat) + (QDesagregacao.FieldByname('QUANTIDADE').AsFloat) >= 100 Then
      Begin

        IF (IQuery.FieldByName('QUANTIDADE').AsFloat) = 100 Then
        Begin
         Application.MessageBox('Total da quantidade das peças concluido em  100%' , PChar(Msg_Title), mb_IconStop);
         Abort;
        End;

      Application.MessageBox(Pchar('Total da quantidade das peças deve ser 100%' + #13 + 'Quantidade(%) Atual : ' + FloatToStrF(IQuery.FieldByName('QUANTIDADE').AsFloat,ffNumber,15,2)) , PChar(Msg_Title), mb_IconStop);

      QDesagregacao.FieldByname('QUANTIDADE').AsFloat := 0;
      QDesagregacao.FieldByname('QUANTIDADE').AsFloat :=  100 - IQuery.FieldByName('QUANTIDADE').AsFloat;
      Grid_Desagregacao.SelectedIndex := 2;
      End;
    End;

    if Grid_Desagregacao.SelectedField.FieldName = 'perda' then
    QDesagregacao.FieldByName('QUANTIDADE_FIM').AsFloat := QDesagregacao.FieldByName('QUANTIDADE').AsFloat  - RoundTo((QDesagregacao.FieldByName('PERDA').AsFloat * QDesagregacao.FieldByName('QUANTIDADE').AsFloat) / 100 , -2)

  end;


end;

