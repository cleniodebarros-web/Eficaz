procedure TFrmTrans_Pagamento.btnInsertClick(Sender: TObject);
begin
  if FrmData.QAcesso.FieldByName('INCLUSAO').AsString = 'NĂO' then
  begin
    Application.MessageBox('Usuário sem permissăo para inclusăo', PChar(Msg_Title), mb_IconStop);
    exit;
  end;

  Operacao := 'Inserindo';
  Botoes_Editing;
  Set_Campos(True);
  Habilitar(True);

  QEmpresa.Close;
  QBanco.Close;
  QConta.Close;

  DT_TRANS.Date        := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  DT_MOVIMENTO.Date    := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  DT_ENT_SAI.Date      := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  BALANCO.Text         := 'LIBERADO';
  AUTORIZ_ID.Value     := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
  FLUXO_CAIXA_ID.Value := 3;
  HORA.Text            := TimeToStr(TIME);

  if LeIni(Arq_Ini, 'Sistema', 'Caixa') <> '' then
    BANCO_ID.Value := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Caixa'));

  Application.CreateForm(TFrmSeleciona_Credores, FrmSeleciona_Credores);
  try
    if (FrmSeleciona_Credores.ShowModal = mrOk) and (not FrmSeleciona_Credores.QTabela.IsEmpty) then
    begin
      VALOR_PARCELA.Value := FrmSeleciona_Credores.QTabela.FieldByName('VALOR').AsFloat;
      VALOR.Value         := FrmSeleciona_Credores.QTabela.FieldByName('VALOR').AsFloat;
      HISTORICO.Text      := FrmSeleciona_Credores.QTabela.FieldByName('HISTORICO').AsString;
      NUM_DOC.Text        := FrmSeleciona_Credores.QTabela.FieldByName('NUM_DOC').AsString;
      PARCELA_ID.Text     := FrmSeleciona_Credores.QTabela.FieldByName('PARCELA_ID').AsString;
      FORNECEDOR_ID.Value := FrmSeleciona_Credores.QTabela.FieldByName('FORNECEDOR_ID').AsInteger;
      EMPRESA_ID.Value    := FrmSeleciona_Credores.QTabela.FieldByName('EMPRESA_ID').AsInteger;
      ENTRADA_ID.Value    := FrmSeleciona_Credores.QTabela.FieldByName('TRANSACAO_ID').AsInteger;
      COMPLEMENTO.Text    := 'Duplicata :' + FrmSeleciona_Credores.QTabela.FieldByName('DUPLICATA').AsString + ' Venc.: ' + FrmSeleciona_Credores.QTabela.FieldByName('DT_VENCIMENTO').AsString;

      Consulta.TabVisible := False;
      DT_TRANS.SetFocus;
    end
    else
      btnDiscardClick(Self);
  finally
    FrmSeleciona_Credores.Release;
  end;
end;

