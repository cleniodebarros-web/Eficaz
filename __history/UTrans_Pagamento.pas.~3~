procedure TFrmTrans_Pagamento.Set_Campos(Vazio: Boolean);
var
I: Integer;
Temp: TComponent;
begin
  for I := 0 to (ComponentCount - 1) do
  begin
    Temp := Components[I];

    if Vazio then
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := '';

      if Temp is TDateEdit then
        TDateEdit(Temp).Text := '';

      if Temp is TComboBox then
        TComboBox(Temp).Text := '';

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := 0;

      if Temp is TRxCalcEdit then
        TRxCalcEdit(Temp).Value := 0;
    end
    else
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := QTabela.FieldByName(TEdit(Temp).Name).AsString;

      if Temp is TDateEdit then
        TDateEdit(Temp).Text := QTabela.FieldByName(TDateEdit(Temp).Name).AsString;

      if Temp is TComboBox then
        TComboBox(Temp).Text := QTabela.FieldByName(TComboBox(Temp).Name).AsString;

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := QTabela.FieldByName(TCurrencyEdit(Temp).Name).AsFloat;

      if Temp is TRxCalcEdit then
        TRxCalcEdit(Temp).Value := QTabela.FieldByName(TRxCalcEdit(Temp).Name).AsFloat;
    end;
  end;

  if QTabela.FieldByName('FUNCIONARIO_ID').AsInteger > 0 then
  begin
   QRel.SQL.Clear;
   QRel.SQL.Add('SELECT NOME FROM FUNCIONARIOS WHERE FUNCIONARIO_ID = :FUNCIONARIO_ID');
   QRel.ParamByName('FUNCIONARIO_ID').AsInteger := QTabela.FieldByName('FUNCIONARIO_ID').AsInteger;
   QRel.Prepare;
   QRel.Open;

    Lbl_Funcionario.Visible := True;
    Lbl_Funcionario.Caption := 'Funcionário: ' + Copy(QREl.FieldByName('NOME').AsString,1,15);

  end
  Else
  Begin
    Lbl_Funcionario.Visible := False;
    Lbl_Funcionario.Caption := '';
  End;


  DetailSearch('');

  CONDUTA.Text := '08';
  DEPTO.Text   := '';
  TPCTB.Text   := FrmData.QAcesso.FieldByName('TPCTB').AsString;
end;

