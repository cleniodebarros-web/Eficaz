procedure TFrmTrans_Pagamento.btnSaveClick(Sender: TObject);
begin
  DetailSearch('');

  if VALOR.Value = VALOR_PARCELA.Value then
  begin
    CONTA_ID.Value := 0;
    SERIE.Text     := 'N';
  end;

  if Validacao then
  begin
    if Operacao = 'Inserindo' then
    begin
      Insert;

      CmdSelectNull := 'WHERE (TRANSACAO_ID IS NOT NULL) AND (DT_MOVIMENTO = :DT_MOVIMENTO) AND (CONDUTA = :CONDUTA) AND (TPCTB = :TPCTB) AND (EMPRESA_ID = :EMPRESA_ID)';
      CmdOrderBy    := 'ORDER BY TRANSACAO_ID';

      QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

      QTabela.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      QTabela.ParamByName('CONDUTA').AsString        := '08';
      QTabela.ParamByName('TPCTB').AsString          := FrmData.QAcesso.FieldByName('TPCTB').AsString;
      QTabela.ParamByName('EMPRESA_ID').AsInteger    := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

      QTabela.Prepare;
      QTabela.Open;
      QTabela.Last;

      If (FrmPrincipal.Config.FieldByName('AUDITORIA').AsString = 'True') Then
       GravarLog('PAGAMENTO','INSERIR',DateToStr(date),TimeToStr(time),'Transaçăo_id ' , IntToStr(id),'Valor: ' + FloatToStr(QTabela.FieldByName('VALOR').AsFloat) + ' Documento: ' + QTabela.FieldByName('NUM_DOC').AsString  ,FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger,QTabela.FieldByName('FORNECEDOR_ID').AsInteger);
    end;

    Set_Campos(False);

    if QTabela.IsEmpty then
    begin
      QEmpresa.Close;
      QBanco.Close;
      QConta.Close;
    end;

    Habilitar(False);
    Botoes_Normal;
    Operacao := '';
    Consulta.TabVisible := True;
  end;
end;

