    FrmPrincipal.MemoResp.Lines.Add('Empresa: ' + FrmPrincipal.QEmpresa.FieldByName('RAZAO').AsString + ' CNPJ: ' + FrmPrincipal.QEmpresa.FieldByName('CNPJ').AsString );
