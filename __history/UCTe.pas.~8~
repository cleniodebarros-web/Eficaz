      UF_EXPEDIDOR.SetFocus;
      exit;
    end;

    if Length(AllTrim(sub_chave_cte.Text)) <> 44 then
    Begin
      Application.MessageBox('Tamanho da Chave Cte Inválido! deve conter 44 Caracteres favor verificar a digitaçăo!', PChar(Msg_Title), mb_IconStop);
      sub_chave_cte.Color := clYellow;
