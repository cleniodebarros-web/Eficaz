procedure TFrmPosicao_Estoque_Filiais.btnExecutaClick(Sender: TObject);
begin
// 151, 325
  try


    btnExecuta.Enabled := False;
    btnRetorna.Enabled := False;
    Posicao_produtos_filial.EM

    if Data.Text <> '' then
    begin
      Qempresa.Open;
      QFilial.Sql.Clear;

      if Data.Text <> 'Hoje' then
      begin
        if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
          QFilial.Sql.Add('SELECT posicao_produtos.PRODUTO_ID, posicao_produtos.CUSTO_COMPRA, posicao_produtos.VALOR_COMPRA, ' +
                         'posicao_produtos.CUSTOMEDIO, posicao_produtos.PRECO_VAREJO, posicao_produtos.PRECO_ATACADO, posicao_produtos.QUANTIDADE_C AS QUANTIDADE, posicao_produtos.DESCRICAO, PRODUTOS.UNIDADE_VENDA, PRODUTOS.COD_BARRA,PRODUTOS.PRODUTO_ID_MATRIZ')
        else
          QFilial.Sql.Add('SELECT posicao_produtos.PRODUTO_ID, posicao_produtos.CUSTO_COMPRA, posicao_produtos.VALOR_COMPRA, ' +
                         'posicao_produtos.CUSTOMEDIO, posicao_produtos.PRECO_VAREJO, posicao_produtos.PRECO_ATACADO, posicao_produtos.QUANTIDADE_G AS QUANTIDADE, posicao_produtos.DESCRICAO, PRODUTOS.UNIDADE_VENDA, PRODUTOS.COD_BARRA,PRODUTOS.PRODUTO_ID_MATRIZ');

        QFilial.Sql.Add('FROM posicao_produtos');
        QFilial.Sql.Add('LEFT JOIN PRODUTOS');
        QFilial.Sql.Add('ON (posicao_produtos.PRODUTO_ID = PRODUTOS.PRODUTO_ID) AND (posicao_produtos.DT_MOVIMENTO = :DT_MOVIMENTO)');
        QFilial.Sql.Add('WHERE');
        QFilial.Sql.Add('(PRODUTOS.EMPRESA_ID = :EMPRESA_ID)');

        if Tipo_item.Text <> ''  then
        QFilial.Sql.Add('AND (PRODUTOS.TIPO_ITEM = :TIPO) ');

        if Tipo_item.Text <> ''  then
        QFilial.ParamByName('TIPO').AsString := Tipo_item.Text;

        QFilial.ParamByName('DT_MOVIMENTO').AsDateTime := StrToDate(Data.Text);

        if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
        begin
          if Selecao.Text = 'Igual a 0' then
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_C = 0)')
          else if Selecao.Text = 'Maior do que 0' then
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_C > 0)')
          else if Selecao.Text = 'Menor do que 0' then
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_C < 0)')
          else if Selecao.Text = 'Todos' then
            QFilial.Sql.Add('AND ((posicao_produtos.QUANTIDADE_C < 0) OR (posicao_produtos.QUANTIDADE_C = 0) OR (posicao_produtos.QUANTIDADE_C > 0))')
          else
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_C <> 0)');
        end
        else
        begin
          if Selecao.Text = 'Igual a 0' then
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_G = 0)')
          else if Selecao.Text = 'Maior do que 0' then
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_G > 0)')
          else if Selecao.Text = 'Menor do que 0' then
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_G < 0)')
          else if Selecao.Text = 'Todos' then
            QFilial.Sql.Add('AND ((posicao_produtos.QUANTIDADE_G < 0) OR (posicao_produtos.QUANTIDADE_C = 0) OR (posicao_produtos.QUANTIDADE_C > 0))')
          else
            QFilial.Sql.Add('AND (posicao_produtos.QUANTIDADE_G <> 0)');
        end;
      end
      else
      begin
        if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
          QFilial.Sql.Add('SELECT PRODUTO_ID, DESCRICAO, CUSTO_COMPRA, VALOR_COMPRA, CUSTOMEDIO, PRECO_VAREJO, PRECO_ATACADO, UNIDADE_VENDA, QUANTIDADE_C AS QUANTIDADE, COD_BARRA')
        else
          QFilial.Sql.Add('SELECT PRODUTO_ID, DESCRICAO, CUSTO_COMPRA, VALOR_COMPRA, CUSTOMEDIO, PRECO_VAREJO, PRECO_ATACADO, UNIDADE_VENDA, QUANTIDADE_G AS QUANTIDADE, COD_BARRA');

        QFilial.Sql.Add('FROM PRODUTOS');
        QFilial.Sql.Add('WHERE');
        QFilial.Sql.Add('(EMPRESA_ID = :EMPRESA_ID)');

        if Tipo_item.Text <> ''  then
         QFilial.Sql.Add('AND (PRODUTOS.TIPO_ITEM = :TIPO) ');

        if Tipo_item.Text <> ''  then
         QFilial.ParamByName('TIPO').AsString := Tipo_item.Text;


        if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) > 0 then
        begin
          QFilial.Sql.Add('AND (LOCALIZACAO_ID = :LOCALIZACAO_ID)');

          QFilial.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo'));
        end;

        if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
        begin
          if Selecao.Text = 'Igual a 0' then
            QFilial.Sql.Add('AND (QUANTIDADE_C = 0)')
          else if Selecao.Text = 'Maior do que 0' then
            QFilial.Sql.Add('AND (QUANTIDADE_C > 0)')
          else if Selecao.Text = 'Menor do que 0' then
            QFilial.Sql.Add('AND (QUANTIDADE_C < 0)')
          else if Selecao.Text = 'Todos' then
            QFilial.Sql.Add('AND ((QUANTIDADE_C < 0) OR (QUANTIDADE_C = 0) OR (QUANTIDADE_C > 0))')
          else
            QFilial.Sql.Add('AND (QUANTIDADE_C <> 0)');
        end
        else
        begin
          if Selecao.Text = 'Igual a 0' then
            QFilial.Sql.Add('AND (QUANTIDADE_G = 0)')
          else if Selecao.Text = 'Maior do que 0' then
            QFilial.Sql.Add('AND (QUANTIDADE_G > 0)')
          else if Selecao.Text = 'Menor do que 0' then
            QFilial.Sql.Add('AND (QUANTIDADE_G < 0)')
          else if Selecao.Text = 'Todos' then
            QFilial.Sql.Add('AND ((QUANTIDADE_G < 0) OR (QUANTIDADE_G = 0) OR (QUANTIDADE_G > 0))')
          else
            QFilial.Sql.Add('AND (QUANTIDADE_G <> 0)');
        end;
      end;

      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Fornecedor')) > 0 then
      begin
        QFilial.Sql.Add('AND (PRODUTOS.FORNECEDOR_ID = :FORNECEDOR_ID)');

        QFilial.ParamByName('FORNECEDOR_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Fornecedor'));
      end;

      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo')) > 0 then
      begin
        QFilial.Sql.Add('AND (PRODUTOS.GRUPO_ID = :GRUPO_ID)');

        QFilial.ParamByName('GRUPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo'));
      end;

      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo')) > 0 then
      begin
        QFilial.Sql.Add('AND (PRODUTOS.SUBTIPO_ID = :SUBTIPO_ID)');

        QFilial.ParamByName('SUBTIPO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo'));
      end;

      if StrToInt(LeIni(Arq_Ini, 'Sistema', 'Localizaçăo')) = 0 then
      begin
        if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo')) > 0 then
        begin
          QFilial.Sql.Add('AND (PRODUTOS.LOCALIZACAO_ID = :LOCALIZACAO_ID)');

          QFilial.ParamByName('LOCALIZACAO_ID').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo'));
        end;
      end;

      if StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Inicial')) > 0 then
      begin
        QFilial.Sql.Add('AND (PRODUTOS.PRODUTO_ID BETWEEN :PRODUTO_INICIAL AND :PRODUTO_FINAL)');

        QFilial.ParamByName('PRODUTO_INICIAL').AsInteger := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Inicial'));
        QFilial.ParamByName('PRODUTO_FINAL').AsInteger   := StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Produto Final'));
      end;

      QFilial.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;

      QFilial.Sql.Add('ORDER BY posicao_produtos.DESCRICAO');
      QFilial.Prepare;
      QFilial.Open;

      while not Qfilial.eof do
      Begin
       Posicao_produtos_filial.Append;

       Posicao_produtos_filial.FieldByName('PRODUTO_ID').AsInteger    := QFilial.FieldByName('PRODUTO_ID').AsInteger;
       Posicao_produtos_filial.FieldByName('DT_MOVIMENTO').AsDateTime := StrToDate(Data.Text);;

       IQuery.Sql.Clear;
       IQuery.Sql.Text := 'SELECT CUSTO_COMPRA,VALOR_COMPRA,CUSTOMEDIO FROM PRODUTOS WHERE PRODUTO_ID = :PRODUTO_ID';
       IQuery.ParamByName('PRODUTO_ID').AsInteger :=   QFilial.FieldByName('PRODUTO_ID_MATRIZ').AsInteger;
       IQuery.Prepare;
       IQuery.Open;

       Posicao_produtos_filial.FieldByName('CUSTO_COMPRA').AsFloat := IQuery.FieldByName('CUSTO_COMPRA').AsFloat;
       Posicao_produtos_filial.FieldByName('VALOR_COMPRA').AsFloat := IQuery.FieldByName('VALOR_COMPRA').AsFloat;
       Posicao_produtos_filial.FieldByName('CUSTOMEDIO').AsFloat   := IQuery.FieldByName('CUSTOMEDIO').AsFloat;
       Posicao_produtos_filial.FieldByName('PRECO_VAREJO').AsFloat := QFilial.FieldByName('PRECO_VAREJO').AsFloat;
       Posicao_produtos_filial.FieldByName('QUANTIDADE_C').AsFloat := QFilial.FieldByName('QUANTIDADE_C').AsFloat;
       Posicao_produtos_filial.FieldByName('DESCRICAO').AsString   := QFilial.FieldByName('DESCRICAO').AsString;
       Posicao_produtos_filial.FieldByName('UNIDADE_VENDA').AsString   := QFilial.FieldByName('UNIDADE_VENDA').AsString;
       Posicao_produtos_filial.FieldByName('COD_BARRA').AsString   := QFilial.FieldByName('COD_BARRA').AsString;


       Posicao_produtos_filial.Post;

      End;







      QRLabel1.Caption := 'Data: ' + Data.Text;
      QRLabel2.Caption := 'Preço: ' + Preco.Text;

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo') = '0' then
        QRLabel6.Caption := 'Grupo: TODOS'
      else
        QRLabel6.Caption := 'Grupo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Grupo')), '7');

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo') = '0' then
        QRLabel7.Caption := 'Sub-Tipo: TODOS'
      else
        QRLabel7.Caption := 'Sub-Tipo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'SubTipo')), '5');

      if LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo') = '0' then
        QRLabel8.Caption := 'Localizaçăo: TODAS'
      else
        QRLabel8.Caption := 'Localizaçăo: ' + Search_Tabela(StrToInt(LeIni(Arq_Ini, 'Parâmetros Estoque', 'Localizaçăo')), '8');

      if Preco.Text = 'Valor Compra' then
      begin
        QRDBText8.DataField := 'VALOR_COMPRA';
        QRExpr1.Expression  := '(Posicao_produtos_filial.VALOR_COMPRA * Posicao_produtos_filial.QUANTIDADE)';
        QRExpr2.Expression  := 'Sum(Posicao_produtos_filial.VALOR_COMPRA * Posicao_produtos_filial.QUANTIDADE)';
      end
      else if Preco.Text = 'Custo Compra' then
      begin
        QRDBText8.DataField := 'CUSTO_COMPRA';
        QRExpr1.Expression  := '(Posicao_produtos_filial.CUSTO_COMPRA * Posicao_produtos_filial.QUANTIDADE)';
        QRExpr2.Expression  := 'Sum(Posicao_produtos_filial.CUSTO_COMPRA * Posicao_produtos_filial.QUANTIDADE)';
      end
      else if Preco.Text = 'Customédio' then
      begin
        QRDBText8.DataField := 'CUSTOMEDIO';
        QRExpr1.Expression  := '(Posicao_produtos_filial.CUSTOMEDIO * Posicao_produtos_filial.QUANTIDADE)';
        QRExpr2.Expression  := 'Sum(Posicao_produtos_filial.CUSTOMEDIO * Posicao_produtos_filial.QUANTIDADE)';
      end
      else if Preco.Text = 'Pr. Varejo' then
      begin
        QRDBText8.DataField := 'PRECO_VAREJO';
        QRExpr1.Expression  := '(Posicao_produtos_filial.PRECO_VAREJO * Posicao_produtos_filial.QUANTIDADE)';
        QRExpr2.Expression  := 'Sum(Posicao_produtos_filial.PRECO_VAREJO * Posicao_produtos_filial.QUANTIDADE)';
      end;

      if QFilial.IsEmpty then
        Application.MessageBox('Năo há dados para os parâmetros informados', PChar(Msg_Title), mb_IconInformation)
      else
       Begin
       Posicao.Prepare;
       //Posicao.ExportToFilter(TQRXLSFilter.Create(ExtractFilePath(ParamStr(0)) + 'Exportados\Posicao_' +Data.Text + '.xls'));
       Posicao.PreviewModal;
         if chk_exportar.Checked Then
         Begin
         Posicao.ExportToFilter(TQRXLSFilter.Create(ExtractFilePath(ParamStr(0)) + 'Exportados\Inventario_' + Copy(Data.Text,1,2) + Copy(Data.Text,4,2) + Copy(Data.Text,7,4)  + '.xls'));
         Application.MessageBox(PChar('Arquivo exportado para : ' + ExtractFilePath(ParamStr(0)) + 'Exportados\Inventario_' + Copy(Data.Text,1,2) + Copy(Data.Text,4,2) + Copy(Data.Text,7,4)  + '.xls') , PChar(Msg_Title), mb_IconInformation);
         End;
       //Application.MessageBox(PChar('Arquivo exportado para : ' + ExtractFilePath(ParamStr(0)) + 'Exportados\Posicao_' +Data.Text + '.xls') , PChar(Msg_Title), mb_IconInformation)
       End;
    end
    else
      Application.MessageBox('Necessário informar uma data', PChar(Msg_Title), mb_IconInformation)
  finally
    btnExecuta.Enabled := True;
    btnRetorna.Enabled := True;
  end;
end;

