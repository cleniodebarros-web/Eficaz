procedure TFrmPosicao_Estoque_Filiais.LISTA_EMPRESAExit(Sender: TObject);
begin

  QSearch.Sql.Clear;
  QSearch.Sql.Text := 'SELECT BANCO,USUARIO,SENHA,IP,PORTA FROM EMPRESAS WHERE RAZAO = :RAZAO';
  QSearch.ParamByName('RAZAO').AsString := Lista_Empresa.Text;
  QSearch.Prepare;
  QSearch.Open;



  FilialDb.Free;
  FilialDb := TFDConnection.Create(nil);
 try
  FilialDb.Params.Clear;
  FilialDb.Params.Add('Database= ' + QSearch.FieldByName('BANCO').AsString );
  FilialDb.Params.Add('User_Name= ' + QSearch.FieldByName('USUARIO').AsString );
  FilialDb.Params.Add('Password='+ QSearch.FieldByName('SENHA').AsString );
  FilialDb.Params.Add('Server= ' +  QSearch.FieldByName('IP').AsString );
  FilialDb.Params.Add('Port= ' + QSearch.FieldByName('PORTA').AsString);
  FilialDb.Params.Add('DriverID=PG');
  FilialDb.Params.Add('MonitorBy=Remote');
  FilialDb.Connected:=True;
  FilialDb.Open();
 Except
   Application.MessageBox('Filial năo conectada favor verificar!','Eficaz', MB_ICONERROR + MB_OK);
 end;

  if FilialDb.Connected  Then
  Begin
  lbl_online.font.color := clgreen;
  lbl_online.Caption := 'Filial OnLine';
  End
  Else
  Begin
  lbl_online.font.color := clred;
  lbl_online.Caption := 'Filial OffLIne';
  End;


   if FilialDb.Connected  Then
   Begin

    QFilial.Connection :=FilialDb;

    QFilial.Sql.Clear;
    QFilial.Sql.Add('SELECT DISTINCT DT_MOVIMENTO');
    QFilial.Sql.Add('FROM posicao_produtos');
    QFilial.Sql.Add('ORDER BY DT_MOVIMENTO');
    QFilial.Prepare;
    QFilial.Open;

    Data.Items.Clear;
    Data.Items.Add('Hoje');

    QFilial.First;
    while not QFilial.Eof do
    begin
      Data.Items.Add(QFilial.FieldByName('DT_MOVIMENTO').AsString);
      Application.ProcessMessages;
      QFilial.Next;
    end;
   End;




end;

procedure TFrmPosicao_Estoque_Filiais.DataKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if Key = Vk_Return then
    Perform(Wm_NextDlgctl, 0, 0);
end;

procedure TFrmPosicao_Estoque_Filiais.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  Action := caFree;
end;

procedure TFrmPosicao_Estoque_Filiais.FormShow(Sender: TObject);
begin
  IQuery.Sql.Clear;
  IQuery.Sql.Add('SELECT * FROM EMPRESAS');
  IQuery.Sql.Add('ORDER BY EMPRESA_ID');
  IQuery.Prepare;
  IQuery.Open;

  Lista_Empresa.Items.Clear;


  IQuery.First;
  while not IQuery.Eof do
  begin
    Lista_Empresa.Items.Add(IQuery.FieldByName('RAZAO').AsString);
    Application.ProcessMessages;
    IQuery.Next;
  end;


end;

procedure TFrmPosicao_Estoque_Filiais.PosicaoBeforePrint(Sender: TCustomQuickRep;
  var PrintReport: Boolean);
