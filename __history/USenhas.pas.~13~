procedure TFrmSenhas.btnSaveClick(Sender: TObject);
begin
  DetailSearch('');

  if Validacao then
  begin
    SENHA.Text := EncryptMsg(SENHA.Text, 65);

    if Operacao = 'Inserindo' then
    begin
      Insert;

      CmdOrderBy := 'ORDER BY FUNCIONARIO_ID';

      QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

      QTabela.Prepare;
      QTabela.Open;

      QTabela.Last;
    end
    else
      Edit;

    Set_Campos(False);
    Habilitar(False);
    Botoes_Normal;
    Operacao := '';
  end;
  FrmData.QAcesso.Refresh;
end;

