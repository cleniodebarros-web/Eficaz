procedure TFrmSenhas.MenuClickCheck(Sender: TObject);
var
X: Integer;
begin
  OPCOES.Text := '';

  for X := 0 to (Menu.Items.Count - 1) do
  begin
    if Menu.Checked[X] then
      OPCOES.Text := OPCOES.Text + 'S'
    else
      OPCOES.Text := OPCOES.Text + 'N';
  end;
end;

procedure TFrmSenhas.MenuKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
var
X: Integer;
begin
  if Key = VK_F7 then
  begin
    OPCOES.Text := '';

    for X := 1 to Itens_Menu do
    begin
      Menu.Checked[X - 1] := False;
      OPCOES.Text         := OPCOES.Text + 'N';
    end;
  end;

  if Key = VK_F8 then
  begin
    OPCOES.Text := '';

    for X := 1 to Itens_Menu do
    begin
      if Menu.ItemEnabled[X - 1] then
      begin
        Menu.Checked[X - 1] := True;
        OPCOES.Text         := OPCOES.Text + 'S';
      end
      else
      begin
        Menu.Checked[X - 1] := False;
        OPCOES.Text         := OPCOES.Text + 'N';
      end;
    end;
  end;
end;

procedure TFrmSenhas.Set_Campos(Vazio: Boolean);
var
I, X: Integer;
Temp: TComponent;
begin
  for I := 0 to (ComponentCount - 1) do
  begin
    Temp := Components[I];

    if Vazio then
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := '';

      if Temp is TComboBox then
        TComboBox(Temp).Text := '';

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := 0;
    end
    else
    begin
      if Temp is TEdit then
        TEdit(Temp).Text := QTabela.FieldByName(TEdit(Temp).Name).AsString;

      if Temp is TComboBox then
        TComboBox(Temp).Text := QTabela.FieldByName(TComboBox(Temp).Name).AsString;

      if Temp is TCurrencyEdit then
        TCurrencyEdit(Temp).Value := QTabela.FieldByName(TCurrencyEdit(Temp).Name).AsFloat;

      OPCOES.Text := '';

      for X := 1 to Itens_Menu do
      begin
        Menu.Checked[X - 1] := Caso(Copy(QTabela.FieldByName('OPCOES').AsString, X, 1));
        OPCOES.Text         := OPCOES.Text + Copy(QTabela.FieldByName('OPCOES').AsString, X, 1);
      end;
    end;
  end;

  DetailSearch('');
end;

