end;

function TFrmSenhas.Validacao: Boolean;
begin
  Result := False;

  EMPRESA_ID.Color     := clWindow;
  FUNCIONARIO_ID.Color := clWindow;

  if QEmpresa.IsEmpty then
  begin
    Application.MessageBox('Empresa inexistente', PChar(Msg_Title), mb_IconStop);

    EMPRESA_ID.Color := clYellow;
    EMPRESA_ID.SetFocus;

    exit;
  end;

  if QFuncionario.IsEmpty then
  begin
    Application.MessageBox('Funcionßrio inexistente', PChar(Msg_Title), mb_IconStop);

    FUNCIONARIO_ID.Color := clYellow;
    FUNCIONARIO_ID.SetFocus;

    exit;
  end;

  Result := True;

  IQuery.SQL.Clear;
  IQuery.SQL.Add('select funcionario_id, substr(opcoes,69,1) from acesso where length(opcoes) >= 69 and substr(opcoes,69,1) = ''S''');
  IQuery.Prepare;
  IQuery.Open;

  if not IQuery.IsEmpty then
  begin
    if Copy(FrmData.QAcesso.FieldByName('OPCOES').AsString,69,1) = 'N' then
    begin
      if Menu.Checked[68] then
      begin
        Result := False;
        Menu.Checked[68] := not Menu.Checked[68];
        Application.MessageBox('Usußrio sem permissŃo para alterar a opńŃo de editar limite de cliente', PChar(Msg_Title), mb_IconStop);
        exit;
      end;

      IQuery.SQL.Clear;
      IQuery.SQL.Add('select case when substr(opcoes,69,1) = ''S'' then True else False end as permissao from acesso where funcionario_id = :FUNCIONARIO_ID');
      IQuery.ParamByName('FUNCIONARIO_ID').AsInteger := StrToInt(FUNCIONARIO_ID.Text);
      IQuery.Prepare;
      IQuery.Open;

      if Menu.Checked[68] <> IQuery.FieldByName('PERMISSAO').AsBoolean then
      begin
        Result := False;
        Menu.Checked[68] := not Menu.Checked[68];
        Application.MessageBox('Usußrio sem permissŃo para alterar a opńŃo de editar limite de cliente', PChar(Msg_Title), mb_IconStop);
        exit;
      end;
    end;
  end;

end;

