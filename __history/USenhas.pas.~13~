procedure TFrmSenhas.FormCreate(Sender: TObject);
var
X: Integer;
begin
  if UpperCase(DecryptMsg(Frmprincipal.Config.FieldByName('VERSAO').AsString, 65)) <> 'LIGHT' then
  Begin
    IQuery.Sql.Clear;
    IQuery.Sql.Add('SELECT * FROM CONFIG_SUBMENU');
    IQuery.Sql.Add('ORDER BY ID');

    IQuery.Prepare;
    IQuery.Open;

    Menu.Items.Clear;

    X          := 0;
    Itens_Menu := 0;

    IQuery.First;
    while not IQuery.Eof do
    begin
      Menu.Items.Add(IQuery.FieldByName('DESCRICAO').AsString);

      if (IQuery.FieldByName('STATUS').AsString = 'False') or (IQuery.FieldByName('DESCRICAO').AsString = '-') then
      begin
        Menu.Checked[X]     := False;
        Menu.ItemEnabled[X] := False;
      end;

      Inc(X);
      Inc(Itens_Menu);

      Application.ProcessMessages;
      IQuery.Next;
    end;
  End;

  if FrmData.QAcesso.FieldByName('TPCTB').AsString = '2' then
  begin
    Label7.Visible := False;
    TPCTB.Visible  := False;

  end;

  CmdSelect     := QTabela.Sql.Text;
  CmdSelectNull := 'WHERE (FUNCIONARIO_ID IS NOT NULL)';
  CmdOrderBy    := 'ORDER BY FUNCIONARIO_ID';

  QTabela.Sql.Text := CmdSelect + #13 + CmdSelectNull + #13 + CmdOrderBy;

  QTabela.Prepare;
  QTabela.Open;

  if UpperCase(DecryptMsg(Frmprincipal.Config.FieldByName('VERSAO').AsString, 65)) = 'LIGHT' then
  Begin
  Menu.visible       := False;
  StatusBar1.Visible := False;
  //FrmSenhas.Height   := 307;
  End;

end;

