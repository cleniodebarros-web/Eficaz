  object QTabela: TFDQuery
    Connection = FrmData.DbF_Eficaz
    FetchOptions.AssignedValues = [evAutoFetchAll]
    FetchOptions.AutoFetchAll = afTruncate
    SQL.Strings = (
      ''
      
        'SELECT TRANSITENS.*, TRANSACOES.DT_MOVIMENTO,TRANSACOES.TIPO_IMP' +
        ', TABELAS.DESCRICAO DESCR_CONTA, CFOP.DESC_CFOP, CST_ICMS.DESCRI' +
        'CAO DESCR_ICMS'
      'FROM TRANSITENS'
      'INNER JOIN TABELAS'
      
        'ON ((TRANSITENS.CONTA_ID = TABELAS.TABELA_ID) AND (TABELAS.TIPO_' +
        'TABELA = '#39'4'#39'))'
      'INNER JOIN CFOP'
      'ON (TRANSITENS.CFOP = CFOP.COD_CFOP)'
      'INNER JOIN CST_ICMS'
      'ON (TRANSITENS.CST = CST_ICMS.CODIGO)'
      'INNER JOIN TRANSACOES'
      'ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)'
      'WHERE'
      '(TRANSITENS.TRANSACAO_ID = :TRANSACAO_ID)')
    Left = 32
    Top = 392
    ParamData = <
      item
        Name = 'TRANSACAO_ID'
        ParamType = ptInput
      end>
  end
