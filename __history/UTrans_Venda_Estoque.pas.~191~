procedure TFrmTrans_Venda_Estoque.Pedido_idExit(Sender: TObject);
begin
  if Pedido_id.Value > 0 then
  Begin
    if Chk_Imp_os.Checked then
    Begin
    Detailsearch('Ordem de Serviço');
    Tipo_imp.value := 2;
      if QPedido_Venda.IsEmpty then
      Begin
      Application.MessageBox('Informar Ordem de Serviço válido e năo faturado!', PChar(Msg_Title), mb_IconSTop);
      Pedido_ID.Color := clYellow;
      Pedido_ID.SetFocus;
      exit;
      End;
      if not VerificaRegistro(StrToInt(Pedido_id.Text),'ORDEM SERVICO')  Then
      Begin
      Application.MessageBox('Ordem de Serviço em uso favor verificar.', PChar(Msg_Title), mb_IconSTop);
      Pedido_ID.Color := clYellow;
      Pedido_ID.SetFocus;
      exit;
      End;
    End
    Else
    Begin
    Detailsearch('Pedido de Venda');
    Tipo_imp.value := 1;
      if QPedido_Venda.IsEmpty then
      Begin
      Application.MessageBox('Informar Pedido de Venda válido e năo faturado!', PChar(Msg_Title), mb_IconSTop);
      Pedido_ID.Color := clYellow;
      Pedido_ID.SetFocus;
      exit;
      End;

      if not VerificaRegistro(StrToInt(Pedido_id.Text),'PEDIDO VENDA')  Then
      Begin
      Application.MessageBox('Pedido de venda em uso favor verificar.', PChar(Msg_Title), mb_IconSTop);
      Pedido_ID.Color := clYellow;
      Pedido_ID.SetFocus;
      exit;
      End;

    End;
  End;
end;

