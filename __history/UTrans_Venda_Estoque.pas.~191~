function TFrmTrans_Venda_Estoque.VerificaRegistro(chave_id:integer;tabela:string): Boolean;
Begin
 Result := False;

  QControle_Registro.Sql.Clear;
  QControle_Registro.Sql.Text := 'SELECT * FROM CONTROLE_REGISTRO ' +
                                 'LEFT JOIN FUNCIONARIOS ON FUNCIONARIOS.FUNCIONARIO_ID = CONTROLE_REGISTRO.USUARIO_ID ' +
                                 'WHERE TABELA = :TABELA AND CHAVE_ID = :CHAVE_ID AND CONTROLE_REGISTRO.EMPRESA_ID = :EMPRESA_ID';

  QControle_Registro.ParamByName('TABELA').AsString      := tabela;
  QControle_Registro.ParamByName('CHAVE_ID').AsInteger   := chave_id;
  QControle_Registro.ParamByName('EMPRESA_ID').AsInteger := FrmData.QAcesso.FieldByName('EMPRESA_ID').AsInteger;
  QControle_Registro.Prepare;
  QControle_Registro.Open;

  if (not QControle_Registro.IsEmpty) Then
  Begin


   if Chk_Imp_os.Checked then
   Application.MessageBox(PChar('Ordem Serviço: ' + IntToStr(chave_id) + #13 +'Aberto por: ' + QControle_Registro.FieldByName('NOME').AsString + #13 + 'Favor aguardar liberaçăo do registro.'), PChar(Msg_Title), MB_ICONINFORMATION)
   Else
   Application.MessageBox(PChar('Pedido de Venda: ' + IntToStr(chave_id) + #13 +'Aberto por: ' + QControle_Registro.FieldByName('NOME').AsString + #13 + 'Favor aguardar liberaçăo do registro.'), PChar(Msg_Title), MB_ICONINFORMATION);


  Result := False;
  End
  Else
