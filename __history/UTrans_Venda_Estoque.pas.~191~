procedure TFrmTrans_Venda_Estoque.TIPO_VENDAChange(Sender: TObject);
begin
  if (Operacao = 'Alterando') or (Operacao = 'Inserindo') then
  begin
    if (TIPO_VENDA.Text = 'REMESSA') OR (TIPO_VENDA.Text = 'CONSUMO')  then
    begin
      CONTA_ID.Value          := 0;
      C_CUSTO_ID.Value        := 0;
      COND_PAGTO.Text         := '';
      BANCO_ID.Value          := 0;
      BALANCO.Text            := '';
      CONTA_ID.Enabled        := True;
      C_CUSTO_ID.Enabled      := False;
      COND_PAGTO.Enabled      := False;
      BANCO_ID.Enabled        := False;
      BALANCO.Enabled         := True;
      FLUXO_CAIXA_ID.Enabled  := True;
      //btnConta.Enabled        := False;
      btnCentro_Custo.Enabled := False;
      btnBanco.Enabled        := False;
      btnFluxoCaixa.Enabled   := True;
      SUB_CODIGO.Text         := '3 - SIMP. REMESSA';

      DetailSearch('');
    end
    else if (TIPO_VENDA.Text = 'BONIFICACAO') then
    begin
      CONTA_ID.Value          := 0;
      C_CUSTO_ID.Value        := 0;
      COND_PAGTO.Text         := 'A VISTA';
      BANCO_ID.Value          := 0;
      BALANCO.Text            := '';
      CONTA_ID.Enabled        := True;
      C_CUSTO_ID.Enabled      := False;
      COND_PAGTO.Enabled      := False;
      BANCO_ID.Enabled        := False;
      BALANCO.Enabled         := True;
      FLUXO_CAIXA_ID.Enabled  := True;
      //btnConta.Enabled        := False;
      btnCentro_Custo.Enabled := False;
      btnBanco.Enabled        := False;
      btnFluxoCaixa.Enabled   := True;
      SUB_CODIGO.Text         := '3 - SIMP. REMESSA';

      DetailSearch('');
    end
     Else
    begin
      CONTA_ID.Enabled        := True;
      C_CUSTO_ID.Enabled      := True;
      COND_PAGTO.Enabled      := True;
      BANCO_ID.Enabled        := True;
      BALANCO.Enabled         := True;
      FLUXO_CAIXA_ID.Enabled  := True;
