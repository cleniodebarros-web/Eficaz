   //  ShowMessage(FloatToStr(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat - QSub_Detail.FieldByName('DESC_RODAPE').AsFloat) - RoundTo((((QSub_Detail.FieldByName('VR_TOTAL').AsFloat - QSub_Detail.FieldByName('DESC_RODAPE').AsFloat) * ( 100 - QProduto.FieldByName('REDUCAO_ICMS').AsFloat )) / 100), -2))));

     // QSub_Detail.FieldByName('VR_UNITARIO').AsFloat := RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat + (QSub_Detail.FieldByName('VR_DESCONTO').AsFloat * QSub_Detail.FieldByName('QUANTIDADE').AsFloat) - (QSub_Detail.FieldByName('VR_ACRESCIMO').AsFloat * QSub_Detail.FieldByName('QUANTIDADE').AsFloat)) / QSub_Detail.FieldByName('QUANTIDADE').AsFloat), -3);

    if QSub_Detail.FieldByName('BASE_CALC_PIS').AsFloat = 0 then
      QSub_Detail.FieldByName('BASE_CALC_PIS').AsFloat := QSub_Detail.FieldByName('VR_TOTAL').AsFloat;

    QSub_Detail.FieldByName('VR_PIS').AsFloat := ((QSub_Detail.FieldByName('BASE_CALC_PIS').AsFloat * QSub_Detail.FieldByName('ALIQUOTA_PIS').AsFloat) / 100);



    if QSub_Detail.FieldByName('BASE_CALC_COFINS').AsFloat = 0 then
      QSub_Detail.FieldByName('BASE_CALC_COFINS').AsFloat := QSub_Detail.FieldByName('VR_TOTAL').AsFloat;

    QSub_Detail.FieldByName('VR_COFINS').AsFloat := ((QSub_Detail.FieldByName('BASE_CALC_COFINS').AsFloat * QSub_Detail.FieldByName('ALIQUOTA_COFINS').AsFloat) / 100);

    if (Copy(Cfop.Text,1,1) = '3') or (Cfop.Text = '7501') then
      Edita_Import(QTabela.FieldByName('TRANSACAO_ID').AsInteger, QSub_Detail.FieldByName('PRODUTO_ID').AsInteger , QSub_Detail.FieldByName('DESCRICAO').AsString);

    if  QSub_Detail.FieldByName('VR_IPI').AsFloat = 0 Then
      QSub_Detail.FieldByName('VR_IPI').AsFloat := ((QSub_Detail.FieldByName('VR_TOTAL').AsFloat * QProduto.FieldByName('IPI').AsFloat) / 100);

  End;
  if (QSub_Detail.FieldByName('VR_TOTAL').AsFloat > 0) and (QSub_Detail.FieldByName('QUANTIDADE').AsFloat > 0) and  (FrmPrincipal.Config.FieldByName('VR_UNITARIO_X_QUANTIDADE').AsString <> 'True') then
  QSub_Detail.FieldByName('VR_UNITARIO').AsFloat := RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat + (QSub_Detail.FieldByName('VR_DESCONTO').AsFloat * QSub_Detail.FieldByName('QUANTIDADE').AsFloat) - (QSub_Detail.FieldByName('VR_ACRESCIMO').AsFloat * QSub_Detail.FieldByName('QUANTIDADE').AsFloat)) / QSub_Detail.FieldByName('QUANTIDADE').AsFloat), -3);

end;

