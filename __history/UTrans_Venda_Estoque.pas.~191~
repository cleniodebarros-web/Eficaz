procedure TFrmTrans_Venda_Estoque.Chk_NcmCestClick(Sender: TObject);
var
item,codigo,descricao,ncm,cest:string;
begin
 if Chk_NcmCest.Checked Then
 begin

   Ncm_Cest_text.Visible := True;
   Ncm_Cest_text.Lines.Clear;
   Ncm_Cest_text.Lines.Add(' ');
   Ncm_Cest_text.Lines.Add('                 **** Verificar Ncm/Cest Produtos ****');
   Ncm_Cest_text.Lines.Add('Item/Código  -     Descricao      -                 Ncm     -          Cest');
   Ncm_Cest_text.Lines.Add(' ');

   QSub_Detail.First;


   While not QSub_Detail.Eof  do
   begin

         QSearch.SQL.Clear;
         QSearch.SQL.Add('SELECT NCM,CEST FROM PRODUTOS WHERE PRODUTO_ID = :PRODUTO_ID ');
         QSearch.ParamByName('PRODUTO_ID').AsInteger := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;
         QSearch.Prepare;
         QSearch.Open();

         item      := IntToStr (QSub_Detail.FieldByName('SEQUENCIA').AsInteger);
         codigo    := IntToStr (QSub_Detail.FieldByName('PRODUTO_ID').AsInteger);
         descricao := Copy(QSub_Detail.FieldByName('DESCRICAO').AsString,1,20);
         Ncm       := QSearch.FieldByName('NCM').AsString;
         Cest      := QSearch.FieldByName('CEST').AsString;

         if cest = '' then
         cest := 'Vazio';

         if ncm = '' then
         ncm := 'Vazio';

         //List_NcmCest.Items.Add('Item  -    Código    -    Descricao         -          Ncm        -      Cest');

       if (QSub_Detail.FieldByName('CST').AsString = '060') OR (QSub_Detail.FieldByName('CST').AsString = '010') OR (QSub_Detail.FieldByName('CST').AsString = '500') Then
       Begin
         if (cest = 'Vazio') or (ncm = 'Vazio') Then
         Begin
         Ncm_Cest_text.SelAttributes.Style:=[fsBold];
         Ncm_Cest_text.SelAttributes.Color:=clRed;
         End
         else
         Begin
         Ncm_Cest_text.SelAttributes.Style:=[];
         Ncm_Cest_text.SelAttributes.Color:=clBlack;
         End;

        // Ncm_Cest_text.Lines.Add(Item +'    ' +Codigo +' '+  Descricao + '     ' +  Ncm + '     ' +cest);


         Ncm_Cest_text.Lines.Add(ForcaComprimento(Item, 3, ' ')  + '/'+ ForcaComprimento(codigo, 8, ' ') +
                                ForcaComprimento(descricao,25, ' ') +
                                ForcaComprimento((ncm), 15, ' ') +  ForcaComprimento((cest), 15, ' '));
       End;

         QSub_Detail.Next;
         Application.ProcessMessages;
   end;


 end
 else
 begin

    Ncm_Cest_text.Visible :=False;
    Ncm_Cest_text.Clear;

 end;


end;

