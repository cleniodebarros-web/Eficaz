  if QSub_Detail.State in [dsInsert, dsEdit] then
  begin
    ProdutoSearch;
    TributoSearch;
    ContaSearch;
    CFOPSearch;

    if QSub_Detail.FieldByName('TP_PROD_SERV').AsString = 'P' then
    begin
      if (Grid_Itens.SelectedField.FieldName = 'conta_id') and (QProduto.IsEmpty) then
        Grid_Itens.SelectedIndex := 1;
