procedure TFrmTrans_Venda_Estoque.CancelaOuInutiliza;
var Status: Integer;
var Justificativa: String;
var Vr_Lancado: Real;
begin

  FrmPrincipal.ACBrNFe1.Configuracoes.WebServices.Visualizar := False;

  try
    FrmPrincipal.ACBrNFe1.NotasFiscais.Clear;
    FrmPrincipal.ACBrNFe1.Consultar(QTabela.FieldByName('CHAVE_NFE').AsString);
    Status := FrmPrincipal.ACBrNFe1.WebServices.Consulta.cStat;
  except
    Status := 217;
  end;

  if Status = 100 then
  begin
    if Application.MessageBox('Deseja realmente CANCELAR a NF-e?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDNO then
      Exit;
    Cancelar1Click(Self);
  end
  else
  if Status = 101 then
  begin
    Application.MessageBox('Essa NF-e já foi cancelada.'+#13+'Năo é necessário excluir.', PChar(Msg_Title), mb_IconInformation);
  end
  else
  if Status = 217 then
  begin
    if QTabela.FieldByName('COMPLEMENTO').AsString = 'INUTILIZADA' then
      Application.MessageBox('Esse número de NF-e já foi inutilizado.'+#13+'Năo é necessário excluir.', PChar(Msg_Title), mb_IconInformation)
    else
    begin
      if Application.MessageBox('Deseja realmente INUTILIZAR a NF-e?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDNO then
        Abort;

      InputQuery('WebServices Inutilizaçăo ', 'Justificativa', Justificativa);

      if Length(Justificativa) < 15 Then
      begin
        Application.MessageBox('Favor inserir no mínimo 15 caracteres para justificativa!' + #13 + 'Repita o Processo.', PChar(Msg_Title), mb_IconInformation);
        Abort;
      end;

      try
        FrmPrincipal.ACBrNFe1.WebServices.Inutiliza(
                    SemMascara(QEmpresa.FieldByName('CNPJ').AsString),
                    'NOTA FISCAL INUTILIZADA',
                    StrToInt(Copy(DateToStr(QTabela.FieldByName('DT_TRANS').AsDateTime),7,4)),
                    StrToInt(QTabela.FieldByName('MODELO').AsString),
                    StrToInt(QTabela.FieldByName('SERIE').AsString),
                    StrToInt(QTabela.FieldByName('NUM_DOC').AsString),
                    StrToInt(QTabela.FieldByName('NUM_DOC').AsString));
      finally
        IQuery.SQL.Clear;
        IQuery.SQL.Add('UPDATE TRANSACOES SET COMPLEMENTO = :INUTILIZADA, OBSERVACAO = :INUTILIZADA2 , HISTORICO = :HISTORICO');
        IQuery.SQL.Add('WHERE TRANSACAO_ID =:TRANSACAO_ID');
        IQuery.ParamByName('INUTILIZADA').AsString    := 'INUTILIZADA';
        IQuery.ParamByName('INUTILIZADA2').AsByteStr  := 'INUTILIZADA';
        IQuery.ParamByName('HISTORICO').AsString      := 'NOTA FISCAL INUTILIZADA';
        IQuery.ParamByName('TRANSACAO_ID').AsInteger  := QTabela.FieldByName('TRANSACAO_ID').AsInteger;

        IQuery.Prepare;
        IQuery.ExecSQL;

        IQuery.Sql.Clear;
        IQuery.Sql.Add('INSERT INTO NOTAS_CANCELADAS(TRANSACAO_ID,EMPRESA_ID, NO_DOC_FISCAL, DT_SAIDA, SERIE, '  +
                     'RECIBO, HR_SAIDA)');
        IQuery.Sql.Add('SELECT TRANSACAO_ID, EMPRESA_ID, CAST(NUM_DOC AS INTEGER), DT_TRANS, SERIE, '  +
                     ':RECIBO, HORA');
        IQuery.Sql.Add('FROM TRANSACOES');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('TRANSACAO_ID  = :TRANSACAO_ID');

        IQuery.ParamByName('TRANSACAO_ID').AsInteger   := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        IQuery.ParamByName('RECIBO').AsString          := 'INUTILIZADA';

        IQuery.Prepare;
        IQuery.ExecSql;


        IQuery.SQL.Clear;
        IQuery.SQL.Add('DELETE FROM COMPL_NFISCAL WHERE TRANSACAO_ID = :TRANSACAO_ID');
        IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        IQuery.Prepare;
        IQuery.ExecSQL;

        IQuery.SQL.Clear;
        IQuery.SQl.Add('ALTER TABLE TRANSACOES DISABLE TRIGGER TRANSACOES_UP');
        IQuery.Prepare;
        IQuery.ExecSQL;

        IQuery.SQL.Clear;
        IQuery.SQL.Add('UPDATE TRANSACOES SET COD_CONT = ''0'' WHERE COD_CONT = :TRANSACAO_ID');
        IQuery.ParamByName('TRANSACAO_ID').AsString := IntToStr(QTabela.FieldByName('TRANSACAO_ID').AsInteger);
        IQuery.Prepare;
        IQuery.ExecSQL;

        IQuery.SQL.Clear;
        IQuery.SQl.Add('ALTER TABLE TRANSACOES ENABLE TRIGGER TRANSACOES_UP');
        IQuery.Prepare;
        IQuery.ExecSQL;


        IQuery.Sql.Clear;
        IQuery.Sql.Add('SELECT * FROM TRANSACOES');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(NUM_DOC = :NUM_DOC)');
        IQuery.Sql.Add('AND (CONDUTA = :CONDUTA)');
        IQuery.Sql.Add('AND (DEPTO = :DEPTO)');

        IQuery.ParamByName('NUM_DOC').AsString := StrZero(QTabela.FieldByName('TRANSACAO_ID').AsString, 6, 0);
        IQuery.ParamByName('CONDUTA').AsString := '18';
        IQuery.ParamByName('DEPTO').AsString   := '07';

        IQuery.Prepare;
        IQuery.Open;

        if IQuery.IsEmpty then
        begin
          Estorno_Transacao;

          Application.MessageBox('Estorno realizado com sucesso', PChar(Msg_Title), mb_IconInformation);
        end
        else
          Application.MessageBox('Estorno já realizado', PChar(Msg_Title), mb_IconStop);

        QSearch.Sql.Clear;
        QSearch.Sql.Add('UPDATE PEDIDOS SET STATUS = :STATUS , TRANSACAO_ID = 0');
        QSearch.Sql.Add('WHERE');
        QSearch.Sql.Add('(PEDIDO_ID = :PEDIDO_ID)');

        QSearch.ParamByName('PEDIDO_ID').AsInteger := QTabela.FieldByName('PEDIDO_ID').AsInteger;
        QSearch.ParamByName('STATUS').AsString     := 'NORMAL';

        QSearch.Prepare;
        QSearch.ExecSql;

        QSearch.Sql.Clear;
        QSearch.Sql.Add('UPDATE ORCAMENTOS SET STATUS = :STATUS ,TRANSACAO_ID = 0');
        QSearch.Sql.Add('WHERE');
        QSearch.Sql.Add('(PEDIDO_ID = :PEDIDO_ID)');

        QSearch.ParamByName('PEDIDO_ID').AsInteger := QTabela.FieldByName('PEDIDO_ID').AsInteger;
        QSearch.ParamByName('STATUS').AsString     := 'NORMAL';

        QSearch.Prepare;
        QSearch.ExecSql;




        Application.MessageBox('Nota inutilizada com sucesso!'+#13+'Năo é necessário excluir.', PChar(Msg_Title), mb_IconInformation);
      end;
    end;
  end;

  QRel.SQL.Clear;
  QRel.SQL.Add('SELECT TRANSACAO_ID FROM NOTAS_CANCELADAS WHERE TRANSACAO_ID = :TRANSACAO_ID');
  QRel.SQL.Add('UNION ALL');
  QRel.SQL.Add('SELECT TRANSACAO_ID FROM NOTAS_CANCELADAS_NFCE WHERE TRANSACAO_ID = :TRANSACAO_ID');
  QRel.ParamByName('TRANSACAO_ID').AsInteger   := StrToInt(Transacao_id.Text);
  QRel.Prepare;
  QRel.Open();

  if QRel.RecordCount > 0 then
  begin
    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT * FROM CLIENTES_SALDO');
    IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');
    IQuery.ParamByName('TRANSACAO_ID').AsInteger   := StrToInt(Transacao_id.Text);
    IQuery.Prepare;
    IQuery.Open;

    if not IQuery.IsEmpty then
    begin
      QCliente.Refresh;

      Vr_Lancado := IQuery.FieldByName('VALOR_LANCADO').AsFloat;
      IQuery.SQL.Clear;
      IQuery.SQL.Add('UPDATE CLIENTES');
      IQuery.SQL.Add('SET SALDO_CONTA = :SALDO_CONTA');
      IQuery.SQL.Add('WHERE CLIENTE_ID = :CLIENTE_ID');
      IQuery.ParamByName('CLIENTE_ID').AsInteger := StrToInt(CLIENTE_ID.Text);
      IQuery.ParamByName('SALDO_CONTA').AsFloat  := QCliente.FieldByName('SALDO_CONTA').AsFloat - Vr_Lancado;
      IQuery.Prepare;
      IQuery.ExecSQL;

      QCliente.Refresh;

      IQuery.SQL.Clear;
      IQuery.SQL.Add('DELETE FROM CLIENTES_SALDO');
      IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');
      IQuery.ParamByName('TRANSACAO_ID').AsInteger := StrToInt(Transacao_id.Text);
      IQuery.Prepare;
      IQuery.ExecSQL;
    end;
  end;

  FrmPrincipal.ACBrNFe1.Configuracoes.WebServices.Visualizar := True;
end;

