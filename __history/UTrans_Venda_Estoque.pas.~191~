             Edita_AddAnvisa(QTabela.FieldByName('TRANSACAO_ID').AsInteger, QSub_Detail.FieldByName('PRODUTO_ID').AsInteger , QSub_Detail.FieldByName('DESCRICAO').AsString,3);

