     if (TIPO_VENDA.Text = 'VENDA') then
         Cond_pagto.Text          := QPedido_venda.FieldByName('COND_PAGTO').AsString;

         Finalizadora_id.KeyValue := QPedido_Venda.FieldByName('FINALIZADORA_ID').AsInteger;
         Vendedor_id.Value        := QPedido_venda.FieldByName('FUNCIONARIO_ID').AsInteger;
         Cliente_id.Value         := QPedido_venda.FieldByName('CLIENTE_ID').AsInteger;
    End;


  end;

  if (Tabela = 'Ordem de Serviço') and (pedido_ID.value > 0 ) then
  begin
    QPedido_Venda.Close;
