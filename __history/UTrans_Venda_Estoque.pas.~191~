procedure TFrmTrans_Venda_Estoque.btnCopyClick(Sender: TObject);
var
Id_trans, num: Integer;
campos, tabela: string;
begin

  if Application.MessageBox('Deseja realmente copiar a transaçăo atual para uma nova transaçăo?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
  begin
    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
    IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';
    IQuery.Prepare;
    IQuery.Open;

    Id_Trans := IQuery.FieldByName('ID').AsInteger;

    IQuery.SQL.Clear;
    IQuery.SQL.Add('select string_agg(column_name, '','') as campos FROM information_schema.columns where table_name = ''transacoes'' ');
    IQuery.SQL.Add('and column_name not in (''transacao_id'', ''chave_nfe'', ''complemento'')');
    IQuery.Prepare;
    IQuery.Open;

    campos := IQuery.FieldByName('CAMPOS').AsString;

    IQuery.SQL.Clear;
    IQuery.SQL.Add('INSERT INTO TRANSACOES (TRANSACAO_ID, '+campos+')');
    IQuery.SQL.Add('SELECT :TRANSACAO_ID_NOVO, '+campos+' FROM TRANSACOES');
    IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');
    IQuery.SQL.Add('RETURNING HISTORICO');
    IQuery.ParamByName('TRANSACAO_ID').AsInteger      := StrToInt(Transacao_id.Text);
    IQuery.ParamByName('TRANSACAO_ID_NOVO').AsInteger := Id_Trans;
    IQuery.Prepare;
    IQuery.Open;

    if QTabela.FieldByName('MODELO').AsString = '55' then
    begin
      IQuery.SQL.Clear;
      IQuery.SQL.Add('select ''notas_canceladas'' as tabela from notas_canceladas where transacao_id = :TRANSACAO_ID');
      IQuery.SQL.Add('union all');
      IQuery.SQL.Add('select ''compl_nfiscal'' as tabela from compl_nfiscal where transacao_id = :TRANSACAO_ID');
      IQuery.ParamByName('TRANSACAO_ID').AsInteger := StrToInt(Transacao_id.Text);
      IQuery.Prepare;
      IQuery.Open;

      IQuery.First;
      tabela := IQuery.FieldByName('TABELA').AsString;

      IQuery.SQL.Clear;
      IQuery.SQL.Add('select string_agg(column_name, '','') as campos FROM information_schema.columns where table_name = :TABELA ');
      IQuery.SQL.Add('and column_name not in (''transacao_id'', ''no_doc_fiscal'', ''dt_saida'', ''hr_saida'', ''recibo'', ''protocolo'', ''chave_nfe'', ''arquivo_xml'')');
      IQuery.ParamByName('TABELA').AsString := tabela;
      IQuery.Prepare;
      IQuery.Open;

      campos := IQuery.FieldByName('CAMPOS').AsString;

      IQuery.SQL.Clear;
      IQuery.SQL.Add('INSERT INTO COMPL_NFISCAL(TRANSACAO_ID, NO_DOC_FISCAL, DT_SAIDA, '+campos+') ');
      IQuery.SQL.Add('SELECT :TRANSACAO_ID_NOVO, :NO_DOC_FISCAL, :DT_SAIDA, '+campos+' FROM '+tabela);
      IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');
      IQuery.SQL.Add('returning NO_DOC_FISCAL');
      IQuery.ParamByName('TRANSACAO_ID_NOVO').AsInteger := Id_Trans;
      IQuery.ParamByName('TRANSACAO_ID').AsInteger      := StrToInt(Transacao_id.Text);
      IQuery.ParamByName('NO_DOC_FISCAL').AsInteger     := 0;
      IQuery.ParamByName('DT_SAIDA').AsDateTime         := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      IQuery.Prepare;
      IQuery.Open;
    end
    else
    if (QTabela.FieldByName('MODELO').AsString = '57') or (QTabela.FieldByName('MODELO').AsString = '67') then
    begin
      IQuery.SQL.Clear;
      IQuery.SQL.Add('select ''ctes_canceladas'' as tabela from ctes_canceladas where transacao_id = :TRANSACAO_ID');
      IQuery.SQL.Add('union all');
      IQuery.SQL.Add('select ''compl_ctefiscal'' as tabela from compl_ctefiscal where transacao_id = :TRANSACAO_ID');
      IQuery.ParamByName('TRANSACAO_ID').AsInteger := StrToInt(Transacao_id.Text);
      IQuery.Prepare;
      IQuery.Open;

      IQuery.First;
      tabela := IQuery.FieldByName('TABELA').AsString;

      IQuery.SQL.Clear;
      IQuery.SQL.Add('select string_agg(column_name, '','') as campos FROM information_schema.columns where table_name = :TABELA ');
      IQuery.SQL.Add('and column_name not in (''transacao_id'', ''no_doc_fiscal'', ''dt_saida'', ''hr_saida'', ''recibo'', ''protocolo'', ''chave_nfe'', ''arquivo_xml'')');
      IQuery.ParamByName('TABELA').AsString := tabela;
      IQuery.Prepare;
      IQuery.Open;

      campos := IQuery.FieldByName('CAMPOS').AsString;

      IQuery.SQL.Clear;
      IQuery.SQL.Add('INSERT INTO COMPL_CTEFISCAL(TRANSACAO_ID, NO_DOC_FISCAL, DT_SAIDA, '+campos+') ');
      IQuery.SQL.Add('SELECT :TRANSACAO_ID_NOVO, :NO_DOC_FISCAL, :DT_SAIDA, '+campos+' FROM '+tabela);
      IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');
      IQuery.SQL.Add('returning NO_DOC_FISCAL');
      IQuery.ParamByName('TRANSACAO_ID_NOVO').AsInteger := Id_Trans;
      IQuery.ParamByName('TRANSACAO_ID').AsInteger      := StrToInt(Transacao_id.Text);
      IQuery.ParamByName('NO_DOC_FISCAL').AsInteger     := 0;
      IQuery.ParamByName('DT_SAIDA').AsDateTime         := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
      IQuery.Prepare;
      IQuery.Open;
    end;

    num := IQuery.FieldByName('NO_DOC_FISCAL').AsInteger;

    IQuery.SQL.Clear;
    IQuery.SQL.Add('UPDATE TRANSACOES SET DT_TRANS = :DATA, DT_MOVIMENTO = :DATA, DT_ENT_SAI = :DATA, DT_SPED = :DATA, HORA = :HORA, NUM_DOC = TO_CHAR(:NUM_DOC,''fm000000000''), ');
    IQuery.SQL.Add('HISTORICO = :HISTORICO, OBSERVACAO = :OBSERVACAO');
    IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');
    IQuery.ParamByName('DATA').AsDate             := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
    IQuery.ParamByName('HORA').AsString           := TimeToStr(time);
    IQuery.ParamByName('NUM_DOC').AsInteger       := num;
    if QTabela.FieldByName('HISTORICO').AsString = 'NOTA FISCAL INUTILIZADA' then
    begin
      IQuery.ParamByName('HISTORICO').AsString    := 'Vr. N. Fiscal nş ' + StrZero(IntToStr(num), 9, 0);
      IQuery.ParamByName('OBSERVACAO').AsByteStr  := '';
    end
    else
    begin
      IQuery.ParamByName('HISTORICO').AsString    := StringReplace(QTabela.FieldByName('HISTORICO').AsString, QTabela.FieldByName('NUM_DOC').AsString, StrZero(IntToStr(num), 9, 0), []);
      IQuery.ParamByName('OBSERVACAO').AsByteStr  := QTabela.FieldByName('OBSERVACAO').AsString;
    end;
    IQuery.ParamByName('TRANSACAO_ID').AsInteger  := Id_Trans;
    IQuery.Prepare;
    IQuery.ExecSQL;

    //inserir transitens
    IQuery.SQL.Clear;
    IQuery.SQL.Add('select string_agg(column_name, '','') as campos FROM information_schema.columns where table_name = ''transitens'' ');
    IQuery.SQL.Add('and column_name not in (''transacao_id'')');
    IQuery.Prepare;
    IQuery.Open;

    campos := IQuery.FieldByName('CAMPOS').AsString;

    IQuery.SQL.Clear;
    IQuery.SQL.Add('INSERT INTO TRANSITENS (TRANSACAO_ID, '+campos+')');
    IQuery.SQL.Add('SELECT :TRANSACAO_ID_NOVO, '+campos+' FROM TRANSITENS');
    IQuery.SQL.Add('WHERE TRANSACAO_ID = :TRANSACAO_ID');
    IQuery.ParamByName('TRANSACAO_ID_NOVO').AsInteger := Id_Trans;
    IQuery.ParamByName('TRANSACAO_ID').AsInteger      := StrToInt(Transacao_id.Text);
    IQuery.Prepare;
    IQuery.ExecSQL;

    QTabela.Refresh;

    QTabela.Close;
    QTabela.ParamByName('DT_MOVIMENTO').AsDateTime := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
    QTabela.Open;
    QTabela.Last;
    Dias.TabIndex := StrToInt(Copy(DateToStr(FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime),1,2))-1;

    //QTabela.Locate('TRANSACAO_ID', Id_Trans, [loCaseInsensitive]);
    Botoes_Disable;
    Set_Campos(False);
    Finalizadora_id.KeyValue := QTabela.FieldByName('FINALIZADORA_ID').AsInteger;
    Botoes_Normal;

    if COND_PAGTO.Text = 'A PRAZO' then
      btnParcelasClick(Sender);
  end;
end;

procedure TFrmTrans_Venda_Estoque.btnCteFiscalClick(Sender: TObject);
var
Nota_Servico: Boolean;
begin
  if not QCliente.IsEmpty then
  begin
    Set_Campos(False);
    Botoes_Normal;

    if Existe_Nota(QTabela.FieldByName('TRANSACAO_ID').AsInteger) then
    begin
      Application.MessageBox('Cte já foi impresso. Impossível alterar.', PChar(Msg_Title), mb_IconStop);
      exit;
    end;

    if QTabela.FieldByName('MODELO').AsString = '2D' then
    begin
      Application.MessageBox('Transaçăo refere-se a cupom fiscal. Use a opçăo de Agrupar Vendas no menu NFe', PChar(Msg_Title), mb_IconStop);
      abort;
    end;

    if COND_PAGTO.Text = 'A PRAZO' then
    begin
      IQuery.Sql.Clear;
      IQuery.Sql.Add('UPDATE TRANSPARCELAS SET TIPO_TRANSACAO = :TIPO_TRANSACAO');
      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
      IQuery.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANS)');

      IQuery.ParamByName('TIPO_TRANSACAO').AsString := 'U';
      IQuery.ParamByName('TRANSACAO_ID').AsInteger  := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
      IQuery.ParamByName('TIPO_TRANS').AsString     := 'T';

      IQuery.Prepare;
      IQuery.ExecSql;


    end;

    if LeIni(Arq_Ini, 'Sistema', 'Nf. Pré-Impressa') = 'True' then
      Nota_Fiscal(QTabela.FieldByName('TRANSACAO_ID').AsInteger);

    if LeIni(ExtractFilePath(ParamStr(0)) + 'NFe.Ini', 'NFe', 'NFe') = 'True' then
    begin
      if DecryptMsg(FrmPrincipal.Config.FieldByName('VERSAO').AsString, 65) = 'LIGHT' then
        Nota_Fiscal(QTabela.FieldByName('TRANSACAO_ID').AsInteger)
      else
      begin
        IQuery.Sql.Clear;
        IQuery.Sql.Add('SELECT * FROM TRANSITENS');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
        IQuery.Sql.Add('AND (TP_PROD_SERV = :TP_PROD_SERV)');

        IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        IQuery.ParamByName('TP_PROD_SERV').AsString  := 'S';

        IQuery.Prepare;
        IQuery.Open;

        if IQuery.IsEmpty then
          Nota_Servico := False
        else
          Nota_Servico := True;

        IQuery.Sql.Clear;
        IQuery.Sql.Add('SELECT CFOP, COUNT(*)');
        IQuery.Sql.Add('FROM TRANSITENS');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
        IQuery.Sql.Add('GROUP BY CFOP');
        IQuery.Sql.Add('ORDER BY 2');

        IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;

        IQuery.Prepare;
        IQuery.Open;

        IQuery.Last;


        if Existe_Nota(QTabela.FieldByName('TRANSACAO_ID').AsInteger) then
        CTe(QTabela.FieldByName('TRANSACAO_ID').AsInteger,1, IQuery.FieldByName('CFOP').AsString)
        Else
        CTe(QTabela.FieldByName('TRANSACAO_ID').AsInteger,0, IQuery.FieldByName('CFOP').AsString)
      end;
    end;

    if COND_PAGTO.Text = 'A PRAZO' then
    begin
      IQuery.Sql.Clear;
      IQuery.Sql.Add('UPDATE TRANSPARCELAS SET TIPO_TRANSACAO = :TIPO_TRANSACAO');
      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
      IQuery.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANS)');

      IQuery.ParamByName('TIPO_TRANSACAO').AsString := 'T';
      IQuery.ParamByName('TRANSACAO_ID').AsInteger  := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
      IQuery.ParamByName('TIPO_TRANS').AsString     := 'U';

      IQuery.Prepare;
      IQuery.ExecSql;


    end;
  end
  else
    Application.MessageBox('Informe o Cliente', PChar(Msg_Title), mb_IconStop);


end;

