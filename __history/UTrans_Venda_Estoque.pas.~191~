          Writeln(MyFile, ForcaComprimento('Total', 48 - Length(FormatFloat('#,##0.00', QTabela.FieldByName('VALOR_PRODUTOS').AsFloat + QTabela.FieldByName('VR_ACRESCIMO').AsFloat - QTabela.FieldByName('VR_DESCONTO').AsFloat)), ' ') + FormatFloat('#,##0.00', QTabela.FieldByName('VALOR_PRODUTOS').AsFloat + QTabela.FieldByName('VR_ACRESCIMO').AsFloat - QTabela.FieldByName('VR_DESCONTO').AsFloat));

