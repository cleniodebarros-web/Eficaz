        IQuery.Sql.Clear;
        IQuery.Sql.Add('ALTER TABLE PRODUTOS ENABLE TRIGGER PRODUTOS_UP');

        IQuery.Prepare;
        IQuery.ExecSql;
        End;

      //End;
     End;

      Operacao := '';

