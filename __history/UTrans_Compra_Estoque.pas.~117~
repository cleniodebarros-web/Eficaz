      QNotas.Close;
      QNotas.ParamByName('TRANSACAO_ID').AsInteger := 0;
      QNotas.Prepare;
      QNotas.Open;
    End;
  end;

  if QTabela.FieldByName('SUB_SERIE').AsString = 'P' then
  Begin
   BtnImprimirxml.Enabled  := True;
   Nfe_Propria.Checked := True;
  End
  Else
  Begin
   BtnImprimirxml.Enabled  := False;
   Nfe_Propria.Checked := False;
  End;

  if QTabela.FieldByName('FUNCIONARIO_ID').AsInteger > 0 then
  begin
   QRel.SQL.Clear;
   QRel.SQL.Add('SELECT NOME FROM FUNCIONARIOS WHERE FUNCIONARIO_ID = :FUNCIONARIO_ID');
   QRel.ParamByName('FUNCIONARIO_ID').AsInteger := QTabela.FieldByName('FUNCIONARIO_ID').AsInteger;
   QRel.Prepare;
   QRel.Open;

    Lbl_Funcionario.Visible := True;
    Lbl_Funcionario.Caption := 'Funcionário: ' + Copy(QREl.FieldByName('NOME').AsString,1,15);
  end
  Else
  Begin
    Lbl_Funcionario.Visible := False;
    Lbl_Funcionario.Caption := '';
  End;

  if QTabela.FieldByName('MOVIMENTO_PISCOFINS').AsInteger = 0 then
   Chk_movimentoSpedPiscofins.Checked := False
  Else
   Chk_movimentoSpedPiscofins.Checked := True;


  QSub_Detail.Close;
  QSub_Detail.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
  QSub_Detail.Prepare;
  QSub_Detail.Open;

  if (FrmPrincipal.Config.FieldByName('OBJETO_ORDEM').AsString = 'Cooperativa') then
  Begin
  QNotas.Close;
  QNotas.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
  QNotas.Prepare;
  QNotas.Open;
  End;

  if QTabela.IsEmpty then
