  begin
    Application.MessageBox('Nota Fiscal já foi impressa. Impossível continuar', PChar(Msg_Title), mb_IconStop);
    exit;
  end;

  Operacao := 'Alterando';
  ID := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
  Botoes_Editing;
  Habilitar(True);
  Pedido_id.Enabled  := False;
  Grid_Itens.Enabled := False;

  if (FrmPrincipal.Config.FieldByName('OBJETO_ORDEM').AsString = 'Cooperativa') Then
  Grid_Notas.Enabled := False;

  if (QTabela.FieldByName('MODELO').AsString = '55') and (QTabela.FieldByName('SUB_SERIE').AsString = 'P')  then
  Begin
  MODELO.Enabled      := False;
  Nfe_propria.Enabled := False;
  End;

  COND_PAGTOChange(Self);

  Consulta.TabVisible := False;

  DT_TRANS.SetFocus;

  Localizacao_id.Enabled := False;
end;

