              Perc_Desp := ((QTabela.FieldByName('VR_ACRESCIMO').AsFloat * 100) / Vl_Prod)
            else
              Perc_Desp := 0;

            if (QTabela.FieldByName('VR_OUTROS').AsFloat > 0) and (Vl_Prod > 0) then
              Perc_Desp := (Perc_Desp + ((QTabela.FieldByName('VR_OUTROS').AsFloat * 100) / Vl_Prod))
            else
              Perc_Desp := Perc_Desp;

            if (QTabela.FieldByName('DESPESAS_CUSTO').AsFloat > 0) and (Vl_Prod > 0) then
              Perc_Desp_Custo := (Perc_Desp_Custo + ((QTabela.FieldByName('DESPESAS_CUSTO').AsFloat * 100) / Vl_Prod))
            else
              Perc_Desp_Custo := 0;


            QCalculos.Sql.Clear;
            QCalculos.Sql.Add('SELECT SUM(VR_TOTAL) AS VALOR');
            QCalculos.Sql.Add('FROM TRANSITENS');
            QCalculos.Sql.Add('WHERE');
            QCalculos.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
            QCalculos.Sql.Add('AND (CST LIKE :CST1 OR CST LIKE :CST2 OR CST LIKE :CST3 OR CST LIKE :CST4)');

            QCalculos.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
            QCalculos.ParamByName('CST1').AsString          := '%10';
            QCalculos.ParamByName('CST2').AsString          := '%30';
            QCalculos.ParamByName('CST3').AsString          := '%60';
            QCalculos.ParamByName('CST4').AsString          := '%70';

            QCalculos.Prepare;
            QCalculos.Open;

            Vl_Sbt := QCalculos.FieldByName('VALOR').AsFloat;

            if (QTabela.FieldByName('VR_ICMS_ST').AsFloat > 0) and (Vl_Sbt > 0) then
              Perc_Sub := ((QTabela.FieldByName('VR_ICMS_ST').AsFloat * 100) / Vl_Sbt)
            else
              Perc_Sub := 0;

            New_Custo := 0;

            New_Custo := (QSub_Detail.FieldByName('VR_UNITARIO').AsFloat - QSub_Detail.FieldByName('VR_DESCONTO').AsFloat);

            if (Perc_Desc > 0)  then
              Desc_Footer := ((Perc_Desc * New_Custo) / 100)
            else
              Desc_Footer := 0;

            if QSub_Detail.FieldByName('DESC_RODAPE').AsFloat > 0  then
              Desc_Footer :=  QSub_Detail.FieldByName('DESC_RODAPE').AsFloat / QSub_Detail.FieldByName('QUANTIDADE').AsFloat
            else
              Desc_Footer := 0;

            New_Custo := New_Custo - Desc_Footer;
            ICMS_Sub  := 0;

            if QSub_Detail.FieldByName('VR_IPI').AsFloat > 0  then
            begin
              New_IPI  := (QSub_Detail.FieldByName('VR_IPI').AsFloat / QSub_Detail.FieldByName('QUANTIDADE').AsFloat);
              Perc_IPI := ((New_IPI * 100) / (QSub_Detail.FieldByName('VR_UNITARIO').AsFloat - QSub_Detail.FieldByName('VR_DESCONTO').AsFloat));
            end
            else
            begin
              New_IPI  := 0;
              Perc_IPI := 0;
            end;

            if Perc_Frt > 0 then
              New_Frt := ((New_Custo * Perc_Frt) / 100)
            else
              New_Frt := 0;

            if Perc_Desp > 0 then
              New_Desp := ((New_Custo * Perc_Desp) / 100)
            else
              New_Desp := 0;

            if Perc_Desp_Custo > 0 then
              New_Desp_Custo := ((New_Custo * Perc_Desp_Custo) / 100)
            else
              New_Desp_Custo := 0;


           // if (Copy(QSub_Detail.FieldByName('CST').AsString, 2, 2) = '10') or (Copy(QSub_Detail.FieldByName('CST').AsString, 2, 2) = '30') or
           //    (Copy(QSub_Detail.FieldByName('CST').AsString, 2, 2) = '60') or (Copy(QSub_Detail.FieldByName('CST').AsString, 2, 2) = '70') then
            //begin
              if (QSub_Detail.FieldByName('VALOR_ICMS_ST').AsFloat > 0) and (Vl_Sbt > 0) then
                ICMS_Sub := ((New_Custo * Perc_Sub) / 100);

              if QSub_Detail.FieldByName('VALOR_ICMS_ST').AsFloat > 0 then
                ICMS_Sub := (QSub_Detail.FieldByName('VALOR_ICMS_ST').AsFloat / QSub_Detail.FieldByName('QUANTIDADE').AsFloat);
          //  end;



            Est_Exist :=  IQuery.FieldByName('ESTOQUE_INICIAL').AsFloat;

           {
            if (Est_Exist > 0)  then
              Cst_Med_Entr := (((IQuery.FieldByName('CUSTOMEDIO').AsFloat * Est_Exist) +
                              (Cst_Entr * QSub_Detail.FieldByName('QUANTIDADE').AsFloat)) / (Est_Exist + QSub_Detail.FieldByName('QUANTIDADE').AsFloat))
            else
              Cst_Med_Entr := Cst_Entr;
             }

             Cst_Med_Entr := (IQuery.FieldByName('CUSTOMEDIO').AsFloat);

            // showmessage(floatTostr(IQuery.FieldByName('CUSTOMEDIO').AsFloat * Est_Exist));
            // showmessage(FloatToStr(Cst_Entr * QSub_Detail.FieldByName('QUANTIDADE').AsFloat));
            // Showmessage(FloatToStr(Est_Exist + QSub_Detail.FieldByName('QUANTIDADE').AsFloat));


            if ICMS_Sub = 0 then
            begin
              New_PMZ      := ((New_Custo - ((New_Custo * QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat) / 100)) / (1 - ((QIndices.FieldByName('VALOR').AsFloat + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + IQuery.FieldByName('ALIQUOTA_ICMS').AsFloat) / 100)));
              New_Sugestao := ((New_Custo - ((New_Custo * QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat) / 100)) / (1 - ((QIndices.FieldByName('VALOR').AsFloat + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + IQuery.FieldByName('ALIQUOTA_ICMS').AsFloat) / 100)));
            end
            else
            begin
              New_PMZ      := (New_Custo / (1 - ((QIndices.FieldByName('VALOR').AsFloat + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + IQuery.FieldByName('ALIQUOTA_ICMS').AsFloat) / 100)));
              New_Sugestao := (New_Custo / (1 - ((QIndices.FieldByName('VALOR').AsFloat + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + IQuery.FieldByName('ALIQUOTA_ICMS').AsFloat) / 100)));
              New_Dif_ICMS := 0;
            end;


            if  FrmPrincipal.Config.FieldByName('DIFERENCA_ICMS').AsString = 'True' Then
            Begin

            if (Copy(QSub_Detail.FieldByName('CFOP').AsString,1,1) = '2') and (IQuery.FieldByName('ALIQUOTA_ICMS').AsFloat > QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat) AND (QSub_Detail.FieldByName('VALOR_ICMS').AsFloat > 0 )  then
              New_Dif_ICMS := ((New_Custo * (IQuery.FieldByName('ALIQUOTA_ICMS').AsFloat - QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat)) / 100)
            else
              New_Dif_ICMS := 0;

            End;

            Cst_Entr  := New_Custo + New_IPI + New_Frt + New_Desp + New_Desp_Custo +  ICMS_Sub + New_Dif_ICMS;

            QUpdate.Sql.Clear;
            QUpdate.Sql.Add('UPDATE PRODUTOS SET FORNECEDOR_ID   = :FORNECEDOR_ID,  VALOR_COMPRA   = :VALOR_COMPRA, ' +
                                                 'CUSTO_COMPRA   = :CUSTO_COMPRA,   CUSTOMEDIO     = :CUSTOMEDIO, ' +
                                                 'DT_COMPRA      = :DT_COMPRA,      DT_ENTRADA     = :DT_ENTRADA, ' +
                                                 'ULT_QUANTIDADE = :ULT_QUANTIDADE, DESPESAS       = :DESPESAS, ' +
                                                 'PMZ            = :PMZ,            PRECO_SUGESTAO = :PRECO_SUGESTAO, ' +
                                                 'VR_ICMSST      = :VR_ICMSST,      VR_FRETE       = :VR_FRETE, ' +
                                                 'VR_IPI         = :VR_IPI,         VR_DESPESAS    = :VR_DESPESAS, ' +
                                                 'DIF_ICMS       = :DIF_ICMS,       VR_COMPRA_MANUAL = 0 ' +
                                                 'WHERE ' +
                                                 '(PRODUTO_ID = :PRODUTO_ID)');



            QUpdate.ParamByName('FORNECEDOR_ID').AsInteger := QTabela.FieldByName('FORNECEDOR_ID').AsInteger;
            QUpdate.ParamByName('VALOR_COMPRA').AsFloat    := RoundTo(New_Custo, -2);
            QUpdate.ParamByName('CUSTO_COMPRA').AsFloat    := RoundTo(Cst_Entr, -2);
            QUpdate.ParamByName('CUSTOMEDIO').AsFloat      := RoundTo(Cst_Med_Entr, -2);
            QUpdate.ParamByName('DT_COMPRA').AsDateTime    := QTabela.FieldByName('DT_TRANS').AsDateTime;
            QUpdate.ParamByName('DT_ENTRADA').AsDateTime   := QTabela.FieldByName('DT_ENT_SAI').AsDateTime;
            QUpdate.ParamByName('ULT_QUANTIDADE').AsFloat  := QSub_Detail.FieldByName('QUANTIDADE').AsFloat;
            QUpdate.ParamByName('DESPESAS').AsFloat        := RoundTo(QIndices.FieldByName('VALOR').AsFloat + QSub_Detail.FieldByName('ALIQUOTA_ICMS').AsFloat, -2);
            QUpdate.ParamByName('PMZ').AsFloat             := RoundTo(New_PMZ, -2);
            QUpdate.ParamByName('PRECO_SUGESTAO').AsFloat  := RoundTo(New_Sugestao, -3);
            QUpdate.ParamByName('VR_ICMSST').AsFloat       := RoundTo(Icms_Sub, -2);
            QUpdate.ParamByName('VR_FRETE').AsFloat        := RoundTo(New_Frt, -2);
            QUpdate.ParamByName('VR_IPI').AsFloat          := RoundTo(New_Ipi, -2);
            QUpdate.ParamByName('VR_DESPESAS').AsFloat     := RoundTo(New_Desp, -2);
            QUpdate.ParamByName('DIF_ICMS').AsFloat        := RoundTo(New_Dif_ICMS, -2);
            QUpdate.ParamByName('PRODUTO_ID').AsInteger    := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;

            QUpdate.Prepare;
            QUpdate.ExecSql;



            QSearch.Sql.Clear;
            QSearch.Sql.Text := 'SELECT * FROM TRANSITENS_CUSTO WHERE PRODUTO_ID = :PRODUTO_ID AND TRANSACAO_ID = :TRANSACAO_ID AND NUM_DOC = :NUM_DOC';
            QSearch.ParamByName('PRODUTO_ID').AsInteger   := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;
            QSearch.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
            QSearch.ParamByName('NUM_DOC').AsString       := QTabela.FieldByName('NUM_DOC').AsString;
            QSearch.Prepare;
            QSearch.Open;

            if QSearch.IsEmpty Then
            Begin
             try
              QUpdate.Sql.Clear;
              QUpdate.Sql.Text:='INSERT INTO TRANSITENS_CUSTO(TRANSACAO_ID,PRODUTO_ID,FORNECEDOR_ID,NUM_DOC,DT_EMISSAO,VALOR_COMPRA,CUSTO_COMPRA,CUSTO_MEDIO) '+
                                'VALUES(:TRANSACAO_ID,:PRODUTO_ID,:FORNECEDOR_ID,:NUM_DOC,:DT_EMISSAO,:VALOR_COMPRA,:CUSTO_COMPRA,:CUSTO_MEDIO)';

              QUpdate.ParamByName('TRANSACAO_ID').AsInteger  := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
              QUpdate.ParamByName('PRODUTO_ID').AsInteger    := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;
              QUpdate.ParamByName('FORNECEDOR_ID').AsInteger := QTabela.FieldByName('FORNECEDOR_ID').AsInteger;
