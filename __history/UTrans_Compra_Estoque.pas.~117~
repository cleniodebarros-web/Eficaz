         GravarLog('COMPRA','EDITAR',DateToStr(date),TimeToStr(time),'Transaçăo_id ' , IntToStr(QTabela.FieldByName('TRANSACAO_ID').AsInteger),FloatToStr(Valor.value) + '          Documento: ' + QTabela.FieldByName('NUM_DOC').AsString  ,FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger,QTabela.FieldByName('FORNECEDOR_ID').AsInteger)
      Else
         GravarLog('COMPRA','INSERIR',DateToStr(date),TimeToStr(time),'Transaçăo_id ' , IntToStr(QTabela.FieldByName('TRANSACAO_ID').AsInteger),FloatToStr(Valor.value) + '          Documento: ' + QTabela.FieldByName('NUM_DOC').AsString  ,FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger,QTabela.FieldByName('FORNECEDOR_ID').AsInteger);


    End;
