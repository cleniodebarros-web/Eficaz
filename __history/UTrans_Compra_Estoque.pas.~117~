procedure TFrmTrans_Compra_Estoque.btnImpostosClick(Sender: TObject);
var
T_Id: Integer;
B_ICMS, V_ICMS, B_ICMS_ST, V_ICMS_ST, Vr_Old: Real;
begin

  Atualiza_Impostos(QTabela.FieldByName('TRANSACAO_ID').AsInteger, 0);

  if not Existe_Pagamento(QTabela.FieldByName('TRANSACAO_ID').AsInteger) then
  begin
    T_Id      := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
    B_ICMS    := QTabela.FieldByName('BASE_ICMS_NORMAL').AsFloat;
    V_ICMS    := QTabela.FieldByName('VR_ICMS_NORMAL').AsFloat;
    B_ICMS_ST := QTabela.FieldByName('BASE_ICMS_ST').AsFloat;
    V_ICMS_ST := QTabela.FieldByName('VR_ICMS_ST').AsFloat;
    Vr_Old    := QTabela.FieldByName('VALOR').AsFloat;


    if QTabela.FieldByName('DT_MOVIMENTO').AsDateTime = FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime then
    begin
      IQuery.Sql.Clear;
      IQuery.Sql.Add('SELECT SUM(DESC_RODAPE) DESC_RODAPE,SUM(BASE_CALC_ICMS) BASE_CALC_ICMS, SUM(VALOR_ICMS) VALOR_ICMS, SUM(BASE_CALC_ST) BASE_CALC_ST, SUM(VALOR_ICMS_ST) VALOR_ICMS_ST,SUM(VALOR_ICMS_DESON) VALOR_ICMS_DESON');
      IQuery.Sql.Add('FROM TRANSITENS');
      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');

      IQuery.ParamByName('TRANSACAO_ID').AsInteger := T_Id;

      IQuery.Prepare;
      IQuery.Open;

      BASE_ICMS_NORMAL.Value := IQuery.FieldByName('BASE_CALC_ICMS').AsFloat;
      VR_ICMS_NORMAL.Value   := IQuery.FieldByName('VALOR_ICMS').AsFloat;
      BASE_ICMS_ST.Value     := IQuery.FieldByName('BASE_CALC_ST').AsFloat;
      VR_ICMS_ST.Value       := IQuery.FieldByName('VALOR_ICMS_ST').AsFloat;
      VR_ICMS_DESON.VALUE    := IQuery.FieldByName('VALOR_ICMS_DESON').AsFloat;
      VR_DESCONTO.Value      := IQuery.FieldByName('DESC_RODAPE').AsFloat;

      VALOR.Value            := (VALOR_PRODUTOS.Value + VR_ICMS_ST.Value + VR_IPI.Value + VR_ACRESCIMO.Value + VR_FRETE.Value +  VR_FCPSTRET.VALUE + VR_FCPST.VALUE - (VR_DESCONTO.Value + VR_ICMS_DESON.Value));

      if (BASE_ICMS_NORMAL.Value <> B_ICMS) or (VR_ICMS_NORMAL.Value <> V_ICMS) or (BASE_ICMS_ST.Value <> B_ICMS_ST) or (VR_ICMS_ST.Value <> V_ICMS_ST) or (VALOR.Value <> Vr_Old) then
      begin
       IQuery.SQL.Clear;
       IQuery.Sql.Add('SELECT * FROM TRANSPARCELAS WHERE TRANSACAO_ID = :TRANSACAO_ID');
       IQuery.ParamByName('TRANSACAO_ID').AsInteger  := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
       IQuery.Prepare;
       IQuery.Open;

       If not IQuery.IsEmpty Then
       Begin
       IQuery.Sql.Clear;
       IQuery.Sql.Add('UPDATE TRANSPARCELAS SET TIPO_TRANSACAO = :TIPO_TRANSACAO');
       IQuery.Sql.Add('WHERE');
       IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
       IQuery.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANS)');

       IQuery.ParamByName('TIPO_TRANSACAO').AsString := 'U';
       IQuery.ParamByName('TRANSACAO_ID').AsInteger  := T_Id;
       IQuery.ParamByName('TIPO_TRANS').AsString     := 'T';

       IQuery.Prepare;
       IQuery.ExecSql;


       End;
        IQuery.Sql.Clear;
        IQuery.Sql.Add('UPDATE TRANSACOES SET BASE_ICMS_NORMAL = :BASE_ICMS_NORMAL, ' +
                                              'VR_ICMS_NORMAL = :VR_ICMS_NORMAL, ' +
                                              'BASE_ICMS_ST = :BASE_ICMS_ST, ' +
                                              'VR_ICMS_ST = :VR_ICMS_ST, VR_DESCONTO = :VR_DESCONTO, ' +
                                              'VALOR = :VALOR ' +
                                              'WHERE (TRANSACAO_ID = :TRANSACAO_ID)');

        IQuery.ParamByName('BASE_ICMS_NORMAL').AsFloat := BASE_ICMS_NORMAL.Value;
        IQuery.ParamByName('VR_ICMS_NORMAL').AsFloat   := VR_ICMS_NORMAL.Value;
        IQuery.ParamByName('BASE_ICMS_ST').AsFloat     := BASE_ICMS_ST.Value;
        IQuery.ParamByName('VR_ICMS_ST').AsFloat       := VR_ICMS_ST.Value;
        IQuery.ParamByName('VR_DESCONTO').AsFloat      := VR_DESCONTO.Value;
        IQuery.ParamByName('VALOR').AsFloat            := VALOR.Value;

        IQuery.ParamByName('TRANSACAO_ID').AsInteger := T_Id;

        IQuery.Prepare;
        IQuery.ExecSql;



       IQuery.Sql.Clear;
       IQuery.Sql.Add('UPDATE TRANSPARCELAS SET TIPO_TRANSACAO = :TIPO_TRANSACAO');
       IQuery.Sql.Add('WHERE');
       IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
       IQuery.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANS)');

       IQuery.ParamByName('TIPO_TRANSACAO').AsString := 'T';
       IQuery.ParamByName('TRANSACAO_ID').AsInteger  := T_Id;
       IQuery.ParamByName('TIPO_TRANS').AsString     := 'U';

       IQuery.Prepare;
       IQuery.ExecSql;





        QTabela.Close;

        QTabela.Prepare;
        QTabela.Open;

        QTabela.Locate('TRANSACAO_ID', T_Id, [loCaseInsensitive]);

        Set_Campos(False);
        Botoes_Normal;

        if COND_PAGTO.Text = 'A PRAZO' then
         Begin
       IQuery.SQL.Clear;
       IQuery.Sql.Add('SELECT * FROM TRANSPARCELAS WHERE TRANSACAO_ID = :TRANSACAO_ID');
       IQuery.ParamByName('TRANSACAO_ID').AsInteger  := T_Id;
       IQuery.Prepare;
       IQuery.Open;

       If IQuery.IsEmpty then
       btnParcelasClick(Self)
       Else
       If Application.MessageBox('Pagamento já emitido deseja recriar o pagamento?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = idYes then
       Begin
        IQuery.Sql.Clear;
        IQuery.Sql.Add('DELETE FROM TRANSPARCELAS');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
        IQuery.Sql.Add('AND (TIPO_TRANSACAO = :TIPO_TRANSACAO)');

        IQuery.ParamByName('TRANSACAO_ID').AsInteger  := T_Id;
        IQuery.ParamByName('TIPO_TRANSACAO').AsString := 'T';

        IQuery.Prepare;
        IQuery.ExecSql;





        btnParcelasClick(Self)
       End;
      End;
      end;
    end;
  end
  else
    Application.MessageBox('Transaçăo possui parcela quitada. Impossível continuar', PChar(Msg_Title), mb_IconStop);
end;

