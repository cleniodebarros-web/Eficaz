function TFrmTrans_Compra_Estoque.CFOP_Conv(CFOP,CFOP_NF: String): String;
begin
  Result := CFOP;

  QCFOP_Conv.Sql.Clear;
  QCFOP_Conv.Sql.Add('SELECT * FROM CFOP');
  QCFOP_Conv.Sql.Add('WHERE');
  QCFOP_Conv.Sql.Add('(COD_CFOP = :COD_CFOP)');

  QCFOP_Conv.ParamByName('COD_CFOP').AsString := CFOP;

  QCFOP_Conv.Prepare;
  QCFOP_Conv.Open;

  if (not QCFOP_Conv.IsEmpty) and (QCFOP_Conv.FieldByName('CFOP_CONV').AsString <> '')  then

    Result := QCFOP_Conv.FieldByName('CFOP_CONV').AsString
  else
    Result := CFOP_NF;

end;
