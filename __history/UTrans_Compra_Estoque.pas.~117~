      IQuery.ParamByName('PRODUTO_ID').AsInteger   := Ult_Produto;

      IQuery.Prepare;
      IQuery.ExecSql;


    end;
  End;

  if BASE_ICMS_NORMAL.CanFocus then
    BASE_ICMS_NORMAL.SetFocus
  else
