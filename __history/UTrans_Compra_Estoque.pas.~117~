      TCheckBox(Temp).Enabled := Status;

    if (Temp is TMemo) and (TMemo(Temp).Name <> 'MemoConsultadfe')   then
      TMemo(Temp).Enabled := Status;

     if Temp is TDBLookupComboBox then
