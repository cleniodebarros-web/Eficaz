procedure TFrmTrans_Compra_Estoque.Posicao_Produtos_id(dt_posicao:String);
var
Base_Calc_Desc_Rodape, Vl_Prod, Perc_Desc, Perc_Frt, Perc_Desp, New_Custo, Vl_Sbt, Perc_Sub, Desc_Footer, ICMS_Sub,X: Real;
New_IPI, New_Frt, New_Desp, Cst_Entr, Est_Exist, Cst_Med_Entr, Indices, New_PMZ, New_Sugestao, New_Dif_ICMS, Perc_IPI,New_Desp_Custo,Perc_Desp_Custo: Real;

begin
        QUpdate.Sql.Clear;
        QUpdate.Sql.Add('SELECT SUM(VALOR) AS VALOR FROM INDICES');

        QUpdate.Prepare;
        QUpdate.Open;

        Indices := QUpdate.FieldByName('VALOR').AsFloat;

        QEntrada.Sql.Clear;
        QEntrada.Sql.Add('SELECT TRANSITENS.PRODUTO_ID, TRANSITENS.VR_UNITARIO, TRANSITENS.VR_DESCONTO AS DESC_ITEM, TRANSITENS.QUANTIDADE, TRANSITENS.ALIQUOTA_ICMS AS ICMS_ENTRADA,TRANSITENS.VALOR_ICMS,TRANSITENS.CFOP, ' +
                         'TRANSITENS.DESC_RODAPE,TRANSITENS.VR_IPI, TRANSITENS.CST, TRANSITENS.VALOR_ICMS_ST, TRANSACOES.VR_DESCONTO, TRANSACOES.VR_FRETE, TRANSACOES.VR_ACRESCIMO, TRANSACOES.FORNECEDOR_ID, ' +
                         'TRANSACOES.VR_ICMS_ST, TRANSACOES.DT_TRANS, TRANSACOES.DT_MOVIMENTO,TRANSACOES.DT_ENT_SAI, TRANSACOES.TRANSACAO_ID, TRANSACOES.VALOR_PRODUTOS, TRANSACOES.VR_OUTROS, PRODUTOS.QUANTIDADE_G, ' +
                         'PRODUTOS.CUSTOMEDIO, PRODUTOS.ESTOQUE_INICIAL, PRODUTOS.ALIQUOTA_ICMS AS ICMS_SAIDA, PRODUTOS.MARGEM_LUCRO,TRANSACOES.DESPESAS_CUSTO');
        QEntrada.Sql.Add('FROM TRANSITENS');
        QEntrada.Sql.Add('INNER JOIN TRANSACOES');
        QEntrada.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
        QEntrada.Sql.Add('INNER JOIN PRODUTOS');
        QEntrada.Sql.Add('ON (TRANSITENS.PRODUTO_ID = PRODUTOS.PRODUTO_ID)');
        QEntrada.Sql.Add('WHERE');
        QEntrada.Sql.Add('(TRANSACOES.DT_MOVIMENTO = :DT_MOVIMENTO)');
        QEntrada.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
        QEntrada.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
        QEntrada.Sql.Add('AND (TRANSITENS.TP_PROD_SERV = :TP_PROD_SERV)');
        QEntrada.Sql.Add('AND (TRANSACOES.TIPO_COMPRA = :TIPO_COMPRA)');
        QEntrada.Sql.Add('ORDER BY TRANSACOES.TRANSACAO_ID');

        QEntrada.ParamByName('DT_MOVIMENTO').AsDateTime := StrToDate(dt_posicao);
        QEntrada.ParamByName('CONDUTA').AsString        := '02';
        QEntrada.ParamByName('DEPTO').AsString          := '07';
        QEntrada.ParamByName('TP_PROD_SERV').AsString   := 'P';
        QEntrada.ParamByName('TIPO_COMPRA').AsString    := 'COMPRA';

        QEntrada.Prepare;
        QEntrada.Open;

        QEntrada.First;

        X:= 0.2;
        while not QEntrada.Eof do
        begin
          try

           Perc_Desp       := 0;
           Perc_Desp_Custo := 0;
           Perc_Desc       := 0;
           Perc_Frt        := 0;
           Cst_Entr        := 0;
           Cst_Med_Entr    := 0;

            X := X + 0.5;
            Base_Calc_Desc_Rodape := QEntrada.FieldByName('VALOR_PRODUTOS').AsFloat;
            Vl_Prod               := QEntrada.FieldByName('VALOR_PRODUTOS').AsFloat;

            if (QEntrada.FieldByName('VR_DESCONTO').AsFloat > 0) and (Base_Calc_Desc_Rodape > 0) then
              Perc_Desc := ((QEntrada.FieldByName('VR_DESCONTO').AsFloat * 100) / Base_Calc_Desc_Rodape)
            else
              Perc_Desc := 0;

            if (QEntrada.FieldByName('VR_FRETE').AsFloat > 0) and (Vl_Prod > 0) then
              Perc_Frt := ((QEntrada.FieldByName('VR_FRETE').AsFloat * 100) / Vl_Prod)
            else
              Perc_Frt := 0;

            if (QEntrada.FieldByName('VR_ACRESCIMO').AsFloat > 0) and (Vl_Prod > 0) then
              Perc_Desp := ((QEntrada.FieldByName('VR_ACRESCIMO').AsFloat * 100) / Vl_Prod)
            else
              Perc_Desp := 0;

            if (QEntrada.FieldByName('VR_OUTROS').AsFloat > 0) and (Vl_Prod > 0) then
              Perc_Desp := (Perc_Desp + ((QEntrada.FieldByName('VR_OUTROS').AsFloat * 100) / Vl_Prod))
            else
              Perc_Desp := 0;

            if (QEntrada.FieldByName('DESPESAS_CUSTO').AsFloat > 0) and (Vl_Prod > 0) then
              Perc_Desp_Custo := (Perc_Desp_Custo + ((QEntrada.FieldByName('DESPESAS_CUSTO').AsFloat * 100) / Vl_Prod))
            else
              Perc_Desp_Custo := 0;

            QCalculos.Sql.Clear;
            QCalculos.Sql.Add('SELECT SUM(VR_TOTAL) AS VALOR');
            QCalculos.Sql.Add('FROM TRANSITENS');
            QCalculos.Sql.Add('WHERE');
            QCalculos.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
            QCalculos.Sql.Add('AND (CST LIKE :CST1 OR CST LIKE :CST2 OR CST LIKE :CST3 OR CST LIKE :CST4)');

            QCalculos.ParamByName('TRANSACAO_ID').AsInteger := QEntrada.FieldByName('TRANSACAO_ID').AsInteger;
            QCalculos.ParamByName('CST1').AsString          := '%10';
            QCalculos.ParamByName('CST2').AsString          := '%30';
            QCalculos.ParamByName('CST3').AsString          := '%60';
            QCalculos.ParamByName('CST4').AsString          := '%70';

            QCalculos.Prepare;
            QCalculos.Open;

            Vl_Sbt := QCalculos.FieldByName('VALOR').AsFloat;

            if (QEntrada.FieldByName('VALOR_ICMS_ST').AsFloat > 0) and (Vl_Sbt > 0) then
              Perc_Sub := ((QEntrada.FieldByName('VALOR_ICMS_ST').AsFloat * 100) / Vl_Sbt)
            else
              Perc_Sub := 0;

            New_Custo := (QEntrada.FieldByName('VR_UNITARIO').AsFloat - QEntrada.FieldByName('DESC_ITEM').AsFloat);

            if Perc_Desc > 0 then
              Desc_Footer := ((Perc_Desc * New_Custo) / 100)
            else
              Desc_Footer := 0;

            if QEntrada.FieldByName('DESC_RODAPE').AsFloat > 0  then
              Desc_Footer :=  QEntrada.FieldByName('DESC_RODAPE').AsFloat / QEntrada.FieldByName('QUANTIDADE').AsFloat;

            New_Custo := New_Custo - Desc_Footer;
            ICMS_Sub  := 0;

            if QEntrada.FieldByName('VR_IPI').AsFloat > 0  then
            begin
              New_IPI  := (QEntrada.FieldByName('VR_IPI').AsFloat / QEntrada.FieldByName('QUANTIDADE').AsFloat);
              Perc_IPI := ((New_IPI * 100) / (QEntrada.FieldByName('VR_UNITARIO').AsFloat - QEntrada.FieldByName('DESC_ITEM').AsFloat));
            end
            else
            begin
              New_IPI  := 0;
              Perc_IPI := 0;
            end;

            if Perc_Frt > 0 then
              New_Frt := ((New_Custo * Perc_Frt) / 100)
            else
              New_Frt := 0;

            if Perc_Desp > 0 then
              New_Desp := ((New_Custo * Perc_Desp) / 100)
            else
              New_Desp := 0;

            if Perc_Desp_Custo > 0 then
              New_Desp_Custo := ((New_Custo * Perc_Desp_Custo) / 100)
            else
              New_Desp_Custo := 0;


          //  if (Copy(QEntrada.FieldByName('CST').AsString, 2, 2) = '10') or (Copy(QEntrada.FieldByName('CST').AsString, 2, 2) = '30') or
          //     (Copy(QEntrada.FieldByName('CST').AsString, 2, 2) = '60') or (Copy(QEntrada.FieldByName('CST').AsString, 2, 2) = '70') then
           // begin

              if (QEntrada.FieldByName('VR_ICMS_ST').AsFloat > 0) and (Vl_Sbt > 0) then
                ICMS_Sub := ((New_Custo * Perc_Sub) / 100);

              if QEntrada.FieldByName('VALOR_ICMS_ST').AsFloat > 0 then
                ICMS_Sub := (QEntrada.FieldByName('VALOR_ICMS_ST').AsFloat / QEntrada.FieldByName('QUANTIDADE').AsFloat);

           // end;

            Cst_Entr := New_Custo + New_IPI + New_Frt + New_Desp + New_Desp_Custo + ICMS_Sub;

            Est_Exist :=  QEntrada.FieldByName('ESTOQUE_INICIAL').AsFloat;

            if (Est_Exist > 0) then
              Cst_Med_Entr := (((QEntrada.FieldByName('CUSTOMEDIO').AsFloat * Est_Exist) +
                              (Cst_Entr * QEntrada.FieldByName('QUANTIDADE').AsFloat)) / (Est_Exist + QEntrada.FieldByName('QUANTIDADE').AsFloat))
            else
              Cst_Med_Entr := Cst_Entr;




            if ICMS_Sub = 0 then
            begin
              New_PMZ      := ((New_Custo - ((New_Custo * QEntrada.FieldByName('ICMS_ENTRADA').AsFloat) / 100)) / (1 - ((Indices + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + QEntrada.FieldByName('ICMS_SAIDA').AsFloat) / 100)));
              New_Sugestao := ((New_Custo - ((New_Custo * QEntrada.FieldByName('ICMS_ENTRADA').AsFloat) / 100)) / (1 - ((Indices + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + QEntrada.FieldByName('ICMS_SAIDA').AsFloat + QEntrada.FieldByName('MARGEM_LUCRO').AsFloat) / 100)));

            end
            else
            begin
              New_PMZ      := (New_Custo / (1 - ((Indices + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + QEntrada.FieldByName('ICMS_SAIDA').AsFloat) / 100)));
              New_Sugestao := (New_Custo / (1 - ((Indices + Perc_IPI + Perc_Frt + Perc_Desp + Perc_Sub + QEntrada.FieldByName('ICMS_SAIDA').AsFloat + QEntrada.FieldByName('MARGEM_LUCRO').AsFloat) / 100)));
              New_Dif_ICMS := 0;
            end;

            if  FrmPrincipal.Config.FieldByName('DIFERENCA_ICMS').AsString = 'True' Then
            Begin
       

            if (Copy(QEntrada.FieldByName('CFOP').AsString,1,1) = '2') and (QEntrada.FieldByName('ICMS_SAIDA').AsFloat > QEntrada.FieldByName('ICMS_ENTRADA').AsFloat) AND (QEntrada.FieldByName('VALOR_ICMS').AsFloat > 0 )  then
              New_Dif_ICMS := ((New_Custo * (QEntrada.FieldByName('ICMS_SAIDA').AsFloat - QEntrada.FieldByName('ICMS_ENTRADA').AsFloat)) / 100)
            else
              New_Dif_ICMS := 0;
            End;


            Cst_Entr := New_Custo + New_IPI + New_Frt + New_Desp + New_Desp_Custo + ICMS_Sub + New_Dif_ICMS ;

            QUpdate.Sql.Clear;
            QUpdate.Sql.Clear;
            if  FrmPrincipal.Config.FieldByName('DESATIVAR_CUSTOS').AsString <> 'True' then
             {
            QUpdate.Sql.Add('UPDATE PRODUTOS SET FORNECEDOR_ID   = :FORNECEDOR_ID,  VALOR_COMPRA   = :VALOR_COMPRA, ' +
                                                 'CUSTO_COMPRA   = :CUSTO_COMPRA,   CUSTOMEDIO     = :CUSTOMEDIO, ' +
                                                 'DT_COMPRA      = :DT_COMPRA,      DT_ENTRADA     = :DT_ENTRADA, ' +
                                                 'ULT_QUANTIDADE = :ULT_QUANTIDADE, DESPESAS       = :DESPESAS, ' +
                                                 'PMZ            = :PMZ,            PRECO_SUGESTAO = :PRECO_SUGESTAO, ' +
                                                 'VR_ICMSST      = :VR_ICMSST,      VR_FRETE       = :VR_FRETE, ' +
                                                 'VR_IPI         = :VR_IPI,         VR_DESPESAS    = :VR_DESPESAS, ' +
                                                 'DIF_ICMS       = :DIF_ICMS ' +
                                                 'WHERE ' +
                                                 '(PRODUTO_ID = :PRODUTO_ID)')
              }

              QUpdate.Sql.Add('UPDATE PRODUTOS SET CUSTOMEDIO = :CUSTOMEDIO ' +
                              'WHERE (PRODUTO_ID = :PRODUTO_ID)' )



            Else
            QUpdate.Sql.Add('UPDATE PRODUTOS SET FORNECEDOR_ID   = :FORNECEDOR_ID, ' +
                                                 'DT_COMPRA      = :DT_COMPRA,      DT_ENTRADA     = :DT_ENTRADA, ' +
                                                 'ULT_QUANTIDADE = :ULT_QUANTIDADE, DESPESAS       = :DESPESAS, ' +
                                                 'PMZ            = :PMZ,            PRECO_SUGESTAO = :PRECO_SUGESTAO, ' +
                                                 'VR_ICMSST      = :VR_ICMSST,      VR_FRETE       = :VR_FRETE, ' +
                                                 'VR_IPI         = :VR_IPI,         VR_DESPESAS    = :VR_DESPESAS, ' +
                                                 'DIF_ICMS       = :DIF_ICMS ' +
                                                 'WHERE ' +
                                                 '(PRODUTO_ID = :PRODUTO_ID)');


            //QUpdate.ParamByName('FORNECEDOR_ID').AsInteger := QEntrada.FieldByName('FORNECEDOR_ID').AsInteger;

            if  FrmPrincipal.Config.FieldByName('DESATIVAR_CUSTOS').AsString <> 'True' then
            Begin
            //QUpdate.ParamByName('VALOR_COMPRA').AsFloat    := RoundTo(New_Custo, -2);
            //QUpdate.ParamByName('CUSTO_COMPRA').AsFloat    := RoundTo(Cst_Entr, -2);
            QUpdate.ParamByName('CUSTOMEDIO').AsFloat      := RoundTo(Cst_Med_Entr, -2);
            QUpdate.ParamByName('PRODUTO_ID').AsInteger    := QEntrada.FieldByName('PRODUTO_ID').AsInteger;
            End;
            {Begin
            QUpdate.ParamByName('DT_COMPRA').AsDateTime    := QEntrada.FieldByName('DT_TRANS').AsDateTime;
            QUpdate.ParamByName('DT_ENTRADA').AsDateTime   := QEntrada.FieldByName('DT_ENT_SAI').AsDateTime;
            QUpdate.ParamByName('ULT_QUANTIDADE').AsFloat  := QEntrada.FieldByName('QUANTIDADE').AsFloat;
            QUpdate.ParamByName('DESPESAS').AsFloat        := (Indices + QEntrada.FieldByName('ICMS_SAIDA').AsFloat);
            QUpdate.ParamByName('PMZ').AsFloat             := RoundTo(New_PMZ, -2);
            QUpdate.ParamByName('PRECO_SUGESTAO').AsFloat  := RoundTo(New_Sugestao, -2);
            QUpdate.ParamByName('VR_ICMSST').AsFloat       := RoundTo(Icms_Sub, -2);
            QUpdate.ParamByName('VR_FRETE').AsFloat        := RoundTo(New_Frt, -2);
            QUpdate.ParamByName('VR_IPI').AsFloat          := RoundTo(New_Ipi, -2);
            QUpdate.ParamByName('VR_DESPESAS').AsFloat     := RoundTo(New_Desp, -2);
            QUpdate.ParamByName('DIF_ICMS').AsFloat        := RoundTo(New_Dif_ICMS, -2);
            QUpdate.ParamByName('PRODUTO_ID').AsInteger    := QEntrada.FieldByName('PRODUTO_ID').AsInteger;
            End;
            }
            QUpdate.Prepare;
            QUpdate.ExecSql;



            Label2.Caption := QEntrada.FieldByName('TRANSACAO_ID').AsString;
          except
            on e:Exception do
            begin
              Application.MessageBox(PChar('Erro ao efetuar o fechamento/abertura. Produto: ' + QEntrada.FieldByName('PRODUTO_ID').AsString + ' Entrada: ' + QEntrada.FieldByName('TRANSACAO_ID').AsString + #13 +
                'Erro: ' + e.Message), PChar(Msg_Title), mb_IconInformation + mb_TaskModal);
            end;
          end;
          //Resu                := FormatFloat('0', (X));
          //Progresso.Position := StrToInt(resu) ;

          Application.ProcessMessages;


          QEntrada.Next;

          FrmPrincipal.StatusBar.Panels[4].Text := 'Dt: ' + DateToStr(QEntrada.FieldByName('DT_TRANS').AsDateTime) + 'Trans: ' + QEntrada.FieldByName('TRANSACAO_ID').AsString;
        end;


     {
        QEntrada.Sql.Clear;
        QEntrada.Sql.Add('SELECT DISTINCT PRODUTO_ID');
        QEntrada.Sql.Add('FROM TRANSITENS');
        QEntrada.Sql.Add('INNER JOIN TRANSACOES');
        QEntrada.Sql.Add('ON (TRANSITENS.TRANSACAO_ID = TRANSACOES.TRANSACAO_ID)');
        QEntrada.Sql.Add('WHERE');
        QEntrada.Sql.Add('(TRANSACOES.DT_MOVIMENTO = :DT_MOVIMENTO)');
        QEntrada.Sql.Add('AND (TRANSACOES.CONDUTA = :CONDUTA)');
        QEntrada.Sql.Add('AND (TRANSACOES.DEPTO = :DEPTO)');
        QEntrada.Sql.Add('AND (TRANSITENS.TP_PROD_SERV = :TP_PROD_SERV)');

        QEntrada.ParamByName('DT_MOVIMENTO').AsDateTime := StrToDate(dt_posicao);
        QEntrada.ParamByName('CONDUTA').AsString        := '01';
        QEntrada.ParamByName('DEPTO').AsString          := '07';
        QEntrada.ParamByName('TP_PROD_SERV').AsString   := 'P';

        QEntrada.Prepare;
        QEntrada.Open;

        QEntrada.First;

        X := 0.2;

        while not QEntrada.Eof do
        begin
          X := X + 0.5;
          QUpdate.Sql.Clear;
          QUpdate.Sql.Add('UPDATE PRODUTOS SET DT_MOVIMENTO = :DT_MOVIMENTO ' +
                          'WHERE ' +
                          '(PRODUTO_ID = :PRODUTO_ID)');

          QUpdate.ParamByName('DT_MOVIMENTO').AsDateTime := StrToDate(dt_posicao);
          QUpdate.ParamByName('PRODUTO_ID').AsInteger    := QEntrada.FieldByName('PRODUTO_ID').AsInteger;

          QUpdate.Prepare;
          QUpdate.ExecSql;



          Label2.Caption := QEntrada.FieldByName('PRODUTO_ID').AsString;



          //Resu                := FormatFloat('0', (X));
          //Progresso.Position := StrToInt(resu) ;

          Application.ProcessMessages;
          QEntrada.Next;
        end;

        Label2.Caption := 'Criando posiçăo de produtos.';
        Application.ProcessMessages;

        QUpdate.Sql.Clear;
        QUpdate.Sql.Add('INSERT INTO POSICAO_PRODUTOS(PRODUTO_ID, DT_MOVIMENTO, CUSTO_COMPRA, VALOR_COMPRA, CUSTOMEDIO, PRECO_VAREJO, PRECO_ATACADO, QUANTIDADE_C, QUANTIDADE_G)');
        QUpdate.Sql.Add('SELECT PRODUTO_ID, :DT_MOVIMENTO, CUSTO_COMPRA, VALOR_COMPRA, CUSTOMEDIO, PRECO_VAREJO, PRECO_ATACADO, QUANTIDADE_C, QUANTIDADE_G');
        QUpdate.Sql.Add('FROM PRODUTOS');
        QUpdate.Sql.Add('WHERE');
        QUpdate.Sql.Add('(QUANTIDADE_C <> 0 OR QUANTIDADE_G <> 0) ');

        QUpdate.ParamByName('DT_MOVIMENTO').AsDateTime := StrToDate(dt_posicao);

        QUpdate.Prepare;
        QUpdate.ExecSql;



      QUpdate.Sql.Clear;
      QUpdate.Sql.Add('UPDATE PRODUTOS SET ESTOQUE_INICIAL = (QUANTIDADE_C + QUANTIDADE_G)');

      QUpdate.Prepare;
      QUpdate.ExecSql;
     }

end;




procedure Trans_Compra_Estoque(Transacao: Integer);
begin
  Id_Trans := Transacao;

  if not ThereIs('Trans. de Estoque - Compra') then
    TFrmTrans_Compra_Estoque.Create(Application);

  if LeIni(Arq_Ini, 'Sistema', 'Organizar Janelas Automaticamente') = 'True' then
    FrmPrincipal.Cascade;
end;

procedure TFrmTrans_Compra_Estoque.Estorno_Transacao;
var
Id_Trans: Integer;
begin
    IQuery.SQL.Clear;
    IQuery.SQL.Add('SELECT NEXTVAL(:GEN_TRANSACOES) ID');
    IQuery.ParamByName('GEN_TRANSACOES').AsString :=  'GEN_TRANSACOES';

    IQuery.Prepare;
    IQuery.Open;

    Id_Trans := IQuery.FieldByName('ID').AsInteger;


  QRel.Sql.Clear;
  QRel.Sql.Add('INSERT INTO TRANSACOES( ' +
               'TRANSACAO_ID,  DT_TRANS,    DT_MOVIMENTO, CONDUTA, ' +
               'DEPTO,         EMPRESA_ID,  CONTA_ID,     C_CUSTO_ID, ' +
               'VALOR,         TPCTB,       AUTORIZ_ID,   HISTORICO, ' +
               'CONTAAUX_ID,   NUM_DOC) VALUES(' +
               ':TRANSACAO_ID, :DT_TRANS,   :DT_MOVIMENTO, :CONDUTA, :DEPTO,      :EMPRESA_ID, ' +
               ':CONTA_ID,     :C_CUSTO_ID, :VALOR,        :TPCTB,   :AUTORIZ_ID, :HISTORICO, ' +
