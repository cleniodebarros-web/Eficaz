       QSearch.ExecSQL;

       QUpdate.Sql.Text:= 'UPDATE TRANSACOES SET MOVIMENTO_PISCOFINS = 1 WHERE TRANSACAO_ID = :TRANSACAO_ID';
       QUpdate.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
       QUpdate.Prepare;
       QUpdate.ExecSQL;

       Chk_movimentoSpedPiscofins.Checked  := True;

       QSearch.Sql.Text:= 'ALTER TABLE TRANSACOES ENABLE TRIGGER TRANSACOES_UP';
       QSearch.Prepare;
       QSearch.ExecSQL;

      End;
     End
     Else
     Begin

      if Application.MessageBox('Deseja inserir esta nota do movimento Fiscal(Sped)?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
      Begin

       QSearch.Sql.Text:= 'ALTER TABLE TRANSACOES DISABLE TRIGGER TRANSACOES_UP';
       QSearch.Prepare;
       QSearch.ExecSQL;

       QUpdate.Sql.Text:= 'UPDATE TRANSACOES SET MOVIMENTO_PISCOFINS = 0 WHERE TRANSACAO_ID = :TRANSACAO_ID';
       QUpdate.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
       QUpdate.Prepare;
       QUpdate.ExecSQL;

       Chk_movimentoSpedPiscofins.Checked  := False;

       QSearch.Sql.Text:= 'ALTER TABLE TRANSACOES ENABLE TRIGGER TRANSACOES_UP';
       QSearch.Prepare;
       QSearch.ExecSQL;

      End;

     End ;

     id := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
     QTabela.Close;
     QTabela.Prepare;
     QTabela.Open;
     QTabela.Locate('TRANSACAO_ID', ID, [loCaseInsensitive]);

    exit;
   End;

  if Existe_Pagamento(QTabela.FieldByName('TRANSACAO_ID').AsInteger) then
  begin
    Application.MessageBox('Transaçăo possui parcela quitada. Impossível continuar', PChar(Msg_Title), mb_IconStop);
