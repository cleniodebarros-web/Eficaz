              QUpdate.ParamByName('DT_EMISSAO').AsDateTime   := QTabela.FieldByName('DT_ENT_SAI').AsDateTime;
              QUpdate.ParamByName('VALOR_COMPRA').AsFloat    := RoundTo(New_Custo, -2);
              QUpdate.ParamByName('CUSTO_COMPRA').AsFloat    := RoundTo(Cst_Entr, -2);
              QUpdate.ParamByName('CUSTO_MEDIO').AsFloat     := RoundTo(Cst_Med_Entr, -2);

              QUpdate.prepare;
              QUpdate.ExecSQL;

             Except

             end;

            End
            Else
            Begin
             QUpdate.Sql.Clear;
             QUpdate.Sql.Text:='UPDATE TRANSITENS_CUSTO SET VALOR_COMPRA = :VALOR_COMPRA, CUSTO_COMPRA = :CUSTO_COMPRA, CUSTO_MEDIO = :CUSTO_MEDIO '+
                               'WHERE TRANSACAO_ID = :TRANSACAO_ID AND PRODUTO_ID = :PRODUTO_ID';


             QUpdate.ParamByName('TRANSACAO_ID').AsInteger  := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
             QUpdate.ParamByName('PRODUTO_ID').AsInteger    := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;
             QUpdate.ParamByName('VALOR_COMPRA').AsFloat    := RoundTo(New_Custo, -2);
             QUpdate.ParamByName('CUSTO_COMPRA').AsFloat    := RoundTo(Cst_Entr, -2);
             QUpdate.ParamByName('CUSTO_MEDIO').AsFloat     := RoundTo(Cst_Med_Entr, -2);

             QUpdate.prepare;
             QUpdate.ExecSQL;

            End;

          except
            on e:Exception do
            begin
              Application.MessageBox(PChar('Erro ao atualizar preço de custo. Produto: ' + QSub_Detail.FieldByName('PRODUTO_ID').AsString + ' Entrada: ' + QTabela.FieldByName('TRANSACAO_ID').AsString + #13 +
                'Erro: ' + e.Message), PChar(Msg_Title), mb_IconInformation + mb_TaskModal);
            end;
          end;


          if Chk_EnviarAlteracoes.Checked Then
          Begin
          Resu := FormatFloat('0',((I * 100) / (QSub_Detail.RecordCount)));
          Gauge1.Progress := StrToInt(Resu);
          End;

          Application.ProcessMessages;
          QSub_Detail.Next;
        end
        Else
        QSub_Detail.Next;

       End;
        if NOT chk_enviarAlteracoes.Checked then
