procedure TFrmTrans_Compra_Estoque.Grid_ItensExit(Sender: TObject);
var
Resp: TModalResult;
Perc_ST, Soma_ST, Ult_Valor : Real;
CST: String;
Ult_Produto: Integer;
Aliquota_Inter_Estadual, Aliquota_ICMS_Local:Real;

begin
  Consulta.TabVisible := False;
  DBText7.Visible     := False;
  Chk_EnviarAlteracoes.Visible := True;

  if QSub_Detail.State in [dsInsert, dsEdit] then
  begin
    QSub_Detail.Cancel;

  end;

  if FrmData.QAcesso.FieldByName('ALTERACAO').AsString = 'NĂO' then
  begin
    Application.MessageBox('Usuário sem permissăo para alteraçăo', PChar(Msg_Title), mb_IconStop);
    Botoes_Normal;
    Consulta.TabVisible := True;
    exit;
  end;

  if QTabela.FieldByName('DT_MOVIMENTO').AsDateTime < FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime then
  begin
    Application.MessageBox('Movimento já encerrado', PChar(Msg_Title), mb_IconStop);
    Botoes_Normal;
    Consulta.TabVisible := True;
    exit;
  end;

  // Caso queira ratear o valor do ICMS ST retirado a pedido de regivaldo 11/06/15

  Perc_ST := 0;

  {if VR_ICMS_ST.Value > 0 then
  begin
    Resp := Application.MessageBox('Deseja ratear o valor da Substituiçăo Tributária entre os itens?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2);

    if Resp = mrYes then
    begin
      IQuery.Sql.Clear;
      IQuery.Sql.Add('SELECT SUM(VR_TOTAL) VR_TOTAL');
      IQuery.Sql.Add('FROM TRANSITENS');
      IQuery.Sql.Add('WHERE');
      IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
      IQuery.Sql.Add('AND (CST LIKE :CST1 OR CST LIKE :CST2 OR CST LIKE :CST3 OR CST LIKE :CST4)');

      IQuery.Sql.Add('GROUP BY CFOP');

      IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
      IQuery.ParamByName('CST1').AsString          := '%10';
      IQuery.ParamByName('CST2').AsString          := '%30';
      IQuery.ParamByName('CST3').AsString          := '%60';
      IQuery.ParamByName('CST4').AsString          := '%70';

      IQuery.Prepare;
      IQuery.Open;

      if IQuery.FieldByName('VR_TOTAL').AsFloat > 0 then
        Perc_ST := ((VR_ICMS_ST.Value * 100) / IQuery.FieldByName('VR_TOTAL').AsFloat)
      else
        Perc_ST := 0;
    end;
  end;}

  btnEditClick(Self);

  if QTabela.FieldByName('TIPO_IMP').AsInteger <> 2 then
  Begin
    VALOR_PRODUTOS.Value := 0;
    VR_IPI.Value         := 0;
    ITENS.Value          := 0;
    UNIDADES.Value       := 0;
    Soma_ST              := 0;
    VR_PIS.Value         := 0;
    VR_COFINS.Value      := 0;
    VR_PIS_ST.Value      := 0;
    VR_COFINS_ST.Value   := 0;

    QSub_Detail.First;
    while not QSub_Detail.Eof do
    begin
      CST := Copy(QSub_Detail.FieldByName('CST').AsString, 2, 2);

      if (Resp = mrYes) and (Perc_ST > 0) and ((CST = '10') or (CST = '30') or (CST = '60') or (CST = '70')) then
      begin
        IQuery.Sql.Clear;
        IQuery.Sql.Add('UPDATE TRANSITENS SET VALOR_ICMS_ST = :VALOR_ICMS_ST, VALOR_OUTROS = :VALOR_OUTROS');
        IQuery.Sql.Add('WHERE');
        IQuery.Sql.Add('(TRANSACAO_ID = :TRANSACAO_ID)');
        IQuery.Sql.Add('AND (PRODUTO_ID = :PRODUTO_ID)');

        IQuery.ParamByName('VALOR_ICMS_ST').AsFloat  := RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat * Perc_ST) / 100), -2);
        IQuery.ParamByName('VALOR_OUTROS').AsFloat   := (QSub_Detail.FieldByName('VR_TOTAL').AsFloat + RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat * Perc_ST) / 100), -2) + QSub_Detail.FieldByName('VR_IPI').AsFloat);
        IQuery.ParamByName('TRANSACAO_ID').AsInteger := QTabela.FieldByName('TRANSACAO_ID').AsInteger;
        IQuery.ParamByName('PRODUTO_ID').AsInteger   := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;

        IQuery.Prepare;
        IQuery.ExecSql;



        Soma_ST   := Soma_ST + RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat * Perc_ST) / 100), -2);
        Ult_Valor := RoundTo(((QSub_Detail.FieldByName('VR_TOTAL').AsFloat * Perc_ST) / 100), -2);

        Ult_Produto := QSub_Detail.FieldByName('PRODUTO_ID').AsInteger;
      end;

      VALOR_PRODUTOS.Value := VALOR_PRODUTOS.Value + QSub_Detail.FieldByName('VR_TOTAL').AsFloat;
      VR_IPI.Value         := VR_IPI.Value + QSub_Detail.FieldByName('VR_IPI').AsFloat;
      ITENS.Value          := ITENS.Value + 1;
      UNIDADES.Value       := UNIDADES.Value + QSub_Detail.FieldByName('QUANTIDADE').AsFloat;

      if (QSub_Detail.FieldByName('CST_PIS').AsString = '05') or (QSub_Detail.FieldByName('CST_PIS').AsString = '75') then
        VR_PIS_ST.Value := VR_PIS_ST.Value + QSub_Detail.FieldByName('VR_PIS').AsFloat
      else
        VR_PIS.Value := VR_PIS.Value + QSub_Detail.FieldByName('VR_PIS').AsFloat;

      if (QSub_Detail.FieldByName('CST_COFINS').AsString = '05') or (QSub_Detail.FieldByName('CST_COFINS').AsString = '75') then
        VR_COFINS_ST.Value := VR_COFINS_ST.Value + QSub_Detail.FieldByName('VR_COFINS').AsFloat
      else
        VR_COFINS.Value := VR_COFINS.Value + QSub_Detail.FieldByName('VR_COFINS').AsFloat;

      Application.ProcessMessages;
      QSub_Detail.Next;
    end;

    if (Soma_ST > 0) and (VR_ICMS_ST.Value <> Soma_ST) then
    begin
