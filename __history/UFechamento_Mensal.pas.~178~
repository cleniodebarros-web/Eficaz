    QReceitas.Sql.Add('0 MENSALIDADE_RELOGIO,0 MENSALIDADE_RELOGIO_ANO, 0 VENDA_SISTEMA, 0 MENSALIDADE_EFICAZ,0 EMPRESTIMOS,0 POSICAO_ESTOQUE');
    QReceitas.Sql.Add('FROM ordem_servico');
    QReceitas.Sql.Add('WHERE DT_FECHAMENTO BETWEEN :DT_INICIAL AND :DT_FINAL ');
    QReceitas.Sql.Add('AND STATUS = ''FATURADO'' AND ATENDENTE = 108 ');
    QReceitas.Sql.Add('AND EMPRESA_ID_RATEIO = 0 ');
    QReceitas.Sql.Add('GROUP BY EMPRESA_ID');
    QReceitas.Sql.Add('UNION ALL');
    // PECAS E SERVICOS RATEIO
    QReceitas.Sql.Add('SELECT  EMPRESA_ID EMPRESA, CASE WHEN SUM(VALORP_RATEIO1) > 0 Then  SUM(VALORP_RATEIO1) ELSE SUM(VALOR_PECAS) END PECAS ,');
    QReceitas.Sql.Add('CASE WHEN SUM(VALORS_RATEIO1) > 0 Then SUM(VALORS_RATEIO1 - (DESCONTO/2)) ELSE SUM(VALOR_SERVICOS - DESCONTO) END SERVICOS ,');
    QReceitas.Sql.Add('0 PECAS2 ,0 SERVICOS2,0 EQUIPAMENTO, 0 COMISSAO, 0 CONTRATO,');
    QReceitas.Sql.Add('0 MENSALIDADE_RELOGIO,0 MENSALIDADE_RELOGIO_ANO, 0 VENDA_SISTEMA, 0 MENSALIDADE_EFICAZ,0 EMPRESTIMOS,0 POSICAO_ESTOQUE');
    QReceitas.Sql.Add('FROM ordem_servico');
    QReceitas.Sql.Add('WHERE DT_FECHAMENTO BETWEEN :DT_INICIAL AND :DT_FINAL ');
    QReceitas.Sql.Add('AND STATUS = ''FATURADO''');
    QReceitas.Sql.Add('AND EMPRESA_ID_RATEIO > 0');
    QReceitas.Sql.Add('GROUP BY EMPRESA');
    QReceitas.Sql.Add('UNION ALL');
    QReceitas.Sql.Add('SELECT EMPRESA_ID_RATEIO EMPRESA, CASE WHEN SUM(VALORP_RATEIO2) > 0 Then  SUM(VALORP_RATEIO2) ELSE SUM(VALOR_PECAS) END PECAS ,');
