  IF QSearch.IsEmpty Then
  Begin

    QReceitas.Sql.Clear;
    QReceitas.Sql.Add('SELECT EMPRESA, SUM(PECAS) PECAS , SUM(SERVICOS) SERVICOS,SUM(PECAS2) PECAS2 ,SUM(SERVICOS2) SERVICOS2, SUM(EQUIPAMENTO) EQUIPAMENTO ,SUM(COMISSAO) COMISSAO,');
