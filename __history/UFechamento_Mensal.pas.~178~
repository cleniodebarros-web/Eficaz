procedure TFrmFechamento_Mensal.chk_AtualizarClick(Sender: TObject);
begin
  iF Chk_Atualizar.Checked Then
  Begin
    if Application.MessageBox('Deseja apagar os dados do fechamento?', PChar(Msg_Title), mb_YesNo + mb_IconQuestion + mb_DefButton2) = IDYES then
    Begin

      QUpdate.Sql.Clear;
      QUpdate.Sql.Add('DELETE FROM FECHAMENTO_MENSAL WHERE DT_INICIAL = :DT_INICIAL AND DT_FINAL = :DT_FINAL');

      QUpdate.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
      QUpdate.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;

      QUpdate.Prepare;
      QUpdate.ExecSQL;


      Application.MessageBox(Pchar('Fechamento mensal referente ao período :' + #13 + dtmen.Text + ' a '  + dtmen.Text  + #13 + 'Excluído com sucesso.'),PChar(Msg_Title), MB_ICONINFORMATION + MB_OK);

      Chk_Atualizar.Checked := False;

    End;


  End;

end;

