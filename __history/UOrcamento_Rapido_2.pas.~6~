procedure TFrmOrcamento_Rapido_2.Soma;
begin
  if DataLog_Itens.DataSet = QLog_Orcamento then
  BEGIN
    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT SUM(VR_TOTAL) VR_TOTAL');
    QRel.Sql.Add('FROM LOG_ORCAMENTO');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(CUPOM = :CUPOM)');

    QRel.ParamByName('CUPOM').AsString := Cod_Cupom; // SerialNum('C');

    QRel.Prepare;
    QRel.Open;

    Total_Orcamento.Value := QRel.FieldByName('VR_TOTAL').AsFloat - VR_DESCONTO.Value;

    if  QRel.FieldByName('VR_TOTAL').AsFloat > 0.01 then
    BtnExecuta.Enabled := True
    else
    BtnExecuta.Enabled := False;

  end
  Else
  begin

    QRel.Sql.Clear;
    QRel.Sql.Add('SELECT SUM(VR_TOTAL) VR_TOTAL');
    QRel.Sql.Add('FROM ORCITENS');
    QRel.Sql.Add('WHERE');
    QRel.Sql.Add('(ORCAMENTO_ID = :ORCAMENTO_ID)');

    QRel.ParamByName('ORCAMENTO_ID').AsInteger := StrToInt(Orcamento_id.Text); // SerialNum('C');

    QRel.Prepare;
    QRel.Open;

    Total_Orcamento.Value := QRel.FieldByName('VR_TOTAL').AsFloat - VR_DESCONTO.Value;

    if  QRel.FieldByName('VR_TOTAL').AsFloat > 0.01 then
    BtnExecuta.Enabled := True
    else
    BtnExecuta.Enabled := False;

  end;


end;




