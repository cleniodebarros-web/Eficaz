procedure TFrmTrans_Recebimento.btnInsertClick(Sender: TObject);
var
Dif, Correc: Real;
begin
  if FrmData.QAcesso.FieldByName('INCLUSAO').AsString = 'NĂO' then
  begin
    Application.MessageBox('Usuário sem permissăo para inclusăo', PChar(Msg_Title), mb_IconStop);
    exit;
  end;

  Operacao := 'Inserindo';
  Botoes_Editing;
  Set_Campos(True);
  Habilitar(True);

  QEmpresa.Close;
  QBanco.Close;
  QConta.Close;

  DT_TRANS.Date        := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  DT_MOVIMENTO.Date    := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  DT_ENT_SAI.Date      := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
  BALANCO.Text         := 'LIBERADO';
  AUTORIZ_ID.Value     := FrmData.QAcesso.FieldByName('FUNCIONARIO_ID').AsInteger;
  CONTA_ID.Value       := 0;
  SERIE.Text           := 'N';
  FLUXO_CAIXA_ID.Value := 1;
  HORA.Text            := TimeToStr(TIME);

  if LeIni(Arq_Ini, 'Sistema', 'Caixa') <> '' then
    BANCO_ID.Value := StrToInt(LeIni(Arq_Ini, 'Sistema', 'Caixa'));

  Application.CreateForm(TFrmSeleciona_Devedores, FrmSeleciona_Devedores);
  try
    if (FrmSeleciona_Devedores.ShowModal = mrOk) and (not FrmSeleciona_Devedores.QTabela.IsEmpty) then
    begin
      VALOR_PARCELA.Value := FrmSeleciona_Devedores.QTabela.FieldByName('VALOR').AsFloat;

      Correc := 0;

      if (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime > FrmSeleciona_Devedores.QTabela.FieldByName('DT_VENCIMENTO').AsDateTime) and (FrmPrincipal.Config.FieldByName('JUROS_MENSAL').AsFloat > 0) then
      begin
        Dif    := FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime - FrmSeleciona_Devedores.QTabela.FieldByName('DT_VENCIMENTO').AsDateTime;
        Correc := ((((FrmSeleciona_Devedores.QTabela.FieldByName('VALOR').AsFloat * FrmPrincipal.Config.FieldByName('JUROS_MENSAL').AsFloat) / 100) / 30) * Dif);
        Correc := RoundTo(Correc, -2);
      end;

      if (FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime < FrmSeleciona_Devedores.QTabela.FieldByName('DT_VENCIMENTO').AsDateTime) and (FrmPrincipal.Config.FieldByName('DESCONTO_MENSAL').AsFloat > 0) then
      begin
        Dif    := FrmSeleciona_Devedores.QTabela.FieldByName('DT_VENCIMENTO').AsDateTime - FrmPrincipal.Abertura.FieldByName('DT_MOVIMENTO').AsDateTime;
        Correc := ((((FrmSeleciona_Devedores.QTabela.FieldByName('VALOR').AsFloat * FrmPrincipal.Config.FieldByName('DESCONTO_MENSAL').AsFloat) / 100) / 30) * Dif);
        Correc := RoundTo(Correc, -2);
        Correc := (Correc * -1);
      end;

      VALOR.Value      := (FrmSeleciona_Devedores.QTabela.FieldByName('VALOR').AsFloat + Correc);
      CLIENTE_ID.Value := FrmSeleciona_Devedores.QTabela.FieldByName('CLIENTE_ID').AsInteger;

      DetailSearch('Cliente');

      HISTORICO.Text      := 'Vr. rec. ' + QCliente.FieldByName('NOME').AsString + ' ref. parc. ' + FrmSeleciona_Devedores.QTabela.FieldByName('PARCELA_ID').AsString;
      NUM_DOC.Text        := FrmSeleciona_Devedores.QTabela.FieldByName('NUM_DOC').AsString;
      PARCELA_ID.Text     := FrmSeleciona_Devedores.QTabela.FieldByName('PARCELA_ID').AsString;
      EMPRESA_ID.Value    := FrmSeleciona_Devedores.QTabela.FieldByName('EMPRESA_ID').AsInteger;
      SAIDA_ID.Value      := FrmSeleciona_Devedores.QTabela.FieldByName('TRANSACAO_ID').AsInteger;
      COMPLEMENTO.Text    := 'Duplicata :' + FrmSeleciona_Devedores.QTabela.FieldByName('DUPLICATA').AsString;

      Consulta.TabVisible := False;

      DT_TRANS.SetFocus;
    end
    else
      btnDiscardClick(Self);
  finally
    FrmSeleciona_Devedores.Release;
  end;

  QFinalizadora.Close;
  QFinalizadora.SQL.Clear;
  QFinalizadora.Sql.Add('SELECT * FROM FINALIZADORAS WHERE TIPO_TRANSACAO IN (1,3,7) ');
  QFinalizadora.Prepare;
  QFinalizadora.Open;

  Finalizadora_id.KeyValue := 1;
  Finalizadora_id.Enabled  := True;

end;

