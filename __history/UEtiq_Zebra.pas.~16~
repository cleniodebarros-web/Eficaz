  Begin
  Impressora.Text      := LeIni(Arq_Ini, 'Impressora Código Barras','Impressora');
  Modelo.Text          := LeIni(Arq_Ini, 'Impressora Código Barras','Modelo');
  Porta.Text           := LeIni(Arq_Ini, 'Impressora Código Barras','Porta');

