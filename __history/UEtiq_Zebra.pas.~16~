procedure TFrmEtiq_Zebra.btnSelecionaClick(Sender: TObject);
begin
  if CheckBox1.Checked then
  begin
    QEstoque.SQL.Clear;
    QEstoque.SQL.Add('SELECT * FROM PRODUTOS,');
    QEstoque.SQL.Add('LATERAL GENERATE_SERIES(1, COPIAS_ETIQUETA) WHERE COPIAS_ETIQUETA > 0');
    QEstoque.Prepare;
    QEstoque.Open;
    QEstoque.First;
    while not QEstoque.Eof do
    begin
      Relat.Append;
      Relat.FieldByName('CODBARRAS').AsString    := QEstoque.FieldByName('COD_BARRA').AsString;
      Relat.FieldByName('INTEGRACAO').AsString   := QEstoque.FieldByName('PRODUTO_ID').AsString;
      Relat.FieldByName('DESCRICAO').AsString    := QEstoque.FieldByName('DESCRICAO').AsString;
      Relat.FieldByName('PRECO_VENDA').AsFloat   := QEstoque.FieldByName('PRECO_VAREJO').AsFloat;
      Relat.FieldByName('PRECO_PRAZO').AsFloat   := QEstoque.FieldByName('PRECO_PRAZO').AsFloat;
      Relat.FieldByName('PRECO_ATACADO').AsFloat := QEstoque.FieldByName('PRECO_ATACADO').AsFloat;
      Relat.FieldByName('QUANT_MAXIMA').AsFloat  := QEstoque.FieldByName('QUANT_MAXIMA').AsFloat;


      if Novos.ItemIndex = 1 then
        Relat.FieldByName('UNID_COMPRA').AsInteger := QEstoque.FieldByName('ULT_QUANTIDADE').AsInteger
      else
        Relat.FieldByName('UNID_COMPRA').AsInteger := QEstoque.FieldByName('QUANTIDADE_G').AsInteger;

      if Modelo.Text = 'Gôndola Individual' then
        Relat.FieldByName('UNID_COMPRA').AsInteger := 1;

      Relat.Post;
      Application.ProcessMessages;
      QEstoque.Next;
    end;
  end;

  if Novos.ItemIndex = 1 then
  begin
    QEstoque.Sql.Clear;
    QEstoque.Sql.Add('SELECT * FROM PRODUTOS');
    QEstoque.Sql.Add('WHERE');

    if Codigo.Value > 0 then
    begin
      QEstoque.Sql.Add('(PRODUTO_ID = :PRODUTO_ID)');

      QEstoque.ParamByName('PRODUTO_ID').AsInteger := StrToInt(Codigo.Text);
    end
    else
    begin
      QEstoque.Sql.Add('((DT_COMPRA BETWEEN :DT_INICIAL AND :DT_FINAL) OR (DT_ATUALIZACAO BETWEEN :DT_INICIAL AND :DT_FINAL))');

      QEstoque.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
      QEstoque.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
    end;

    if Start_Wait.Text <> '' then
    begin
      QEstoque.Sql.Add('AND (DESCRICAO LIKE :DESCRICAO)');

      QEstoque.ParamByName('DESCRICAO').AsString := Start_Wait.Text + '%';
    end;

    QEstOque.Sql.Add('AND (STATUS = :STATUS)');

    QEstoque.ParamByName('STATUS').AsString := 'A';
  end
  else
  begin
    QEstoque.Sql.Clear;
    QEstoque.Sql.Add('SELECT * FROM PRODUTOS');
    QEstoque.Sql.Add('WHERE');

    if Codigo.Value > 0 then
    begin
      QEstoque.Sql.Add('(PRODUTO_ID = :PRODUTO_ID)');

      QEstoque.ParamByName('PRODUTO_ID').AsInteger := StrToInt(Codigo.Text);
    end
    else
    begin
      QEstoque.Sql.Add('((DT_PRECO BETWEEN :DT_INICIAL AND :DT_FINAL))');

      QEstoque.ParamByName('DT_INICIAL').AsDateTime := Dtmen.Date;
      QEstoque.ParamByName('DT_FINAL').AsDateTime   := Dtmai.Date;
    end;

    if Posicao.Checked then
      QEstoque.Sql.Add('AND (QUANTIDADE_C > 0)');

    if Start_Wait.Text <> '' then
    begin
      QEstoque.Sql.Add('AND (DESCRICAO LIKE :DESCRICAO)');

      QEstoque.ParamByName('DESCRICAO').AsString := Start_Wait.Text + '%';
    end;

    QEstOque.Sql.Add('AND (STATUS = :STATUS)');

    QEstoque.ParamByName('STATUS').AsString := 'A';
  end;

  if Entrada_id.Value > 0 then
  Begin
   if not QFornecedor.IsEmpty then
   Begin
    QEstoque.SQL.Clear;
    QEstoque.SQL.Add('SELECT PRODUTOS.* ,TRANSACOES.TRANSACAO_ID FROM TRANSITENS');
    QEstoque.SQL.Add('INNER JOIN TRANSACOES ON TRANSACOES.TRANSACAO_ID = TRANSITENS.TRANSACAO_ID');
    QEstoque.SQL.Add('INNER JOIN PRODUTOS ON PRODUTOS.PRODUTO_ID = TRANSITENS.PRODUTO_ID');
    QEstoque.SQL.Add('WHERE CONDUTA = :CONDUTA AND DEPTO = :DEPTO AND TRANSACOES.TRANSACAO_ID = :TRANSACAO_ID');

    QEstoque.ParamByName('CONDUTA').AsString := '02';
    QEstoque.ParamByName('DEPTO').AsString   := '07';
    QEstoque.ParamByName('TRANSACAO_ID').AsInteger := StrToInt(Entrada_id.Text);
    QEstoque.Sql.Add('ORDER BY TRANSITENS.DESCRICAO')

   End;
  End
  Else
  QEstoque.Sql.Add('ORDER BY DESCRICAO');

  QEstoque.Prepare;
  QEstoque.Open;


  QEstoque.First;
  while not QEstoque.Eof do
  begin
   // if not Digito(QEstoque.FieldByName('COD_BARRA').AsString) then
   //   Application.MessageBox(PChar('O item ' + QEstoque.FieldByName('DESCRICAO').AsString + ' năo possui um Código de Barras válido'), PChar(Msg_Title), mb_IconWarning)
   // else
    begin

      Relat.Append;
      Relat.FieldByName('CODBARRAS').AsString    := QEstoque.FieldByName('COD_BARRA').AsString;
      Relat.FieldByName('INTEGRACAO').AsString   := QEstoque.FieldByName('PRODUTO_ID').AsString;
      Relat.FieldByName('DESCRICAO').AsString    := QEstoque.FieldByName('DESCRICAO').AsString;
      Relat.FieldByName('PRECO_VENDA').AsFloat   := QEstoque.FieldByName('PRECO_VAREJO').AsFloat;
      Relat.FieldByName('PRECO_PRAZO').AsFloat   := QEstoque.FieldByName('PRECO_PRAZO').AsFloat;
      Relat.FieldByName('PRECO_ATACADO').AsFloat := QEstoque.FieldByName('PRECO_ATACADO').AsFloat;
      Relat.FieldByName('QUANT_MAXIMA').AsFloat  := QEstoque.FieldByName('QUANT_MAXIMA').AsFloat;


      if Novos.ItemIndex = 1 then
        Relat.FieldByName('UNID_COMPRA').AsInteger := QEstoque.FieldByName('ULT_QUANTIDADE').AsInteger
      else
        Relat.FieldByName('UNID_COMPRA').AsInteger := QEstoque.FieldByName('QUANTIDADE_G').AsInteger;

      if Modelo.Text = 'Gôndola Individual' then
        Relat.FieldByName('UNID_COMPRA').AsInteger := 1;

      Relat.Post;
    end;

    Application.ProcessMessages;
    QEstoque.Next;
  end;

  if QEstoque.IsEmpty then
    Application.MessageBox('Sem produtos para os parâmetros informados', PChar(Msg_Title), mb_IconStop);

  Codigo.Value := 0;
  Codigo.SetFocus;
end;

