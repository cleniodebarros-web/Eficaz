  object Estrutura_Tabelas: TMemo
    Left = 650
    Top = 331
    Width = 260
    Height = 354
    Font.Charset = DEFAULT_CHARSET
    Font.Color = clBlack
    Font.Height = -11
    Font.Name = 'Tahoma'
    Font.Style = []
    Lines.Strings = (
      'CREATE TABLE public.calculo_pis_cofins_icms'
      '('
      '    '
      '    transacao_id integer NOT NULL,    '
      '    dt_sped date DEFAULT '#39'2015-06-25'#39'::date,'
      
        '    cst_cofins character varying(5) COLLATE pg_catalog."default"' +
        ','
      '    cst_pis character varying(5) COLLATE pg_catalog."default",'
      '    cfop character varying(5) COLLATE pg_catalog."default",'
      '    vr_pis  numeric(15,2) ,'
      '    vr_cofins  numeric(15,2) ,'
      '    base_calc_cofins numeric(15,2) ,'
      '    base_calc_pis  numeric(15,2) ,    '
      '    aliquota_pis  numeric(15,2) ,'
      '    aliquota_cofins  numeric(15,2) ,'
      '    vr_total  numeric(15,2) ,'
      '    valor_desconto  numeric(15,2)   '
      ')'
      'WITH ('
      '    OIDS = FALSE'
      ')'
      'TABLESPACE pg_default;'
      ''
      'ALTER TABLE public.calculo_pis_cofins_icms'
      '    OWNER to postgres;'
      ''
      'CREATE INDEX index_calculo_pis_cofins_icms'
      '    ON public.calculo_pis_cofins_icms USING btree'
      '    (transacao_id ASC NULLS LAST)'
      '    TABLESPACE pg_default;')
    ParentFont = False
    ScrollBars = ssBoth
    TabOrder = 17
    Visible = False
  end
  object Tabelas4: TMemo
    Left = 371
    Top = 331
    Width = 258
    Height = 354
    Font.Charset = DEFAULT_CHARSET
    Font.Color = clBlack
    Font.Height = -11
    Font.Name = 'Tahoma'
    Font.Style = []
    Lines.Strings = (
      'DROP FUNCTION public.transacoes_del() CASCADE ;'
      ''
      'CREATE FUNCTION public.transacoes_del()'
      '    RETURNS trigger'
      '    LANGUAGE '#39'plpgsql'#39
      '    COST 100'
      '    VOLATILE NOT LEAKPROOF'
      'AS $BODY$'
      'BEGIN'
      '  DELETE FROM TRANSPARCELAS'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID) AND'
      '        (TIPO_TRANSACAO = '#39'T'#39');'
      ''
      '  DELETE FROM TRANSITENS'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID);'
      ''
      '  DELETE FROM COMPL_NFISCAL'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID);'
      ''
      '  DELETE FROM TRANSITENS_SERIE'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID);'
      ''
      '  DELETE FROM ENTREGA_FUTURA'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID);'
      '  '
      '  DELETE FROM NOTAS_CANCELADAS'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID);'
      '  '
      '  DELETE FROM NOTAS_CANCELADAS_NFCE'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID);'
      '  '
      '  DELETE FROM COMPL_NFCEFISCAL'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID);'
      ''
      ' /* DELETE FROM FECHAMENTO_CUPOM'
      '  WHERE (CUPOM = OLD.TRANSACAO_ID);*/'
      ''
      '/*  Quita'#231#227'o de Cr'#233'dito a Prazo */'
      ''
      '  UPDATE TRANSPARCELAS SET'
      '  VALOR = TRANSPARCELAS.VALOR_ORI,'
      '  PAGTO = '#39'0'#39',ESPECIE ='#39'RECUPERADO'#39
      '  WHERE (TRANSACAO_ID = OLD.SAIDA_ID) AND'
      '        (PARCELA_ID = OLD.PARCELA_ID) AND'
      '        (OLD.SERIE = '#39'P'#39') AND'
      '        (OLD.CONDUTA = '#39'07'#39');'
      ''
      '  UPDATE TRANSPARCELAS SET'
      '  VALOR = TRANSPARCELAS.VALOR + OLD.VALOR_PARCELA,'
      '  PAGTO = '#39'0'#39
      '  WHERE (TRANSACAO_ID = OLD.SAIDA_ID) AND'
      '        (PARCELA_ID = OLD.PARCELA_ID) AND'
      '        (OLD.SERIE <> '#39'P'#39') AND'
      '        (OLD.CONDUTA = '#39'07'#39'); '
      ''
      '/*  Quita'#231#227'o de D'#233'bito a Prazo */'
      ''
      '  UPDATE TRANSPARCELAS SET'
      '  VALOR = TRANSPARCELAS.VALOR + OLD.VALOR,'
      '  PAGTO = '#39'0'#39
      '  WHERE (TRANSACAO_ID = OLD.ENTRADA_ID) AND'
      '        (PARCELA_ID = OLD.PARCELA_ID) AND'
      '        (OLD.SERIE = '#39'P'#39') AND'
      '        (OLD.CONDUTA = '#39'08'#39');'
      ''
      '  UPDATE TRANSPARCELAS SET'
      '  VALOR = VALOR + OLD.VALOR_PARCELA,'
      '  PAGTO = '#39'0'#39
      '  WHERE (TRANSACAO_ID = OLD.ENTRADA_ID) AND'
      '        (PARCELA_ID = OLD.PARCELA_ID) AND'
      '        (OLD.SERIE <> '#39'P'#39') AND'
      '        (OLD.CONDUTA = '#39'08'#39');'
      ''
      '  DELETE FROM RAZAO'
      '  WHERE (TRANSACAO_ID = OLD.TRANSACAO_ID) AND'
      '        (TIPO_TRANSACAO = '#39'T'#39');  '
      'RETURN OLD;'
      'END;'
      '$BODY$;'
      ''
      'ALTER FUNCTION public.transacoes_del()'
      '    OWNER TO postgres;'
      ''
      'CREATE TRIGGER transacoes_del'
      '    BEFORE DELETE'
      '    ON public.transacoes'
      '    FOR EACH ROW'
      '    EXECUTE PROCEDURE public.transacoes_del();')
    ParentFont = False
    ScrollBars = ssBoth
    TabOrder = 18
    Visible = False
  end
  object Estrutura_Tabelas1: TMemo
    Left = 926
    Top = 331
    Width = 258
    Height = 354
    Font.Charset = DEFAULT_CHARSET
    Font.Color = clBlack
    Font.Height = -11
    Font.Name = 'Tahoma'
    Font.Style = []
    Lines.Strings = (
      'CREATE SEQUENCE public.gen_tipo_atividade;'
      ''
      'CREATE FUNCTION public.tabelas_inc_tipo_atividade()'
      '    RETURNS trigger'
      '    LANGUAGE '#39'plpgsql'#39
      '    COST 100'
      '    VOLATILE NOT LEAKPROOF '
      'AS $BODY$'
      'BEGIN'
      ''
      'IF (NEW.TABELA_ID IS NULL AND NEW.TIPO_TABELA = '#39'A'#39') THEN'
      '    NEW.TABELA_ID = NEXTVAL('#39'gen_tipo_atividade'#39');'
      'END IF;'
      ''
      'RETURN NEW; '
      'END;'
      ''
      '$BODY$;'
      ''
      'ALTER FUNCTION public.tabelas_inc_tipo_atividade()'
      '    OWNER TO postgres;'
      #9
      'CREATE TRIGGER tabelas_inc_tipo_atividade'
      'BEFORE INSERT'
      'ON public.tabelas'
      'FOR EACH ROW'
      'EXECUTE PROCEDURE public.tabelas_inc_tipo_atividade();')
    ParentFont = False
    ScrollBars = ssBoth
    TabOrder = 19
    Visible = False
  end
