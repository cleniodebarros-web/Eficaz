  object Tabelas2: TMemo
    Left = 927
    Top = 331
    Width = 260
    Height = 354
    Font.Charset = DEFAULT_CHARSET
    Font.Color = clBlack
    Font.Height = -11
    Font.Name = 'Tahoma'
    Font.Style = []
    Lines.Strings = (
      'CREATE SEQUENCE public.gen_consulta_serasa'
      '    INCREMENT 1'
      '    START 1'
      '    MINVALUE 1'
      '    MAXVALUE 99999999'
      '    CACHE 1;'
      ''
      'ALTER SEQUENCE public.gen_consulta_serasa'
      '    OWNER TO postgres;'
      ''
      'CREATE TABLE public.consulta_serasa'
      '('
      
        '    consulta_id integer NOT NULL DEFAULT nextval('#39'gen_consulta_s' +
        'erasa'#39'::regclass),'
      '    funcionario_id integer NOT NULL,'
      '    dt_consulta date DEFAULT '#39'2015-06-25'#39'::date,'
      
        '    hr_consulta character varying(8) COLLATE pg_catalog."default' +
        '",'
      '    nome character varying(40) COLLATE pg_catalog."default",'
      
        '    tipo_cliente character varying(15) COLLATE pg_catalog."defau' +
        'lt",'
      '    cnpj character varying(18) COLLATE pg_catalog."default",'
      '    resposta character varying(20) COLLATE pg_catalog."default",'
      
        '    protocolo character varying(15) COLLATE pg_catalog."default"' +
        ','
      '    mensagem character varying(30) COLLATE pg_catalog."default",'
      
        '    CONSTRAINT pk_consulta_serasa PRIMARY KEY (consulta_id, func' +
        'ionario_id)'
      ')'
      'WITH ('
      '    OIDS = FALSE'
      ')'
      'TABLESPACE pg_default;'
      ''
      'ALTER TABLE public.consulta_serasa'
      '    OWNER to postgres;'
      ''
      '-- Index: index_consulta_serasa'
      ''
      '-- DROP INDEX public.index_consulta_serasa;'
      ''
      'CREATE INDEX index_consulta_serasa'
      '    ON public.consulta_serasa USING btree'
      '    (consulta_id ASC NULLS LAST, funcionario_id ASC NULLS LAST)'
      '    TABLESPACE pg_default;')
    ParentFont = False
    ScrollBars = ssBoth
    TabOrder = 21
    Visible = False
  end
