procedure TForm_Fiado.Timer_LogsTimer(Sender: TObject);
var
SR: TSearchRec;
I, iT, X: Integer;
F2: TextFile;
S, DT, OP, HR: String;
Log_Certo: Boolean;
begin
  Timer_Logs.Enabled := False;
  Sair.Enabled := False;
  Logs.Open;
  Fechamento.Open;
  Formas.Open;
  DSMain.DataSet.Open;
  DSDetail.DataSet.Open;
  DSContas.DataSet.Open;
  try
    for X := 1 to 2 do
    begin
      if X = 1 then
        I := FindFirst(Caminho_Rx + 'RV*.0??', faAnyFile, SR)
      else
        I := FindFirst(Caminho_Rx + 'PV*.0??', faAnyFile, SR);
      try
        while I = 0 do
        begin
          AssignFile(F2, Caminho_Rx + SR.Name);
          Reset(F2);
          try
            Log_Certo := False;
            while not Eof(F2) do
            begin
              ReadLn(F2, S);
              if (Copy(S, 1, 1) = '0') or (Copy(S, 1, 1) = '6') then 
                Log_Certo := True;
              Application.ProcessMessages;
            end;
          finally
            CloseFile(F2);
          end;
          if not Log_Certo then
            RenameFile(Caminho_Rx + SR.Name, Caminho_Rx + SR.Name + '.Erro');
          Application.ProcessMessages;
          I := FindNext(SR);
        end;
      finally
        FindClose(SR);
      end;
      Application.ProcessMessages;
    end;

    I := FindFirst(Caminho_Rx + 'RV*.0??', faAnyFile, SR);
    try
      while I = 0 do
      begin
        AssignFile(F2, Caminho_Rx + SR.Name);
        Reset(F2);
        iT := 1;
        try
          while not Eof(F2) do
          begin
            ReadLn(F2, S);
            if Copy(S, 1, 1) = '0' then  // Abertura de Cupom
            begin
              DT := Copy(S, 29, 2) + '/' + Copy(S, 31, 2) + '/' + Copy(S, 33, 4);
              OP := Copy(S, 15, 14);
              HR := Copy(S, 37, 2) + ':' + Copy(S, 39, 2) + ':' + Copy(S, 41, 2);
            end;
            if (Copy(S, 1, 1) = '1') or (Copy(S, 1, 1) = '2') then  // Venda ou Cancelamento de Item
            begin
              QEstoque.Close;
              QEstoque.Params[0].Value := Copy(S, 36, 13);
              QEstoque.Open;
              if QEstoque.RecordCount > 0 then
              begin
                Logs.Append;
                Logs.FieldByName('ITEM').AsInteger := iT;
                Logs.FieldByName('CUPOM').AsString := Copy(S, 2, 6);
                Logs.FieldByName('DATA').AsDateTime := StrToDate(DT);
                Logs.FieldByName('CAIXA').AsString := Copy(S, 8, 3);
                Logs.FieldByName('COD_PRODUTO').AsInteger := QEstoque.FieldByName('CODIGO').AsInteger;
                Logs.FieldByName('COD_BARRA').AsString := QEstoque.FieldByName('COD_BARRA').AsString;
                Logs.FieldByName('DESCRICAO').AsString := QEstoque.FieldByName('DESCRICAO').AsString;
                Logs.FieldByName('COD_TRIBUTO').AsInteger := QEstoque.FieldByName('COD_TRIBUTO').AsInteger;
                Logs.FieldByName('ICMS').AsFloat := QEstoque.FieldByName('ICMS').AsFloat;
                Logs.FieldByName('IPI').AsFloat := QEstoque.FieldByName('IPI').AsFloat;
                if Copy(S, 1, 1) = '2' then
                  Logs.FieldByName('QUANTIDADE').AsFloat := (StrToFloat(Copy(S, 49, 9)) / 1000) * -1
                else
                  Logs.FieldByName('QUANTIDADE').AsFloat := (StrToFloat(Copy(S, 49, 9)) / 1000);
                Logs.FieldByName('VR_UNITARIO').AsFloat := (StrToFloat(Copy(S, 58, 12)) / 100);
                Logs.FieldByName('DESCONTO').AsFloat := (StrToFloat(Copy(S, 70, 12)) / 100);
                Logs.FieldByName('VR_COMPRA').AsFloat := QEstoque.FieldByName('VALOR_COMPRA').AsFloat;
                Logs.FieldByName('LOCALIZACAO').AsInteger := QEstoque.FieldByName('LOCALIZACAO').AsInteger;
                Logs.FieldByName('OPERADOR').AsString := OP;
                Logs.FieldByName('VALOR').AsFloat := Logs.FieldByName('QUANTIDADE').AsFloat * (Logs.FieldByName('VR_UNITARIO').AsFloat - Logs.FieldByName('DESCONTO').AsFloat);
                Logs.Post;
                Inc(iT);
              end;
            end;
            if Copy(S, 1, 1) = '6' then  // Cancelamento de cupom
            begin
              QRel.Sql.Clear;
              QRel.Sql.Add('DELETE FROM LOGS');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(CUPOM = ' + #39 + Copy(S, 43, 6) + #39 + ')');
              QRel.Sql.Add('AND (CAIXA = ' + #39 + Copy(S, 8, 3) + #39 + ')');
              QRel.ExecSql;
              QRel.Sql.Clear;
              QRel.Sql.Add('DELETE FROM FECHAMENTO');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(CUPOM = ' + #39 + Copy(S, 43, 6) + #39 + ')');
              QRel.Sql.Add('AND (CAIXA = ' + #39 + Copy(S, 8, 3) + #39 + ')');
              QRel.ExecSql;
              QRel.Sql.Clear;
              QRel.Sql.Add('DELETE FROM TRANS');
              QRel.Sql.Add('WHERE');
              QRel.Sql.Add('(NUM_DOC = ' + #39 + Copy(S, 43, 6) + #39 + ')');
              QRel.Sql.Add('AND (SERIE = ' + #39 + 'ECF' + #39 + ')');
              QRel.ExecSql;
            end;
            if Copy(S, 1, 1) = '3' then  // Pagamento
            begin
              if Formas.FindKey([StrToInt(Copy(S, 29, 2))]) then
              begin
                Fechamento.Append;
                Fechamento.FieldByName('CUPOM').AsString := Copy(S, 2, 6);
                Fechamento.FieldByName('CAIXA').AsString := Copy(S, 8, 3);
                Fechamento.FieldByName('DATA').AsDateTime := StrToDate(DT);
                Fechamento.FieldByName('FORMA').AsString := Formas.FieldByName('NOME').AsString;
                if Copy(S, 138, 1) = 'D' then
                  Fechamento.FieldByName('VALOR').AsFloat := (StrToFloat(Copy(S, 83, 12)) / 100) - (StrToFloat(Copy(S, 95, 12)) / 100);
                if Copy(S, 138, 1) = 'A' then
                  Fechamento.FieldByName('VALOR').AsFloat := (StrToFloat(Copy(S, 83, 12)) / 100) + (StrToFloat(Copy(S, 95, 12)) / 100);
                Fechamento.FieldByName('OPERADOR').AsString := OP;
                Fechamento.FieldByName('HORA').AsString := HR;
                Fechamento.FieldByName('FUNCIONARIO').AsString := Copy(S, 107, 5);
                Fechamento.Post;
              end;
            end;
            Application.ProcessMessages;
          end;
        finally
          CloseFile(F2);
        end;
        if not DirectoryExists('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2)) then
          MkDir('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2));
        if FileExists('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2) + '\' + SR.Name) then
          DeleteFile('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2) + '\' + SR.Name);
        MoveFile(PChar(Caminho_Rx + SR.Name), PChar('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2) + '\' + SR.Name));
        Application.ProcessMessages;
        I := FindNext(SR);
      end;
    finally
      FindClose(SR);
    end;

    I := FindFirst(Caminho_Rx + 'PV*.0??', faAnyFile, SR);
    try
      while I = 0 do
      begin
        AssignFile(F2, Caminho_Rx + SR.Name);
        Reset(F2);
        DT := Copy(DateToStr(date), 1, 2) + '/' + Copy(DateToStr(date), 4, 2) + '/' + Copy(DateToStr(date), 7, 4);
        try
          while not Eof(F2) do
          begin
            ReadLn(F2, S);
            if Copy(S, 1, 1) = '0' then  // Abertura de Cupom
            begin
              DT := Copy(S, 29, 2) + '/' + Copy(S, 31, 2) + '/' + Copy(S, 33, 4);
              DSMain.DataSet.Append;
              DSMain.DataSet.FieldByName('DATA').AsDateTime := StrToDate(DT);
              DSMain.DataSet.FieldByName('NUM_DOC').AsString := Copy(S, 2, 6);
              DSMain.DataSet.FieldByName('SERIE').AsString := 'ECF';
              DSMain.DataSet.FieldByName('CFOP').AsString := '9999';
              DataBase1.StartTransaction;
              try
                DSMain.DataSet.Post;
                TBDEDataSet(DSMain.DataSet).ApplyUpdates;
                TBDEDataSet(DSMain.DataSet).CommitUpdates;
                DataBase1.Commit;
              except
                DataBase1.Rollback;
                TBDEDataSet(DSMain.DataSet).CancelUpdates;
              end;
            end;
            if (Copy(S, 1, 1) = '1') or (Copy(S, 1, 1) = '2') then  // Venda ou Cancelamento de Item
            begin
              QEstoque.Close;
              QEstoque.Params[0].Value := Copy(S, 36, 13);
              QEstoque.Open;
              if QEstoque.RecordCount > 0 then
              begin
                DSDetail.DataSet.Append;
                DSDetail.DataSet.FieldByName('COD_PRODUTO').AsString := QEstoque.FieldByName('CODIGO').AsString;
                DSDetail.DataSet.FieldByName('DESCRICAO').AsString := QEstoque.FieldByName('DESCRICAO').AsString;
                DSDetail.DataSet.FieldByName('COD_TRIBUTO').AsString := QEstoque.FieldByName('COD_TRIBUTO').AsString;
                DSDetail.DataSet.FieldByName('ICMS').AsString := QEstoque.FieldByName('ICMS').AsString;
                DSDetail.DataSet.FieldByName('VR_UNITARIO').AsFloat := (StrToFloat(Copy(S, 58, 12)) / 100);
                if Copy(S, 1, 1) = '2' then
                  DSDetail.DataSet.FieldByName('QUANTIDADE').AsFloat := (StrToFloat(Copy(S, 49, 9)) / 1000) * -1
                else
                  DSDetail.DataSet.FieldByName('QUANTIDADE').AsFloat := (StrToFloat(Copy(S, 49, 9)) / 1000);
                DSDetail.DataSet.FieldByName('DESCONTO').AsFloat := (StrToFloat(Copy(S, 70, 12)) / 100);
                DSDetail.DataSet.FieldByName('VALOR').AsFloat := DSDetail.DataSet.FieldByName('QUANTIDADE').AsFloat * (DSDetail.DataSet.FieldByName('VR_UNITARIO').AsFloat - DSDetail.DataSet.FieldByName('DESCONTO').AsFloat);
                DSDetail.DataSet.FieldByName('VR_COMPRA').AsFloat := QEstoque.FieldByName('VALOR_COMPRA').AsFloat;
                DataBase1.StartTransaction;
                try
                  DSDetail.DataSet.Post;
                  TBDEDataSet(DSDetail.DataSet).ApplyUpdates;
                  TBDEDataSet(DSDetail.DataSet).CommitUpdates;
                  DataBase1.Commit;
                except
                  DataBase1.Rollback;
                  TBDEDataSet(DSDetail.DataSet).CancelUpdates;
                end;
              end;
            end;
            if Copy(S, 1, 1) = '3' then  // Dados do Cliente
            begin
              QRel.Sql.Clear;
              QRel.Sql.Add('SELECT CODIGO, NOME');
              QRel.Sql.Add('FROM CLIENTE');
              QRel.Sql.Add('WHERE');
              if Campo_Pesq = 'CNPJ' then
              begin
                if Copy(S, 112, 3) = '000' then
                  QRel.Sql.Add('(CNPJ = ' + #39 + Copy(S, 115, 3) + '.' + Copy(S, 118, 3) + '.' + Copy(S, 121, 3) + '-' + Copy(S, 124, 2) + #39 + ')')
                else
                  QRel.Sql.Add('(CNPJ = ' + #39 + Copy(S, 112, 2) + '.' + Copy(S, 114, 3) + '.' + Copy(S, 117, 3) + '/' + Copy(S, 120, 4) + '-' + Copy(S, 124, 2) + #39 + ')');
              end
              else
                QRel.Sql.Add('(CODIGO = ' + #39 + Copy(S, 112, 14) + #39 + ')');
              QRel.Open;
              DSMain.DataSet.Edit;
              DSMain.DataSet.FieldByName('VALOR').AsFloat := (StrToFloat(Copy(S, 83, 12)) / 100);
              DSMain.DataSet.FieldByName('ODOMETRO').AsFloat := (StrToFloat(Copy(S, 126, 12)) / 100);
              if Copy(S, 138, 1) = 'D' then
                DSMain.DataSet.FieldByName('DESCONTO').AsFloat := (StrToFloat(Copy(S, 95, 12)) / 100);
              if Copy(S, 138, 1) = 'A' then
                DSMain.DataSet.FieldByName('ACRESCIMO').AsFloat := (StrToFloat(Copy(S, 95, 12)) / 100);
              DSMain.DataSet.FieldByName('FUNCIONARIO').AsString := Copy(S, 107, 5);
              DSMain.DataSet.FieldByName('FORNE_CLIENTE').AsString := QRel.FieldByName('CODIGO').AsString;
              DSMain.DataSet.FieldByName('VALOR').AsFloat := DSMain.DataSet.FieldByName('VALOR').AsFloat + DSMain.DataSet.FieldByName('ACRESCIMO').AsFloat - DSMain.DataSet.FieldByName('DESCONTO').AsFloat;
              DSMain.DataSet.FieldByName('HISTORICO').AsString := 'Vr. cupom fiscal nｺ ' + Copy(S, 2, 6) + '-' + QRel.FieldByName('NOME').AsString;
              DataBase1.StartTransaction;
              try
                DSMain.DataSet.Post;
                TBDEDataSet(DSMain.DataSet).ApplyUpdates;
                TBDEDataSet(DSMain.DataSet).CommitUpdates;
                DataBase1.Commit;
              except
                DataBase1.Rollback;
                TBDEDataSet(DSMain.DataSet).CancelUpdates;
              end;
            end;
            if Copy(S, 1, 1) = '4' then  // Parcelamento
            begin
              DSContas.DataSet.Append;
              DSContas.DataSet.FieldByName('PARCELA').AsString := Copy(S, 29, 5);
              DSContas.DataSet.FieldByName('DT_VENCIMENTO').AsString := Copy(S, 34, 2) + '/' + Copy(S, 36, 2) + '/' + Copy(S, 38, 4);
              DSContas.DataSet.FieldByName('VALOR').AsFloat := (StrToFloat(Copy(S, 42, 12)) / 100);
              DSContas.DataSet.FieldByName('CAIXA_BANCO').AsString := Copy(S, 54, 2);
              DataBase1.StartTransaction;
              try
                DSContas.DataSet.Post;
                TBDEDataSet(DSContas.DataSet).ApplyUpdates;
                TBDEDataSet(DSContas.DataSet).CommitUpdates;
                DataBase1.Commit;
              except
                DataBase1.Rollback;
                TBDEDataSet(DSContas.DataSet).CancelUpdates;
              end;
            end;
            Application.ProcessMessages;
          end;
        finally
          CloseFile(F2);
        end;
        if not DirectoryExists('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2)) then
          MkDir('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2));
        if FileExists('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2) + '\' + SR.Name) then
          DeleteFile('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2) + '\' + SR.Name);
        MoveFile(PChar(Caminho_Rx + SR.Name), PChar('C:\Retag\Logs\' + Copy(DateToStr(date), 1, 2) + Copy(DateToStr(date), 4, 2) + Copy(DateToStr(date), 9, 2) + '\' + SR.Name));
        Application.ProcessMessages;
        I := FindNext(SR);
      end;
    finally
      FindClose(SR);
    end;
  finally
    Timer_Logs.Enabled := True;
    Sair.Enabled := True;
    Logs.Close;
    Fechamento.Close;
    Formas.Close;
    DSMain.DataSet.Close;
    DSDetail.DataSet.Close;
    DSContas.DataSet.Close;
  end;
end;

procedure TForm_Fiado.LogsBeforePost(DataSet: TDataSet);
begin
  if Logs.State = dsInsert then
  begin
    Gen_Codigo.StoredProcName := 'PROC_GENLOGS';
    Gen_Codigo.Prepare;
    Gen_Codigo.ExecProc;
    Logs.FieldByName('CODIGO').AsInteger := Gen_Codigo.Params[0].Value;
  end;
end;

procedure TForm_Fiado.FechamentoBeforePost(DataSet: TDataSet);
begin
  if Fechamento.State = dsInsert then
  begin
    Gen_Codigo.StoredProcName := 'PROC_GENFECHAMENTO';
    Gen_Codigo.Prepare;
    Gen_Codigo.ExecProc;
    Fechamento.FieldByName('CODIGO').AsInteger := Gen_Codigo.Params[0].Value;
  end;
end;

end.
