procedure TForm_Fiado.ColocaZero(Arq: TQuery);
var
I: Integer;
begin
  for I := 0 to Arq.FieldCount - 1 do
  begin
    if Arq.Fields[I].DataType in [ftInteger, ftFloat] then
      Arq.Fields[I].AsInteger := 0;
  end;
end;

