procedure TForm_Fiado.Timer_ConsultaTimer(Sender: TObject);
var
SR: TSearchRec;
I: Integer;
F1, F2: TextFile;
S, Status: String;
Sm: Double;
begin
  Timer_Consulta.Enabled := False;
  Sair.Enabled := False;
  try
    I := FindFirst(Caminho_Rx + Arq_Perg + '*.0??', faAnyFile, SR);
    try
      while I = 0 do
      begin
        AssignFile(F2, Caminho_Rx + SR.Name);
        try
          Reset(F2);
          ReadLn(F2, S);
        finally
          CloseFile(F2);
        end;
        QRel.Sql.Clear;
        QRel.Sql.Add('SELECT CLIENTE.CODIGO, CLIENTE.TIPO_CLIENTE, CLIENTE.NOME, CLIENTE.CNPJ, CLIENTE.LIMITE, CLIENTE.BLOQUEIO, CLIENTE.JUROS, CLIENTE.DIAVEN, SUM(TRANSRP.VALOR)');
        QRel.Sql.Add('FROM CLIENTE CLIENTE');
        QRel.Sql.Add('LEFT JOIN TRANS TRANS');
        QRel.Sql.Add('ON (TRANS.FORNE_CLIENTE = CLIENTE.CODIGO) AND (TRANS.CONDUTA = "05")');
        QRel.Sql.Add('LEFT JOIN TRANSRP TRANSRP');
        QRel.Sql.Add('ON (TRANSRP.TRANSACAO = TRANS.CODIGO) AND (TRANSRP.VALOR > 0) AND (TRANSRP.CAIXA_BANCO = 0)');
        QRel.Sql.Add('WHERE');
//        if Copy(S, 1, 3) = '000' then
//          QRel.Sql.Add('(CLIENTE.CNPJ = ' + #39 + Copy(S, 4, 3) + '.' + Copy(S, 7, 3) + '.' + Copy(S, 10, 3) + '-' + Copy(S, 13, 2) + #39 + ')')
//        else
//          QRel.Sql.Add('(CLIENTE.CNPJ = ' + #39 + Copy(S, 1, 2) + '.' + Copy(S, 3, 3) + '.' + Copy(S, 6, 3) + '/' + Copy(S, 9, 4) + '-' + Copy(S, 13, 2) + #39 + ')');
        QRel.Sql.Add('(CLIENTE.CODIGO = ' + #39 + Copy(S, 1, 14) + #39 + ')');
        QRel.Sql.Add('GROUP BY CLIENTE.CODIGO, CLIENTE.TIPO_CLIENTE, CLIENTE.NOME, CLIENTE.CNPJ, CLIENTE.LIMITE, CLIENTE.BLOQUEIO, CLIENTE.JUROS, CLIENTE.DIAVEN');
        QRel.Open;
        if QRel.RecordCount > 0 then
        begin
          if QRel.FieldByName('SUM').IsNull then
            Sm := 0
          else
            Sm := QRel.FieldByName('SUM').AsFloat;
          Status := 'A0';
          if QRel.FieldByName('BLOQUEIO').AsString = 'S' then
            Status := 'R1';
          AssignFile(F1, Caminho_Tx + Arq_Resp);
          try
            Rewrite(F1);
            WriteLn(F1, Status + Copy(S, 1, 14) + ForcaComprimento(QRel.FieldByName('NOME').AsString, 30, ' ') + Copy(S, 1, 14) +
                        StrZero(FloatToStr(Sm), 10, 2));
          finally
            CloseFile(F1);
          end;
        end
        else
        begin
          AssignFile(F1, Caminho_Tx + Arq_Resp);
          try
            Rewrite(F1);
            WriteLn(F1, 'N0');
          finally
            CloseFile(F1);
          end;
        end;
        RenameFile(Caminho_Tx + Arq_Resp, Caminho_Tx + Arq_Resp + Copy(SR.Name, (length(SR.Name) - 3), 4));
        Application.ProcessMessages;
        DeleteFile(Caminho_Rx + SR.Name);
        I := FindNext(SR);
      end;
    except
      AssignFile(F1, Caminho_Tx + Arq_Resp);
      try
        Rewrite(F1);
        WriteLn(F1, 'N0');
      finally
        CloseFile(F1);
      end;
      RenameFile(Caminho_Tx + Arq_Resp, Caminho_Tx + Arq_Resp + Copy(SR.Name, (length(SR.Name) - 3), 4));
      DeleteFile(Caminho_Rx + SR.Name);
      FindClose(SR);
    end;
  finally
    Timer_Consulta.Enabled := True;
    Sair.Enabled := True;
  end;
end;

procedure TForm_Fiado.QTransBeforePost(DataSet: TDataSet);
begin
  if QTrans.State = dsInsert then
  begin
    Gen_Codigo.StoredProcName := 'PROC_GENTRANS';
    Gen_Codigo.Prepare;
    Gen_Codigo.ExecProc;
    QTrans.FieldByName('CODIGO').AsInteger := Gen_Codigo.Params[0].Value;
  end;
end;

