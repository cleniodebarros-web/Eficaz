function StrZero(TX: String; TAM, DEC: Integer): String;
var
X: Integer;
VIRG: Boolean;
AA, BB: String;
begin
  VIRG := False;
  AA := '';
  BB := '';

  for X := 1 to length(TX) do
  begin
    if Copy(TX, X, 1) = ',' then
      VIRG := True;

    if (not VIRG) and (Copy(TX, X, 1) <> ',') then
      AA := AA + Copy(TX, X, 1)
    else
    begin
      if (length(BB) < DEC) and (Copy(TX, X, 1) <> ',') then
        BB := BB + Copy(TX, X, 1);
    end;
  end;

  if length(BB) < DEC then
  begin
    for X := 1 to (DEC - length(BB)) do
      BB := BB + '0';
  end;

  Result := AA + BB;
  for X := 1 to TAM - length(RESULT) do
    Result := '0' + Result;
end;

function ForcaComprimento(S: String; Comp: Integer; Ch: Char): String;
begin
  if length(S) > Comp then
    Result := Copy(S, 1, Comp)
  else
    Result := S + StringOfChar(Ch,Comp - length(S));
end;

function EncryptMsg(Msg1: String; EncryptNo: Integer): String;
var
ResultStr: String;
Temp: Char;
I, EncryptIndex: Integer;
begin
  ResultStr := '';
  Temp      := ' ';

  for I := 1 to length(Msg1) do
  begin
    for EncryptIndex := 1 to EncryptNo do
    begin
      Temp    := Succ(Msg1[I]);
      Msg1[I] := Temp;
    end;

    ResultStr := ResultStr + Temp;
  end;

  EncryptMsg := ResultStr;
end;

function DecryptMsg(Msg1: String; DecryptNo: Integer): String;
var
ResultStr: String;
Temp: Char;
I, DecryptIndex: Integer;
begin
  ResultStr := '';
  Temp      := ' ';

  for I := 1 to length(Msg1) do
  begin
    for DecryptIndex := 1 to DecryptNo do
    begin
      Temp    := Pred(Msg1[I]);
      Msg1[I] := Temp;
    end;

    ResultStr := ResultStr + Temp;
  end;

  DecryptMsg := ResultStr;
end;

function CriaStr(Num: Integer; Ch: Char): String;
begin
  SetLength(Result, Num);
  FillChar(PChar(Result)^, Num, Ch);
end;

function AllTrim(StrX: String): String;
begin
  AllTrim := StripChar(StrX, EspacoBranco, ReplaceBoth);
end;

function StripChar(SourceStr: ShortString; CharToStrip: Char; Mode: Byte): ShortString;
var
I : Integer;
begin
  Result := '';

  if SourceStr <> '' then
  begin
    if Mode <> ReplaceLeft then
    begin
      while (Byte (SourceStr[0]) > 0) and (String(SourceStr[Byte (SourceStr[0])]) = CharToStrip) do
        Dec (SourceStr[0]);
    end;

    if Mode <> ReplaceRight then
    begin
      I := 1;
      while (I <= Byte(SourceStr[0])) and (String(SourceStr[I]) = CharToStrip) do
        Inc (I);

      if I > 1 then
        SourceStr := Copy (SourceStr, I, 255);

      if Mode = ReplaceAll then
      begin
        for I := 1 to Byte (SourceStr[0]) do
        begin
          if String(SourceStr[I]) <> CharToStrip then
          Result := Result + SourceStr[I];
          SourceStr := Result;
        end;
      end;

      Result := SourceStr;
    end;
  end;
end;

